#!/bin/sh
# Compile a source file using the famc compiler.
# Usage: famc <source> [output]
# If output is omitted, replaces extension with .bin

if [ $# -lt 1 ]; then
	echo "Usage: $0 <source> [output]"
	echo "Example: $0 tmp/test.famc tmp/test.bin"
	exit 1
fi

SELF="$0"
[ -L "$SELF" ] && SELF="$(readlink -f "$SELF")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
ASM="$ROOT_DIR/bin/famc"
SRC="$1"

if [ ! -e "$ASM" ]; then
	echo "Error: $ASM not found"
	exit 1
fi
if [ ! -e "$SRC" ]; then
	echo "Error: $SRC not found"
	exit 1
fi

if [ -n "$2" ]; then
	OUT="$2"
else
	OUT="${SRC%.*}.bin"
fi

(cat "$SRC"; printf '\004') | qemu-system-riscv32 \
	-machine virt \
	-cpu rv32i \
	-nographic \
	-bios none \
	-device loader,file="$ASM",addr=0x80000000 \
	-serial mon:stdio 2>/dev/null > "$OUT"

if [ ! -s "$OUT" ]; then
	echo "Error: compiler produced no output"
	rm -f "$OUT"
	exit 1
fi

MAGIC=$(head -c 4 "$OUT" | xxd -p)
if [ "$MAGIC" != "13000000" ]; then
	cat "$OUT"
	rm -f "$OUT"
	exit 1
fi

echo "$OUT ($(wc -c < "$OUT") bytes)"
