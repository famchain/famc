if [[ "$first" != "13" ]]; then
	echo "Smoke test failed: compile returned '$(head -c20 "$TMPDIR/smoke.bin")'"
	exit 1
fi
rc=0
run_bin "$TMPDIR/smoke.bin" > /dev/null || rc=$?
if [[ $rc -ne 0 ]]; then
	echo "Smoke test failed: compiled binary exited with $rc"
	echo "  (If 124, QEMU may not be exiting — check test device at 0x100000)"
	exit 1
