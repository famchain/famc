# test_stack_overflow: compile, patch tp to trigger overflow, verify 'S' output
#   $1 = test name, $2 = source code
test_stack_ovf() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	if [[ "$first" != "13" ]]; then
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (compile failed)"
		return
	fi
	# Patch: replace "li tp, 0" (0x00000213 at offset 0x14) with
	# "lui tp, 0x88000" (0x88000237) — tp = sp, instant overflow on first push
	local orig
	orig=$(xxd -s 0x18 -l 4 -p "$bin")
	if [[ "$orig" != "13020000" ]]; then
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (tp instruction not at expected offset, got $orig)"
		return
	fi
	python3 -c "
import struct, sys
with open(sys.argv[1], 'r+b') as f:
    f.seek(0x18)
    f.write(struct.pack('<I', 0x88000237))
" "$bin"
	local actual
	actual=$(run_bin "$bin" || true)
	if [[ "$actual" == "S"* ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (expected 'S' output, got '$actual')"
	fi
}

# test_no_overflow: verify check is present but doesn't fire with tp=0
test_has_check() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	# Check for bgeu sp, tp pattern (0x00417463 = bgeu sp, tp, +8)
	if xxd -p "$bin" | tr -d '\n' | grep -q "63744100"; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (no bgeu sp,tp check found in binary)"
	fi
}

test_has_check  "sp check emitted"        "x := 42; x"
