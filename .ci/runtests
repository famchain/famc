#!/usr/bin/env bash
# Test runner for famc compiler
# Usage: .ci/runtests [--verbose]
set -u

DIR="$(cd "$(dirname "$0")/.." && pwd)"
FAMC="$DIR/bin/famc"
TMPDIR=$(mktemp -d)

# Kill all child processes on exit or Ctrl-C
cleanup() {
	kill $(jobs -p) 2>/dev/null || true
	wait 2>/dev/null || true
	rm -rf "$TMPDIR"
}
trap cleanup EXIT INT TERM

VERBOSE=0
[[ "${1:-}" == "--verbose" ]] && VERBOSE=1

PASS=0
FAIL=0
TOTAL=0

# compile: run famc compiler on source code, output binary to stdout
compile() {
	(echo "$1"; printf '\004') | timeout -k 2 10 qemu-system-riscv32 \
		-machine virt -cpu rv32i -nographic -bios none \
		-device loader,file="$FAMC",addr=0x80000000 \
		-serial mon:stdio 2>/dev/null
}

# run_bin: execute a compiled binary, stdin from /dev/null
#   Uses -serial stdio (not mon:stdio) to avoid monitor blocking on terminal
run_bin() {
	timeout -k 2 10 qemu-system-riscv32 \
		-machine virt -cpu rv32i -nographic -bios none \
		-device loader,file="$1",addr=0x80000000 \
		-serial stdio -monitor none < /dev/null 2>/dev/null
}

# test_compiles: compile source, expect success (output starts with NOP 0x13)
test_compiles() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	if [[ "$first" == "13" ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (expected binary, got: $(head -c40 "$bin"))"
	fi
}

# test_runs: compile and run, expect exit code 0
test_runs() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	if [[ "$first" != "13" ]]; then
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (compile failed: $(head -c40 "$bin"))"
		return
	fi
	local rc=0
	run_bin "$bin" > /dev/null || rc=$?
	if [[ $rc -eq 0 ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (exit code $rc)"
	fi
}

# test_output: compile and run, check UART output matches expected
test_output() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2" expected="$3"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	if [[ "$first" != "13" ]]; then
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (compile failed: $(head -c40 "$bin"))"
		return
	fi
	local actual
	actual=$(run_bin "$bin" || true)
	if [[ "$actual" == "$expected" ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (expected '$expected', got '$actual')"
	fi
}

# test_error: compile source, expect error output starting with 'E'
test_error() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2" prefix="$3"
	local out
	out=$(compile "$src" 2>&1 || true)
	if [[ "$out" == "${prefix}"* ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (expected '${prefix}...', got '$(echo "$out" | head -c40)')"
	fi
}

