#!/usr/bin/env bash
# Test runner for famc compiler.
# Usage: .ci/runtests [--verbose]
#
# Tests the features currently implemented in the rewrite. Anything not
# listed here either isn't wired up yet (loops, ternary, struct, arrays,
# closures, asm blocks, macros, multiply/divide) or is part of a future
# milestone — see codegen_todo for the larger plan.
set -u

DIR="$(cd "$(dirname "$0")/.." && pwd)"
FAMC="$DIR/bin/famc"
TMPDIR=$(mktemp -d)

cleanup() {
	kill $(jobs -p) 2>/dev/null || true
	wait 2>/dev/null || true
	rm -rf "$TMPDIR"
}
trap cleanup EXIT INT TERM

VERBOSE=0
[[ "${1:-}" == "--verbose" ]] && VERBOSE=1

PASS=0
FAIL=0
TOTAL=0

# compile: feed source to famc via stdin, return generated binary on stdout.
compile() {
	(echo "$1"; printf '\004') | timeout -k 2 10 qemu-system-riscv32 \
		-machine virt -cpu rv32i -nographic -bios none \
		-device loader,file="$FAMC",addr=0x80000000 \
		-serial mon:stdio 2>/dev/null
}

# run_bin: execute a compiled binary in qemu, return UART output on stdout.
run_bin() {
	timeout -k 2 10 qemu-system-riscv32 \
		-machine virt -cpu rv32i -nographic -bios none \
		-device loader,file="$1",addr=0x80000000 \
		-serial stdio -monitor none < /dev/null 2>/dev/null
}

# test_compiles: source must compile to a valid binary (first byte 0x13 nop).
test_compiles() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	if [[ "$first" == "13" ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (expected binary, got: $(head -c40 "$bin"))"
	fi
}

# test_runs: source must compile AND execute to clean exit (rc 0).
test_runs() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	if [[ "$first" != "13" ]]; then
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (compile failed: $(head -c40 "$bin"))"
		return
	fi
	local rc=0
	run_bin "$bin" > /dev/null || rc=$?
	if [[ $rc -eq 0 ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (exit code $rc)"
	fi
}

# test_output: source compiles and runs, UART output matches expected exactly.
test_output() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2" expected="$3"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	if [[ "$first" != "13" ]]; then
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (compile failed: $(head -c40 "$bin"))"
		return
	fi
	local actual
	actual=$(run_bin "$bin" || true)
	if [[ "$actual" == "$expected" ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (expected '$expected', got '$actual')"
	fi
}

# test_error: source must NOT produce a valid binary; output starts with prefix.
test_error() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2" prefix="$3"
	local out
	out=$(compile "$src" 2>&1 || true)
	if [[ "$out" == "${prefix}"* ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (expected '${prefix}...', got '$(echo "$out" | head -c60)')"
	fi
}

# ============================================================================
echo "Building..."
if ! (cd "$DIR" && bash build.sh) > /dev/null 2>&1; then
	echo "Build failed!"
	exit 1
fi

# Smoke test: a trivial program must compile and exit cleanly.
echo "Smoke test..."
compile "42" > "$TMPDIR/smoke.bin" 2>&1 || true
first=$(xxd -l1 -p "$TMPDIR/smoke.bin" 2>/dev/null || echo "")
if [[ "$first" != "13" ]]; then
	echo "Smoke test failed: compile returned '$(head -c40 "$TMPDIR/smoke.bin")'"
	exit 1
fi
rc=0
run_bin "$TMPDIR/smoke.bin" > /dev/null || rc=$?
if [[ $rc -ne 0 ]]; then
	echo "Smoke test failed: compiled binary exited with $rc"
	exit 1
fi
echo ""

# ============================================================================
echo "=== Literals ==="
test_runs    "decimal literal"          "42"
test_runs    "hex literal"              "0xFF"
test_runs    "binary literal"           "0b1010"
test_runs    "zero"                     "0"
test_runs    "char literal"             "'x'"
test_runs    "char escape newline"      "'\n'"
test_runs    "char escape tab"          "'\t'"
test_runs    "char escape return"       "'\r'"
test_runs    "char escape null"         "'\0'"
test_runs    "char escape backslash"    "'\\\\'"
test_runs    "large hex (UART addr)"    "0x10000000"

# ============================================================================
echo "=== Variables ==="
test_runs    "single immutable"         "x = 42"
test_runs    "single mutable"           "x := 42"
test_runs    "multiple vars"            "x = 1; y = 2; z = 3"
test_runs    "use after define"         "x = 5; x"
test_runs    "reassign existing"        "x = 1; x = 2"
test_runs    "reassign with expression" "x = 5; y = 10; x = y"

# ============================================================================
echo "=== Arithmetic via UART ==="
# These verify computed results: write (computed) char to UART, check output.
test_output  "add"                  "@0x10000000 = 65 + 0"                "A"
test_output  "add positives"        "@0x10000000 = 60 + 5"                "A"
test_output  "subtract"             "@0x10000000 = 75 - 10"               "A"
test_output  "var + literal"        "x = 60; @0x10000000 = x + 5"         "A"
test_output  "var + var"            "x = 60; y = 5; @0x10000000 = x + y"  "A"
test_output  "var - var"            "x = 75; y = 10; @0x10000000 = x - y" "A"
test_output  "char + offset"        "@0x10000000 = 'A' + 0"                "A"
test_output  "char arithmetic"      "@0x10000000 = 'A' + 1"                "B"
test_output  "two-char output"      "@0x10000000 = 'H'; @0x10000000 = 'i'" "Hi"

# ============================================================================
echo "=== Bitwise via UART ==="
test_output  "bitwise and"   "@0x10000000 = 0x4F & 0x4F"                       "O"
test_output  "bitwise or"    "@0x10000000 = 0x40 | 0x01"                       "A"
test_output  "bitwise xor"   "@0x10000000 = 0x50 ^ 0x11"                       "A"
test_output  "shift left"    "@0x10000000 = 1 << 6; @0x10000000 = 1 << 6 | 1"  "@A"
test_output  "shift right"   "@0x10000000 = 260 >> 2"                          "A"

# ============================================================================
echo "=== Comparisons via UART ==="
# Returns 1 (SOH, not printable). Check via "+ 64" → 'A' if true, '@' if false.
test_output  "less true"     "@0x10000000 = (1 < 2) + 64"  "A"
test_output  "less false"    "@0x10000000 = (2 < 1) + 64"  "@"
test_output  "equal true"    "@0x10000000 = (5 == 5) + 64" "A"
test_output  "equal false"   "@0x10000000 = (5 == 6) + 64" "@"
test_output  "not equal"     "@0x10000000 = (5 != 6) + 64" "A"
test_output  "greater"       "@0x10000000 = (5 > 3) + 64"  "A"
test_output  "lte true"      "@0x10000000 = (3 <= 3) + 64" "A"
test_output  "gte true"      "@0x10000000 = (5 >= 5) + 64" "A"

# ============================================================================
echo "=== Unary operators via UART ==="
# -x: write (-x + 130) to UART → 'A' if x = 65.
test_output  "unary minus"      "x = 65; y = -x; @0x10000000 = y + 130"   "A"
test_output  "logical not 0"    "@0x10000000 = (!0) + 64"                 "A"
test_output  "logical not 1"    "@0x10000000 = (!1) + 64"                 "@"
test_output  "bitwise not low"  "x = 0xFFFFFFBE; @0x10000000 = ~x"        "A"

# ============================================================================
echo "=== Compound assignment via UART ==="
test_output  "+= literal"  "x = 60; x += 5; @0x10000000 = x"   "A"
test_output  "-= literal"  "x = 70; x -= 5; @0x10000000 = x"   "A"
test_output  "&= literal"  "x = 0xFF; x &= 0x41; @0x10000000 = x" "A"
test_output  "|= literal"  "x = 0x40; x |= 0x01; @0x10000000 = x" "A"
test_output  "^= literal"  "x = 0x50; x ^= 0x11; @0x10000000 = x" "A"
test_output  "<<= literal" "x = 1; x <<= 6; x |= 1; @0x10000000 = x"   "A"
test_output  ">>= literal" "x = 260; x >>= 2; @0x10000000 = x" "A"
test_output  "+= var"      "x = 60; y = 5; x += y; @0x10000000 = x" "A"

# ============================================================================
echo "=== Blocks ==="
test_runs    "empty block (statement)"  "x = 1; { }; x"
test_runs    "block with statements"    "{ x = 1; y = 2 }"
test_runs    "block as expression"      "x = { y = 10; y + 1 }"
test_runs    "nested blocks"            "x = { y = { z = 1; z + 1 }; y + 1 }"
test_output  "block returning local"    "x = { y = 'B'; y }; @0x10000000 = x" "B"
test_output  "block returning binop"    "x = { y = 'A'; y + 1 }; @0x10000000 = x" "B"
test_output  "block scope reuse"        "x1 = 1; x2 = 2; x3 = 3; { y1 = 11; y2 = 12; y3 = 13 }; x4 = 'A'; @0x10000000 = x4"  "A"
test_output  "block before stmt"        "x = 100; { y = 5 }; @0x10000000 = x - 35" "A"

# ============================================================================
echo "=== Pointer / deref operations ==="
test_compiles "byte deref read"     "p = 0x80200100; @p"
test_compiles "halfword deref read" "p = 0x80200100; #p"
test_compiles "word deref read"     "p = 0x80200100; *p"
test_compiles "byte store"          "p = 0x10000000; @p = 65"
test_compiles "halfword store"      "p = 0x80200100; #p = 0x4142"
test_compiles "word store"          "p = 0x80200100; *p = 0x41424344"

test_output  "byte round trip"   "buf = 0x80200200; p = 0x10000000; @buf = 'H'; @p = @buf" "H"
test_output  "halfword round trip" "buf = 0x80200200; p = 0x10000000; #buf = 0x4142; @p = @buf" "B"
test_output  "word round trip"   "buf = 0x80200200; p = 0x10000000; *buf = 0x41424344; @p = @buf" "D"

# ============================================================================
echo "=== UART direct output ==="
test_output  "single char"        "@0x10000000 = 'A'" "A"
test_output  "char escape \\n"    "@0x10000000 = 'A'; @0x10000000 = '\n'" "A"
test_output  "via variable"       "uart = 0x10000000; @uart = 'H'; @uart = 'i'" "Hi"
test_output  "hello"              "@0x10000000 = 'H'; @0x10000000 = 'e'; @0x10000000 = 'l'; @0x10000000 = 'l'; @0x10000000 = 'o'" "Hello"

# ============================================================================
echo "=== Register pressure / stack spills ==="
# 11 vars exactly fits in s1..s11 (no spill).
test_output  "11 vars in regs" \
  "x1 = 1; x2 = 2; x3 = 3; x4 = 4; x5 = 5; x6 = 6; x7 = 7; x8 = 8; x9 = 9; x10 = 10; x11 = 11; @0x10000000 = x1 + 64" \
  "A"

# 12 vars: one spill (x12 → 0(sp)).
test_output  "12 vars one spill" \
  "x1 = 1; x2 = 2; x3 = 3; x4 = 4; x5 = 5; x6 = 6; x7 = 7; x8 = 8; x9 = 9; x10 = 10; x11 = 11; x12 = 65; @0x10000000 = x12" \
  "A"

# 13 vars: two spills, then read both back.
test_output  "13 vars two spills" \
  "x1 = 1; x2 = 2; x3 = 3; x4 = 4; x5 = 5; x6 = 6; x7 = 7; x8 = 8; x9 = 9; x10 = 10; x11 = 11; x12 = 65; x13 = 66; @0x10000000 = x12; @0x10000000 = x13" \
  "AB"

# 13 vars + nested block + 13 UART writes — exercises register reuse,
# stack spill addressing, scope rewind, and binop temp freeing all together.
test_output  "13 vars + UART writes" \
  "x1 = 1; x2 = 2; x3 = 3; x4 = 4; x5 = 5; x6 = 6; x7 = 7; x8 = 8; x9 = 9; x10 = 10; x11 = 11; x12 = 12; x13 = 13; @0x10000000 = x1 + 'A'; @0x10000000 = x2 + 'A'; @0x10000000 = x3 + 'A'; @0x10000000 = x4 + 'A'; @0x10000000 = x5 + 'A'; @0x10000000 = x6 + 'A'; @0x10000000 = x7 + 'A'; @0x10000000 = x8 + 'A'; @0x10000000 = x9 + 'A'; @0x10000000 = x10 + 'A'; @0x10000000 = x11 + 'A'; @0x10000000 = x12 + 'A'; @0x10000000 = x13 + 'A'" \
  "BCDEFGHIJKLMN"

# Stack-spilled var reassignment lands in the SAME slot (no orphan).
test_output  "stack var reassign" \
  "x1 = 1; x2 = 2; x3 = 3; x4 = 4; x5 = 5; x6 = 6; x7 = 7; x8 = 8; x9 = 9; x10 = 10; x11 = 11; x12 = 12; x13 = 100; x13 = 65; @0x10000000 = x13" \
  "A"

# Compound op on a stack-spilled var.
test_output  "compound op on spill" \
  "x1 = 1; x2 = 2; x3 = 3; x4 = 4; x5 = 5; x6 = 6; x7 = 7; x8 = 8; x9 = 9; x10 = 10; x11 = 11; x12 = 50; x13 = 15; x13 += x12; @0x10000000 = x13" \
  "A"

# ============================================================================
echo "=== Error detection ==="
test_error   "undefined variable"          "y"                          "error:"
test_error   "undefined in expression"     "x = y"                      "error:"
test_error   "undefined RHS in binop"      "x = 1; y = x + z"           "error:"
test_error   "binary multiply"             "x = 3; y = x * 5"           "error:"
test_error   "binary divide"               "x = 10; y = x / 2"          "error:"
test_error   "binary modulo"               "x = 10; y = x % 3"          "error:"
test_error   "compound *= unsupported"     "x = 3; x *= 2"              "error:"
test_error   "compound /= unsupported"     "x = 6; x /= 2"              "error:"
test_error   "compound %= unsupported"     "x = 7; x %= 3"              "error:"
test_error   "missing semicolon"           "x = 1 y = 2"                "error:"

# ============================================================================
echo ""
echo "=== Results ==="
echo "  $PASS passed, $FAIL failed, $TOTAL total"
if [[ $FAIL -gt 0 ]]; then
	exit 1
fi
echo "  All tests passed."
