03 2F 08 02	# lw	t5,32(a6) ; symbol value
83 AF 02 02	# lw	t6,32(t0) ; patch offset
83 A8 42 02	# lw	a7,36(t0) ; slot_type
B3 83 F4 01	# add	t2,s1,t6 ; patch addr
13 0E 10 00	# addi	t3,zero,1
63 86 C8 03	# beq	a7,t3,fp_enc_j
13 0E 70 00	# addi	t3,zero,7
63 82 C8 0B	# beq	a7,t3,fp_enc_uhi_pcrel
13 0E 80 00	# addi	t3,zero,8
63 86 C8 0D	# beq	a7,t3,fp_enc_ilo_pcrp
13 05 20 01	# addi	a0,zero,18 ; E18: unknown fixup type
6F E0 8F 95	# jal	zero,halt_err

# fp_skip:
13 08 88 02	# addi	a6,a6,40
6F F0 1F FA	# jal	zero,fp_sym

# fp_noresolve:
13 05 10 01	# addi	a0,zero,17 ; E17: unresolved symbol
6F E0 8F 94	# jal	zero,halt_err

# fp_enc_j:
33 0F FF 41	# sub	t5,t5,t6 ; PC-relative

# Range check
B7 08 10 00	# lui	a7,0x100 ; 0x100000
63 46 1F 01	# blt	t5,a7,fpj_hi
13 05 60 01	# addi	a0,zero,22
6F E0 4F 93	# jal	zero,halt_err

# fpj_hi:
B3 08 10 41	# sub	a7,zero,a7
63 56 1F 01	# bge	t5,a7,fpj_ok
13 05 60 01	# addi	a0,zero,22
6F E0 4F 92	# jal	zero,halt_err

# fpj_ok:
03 AE 03 00	# lw	t3,0(t2)

# Clear imm bits: keep low 12 bits (rd + opcode)
B7 1E 00 00	# lui	t4,0x1
93 8E FE FF	# addi	t4,t4,-1 ; 0xFFF
33 7E DE 01	# and	t3,t3,t4

# Encode J-type imm
93 5E 4F 01	# srli	t4,t5,0x14
93 FE 1E 00	# andi	t4,t4,1
93 9E FE 01	# slli	t4,t4,0x1f
33 6E DE 01	# or	t3,t3,t4
93 5E 1F 00	# srli	t4,t5,0x1
93 08 F0 3F	# addi	a7,zero,1023
B3 FE 1E 01	# and	t4,t4,a7
93 9E 5E 01	# slli	t4,t4,0x15
33 6E DE 01	# or	t3,t3,t4
93 5E BF 00	# srli	t4,t5,0xb
93 FE 1E 00	# andi	t4,t4,1
93 9E 4E 01	# slli	t4,t4,0x14
33 6E DE 01	# or	t3,t3,t4
93 5E CF 00	# srli	t4,t5,0xc
93 FE FE 0F	# andi	t4,t4,255
93 9E CE 00	# slli	t4,t4,0xc
33 6E DE 01	# or	t3,t3,t4
23 A0 C3 01	# sw	t3,0(t2)
6F 00 80 05	# jal	zero,fp_next

# delta = symbol - patch_offset
# fp_enc_uhi_pcrel:
33 0F FF 41	# sub	t5,t5,t6
03 AE 03 00	# lw	t3,0(t2)
13 1E 4E 01	# slli	t3,t3,0x14
13 5E 4E 01	# srli	t3,t3,0x14 ; clear bits 31:12
B7 1E 00 00	# lui	t4,0x1
93 DE 1E 00	# srli	t4,t4,0x1 ; 0x800
33 0F DF 01	# add	t5,t5,t4
13 5F CF 00	# srli	t5,t5,0xc
13 1F CF 00	# slli	t5,t5,0xc
33 6E EE 01	# or	t3,t3,t5
23 A0 C3 01	# sw	t3,0(t2)
6F 00 80 02	# jal	zero,fp_next

# delta = symbol - (patch_offset - 4)
# fp_enc_ilo_pcrp:
93 8F CF FF	# addi	t6,t6,-4 ; auipc PC
33 0F FF 41	# sub	t5,t5,t6
03 AE 03 00	# lw	t3,0(t2)
13 1E CE 00	# slli	t3,t3,0xc
13 5E CE 00	# srli	t3,t3,0xc ; clear bits 31:20
13 1F 4F 01	# slli	t5,t5,0x14 ; lo12 at bits 31:20
33 6E EE 01	# or	t3,t3,t5
23 A0 C3 01	# sw	t3,0(t2)
6F 00 40 00	# jal	zero,fp_next

# fp_next:
93 82 82 02	# addi	t0,t0,40
6F F0 5F EB	# jal	zero,fp_lp

# fp_ret:
67 80 00 00	# jalr	zero,0(ra)

# dump_output:
13 01 C1 FF	# addi	sp,sp,-4
23 20 11 00	# sw	ra,0(sp)

# Emit q32 magic nop (0x13, 0x00, 0x00, 0x00) before output
93 02 30 01	# addi	t0,zero,19
EF E0 4F 99	# jal	ra,wrch
93 02 00 00	# addi	t0,zero,0
EF E0 CF 98	# jal	ra,wrch
EF E0 8F 98	# jal	ra,wrch
EF E0 4F 98	# jal	ra,wrch
13 85 04 00	# addi	a0,s1,0

# do_lp:
63 00 25 03	# beq	a0,s2,do_ret
83 42 05 00	# lbu	t0,0(a0)
13 05 15 00	# addi	a0,a0,1

# do_tx:
03 CF 5A 00	# lbu	t5,5(s5)
13 7F 0F 02	# andi	t5,t5,32
E3 0C 0F FE	# beq	t5,zero,do_tx
23 80 5A 00	# sb	t0,0(s5)
6F F0 5F FE	# jal	zero,do_lp

# do_ret:
83 20 01 00	# lw	ra,0(sp)
13 01 41 00	# addi	sp,sp,4
67 80 00 00	# jalr	zero,0(ra)
