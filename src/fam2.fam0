# ────────────────────────────────�
# fam2.S — RV32I mnemonic assembler (third-stage bootstrap)
# ────────────────────────────────�
#
# Reads text from UART (terminated by EOT = 0x04), emits a RISC-V binary
# back over UART, then poweroffs.
#
# Grammar:
#   # ... \n                    comment (to end of line)
#   whitespace / comma          token separators (interchangeable)
#   name:                       label definition (name <= 31 ASCII chars)
#   XX                          passthrough hex byte (exactly 2 uppercase hex)
#   mnemonic operands           RV32I instruction or pseudo
#
# Supported mnemonics (RV32I base):
#   R-type:  add sub and or xor sll srl sra slt sltu
#   I-type:  addi andi ori xori slti sltiu slli srli srai
#   Load:    lb lh lw lbu lhu
#   Store:   sb sh sw
#   Branch:  beq bne blt bge bltu bgeu
#   U-type:  lui auipc
#   Jump:    jal jalr
# Pseudos:  nop li mv j ret beqz bnez
#
# Register convention:
#   s0  = token length          s1  = output buf base
#   s2  = output write ptr      s3  = symtab base
#   s4  = symtab write ptr      s5  = UART base (0x10000000)
#   s6  = 10 (constant)         s7  = fixup base
#   s8  = fixup write ptr       s9  = mnem_table base
#   s10 = token buf base        s11 = reg_table base
#   sp  = descending stack      t0-t6, a0-a7, ra = scratch
#
# Memory layout:
#   0x80000000  code + data tables (~5 KB)
#   +0x10000    output buffer (64 KB)
#   +0x20000    symtab  (40-byte entries: 32-byte name + 4 offset + 4 pad)
#   +0x30000    fixup   (40-byte entries: 32-byte name + 4 instr_addr + 4 pad)
#   +0x40000    token buffer (64 bytes)
#   +0x50000    stack top (grows down)
#
# Calling convention:
#   - args in a0..a5, returns in a0 (a1 for two-value)
#   - s-regs are global; subroutines must not clobber
#   - nested-call functions save/restore ra on stack

# .section .text
# .globl _start

# ════════════════════════════════�
# Format codes (in mnemonic table byte 12)
# ════════════════════════════════�
# .equ FMT_R,     0
# .equ FMT_I,     1
# .equ FMT_S,     2
# .equ FMT_B,     3
# .equ FMT_U,     4
# .equ FMT_J,     5
# .equ FMT_PSEUDO,6
# .equ FMT_LOAD,  7	# I-type with load parse pattern: rd, imm(rs1)
# .equ FMT_JALR,  8	# I-type: rd, rs1, imm  OR  rd, imm(rs1)

# Pseudo IDs (in mnemonic table byte 14)
# .equ PS_NOP,    0
# .equ PS_LI,     1
# .equ PS_MV,     2
# .equ PS_J,      3
# .equ PS_RET,    4
# .equ PS_BEQZ,   5
# .equ PS_BNEZ,   6

# Token types (returned by next_token in a0)
# .equ TOK_EOL,   0
# .equ TOK_IDENT, 1
# .equ TOK_NUM,   2
# .equ TOK_LPAREN,4
# .equ TOK_RPAREN,5
# .equ TOK_LABEL, 6	# identifier followed by ':'
# .equ TOK_EOT,   7

# ════════════════════════════════�
#  Initialization
# ════════════════════════════════�
# _start:
13 00 00 00	# addi	zero,zero,0 ; q32 magic

# Constants
13 0B A0 00	# addi	s6,zero,10
B7 0A 00 10	# lui	s5,0x10000 ; UART 0x10000000

# Compute base address
17 05 00 00	# auipc	a0,0x0 ; a0 = PC of this instruction
13 05 05 FF	# addi	a0,a0,-16 ; a0 = _start (back up past nop+li+lui)

# Output buffer at _start + 0x10000
B7 02 01 00	# lui	t0,0x10
B3 04 55 00	# add	s1,a0,t0
13 89 04 00	# addi	s2,s1,0

# Symtab at _start + 0x20000
B7 02 02 00	# lui	t0,0x20
B3 09 55 00	# add	s3,a0,t0
13 8A 09 00	# addi	s4,s3,0

# Fixup table at _start + 0x30000
B7 02 03 00	# lui	t0,0x30
B3 0B 55 00	# add	s7,a0,t0
13 8C 0B 00	# addi	s8,s7,0

# Token buffer at _start + 0x40000
B7 02 04 00	# lui	t0,0x40
33 0D 55 00	# add	s10,a0,t0

# Stack at _start + 0x50000
B7 02 05 00	# lui	t0,0x50
33 01 55 00	# add	sp,a0,t0

# Data tables (embedded in code section)
97 1C 00 00	# auipc	s9,0x1
93 8C CC E6	# addi	s9,s9,-404
97 1D 00 00	# auipc	s11,0x1
93 8D 4D 13	# addi	s11,s11,308

# We use the word just before the token buffer for this
# Putback character (0 = none)
23 2E 0D FE	# sw	zero,-4(s10)

# main_loop:
EF 00 00 7C	# jal	ra,next_token

# Dispatch on token type
93 02 70 00	# addi	t0,zero,7
E3 04 55 48	# beq	a0,t0,resolve ; EOT → resolve fixups
93 02 00 00	# addi	t0,zero,0
E3 08 55 FE	# beq	a0,t0,main_loop ; skip blank/separator
93 02 60 00	# addi	t0,zero,6
63 06 55 0A	# beq	a0,t0,handle_label

# First try hex passthrough: exactly 2 chars, both valid uppercase hex
# Must be TOK_IDENT — mnemonic or hex passthrough
93 02 20 00	# addi	t0,zero,2
63 12 54 04	# bne	s0,t0,try_mnemonic

# Check if both chars are uppercase hex (0-9, A-F)
83 42 0D 00	# lbu	t0,0(s10)
EF 00 D0 0F	# jal	ra,is_upper_hex
63 0C 05 02	# beq	a0,zero,try_mnemonic
83 42 1D 00	# lbu	t0,1(s10)
EF 00 10 0F	# jal	ra,is_upper_hex
63 06 05 02	# beq	a0,zero,try_mnemonic

# Hex passthrough: decode two hex chars → byte
83 42 0D 00	# lbu	t0,0(s10)
EF 00 10 11	# jal	ra,hex_val
13 03 05 00	# addi	t1,a0,0
13 13 43 00	# slli	t1,t1,0x4
83 42 1D 00	# lbu	t0,1(s10)
EF 00 10 10	# jal	ra,hex_val
33 63 A3 00	# or	t1,t1,a0
23 00 69 00	# sb	t1,0(s2)
13 09 19 00	# addi	s2,s2,1
6F F0 1F FA	# jal	zero,main_loop

# try_mnemonic:
EF 00 50 32	# jal	ra,lookup_mnem
E3 06 05 5E	# beq	a0,zero,error_halt ; Unknown mnemonic
93 07 05 00	# addi	a5,a0,0 ; a5 = mnemonic table entry ptr
03 A7 87 00	# lw	a4,8(a5) ; a4 = opcode template
83 C6 C7 00	# lbu	a3,12(a5) ; a3 = format type

# Dispatch on format
93 02 00 00	# addi	t0,zero,0
63 88 56 08	# beq	a3,t0,do_r_type
93 02 10 00	# addi	t0,zero,1
63 84 56 0C	# beq	a3,t0,do_i_type
93 02 20 00	# addi	t0,zero,2
63 80 56 1C	# beq	a3,t0,do_s_type
93 02 30 00	# addi	t0,zero,3
63 80 56 20	# beq	a3,t0,do_b_type
93 02 40 00	# addi	t0,zero,4
63 82 56 26	# beq	a3,t0,do_u_type
93 02 50 00	# addi	t0,zero,5
63 88 56 28	# beq	a3,t0,do_j_type
93 02 70 00	# addi	t0,zero,7
63 80 56 0E	# beq	a3,t0,do_load_type
93 02 80 00	# addi	t0,zero,8
63 80 56 12	# beq	a3,t0,do_jalr_type
93 02 60 00	# addi	t0,zero,6
63 8C 56 2C	# beq	a3,t0,do_pseudo
6F 00 50 59	# jal	zero,error_halt

# Zero 40 bytes at s4
# handle_label:
93 02 0A 00	# addi	t0,s4,0
13 03 8A 02	# addi	t1,s4,40

# hl_zero:
23 A0 02 00	# sw	zero,0(t0)
93 82 42 00	# addi	t0,t0,4
E3 9C 62 FE	# bne	t0,t1,hl_zero

# Copy token buffer to symtab entry (up to 31 chars)
93 02 0A 00	# addi	t0,s4,0 ; dest
13 03 0D 00	# addi	t1,s10,0 ; src
B3 03 8D 00	# add	t2,s10,s0 ; src end

# hl_copy:
63 0C 73 00	# beq	t1,t2,hl_store
03 4E 03 00	# lbu	t3,0(t1)
23 80 C2 01	# sb	t3,0(t0)
93 82 12 00	# addi	t0,t0,1
13 03 13 00	# addi	t1,t1,1
6F F0 DF FE	# jal	zero,hl_copy

# Store output offset (address relative to output base)
# hl_store:
B3 02 99 40	# sub	t0,s2,s1
23 20 5A 02	# sw	t0,32(s4)
13 0A 8A 02	# addi	s4,s4,40
6F F0 9F EF	# jal	zero,main_loop

# do_r_type:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
23 24 E1 00	# sw	a4,8(sp) ; save template
EF 00 D0 04	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rd
EF 00 50 04	# jal	ra,expect_reg
23 20 A1 00	# sw	a0,0(sp) ; rs1
EF 00 D0 03	# jal	ra,expect_reg
93 06 05 00	# addi	a3,a0,0 ; rs2
03 25 81 00	# lw	a0,8(sp) ; template
83 25 41 00	# lw	a1,4(sp) ; rd
03 26 01 00	# lw	a2,0(sp) ; rs1
EF 00 80 4B	# jal	ra,encode_r
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 9F EB	# jal	zero,main_loop

# do_i_type:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
23 24 E1 00	# sw	a4,8(sp)
EF 00 D0 00	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rd
EF 00 50 00	# jal	ra,expect_reg
23 20 A1 00	# sw	a0,0(sp) ; rs1
EF 00 90 01	# jal	ra,expect_imm
93 06 05 00	# addi	a3,a0,0 ; imm
03 25 81 00	# lw	a0,8(sp) ; template
83 25 41 00	# lw	a1,4(sp) ; rd
03 26 01 00	# lw	a2,0(sp) ; rs1
EF 00 80 4A	# jal	ra,encode_i
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 9F E7	# jal	zero,main_loop

# do_load_type:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
23 24 E1 00	# sw	a4,8(sp)
EF 00 C0 7C	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rd
EF 00 00 7E	# jal	ra,expect_imm
23 20 A1 00	# sw	a0,0(sp) ; imm
EF 00 90 0F	# jal	ra,expect_lparen
EF 00 80 7B	# jal	ra,expect_reg
13 06 05 00	# addi	a2,a0,0 ; rs1
EF 00 50 10	# jal	ra,expect_rparen
03 25 81 00	# lw	a0,8(sp) ; template
83 25 41 00	# lw	a1,4(sp) ; rd

# a2 = rs1
83 26 01 00	# lw	a3,0(sp) ; imm
EF 00 00 46	# jal	ra,encode_i
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 1F E3	# jal	zero,main_loop

# do_jalr_type:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
23 24 E1 00	# sw	a4,8(sp)
EF 00 40 78	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rd

# Peek at next token — numeric means load form, else register form
EF 00 80 5D	# jal	ra,next_token
EF 00 C0 70	# jal	ra,is_tok_numeric
63 14 05 02	# bne	a0,zero,jalr_load_form

# Identifier → must be a register (3-operand form: rd, rs1, imm)
EF 00 D0 0D	# jal	ra,parse_reg
23 20 A1 00	# sw	a0,0(sp) ; rs1
EF 00 40 78	# jal	ra,expect_imm
93 06 05 00	# addi	a3,a0,0 ; imm
03 25 81 00	# lw	a0,8(sp)
83 25 41 00	# lw	a1,4(sp)
03 26 01 00	# lw	a2,0(sp)
EF 00 40 41	# jal	ra,encode_i
6F 00 C0 02	# jal	zero,jalr_done

# jalr_load_form:
EF 00 40 78	# jal	ra,parse_num ; token already in buffer
23 20 A1 00	# sw	a0,0(sp) ; imm
EF 00 10 08	# jal	ra,expect_lparen
EF 00 00 74	# jal	ra,expect_reg
13 06 05 00	# addi	a2,a0,0 ; rs1
EF 00 D0 08	# jal	ra,expect_rparen
03 25 81 00	# lw	a0,8(sp)
83 25 41 00	# lw	a1,4(sp)

# a2 = rs1
83 26 01 00	# lw	a3,0(sp) ; imm
EF 00 80 3E	# jal	ra,encode_i

# jalr_done:
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 9F DB	# jal	zero,main_loop

# do_s_type:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
23 24 E1 00	# sw	a4,8(sp)
EF 00 C0 70	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rs2
EF 00 00 72	# jal	ra,expect_imm
23 20 A1 00	# sw	a0,0(sp) ; imm
EF 00 90 03	# jal	ra,expect_lparen
EF 00 80 6F	# jal	ra,expect_reg
93 05 05 00	# addi	a1,a0,0 ; rs1
EF 00 50 04	# jal	ra,expect_rparen
03 25 81 00	# lw	a0,8(sp) ; template

# a1 = rs1
03 26 41 00	# lw	a2,4(sp) ; rs2
83 26 01 00	# lw	a3,0(sp) ; imm
EF 00 00 3D	# jal	ra,encode_s
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 1F D7	# jal	zero,main_loop

# do_b_type:
13 01 C1 FE	# addi	sp,sp,-20
23 28 11 00	# sw	ra,16(sp)
23 26 E1 00	# sw	a4,12(sp)
EF 00 40 6C	# jal	ra,expect_reg
23 24 A1 00	# sw	a0,8(sp) ; rs1
EF 00 C0 6B	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rs2

# Third operand: label or immediate
EF 00 00 51	# jal	ra,next_token
EF 00 40 64	# jal	ra,is_tok_numeric
63 12 05 02	# bne	a0,zero,b_imm

# Identifier → label reference
EF 00 90 10	# jal	ra,lookup_label
63 46 05 00	# blt	a0,zero,b_forward ; not found → forward ref

# Backward ref: compute offset
B3 06 65 40	# sub	a3,a0,t1 ; t1 = current output offset (set by lookup_label helper)
6F 00 C0 01	# jal	zero,b_encode

# Add fixup, emit with imm=0
# b_forward:
93 05 30 00	# addi	a1,zero,3
EF 00 90 17	# jal	ra,add_fixup
93 06 00 00	# addi	a3,zero,0
6F 00 C0 00	# jal	zero,b_encode

# b_imm:
EF 00 00 6C	# jal	ra,parse_num
93 06 05 00	# addi	a3,a0,0 ; numeric immediate

# b_encode:
03 25 C1 00	# lw	a0,12(sp) ; template
83 25 81 00	# lw	a1,8(sp) ; rs1
03 26 41 00	# lw	a2,4(sp) ; rs2
EF 00 80 3A	# jal	ra,encode_b
83 20 01 01	# lw	ra,16(sp)
13 01 41 01	# addi	sp,sp,20
6F F0 5F D0	# jal	zero,main_loop

# do_u_type:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
23 24 E1 00	# sw	a4,8(sp)
EF 00 80 65	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rd
EF 00 C0 66	# jal	ra,expect_imm
13 06 05 00	# addi	a2,a0,0 ; imm20
03 25 81 00	# lw	a0,8(sp) ; template
83 25 41 00	# lw	a1,4(sp) ; rd
EF 00 C0 3D	# jal	ra,encode_u
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 1F CD	# jal	zero,main_loop

# do_j_type:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
23 24 E1 00	# sw	a4,8(sp)
EF 00 40 62	# jal	ra,expect_reg
23 22 A1 00	# sw	a0,4(sp) ; rd

# Next operand: label or immediate
EF 00 80 47	# jal	ra,next_token
EF 00 C0 5A	# jal	ra,is_tok_numeric
63 12 05 02	# bne	a0,zero,j_imm

# Identifier → label
EF 00 10 07	# jal	ra,lookup_label
63 46 05 00	# blt	a0,zero,j_forward
33 06 65 40	# sub	a2,a0,t1 ; offset
6F 00 C0 01	# jal	zero,j_encode

# j_forward:
93 05 50 00	# addi	a1,zero,5
EF 00 10 0E	# jal	ra,add_fixup
13 06 00 00	# addi	a2,zero,0
6F 00 C0 00	# jal	zero,j_encode

# j_imm:
EF 00 80 62	# jal	ra,parse_num
13 06 05 00	# addi	a2,a0,0

# j_encode:
03 25 81 00	# lw	a0,8(sp) ; template
83 25 41 00	# lw	a1,4(sp) ; rd
EF 00 40 3A	# jal	ra,encode_j
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 1F C7	# jal	zero,main_loop

# do_pseudo:
83 C6 E7 00	# lbu	a3,14(a5) ; pseudo ID
93 02 00 00	# addi	t0,zero,0
63 8C 56 02	# beq	a3,t0,ps_nop
93 02 10 00	# addi	t0,zero,1
63 86 56 04	# beq	a3,t0,ps_li
93 02 20 00	# addi	t0,zero,2
63 8C 56 0C	# beq	a3,t0,ps_mv
93 02 30 00	# addi	t0,zero,3
63 80 56 10	# beq	a3,t0,ps_j
93 02 40 00	# addi	t0,zero,4
63 86 56 14	# beq	a3,t0,ps_ret
93 02 50 00	# addi	t0,zero,5
63 86 56 16	# beq	a3,t0,ps_beqz
93 02 60 00	# addi	t0,zero,6
63 82 56 1C	# beq	a3,t0,ps_bnez
6F 00 50 28	# jal	zero,error_halt

# ps_nop:
13 01 C1 FF	# addi	sp,sp,-4
23 20 11 00	# sw	ra,0(sp)
13 05 30 01	# addi	a0,zero,19
EF 00 80 3A	# jal	ra,emit_word
83 20 01 00	# lw	ra,0(sp)
13 01 41 00	# addi	sp,sp,4
6F F0 5F C1	# jal	zero,main_loop

# ps_li:
13 01 01 FF	# addi	sp,sp,-16
23 26 11 00	# sw	ra,12(sp)
EF 00 C0 56	# jal	ra,expect_reg
23 24 A1 00	# sw	a0,8(sp) ; rd
EF 00 00 58	# jal	ra,expect_imm
23 22 A1 00	# sw	a0,4(sp) ; imm

# Check if imm fits in 12-bit signed (-2048..2047)
83 22 41 00	# lw	t0,4(sp)
13 03 F0 7F	# addi	t1,zero,2047
63 42 53 02	# blt	t1,t0,li_two_insn
13 03 00 80	# addi	t1,zero,-2048
63 CE 62 00	# blt	t0,t1,li_two_insn

# Single addi rd, x0, imm
13 05 30 01	# addi	a0,zero,19 ; addi template
83 25 81 00	# lw	a1,8(sp) ; rd
13 06 00 00	# addi	a2,zero,0 ; rs1 = x0
83 26 41 00	# lw	a3,4(sp) ; imm
EF 00 80 1F	# jal	ra,encode_i
6F 00 80 04	# jal	zero,li_done

# lower = imm[11:0] (sign-extended by addi)
# upper = (imm + 0x800) >>> 12 (logical right shift for sign correction)
# lui rd, upper + addi rd, rd, lower
# li_two_insn:
83 22 41 00	# lw	t0,4(sp) ; imm
37 13 00 00	# lui	t1,0x1
13 03 03 80	# addi	t1,t1,-2048
B3 83 62 00	# add	t2,t0,t1 ; imm + 0x800
93 D3 C3 40	# srai	t2,t2,0xc ; upper20 (arithmetic shift is fine here)

# lui rd, upper
13 05 70 03	# addi	a0,zero,55 ; lui template
83 25 81 00	# lw	a1,8(sp) ; rd
13 86 03 00	# addi	a2,t2,0 ; upper20
EF 00 C0 2A	# jal	ra,encode_u

# addi rd, rd, lower
83 22 41 00	# lw	t0,4(sp)

# lower12 = sign-extended low 12 bits
93 92 42 01	# slli	t0,t0,0x14 ; shift left to position
93 D2 42 41	# srai	t0,t0,0x14 ; arithmetic shift right to sign-extend
13 05 30 01	# addi	a0,zero,19 ; addi template
83 25 81 00	# lw	a1,8(sp) ; rd
03 26 81 00	# lw	a2,8(sp) ; rs1 = rd
93 86 02 00	# addi	a3,t0,0 ; lower12
EF 00 00 1B	# jal	ra,encode_i

# li_done:
83 20 C1 00	# lw	ra,12(sp)
13 01 01 01	# addi	sp,sp,16
6F F0 1F B8	# jal	zero,main_loop

# ps_mv:
13 01 81 FF	# addi	sp,sp,-8
23 22 11 00	# sw	ra,4(sp)
EF 00 80 4D	# jal	ra,expect_reg
93 05 05 00	# addi	a1,a0,0 ; rd
EF 00 00 4D	# jal	ra,expect_reg
