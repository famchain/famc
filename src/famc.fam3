.equ	UART, 0x10000

_start:
	j	main

exit:
	lui	t0, 0x100
	lui	t1, 5
	addi	t1, t1, 0x555
	sw	t1, 0(t0)
1:
	wfi
	j	1b

# write_byte: write byte in a0 to UART. Spins until TX ready.
write_byte:
	prologue	t0 t1 x0
	lui	t0, UART
wb_poll:
	lbu	t1, 5(t0)
	andi	t1, t1, 0x20
	beqz	t1, wb_poll
	sb	a0, 0(t0)
	return

# write_data: write bytes from a0 (start) to a1 (end) to UART.
write_data:
	prologue	s0 s1 x0
	mv	s0, a0			# cursor
	mv	s1, a1			# end
wd_loop:
	bgeu	s0, s1, wd_done
	lbu	a0, 0(s0)
	jal	write_byte
	addi	s0, s0, 1
	j	wd_loop
wd_done:
	return

# read_byte: read one byte from UART into a0. Spins until RX ready.
read_byte:
	prologue	t0 t1 x0
	lui	t0, UART
rb_poll:
	lbu	t1, 5(t0)
	andi	t1, t1, 1		# RX data ready (bit 0 of LSR)
	beqz	t1, rb_poll
	lbu	a0, 0(t0)
	return

# read_data: read UART bytes into tp until EOT (0x04).
# Returns a0 = number of bytes read.
read_data:
	prologue	s0 s1 x0
	li	s0, 4
	mv	s1, tp
rd_loop:
	jal	read_byte
	beq	a0, s0, rd_done
	sb	a0, 0(s1)
	addi	s1, s1, 1
	j	rd_loop
rd_done:
	sub	a0, s1, tp		# byte count
	return

# print_hex: print 32-bit value in a0 as "0xHHHHHHHH"
print_hex:
	prologue	s0 s1 t0 t1 t2 x0
	mv	s0, a0			# save value
	li	s1, 28			# shift (28,24,...,0)
	li	a0, '0'
	jal	write_byte
	li	a0, 'x'
	jal	write_byte
ph_digit:
	blt	s1, x0, ph_done
	srl	a0, s0, s1
	andi	a0, a0, 0xF
	li	t0, 10
	blt	a0, t0, ph_dec
	addi	a0, a0, 55		# 'A'-10
	j	ph_out
ph_dec:
	addi	a0, a0, '0'
ph_out:
	jal	write_byte
	addi	s1, s1, -4
	j	ph_digit
ph_done:
	return

# print_dec: print 32-bit unsigned value in a0 as decimal
print_dec:
	prologue	s0 s1 s2 t0 t1 t2 x0
	mv	s0, a0			# value
	li	s1, 1			# leading-zero suppression flag
# Divisors on stack: 1000000000 ... 1
	addi	sp, sp, -40
	li	t0, 1000000000
	sw	t0, 0(sp)
	li	t0, 100000000
	sw	t0, 4(sp)
	li	t0, 10000000
	sw	t0, 8(sp)
	li	t0, 1000000
	sw	t0, 12(sp)
	li	t0, 100000
	sw	t0, 16(sp)
	li	t0, 10000
	sw	t0, 20(sp)
	li	t0, 1000
	sw	t0, 24(sp)
	li	t0, 100
	sw	t0, 28(sp)
	li	t0, 10
	sw	t0, 32(sp)
	li	t0, 1
	sw	t0, 36(sp)
	mv	s2, sp			# divisor pointer
	addi	t2, sp, 40		# end
pd_loop:
	beq	s2, t2, pd_done
	lw	t0, 0(s2)		# current divisor
	li	t1, 0			# digit
pd_sub:
	bltu	s0, t0, pd_emit
	sub	s0, s0, t0
	addi	t1, t1, 1
	j	pd_sub
pd_emit:
	addi	t0, s2, 4
	beq	t0, t2, pd_print	# last digit: always print
	beqz	t1, pd_skip
	li	s1, 0			# saw nonzero: stop suppressing
	j	pd_print
pd_skip:
	bnez	s1, pd_next		# still suppressing
pd_print:
	addi	a0, t1, '0'
	jal	write_byte
pd_next:
	addi	s2, s2, 4
	j	pd_loop
pd_done:
	addi	sp, sp, 40
	return

# ============================================================================
# Constants
# ============================================================================

# Node kinds (lexer tokens + AST nodes)
.equ	NK_ERROR,	0
.equ	NK_TERM,	1
.equ	NK_SEMI,	2
.equ	NK_COMMA,	3
.equ	NK_COLON,	4
.equ	NK_QMARK,	5
.equ	NK_LPAREN,	6
.equ	NK_RPAREN,	7
.equ	NK_LBRACE,	8
.equ	NK_RBRACE,	9
.equ	NK_LBRACKET,	10
.equ	NK_RBRACKET,	11
.equ	NK_DOT,		12
.equ	NK_ARROW,	13
.equ	NK_BANG,	14
.equ	NK_TILDE,	15
.equ	NK_AMP,		16
.equ	NK_STAR,	17
.equ	NK_PLUS,	18
.equ	NK_HYPHEN,	19
.equ	NK_DBL_PLUS,	20
.equ	NK_DBL_HYPHEN,	21
.equ	NK_SLASH,	22
.equ	NK_PERCENT,	23
.equ	NK_EQUAL,	24
.equ	NK_ASSIGN_MUT,	25
.equ	NK_PLUS_EQ,	26
.equ	NK_MINUS_EQ,	27
.equ	NK_STAR_EQ,	28
.equ	NK_SLASH_EQ,	29
.equ	NK_PERCENT_EQ,	30
.equ	NK_PIPE,	31
.equ	NK_CARET,	32
.equ	NK_LSHIFT,	33
.equ	NK_RSHIFT,	34
.equ	NK_LSHIFT_EQ,	35
.equ	NK_RSHIFT_EQ,	36
.equ	NK_AMP_EQ,	37
.equ	NK_PIPE_EQ,	38
.equ	NK_CARET_EQ,	39
.equ	NK_DBL_EQUAL,	40
.equ	NK_NE,		41
.equ	NK_LT,		42
.equ	NK_GT,		43
.equ	NK_LTE,		44
.equ	NK_GTE,		45
.equ	NK_AMP_AMP,	46
.equ	NK_PIPE_PIPE,	47
.equ	NK_AT,		48
.equ	NK_HASH,	49
.equ	NK_FAT_ARROW,	50
.equ	NK_LOOP,	51
.equ	NK_BREAK,	52
.equ	NK_CONTINUE,	53
.equ	NK_SWITCH,	54
.equ	NK_RETURN,	55
.equ	NK_ASM,		56
.equ	NK_STRUCT,	57
.equ	NK_SIZEOF,	58
.equ	NK_IDENT,	59
.equ	NK_NUMBER,	60
.equ	NK_STR,		61
.equ	NK_CHAR,	62

# AST-only node kinds
.equ	NK_PROGRAM,	63
.equ	NK_BINOP,	64
.equ	NK_PREFIX,	65
.equ	NK_POSTFIX,	66
.equ	NK_ASSIGN,	67
.equ	NK_CALL,	68
.equ	NK_TERNARY,	69
.equ	NK_BLOCK,	70
.equ	NK_CLOSURE,	71
.equ	NK_INDEX,	72
.equ	NK_SELF,	73

# Precedence levels (higher = tighter binding, gaps of 2 for Pratt +1)
.equ	P_NONE,		0
.equ	P_ASSIGN,	2
.equ	P_TERNARY,	4
.equ	P_OR,		6
.equ	P_AND,		8
.equ	P_BIT_OR,	10
.equ	P_BIT_XOR,	12
.equ	P_BIT_AND,	14
.equ	P_EQUAL,	16
.equ	P_COMPARE,	18
.equ	P_SHIFT,	20
.equ	P_ADD,		22
.equ	P_MUL,		24
.equ	P_UNARY,	26
.equ	P_POSTFIX,	28
.equ	P_CALL,		30

# Trie node struct (1036 bytes)
.equ	T_KIND,		0
.equ	T_LEN,		4
.equ	T_RESERVED,	8
.equ	T_CHILDREN,	12
.equ	T_NODE_SZ,	1036

# Lexer state struct (20 bytes + root trie node)
.equ	L_IN,		0
.equ	L_END,		4
.equ	L_OFF,		8
.equ	L_LINE,		12
.equ	L_COL_START,	16
.equ	L_ROOT,		20
.equ	L_SZ,		1056

# Node struct (44 bytes)
.equ	N_KIND,		0
.equ	N_LOC_OFF,	4
.equ	N_LOC_LEN,	8
.equ	N_LOC_LINE,	12
.equ	N_LOC_COL,	16
.equ	N_PARENT,	20
.equ	N_FIRST_CHILD,	24
.equ	N_LAST_CHILD,	28
.equ	N_NEXT_SIB,	32
.equ	N_PREV_SIB,	36
.equ	N_DATA,		40
.equ	N_SZ,		44

# Register numbers (for generated code)
.equ	R_ZERO,	0
.equ	R_RA,	1
.equ	R_SP,	2
.equ	R_GP,	3
.equ	R_TP,	4
.equ	R_T0,	5
.equ	R_T1,	6
.equ	R_T2,	7
.equ	R_S0,	8
.equ	R_S1,	9
.equ	R_A0,	10
.equ	R_A1,	11

# Asm mnemonic classes
.equ	MC_RTYPE,	1
.equ	MC_IARITH,	2
.equ	MC_ISHIFT,	3
.equ	MC_ILOAD,	4
.equ	MC_STYPE,	5
.equ	MC_BTYPE,	6
.equ	MC_LUI,		7
.equ	MC_AUIPC,	8
.equ	MC_JAL,		9
.equ	MC_JALR,	10
.equ	MC_LI,		11
.equ	MC_MV,		12
.equ	MC_RET,		13
.equ	MC_J,		14
.equ	MC_NOP,		15
.equ	MC_NOT,		16
.equ	MC_NEG,		17
.equ	MC_SEQZ,	18
.equ	MC_SNEZ,	19
.equ	MC_JR,		20
.equ	MC_WFI,		21
.equ	MC_CSR,		22

# Asm label entry
.equ	AL_OFF,	0
.equ	AL_LEN,	4
.equ	AL_ADDR,	8
.equ	AL_SZ,	12

# Asm label table header
.equ	AT_CNT,	0
.equ	AT_DATA,	4

# Asm local label entry (within an asm block)
.equ	LL_OFF,	0
.equ	LL_LEN,	4
.equ	LL_ADDR,	8
.equ	LL_SZ,	12

# Asm fixup entry
.equ	FX_OFF,	0
.equ	FX_LEN,	4
.equ	FX_ADDR,	8
.equ	FX_TYPE,	12
.equ	FX_SZ,	16

# Symbol table entry (16 bytes, power of 2 for easy indexing)
.equ	SY_OFF,	0
.equ	SY_LEN,	4
.equ	SY_SLOT,	8
.equ	SY_SZ,	16

# Symbol table header
.equ	ST_CNT,	0
.equ	ST_NEXT,	4
.equ	ST_CAP,	8
.equ	ST_CAPS,	12
.equ	ST_DATA,	16

# ============================================================================
# Memory helpers
# ============================================================================

# alloc: bump-allocate a0 bytes from heap (gp). Returns a0 = ptr.
alloc:
	mv	t0, gp
	add	gp, gp, a0
	bgeu	sp, gp, alloc_ok
	li	a0, 'M'
	jal	write_byte
	j	exit
alloc_ok:
	mv	a0, t0
	ret

# memzero: zero a0..a0+a1 (a1 must be multiple of 4)
memzero:
	add	t0, a0, a1
mz_loop:
	bgeu	a0, t0, mz_done
	sw	x0, 0(a0)
	addi	a0, a0, 4
	j	mz_loop
mz_done:
	ret

# ============================================================================
# Lexer
# ============================================================================

# lexer_register: register a token in the lexer trie.
#   a0=lexer, a1=string ptr, a2=len, a3=kind, a4=is_reserved
lex_register:
	prologue s0 s1 s2 s3 s4 s5 s6 s7 x0
	addi	s0, a0, L_ROOT		# s0 = current node (start at root)
	mv	s1, a1			# s1 = string ptr
	mv	s2, a2			# s2 = len
	mv	s3, a3			# s3 = kind
	mv	s4, a4			# s4 = is_reserved
	li	s5, 0			# s5 = index
	addi	s6, s2, -1		# s6 = last index

lr_loop:
	lbu	s7, 0(s1)		# load char
	slli	s7, s7, 2		# * 4 (pointer stride)
	add	s7, s7, s0		# index into children
	addi	s7, s7, T_CHILDREN	# offset to children array
	lw	t0, 0(s7)		# child node ptr
	bnez	t0, lr_exists

	# Allocate new trie node (zeroed)
	li	a0, T_NODE_SZ
	jal	alloc
	mv	t1, a0
	li	a1, T_NODE_SZ
	jal	memzero
	sw	t1, 0(s7)		# store child ptr
	mv	t0, t1
lr_exists:
	mv	s0, t0			# descend to child
	bne	s5, s6, lr_next

	# Last char: store token metadata
	sw	s2, T_LEN(s0)
	sw	s3, T_KIND(s0)
	sw	s4, T_RESERVED(s0)
	j	lr_done

lr_next:
	addi	s5, s5, 1
	addi	s1, s1, 1
	j	lr_loop

lr_done:
	return

# lexer_init: create and initialize lexer.
#   a0=input start, a1=input end. Returns a0=lexer ptr.
lexer_init:
	prologue s0 s1 s2 x0
	mv	s1, a0			# save input start
	mv	s2, a1			# save input end

	# Allocate lexer struct
	li	a0, L_SZ
	jal	alloc
	mv	s0, a0			# s0 = lexer ptr
	li	a1, L_SZ
	jal	memzero

	# Initialize state
	sw	s1, L_IN(s0)
	sw	s2, L_END(s0)
	sw	x0, L_OFF(s0)
	li	t0, 1
	sw	t0, L_LINE(s0)
	sw	x0, L_COL_START(s0)

	# Register tokens (longest first)
	# 3-char operators
	mv	a0, s0
	lla	a1, tok_lshift_eq
	li	a2, 3
	li	a3, NK_LSHIFT_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_rshift_eq
	li	a2, 3
	li	a3, NK_RSHIFT_EQ
	li	a4, 0
	jal	lex_register

	# 2-char operators
	mv	a0, s0
	lla	a1, tok_dbl_plus
	li	a2, 2
	li	a3, NK_DBL_PLUS
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_dbl_hyphen
	li	a2, 2
	li	a3, NK_DBL_HYPHEN
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_assign_mut
	li	a2, 2
	li	a3, NK_ASSIGN_MUT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_plus_eq
	li	a2, 2
	li	a3, NK_PLUS_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_minus_eq
	li	a2, 2
	li	a3, NK_MINUS_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_star_eq
	li	a2, 2
	li	a3, NK_STAR_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_slash_eq
	li	a2, 2
	li	a3, NK_SLASH_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_pct_eq
	li	a2, 2
	li	a3, NK_PERCENT_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_dbl_equal
	li	a2, 2
	li	a3, NK_DBL_EQUAL
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_ne
	li	a2, 2
	li	a3, NK_NE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_lte
	li	a2, 2
	li	a3, NK_LTE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_gte
	li	a2, 2
	li	a3, NK_GTE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_amp_amp
	li	a2, 2
	li	a3, NK_AMP_AMP
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_pipe_pipe
	li	a2, 2
	li	a3, NK_PIPE_PIPE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_lshift
	li	a2, 2
	li	a3, NK_LSHIFT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_rshift
	li	a2, 2
	li	a3, NK_RSHIFT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_arrow
	li	a2, 2
	li	a3, NK_ARROW
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_fat_arrow
	li	a2, 2
	li	a3, NK_FAT_ARROW
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_amp_eq
	li	a2, 2
	li	a3, NK_AMP_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_pipe_eq
	li	a2, 2
	li	a3, NK_PIPE_EQ
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_caret_eq
	li	a2, 2
	li	a3, NK_CARET_EQ
	li	a4, 0
	jal	lex_register

	# 1-char operators
	mv	a0, s0
	lla	a1, tok_semi
	li	a2, 1
	li	a3, NK_SEMI
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_comma
	li	a2, 1
	li	a3, NK_COMMA
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_colon
	li	a2, 1
	li	a3, NK_COLON
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_dot
	li	a2, 1
	li	a3, NK_DOT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_plus
	li	a2, 1
	li	a3, NK_PLUS
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_hyphen
	li	a2, 1
	li	a3, NK_HYPHEN
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_star
	li	a2, 1
	li	a3, NK_STAR
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_slash
	li	a2, 1
	li	a3, NK_SLASH
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_percent
	li	a2, 1
	li	a3, NK_PERCENT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_equal
	li	a2, 1
	li	a3, NK_EQUAL
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_bang
	li	a2, 1
	li	a3, NK_BANG
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_tilde
	li	a2, 1
	li	a3, NK_TILDE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_amp
	li	a2, 1
	li	a3, NK_AMP
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_pipe
	li	a2, 1
	li	a3, NK_PIPE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_caret
	li	a2, 1
	li	a3, NK_CARET
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_lt
	li	a2, 1
	li	a3, NK_LT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_gt
	li	a2, 1
	li	a3, NK_GT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_qmark
	li	a2, 1
	li	a3, NK_QMARK
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_lparen
	li	a2, 1
	li	a3, NK_LPAREN
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_rparen
	li	a2, 1
	li	a3, NK_RPAREN
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_lbrace
	li	a2, 1
	li	a3, NK_LBRACE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_rbrace
	li	a2, 1
	li	a3, NK_RBRACE
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_lbracket
	li	a2, 1
	li	a3, NK_LBRACKET
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_rbracket
	li	a2, 1
	li	a3, NK_RBRACKET
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_at
	li	a2, 1
	li	a3, NK_AT
	li	a4, 0
	jal	lex_register
	mv	a0, s0
	lla	a1, tok_hash
	li	a2, 1
	li	a3, NK_HASH
	li	a4, 0
	jal	lex_register

	# Reserved keywords
	mv	a0, s0
	lla	a1, kw_loop
	li	a2, 4
	li	a3, NK_LOOP
	li	a4, 1
	jal	lex_register
	mv	a0, s0
	lla	a1, kw_break
	li	a2, 5
	li	a3, NK_BREAK
	li	a4, 1
	jal	lex_register
	mv	a0, s0
	lla	a1, kw_continue
	li	a2, 8
	li	a3, NK_CONTINUE
	li	a4, 1
	jal	lex_register
	mv	a0, s0
	lla	a1, kw_switch
	li	a2, 6
	li	a3, NK_SWITCH
	li	a4, 1
	jal	lex_register
	mv	a0, s0
	lla	a1, kw_return
	li	a2, 6
	li	a3, NK_RETURN
	li	a4, 1
	jal	lex_register
	mv	a0, s0
	lla	a1, kw_asm
	li	a2, 3
	li	a3, NK_ASM
	li	a4, 1
	jal	lex_register
	mv	a0, s0
	lla	a1, kw_struct
	li	a2, 6
	li	a3, NK_STRUCT
	li	a4, 1
	jal	lex_register
	mv	a0, s0
	lla	a1, kw_sizeof
	li	a2, 6
	li	a3, NK_SIZEOF
	li	a4, 1
	jal	lex_register

	mv	a0, s0			# return lexer ptr
	return

# next_token: lex next token into node at a1.
#   a0=lexer, a1=token node ptr
next_token:
	prologue s0 s1 s2 s3 s4 s5 x0
	mv	s0, a0			# s0 = lexer
	mv	s1, a1			# s1 = token node

	# Load lexer state
	lw	t0, L_IN(s0)		# input start
	lw	t1, L_OFF(s0)		# offset
	add	s2, t1, t0		# s2 = current ptr
	lw	s3, L_END(s0)		# s3 = end ptr

	# Skip whitespace and comments
nt_ws:
	bgeu	s2, s3, nt_ws_done
	lbu	t5, 0(s2)
	li	t4, 32
	bgtu	t5, t4, nt_ck_comment
	addi	s2, s2, 1
	li	t1, '\n'
	bne	t5, t1, nt_ws
	# Track newline
	lw	t1, L_LINE(s0)
	addi	t1, t1, 1
	sw	t1, L_LINE(s0)
	lw	t0, L_IN(s0)
	sub	t1, s2, t0
	sw	t1, L_COL_START(s0)
	j	nt_ws

nt_ck_comment:
	# Check for // or /*
	addi	t4, s2, 1
	bgeu	t4, s3, nt_ws_done
	li	t6, '/'
	bne	t5, t6, nt_ws_done
	lbu	t5, 1(s2)
	beq	t5, t6, nt_line_cmt
	li	t6, '*'
	beq	t5, t6, nt_block_cmt
	j	nt_ws_done

nt_line_cmt:
	addi	s2, s2, 2
nt_lc_loop:
	bgeu	s2, s3, nt_ws_done
	lbu	t5, 0(s2)
	addi	s2, s2, 1
	li	t4, '\n'
	bne	t5, t4, nt_lc_loop
	lw	t1, L_LINE(s0)
	addi	t1, t1, 1
	sw	t1, L_LINE(s0)
	lw	t0, L_IN(s0)
	sub	t1, s2, t0
	sw	t1, L_COL_START(s0)
	j	nt_ws

nt_block_cmt:
	addi	s2, s2, 2
	li	s4, 1			# depth
nt_bc_loop:
	bgeu	s2, s3, nt_ws_done
	lbu	t5, 0(s2)
	addi	s2, s2, 1
	li	t1, '\n'
	bne	t5, t1, nt_bc_no_nl
	lw	t1, L_LINE(s0)
	addi	t1, t1, 1
	sw	t1, L_LINE(s0)
	lw	t0, L_IN(s0)
	sub	t1, s2, t0
	sw	t1, L_COL_START(s0)
nt_bc_no_nl:
	li	t4, '*'
	bne	t5, t4, nt_bc_no_cl
	bgeu	s2, s3, nt_ws_done
	lbu	t5, 0(s2)
	li	t4, '/'
	bne	t5, t4, nt_bc_loop
	addi	s2, s2, 1
	addi	s4, s4, -1
	bnez	s4, nt_bc_loop
	j	nt_ws
nt_bc_no_cl:
	li	t4, '/'
	bne	t5, t4, nt_bc_loop
	bgeu	s2, s3, nt_ws_done
	lbu	t5, 0(s2)
	li	t4, '*'
	bne	t5, t4, nt_bc_loop
	addi	s2, s2, 1
	addi	s4, s4, 1
	j	nt_bc_loop

nt_ws_done:
	# Store updated offset, init token
	lw	t0, L_IN(s0)
	sub	s4, s2, t0		# s4 = updated offset
	sw	s4, L_OFF(s0)
	sw	x0, N_LOC_LEN(s1)
	sw	s4, N_LOC_OFF(s1)
	lw	t1, L_LINE(s0)
	sw	t1, N_LOC_LINE(s1)
	lw	t1, L_COL_START(s0)
	sub	t1, s4, t1
	sw	t1, N_LOC_COL(s1)

	# Check EOF
	bgeu	s2, s3, nt_eof

	# Trie walk
	sw	x0, N_KIND(s1)
	li	s5, 0			# s5 = reserved flag
	addi	s4, s0, L_ROOT
	addi	s4, s4, T_CHILDREN

nt_trie:
	bgeu	s2, s3, nt_trie_end
	lbu	t4, 0(s2)
	addi	s2, s2, 1
	slli	t4, t4, 2
	add	t4, t4, s4
	lw	t4, 0(t4)		# child ptr
	beqz	t4, nt_trie_end
	addi	s4, t4, T_CHILDREN
	lw	t6, T_LEN(t4)
	beqz	t6, nt_trie
	# Found a match — record it
	sw	t6, N_LOC_LEN(s1)
	lw	t6, T_KIND(t4)
	sw	t6, N_KIND(s1)
	lw	s5, T_RESERVED(t4)
	j	nt_trie

nt_trie_end:
	lw	t4, N_LOC_LEN(s1)
	beqz	t4, nt_no_match

	# Trie matched. If not reserved, accept.
	beqz	s5, nt_update_off

	# Reserved keyword: check if next char continues ident
	lw	t5, N_LOC_OFF(s1)
	add	t5, t5, t4
	lw	t0, L_IN(s0)
	add	t5, t5, t0
	bgeu	t5, s3, nt_update_off
	lbu	t6, 0(t5)
	li	t1, '_'
	beq	t6, t1, nt_no_match
	li	t1, 'a'
	blt	t6, t1, nt_rsv_upper
	li	t1, 'z'
	bge	t1, t6, nt_no_match
nt_rsv_upper:
	li	t1, 'A'
	blt	t6, t1, nt_rsv_digit
	li	t1, 'Z'
	bge	t1, t6, nt_no_match
nt_rsv_digit:
	li	t1, '0'
	blt	t6, t1, nt_update_off
	li	t1, '9'
	bge	t1, t6, nt_no_match
	j	nt_update_off

nt_no_match:
	# Reset to token start, try ident/number/string/char
	lw	t5, N_LOC_OFF(s1)
	lw	t0, L_IN(s0)
	add	s2, t5, t0
	bgeu	s2, s3, nt_update_off
	lbu	t6, 0(s2)

	# Check digit
	li	t1, '0'
	blt	t6, t1, nt_ck_ident
	li	t1, '9'
	bge	t1, t6, nt_scan_num

nt_ck_ident:
	li	t1, '_'
	beq	t6, t1, nt_scan_id
	li	t1, 'a'
	blt	t6, t1, nt_ck_upper
	li	t1, 'z'
	bge	t1, t6, nt_scan_id
nt_ck_upper:
	li	t1, 'A'
	blt	t6, t1, nt_ck_str
	li	t1, 'Z'
	bge	t1, t6, nt_scan_id
	j	nt_ck_str

nt_ck_str:
	li	t1, '"'
	beq	t6, t1, nt_scan_str
	li	t1, '\''
	beq	t6, t1, nt_scan_char
	# Unknown char — consume 1
	li	t4, 1
	sw	t4, N_LOC_LEN(s1)
	j	nt_update_off

nt_scan_id:
	li	t4, NK_IDENT
	sw	t4, N_KIND(s1)
	addi	s2, s2, 1
nt_id_loop:
	bgeu	s2, s3, nt_id_done
	lbu	t6, 0(s2)
	li	t1, '_'
	beq	t6, t1, nt_id_next
	li	t1, 'a'
	blt	t6, t1, nt_id_up
	li	t1, 'z'
	bge	t1, t6, nt_id_next
nt_id_up:
	li	t1, 'A'
	blt	t6, t1, nt_id_dig
	li	t1, 'Z'
	bge	t1, t6, nt_id_next
nt_id_dig:
	li	t1, '0'
	blt	t6, t1, nt_id_done
	li	t1, '9'
	blt	t1, t6, nt_id_done
nt_id_next:
	addi	s2, s2, 1
	j	nt_id_loop
nt_id_done:
	lw	t0, L_IN(s0)
	sub	t4, s2, t0
	lw	t5, N_LOC_OFF(s1)
	sub	t4, t4, t5
	sw	t4, N_LOC_LEN(s1)
	j	nt_update_off

nt_scan_num:
	li	t4, NK_NUMBER
	sw	t4, N_KIND(s1)
	# Check 0x prefix
	lbu	t6, 0(s2)
	li	t1, '0'
	bne	t6, t1, nt_num_dec
	addi	t1, s2, 1
	bgeu	t1, s3, nt_num_dec
	lbu	t6, 0(t1)
	li	t4, 'x'
	beq	t6, t4, nt_hex_go
	li	t4, 'b'
	beq	t6, t4, nt_bin_go
	j	nt_num_dec
nt_hex_go:
	addi	s2, t1, 1
	# Must have at least one hex digit, else just parse "0"
	bgeu	s2, s3, nt_id_done		# "0x" at EOF → just "0"
	lbu	t6, 0(s2)
	li	t1, '0'
	blt	t6, t1, nt_hex_bare
	li	t1, '9'
	bge	t1, t6, nt_num_hex
	li	t1, 'a'
	blt	t6, t1, nt_hex_ck_up
	li	t1, 'f'
	bge	t1, t6, nt_num_hex
nt_hex_ck_up:
	li	t1, 'A'
	blt	t6, t1, nt_hex_bare
	li	t1, 'F'
	bge	t1, t6, nt_num_hex
nt_hex_bare:
	# "0x" with no digits — back up to just "0"
	addi	s2, s2, -1
	j	nt_id_done
nt_num_hex:
	bgeu	s2, s3, nt_id_done
	lbu	t6, 0(s2)
	li	t1, '0'
	blt	t6, t1, nt_id_done
	li	t1, '9'
	bge	t1, t6, nt_num_hex_ok
	li	t1, 'a'
	blt	t6, t1, nt_num_hex_up
	li	t1, 'f'
	bge	t1, t6, nt_num_hex_ok
	j	nt_id_done
nt_num_hex_up:
	li	t1, 'A'
	blt	t6, t1, nt_id_done
	li	t1, 'F'
	blt	t1, t6, nt_id_done
nt_num_hex_ok:
	addi	s2, s2, 1
	j	nt_num_hex

nt_bin_go:
	addi	s2, t1, 1
	# Must have at least one binary digit, else just parse "0"
	bgeu	s2, s3, nt_id_done
	lbu	t6, 0(s2)
	li	t1, '0'
	beq	t6, t1, nt_num_bin
	li	t1, '1'
	beq	t6, t1, nt_num_bin
	# "0b" with no digits — back up to just "0"
	addi	s2, s2, -1
	j	nt_id_done
nt_num_bin:
	bgeu	s2, s3, nt_id_done
	lbu	t6, 0(s2)
	li	t1, '0'
	beq	t6, t1, nt_num_bin_ok
	li	t1, '1'
	bne	t6, t1, nt_id_done
nt_num_bin_ok:
	addi	s2, s2, 1
	j	nt_num_bin

nt_num_dec:
	addi	s2, s2, 1
nt_num_loop:
	bgeu	s2, s3, nt_id_done
	lbu	t6, 0(s2)
	li	t1, '0'
	blt	t6, t1, nt_id_done
	li	t1, '9'
	blt	t1, t6, nt_id_done
	addi	s2, s2, 1
	j	nt_num_loop

nt_scan_str:
	li	t4, NK_STR
	sw	t4, N_KIND(s1)
	addi	s2, s2, 1
nt_str_loop:
	bgeu	s2, s3, nt_str_bad		# EOF without closing quote
	lbu	t6, 0(s2)
	addi	s2, s2, 1
	li	t1, '\\'
	beq	t6, t1, nt_str_esc
	li	t1, '"'
	beq	t6, t1, nt_id_done
	li	t1, '\n'
	bne	t6, t1, nt_str_loop
	# Newline in string (track but continue)
	lw	t1, L_LINE(s0)
	addi	t1, t1, 1
	sw	t1, L_LINE(s0)
	lw	t0, L_IN(s0)
	sub	t1, s2, t0
	sw	t1, L_COL_START(s0)
	j	nt_str_loop
nt_str_esc:
	bgeu	s2, s3, nt_str_bad		# EOF after backslash
	addi	s2, s2, 1
	j	nt_str_loop
nt_str_bad:
	sw	x0, N_KIND(s1)			# NK_ERROR
	j	nt_id_done

nt_scan_char:
	li	t4, NK_CHAR
	sw	t4, N_KIND(s1)
	addi	s2, s2, 1
nt_chr_loop:
	bgeu	s2, s3, nt_id_done
	lbu	t6, 0(s2)
	li	t1, '\n'
	beq	t6, t1, nt_chr_bad		# unterminated at newline
	addi	s2, s2, 1
	li	t1, '\\'
	beq	t6, t1, nt_chr_esc
	li	t1, '\''
	beq	t6, t1, nt_id_done
	j	nt_chr_loop
nt_chr_bad:
	sw	x0, N_KIND(s1)			# NK_ERROR
	j	nt_id_done
nt_chr_esc:
	bgeu	s2, s3, nt_id_done
	addi	s2, s2, 1
	j	nt_chr_loop

nt_eof:
	li	t6, NK_TERM
	sw	t6, N_KIND(s1)
	j	nt_done

nt_update_off:
	lw	t4, N_LOC_LEN(s1)
	lw	t5, N_LOC_OFF(s1)
	add	t5, t5, t4
	sw	t5, L_OFF(s0)

nt_done:
	return

# ============================================================================
# AST helpers
# ============================================================================

# alloc_node: allocate and zero an N_SZ node. Returns a0 = ptr.
alloc_node:
	prologue s0 x0
	li	a0, N_SZ
	jal	alloc
	mv	s0, a0
	li	a1, N_SZ
	jal	memzero
	mv	a0, s0
	return

# append_child: a0=parent, a1=child. Appends child to parent's child list.
append_child:
	sw	a0, N_PARENT(a1)
	lw	t0, N_LAST_CHILD(a0)
	bnez	t0, ac_has_last
	sw	a1, N_FIRST_CHILD(a0)
	sw	a1, N_LAST_CHILD(a0)
	ret
ac_has_last:
	sw	a1, N_NEXT_SIB(t0)
	sw	t0, N_PREV_SIB(a1)
	sw	a1, N_LAST_CHILD(a0)
	ret

# copy_loc: copy source location from a0 (src node) to a1 (dst node)
copy_loc:
	lw	t0, N_LOC_OFF(a0)
	sw	t0, N_LOC_OFF(a1)
	lw	t0, N_LOC_LEN(a0)
	sw	t0, N_LOC_LEN(a1)
	lw	t0, N_LOC_LINE(a0)
	sw	t0, N_LOC_LINE(a1)
	lw	t0, N_LOC_COL(a0)
	sw	t0, N_LOC_COL(a1)
	ret

# ============================================================================
# Parser globals (stored at known offsets from gp-relative addresses)
# We use s-regs during parsing:
#   s0 = lexer ptr
#   s1 = current token node (reused across advance calls)
#   s2 = input buffer start (for error messages)
# ============================================================================

# advance: lex next token into s1. Uses parser globals s0, s1.
advance:
	mv	a0, s0
	mv	a1, s1
	j	next_token		# tail call

# expect: verify current token kind == a0, then advance. Error if mismatch.
expect:
	prologue s3 x0
	mv	s3, a0			# expected kind
	lw	t0, N_KIND(s1)
	bne	t0, s3, exp_fail
	jal	advance			# consume the expected token
	j	exp_ok
exp_fail:
	# Error: unexpected token
	li	a0, 'E'
	jal	write_byte
	lw	a0, N_LOC_LINE(s1)
	jal	print_dec
	li	a0, ':'
	jal	write_byte
	lw	a0, N_LOC_COL(s1)
	jal	print_dec
	li	a0, 32
	jal	write_byte
	li	a0, 'e'
	jal	write_byte
	li	a0, 'x'
	jal	write_byte
	li	a0, 'p'
	jal	write_byte
	li	a0, 32
	jal	write_byte
	mv	a0, s3
	jal	print_dec
	li	a0, '\n'
	jal	write_byte
	j	exit
exp_ok:
	return

# get_prec: return precedence of infix operator in a0 (token kind).
#   Returns a0 = precedence level.
get_prec:
	# Assignment operators (right-assoc, P_ASSIGN=1)
	li	t0, NK_EQUAL
	beq	a0, t0, gp_assign
	li	t0, NK_ASSIGN_MUT
	beq	a0, t0, gp_assign
	li	t0, NK_PLUS_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_MINUS_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_STAR_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_SLASH_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_PERCENT_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_AMP_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_PIPE_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_CARET_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_LSHIFT_EQ
	beq	a0, t0, gp_assign
	li	t0, NK_RSHIFT_EQ
	beq	a0, t0, gp_assign
	# Ternary
	li	t0, NK_QMARK
	beq	a0, t0, gp_ternary
	# Logical
	li	t0, NK_PIPE_PIPE
	beq	a0, t0, gp_or
	li	t0, NK_AMP_AMP
	beq	a0, t0, gp_and
	# Bitwise
	li	t0, NK_PIPE
	beq	a0, t0, gp_bitor
	li	t0, NK_CARET
	beq	a0, t0, gp_bitxor
	li	t0, NK_AMP
	beq	a0, t0, gp_bitand
	# Equality
	li	t0, NK_DBL_EQUAL
	beq	a0, t0, gp_equal
	li	t0, NK_NE
	beq	a0, t0, gp_equal
	# Comparison
	li	t0, NK_LT
	beq	a0, t0, gp_cmp
	li	t0, NK_GT
	beq	a0, t0, gp_cmp
	li	t0, NK_LTE
	beq	a0, t0, gp_cmp
	li	t0, NK_GTE
	beq	a0, t0, gp_cmp
	# Shift
	li	t0, NK_LSHIFT
	beq	a0, t0, gp_shift
	li	t0, NK_RSHIFT
	beq	a0, t0, gp_shift
	# Additive
	li	t0, NK_PLUS
	beq	a0, t0, gp_add
	li	t0, NK_HYPHEN
	beq	a0, t0, gp_add
	# Multiplicative
	li	t0, NK_STAR
	beq	a0, t0, gp_mul
	li	t0, NK_SLASH
	beq	a0, t0, gp_mul
	li	t0, NK_PERCENT
	beq	a0, t0, gp_mul
	# Postfix: call, index, member access
	li	t0, NK_LPAREN
	beq	a0, t0, gp_call
	li	t0, NK_LBRACKET
	beq	a0, t0, gp_call
	li	t0, NK_DOT
	beq	a0, t0, gp_call
	li	t0, NK_ARROW
	beq	a0, t0, gp_call
	li	t0, NK_DBL_PLUS
	beq	a0, t0, gp_postfix
	li	t0, NK_DBL_HYPHEN
	beq	a0, t0, gp_postfix
	# Fat arrow (switch arms, same prec as assign)
	li	t0, NK_FAT_ARROW
	beq	a0, t0, gp_assign
	# No infix precedence
	li	a0, P_NONE
	ret
gp_assign:
	li	a0, P_ASSIGN
	ret
gp_ternary:
	li	a0, P_TERNARY
	ret
gp_or:
	li	a0, P_OR
	ret
gp_and:
	li	a0, P_AND
	ret
gp_bitor:
	li	a0, P_BIT_OR
	ret
gp_bitxor:
	li	a0, P_BIT_XOR
	ret
gp_bitand:
	li	a0, P_BIT_AND
	ret
gp_equal:
	li	a0, P_EQUAL
	ret
gp_cmp:
	li	a0, P_COMPARE
	ret
gp_shift:
	li	a0, P_SHIFT
	ret
gp_add:
	li	a0, P_ADD
	ret
gp_mul:
	li	a0, P_MUL
	ret
gp_call:
	li	a0, P_CALL
	ret
gp_postfix:
	li	a0, P_POSTFIX
	ret

# ============================================================================
# Pratt parser
# ============================================================================

# parse_expr: parse expression with minimum precedence a0.
#   s0=lexer, s1=current token, s2=input base.
#   Returns a0 = AST node ptr.
parse_expr:
	prologue s3 s4 s5 s6 x0
	mv	s5, a0			# s5 = min_prec

	# s1 already holds the current token (primed by caller)
	lw	s3, N_KIND(s1)		# s3 = token kind

	# --- Prefix handlers ---

	# Atoms: ident, number, string, char
	li	t0, NK_IDENT
	beq	s3, t0, px_atom
	li	t0, NK_NUMBER
	beq	s3, t0, px_atom
	li	t0, NK_STR
	beq	s3, t0, px_atom
	li	t0, NK_CHAR
	beq	s3, t0, px_atom

	# Prefix unary: - ! ~ & * ++ --
	li	t0, NK_HYPHEN
	beq	s3, t0, px_unary
	li	t0, NK_BANG
	beq	s3, t0, px_unary
	li	t0, NK_TILDE
	beq	s3, t0, px_unary
	li	t0, NK_AMP
	beq	s3, t0, px_unary
	li	t0, NK_STAR
	beq	s3, t0, px_unary
	li	t0, NK_AT
	beq	s3, t0, px_unary
	li	t0, NK_HASH
	beq	s3, t0, px_unary
	li	t0, NK_DBL_PLUS
	beq	s3, t0, px_unary
	li	t0, NK_DBL_HYPHEN
	beq	s3, t0, px_unary

	# Parenthesized expression
	li	t0, NK_LPAREN
	beq	s3, t0, px_paren

	# Block expression
	li	t0, NK_LBRACE
	beq	s3, t0, px_block

	# Keywords
	li	t0, NK_LOOP
	beq	s3, t0, px_loop
	li	t0, NK_BREAK
	beq	s3, t0, px_break
	li	t0, NK_CONTINUE
	beq	s3, t0, px_continue
	li	t0, NK_RETURN
	beq	s3, t0, px_return
	li	t0, NK_SWITCH
	beq	s3, t0, px_switch
	li	t0, NK_ASM
	beq	s3, t0, px_asm
	li	t0, NK_STRUCT
	beq	s3, t0, px_struct
	li	t0, NK_SIZEOF
	beq	s3, t0, px_sizeof
	li	t0, NK_PIPE
	beq	s3, t0, px_closure
	li	t0, NK_PIPE_PIPE
	beq	s3, t0, px_closure0

	# Unknown prefix — error
	li	a0, 'E'
	jal	write_byte
	lw	a0, N_LOC_LINE(s1)
	jal	print_dec
	li	a0, ':'
	jal	write_byte
	lw	a0, N_LOC_COL(s1)
	jal	print_dec
	li	a0, 32
	jal	write_byte
	li	a0, 'p'
	jal	write_byte
	li	a0, 'x'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit

	# --- Prefix: atom (leaf node) ---
px_atom:
	jal	alloc_node
	mv	s4, a0			# s4 = node
	sw	s3, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume atom, get next token
	j	px_infix

	# --- Prefix: unary operator ---
px_unary:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_PREFIX
	sw	t0, N_KIND(s4)
	sw	s3, N_DATA(s4)		# op kind
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume operator, get operand
	li	a0, P_UNARY
	jal	parse_expr		# parse operand
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	j	px_infix

	# --- Prefix: parenthesized expression ---
px_paren:
	jal	advance			# consume '('
	li	a0, P_NONE
	jal	parse_expr
	mv	s4, a0
	li	a0, NK_RPAREN
	jal	expect
	j	px_infix

	# --- Prefix: block { expr; expr; ... } ---
px_block:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_BLOCK
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume '{'
blk_loop:
	lw	t0, N_KIND(s1)
	li	t1, NK_RBRACE
	beq	t0, t1, blk_end
	li	t1, NK_TERM
	beq	t0, t1, blk_end
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	# Skip optional semicolons
blk_semi:
	lw	t0, N_KIND(s1)
	li	t1, NK_SEMI
	bne	t0, t1, blk_loop
	jal	advance
	j	blk_semi
blk_end:
	li	a0, NK_RBRACE
	jal	expect
	j	px_infix

	# --- Prefix: loop { ... } ---
px_loop:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_LOOP
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'loop'
	li	a0, P_NONE
	jal	parse_expr		# body (should be a block)
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	j	px_infix

	# --- Prefix: break [expr] ---
px_break:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_BREAK
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'break'
	# Check if next token could be a value
	lw	t0, N_KIND(s1)
	li	t1, NK_SEMI
	beq	t0, t1, px_infix
	li	t1, NK_RBRACE
	beq	t0, t1, px_infix
	li	t1, NK_TERM
	beq	t0, t1, px_infix
	li	t1, NK_COLON
	beq	t0, t1, px_infix
	li	t1, NK_RPAREN
	beq	t0, t1, px_infix
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	j	px_infix

	# --- Prefix: return [expr] ---
	# --- Prefix: continue ---
px_continue:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_CONTINUE
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'continue'
	j	px_infix

	# --- Prefix: return [expr] ---
px_return:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_RETURN
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'return'
	lw	t0, N_KIND(s1)
	li	t1, NK_SEMI
	beq	t0, t1, px_infix
	li	t1, NK_RBRACE
	beq	t0, t1, px_infix
	li	t1, NK_TERM
	beq	t0, t1, px_infix
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	j	px_infix

	# --- Prefix: switch { arms } ---
px_switch:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_SWITCH
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'switch'
	li	a0, P_NONE
	jal	parse_expr		# scrutinee
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	# Parse block body
	li	a0, NK_LBRACE
	jal	expect
sw_loop:
	lw	t0, N_KIND(s1)
	li	t1, NK_RBRACE
	beq	t0, t1, sw_end
	li	t1, NK_TERM
	beq	t0, t1, sw_end
	li	a0, P_NONE
	jal	parse_expr		# arm expression
	mv	a1, a0
	mv	a0, s4
	jal	append_child
sw_semi:
	lw	t0, N_KIND(s1)
	li	t1, NK_SEMI
	bne	t0, t1, sw_loop
	jal	advance
	j	sw_semi
sw_end:
	li	a0, NK_RBRACE
	jal	expect
	j	px_infix

	# --- Prefix: asm [label] { ... } ---
px_asm:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_ASM
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'asm'
	# Check for optional label (ident before '{')
	lw	t0, N_KIND(s1)
	li	t1, NK_IDENT
	bne	t0, t1, asm_body
	# Label present — store as first child
	jal	alloc_node
	mv	s6, a0
	lw	t0, N_KIND(s1)
	sw	t0, N_KIND(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s4
	mv	a1, s6
	jal	append_child
	jal	advance			# consume the ident
asm_body:
	# Save body start offset BEFORE expect advances past first body token
	lw	s5, L_OFF(s0)
	li	a0, NK_LBRACE
	jal	expect
	# Read raw asm text as a single string node until '}'
	jal	alloc_node
	mv	s6, a0
	li	t0, NK_STR
	sw	t0, N_KIND(s6)
	# Record start offset (saved before expect)
	sw	s5, N_LOC_OFF(s6)
	# Scan forward to closing '}'
	lw	t0, L_IN(s0)
	lw	t1, L_OFF(s0)
	add	t2, t0, t1		# current ptr
	lw	t3, L_END(s0)
	li	t4, 1			# brace depth
asm_scan:
	bgeu	t2, t3, asm_scan_end
	lbu	t5, 0(t2)
	addi	t2, t2, 1
	li	t6, '{'
	beq	t5, t6, asm_open
	li	t6, '}'
	beq	t5, t6, asm_close
	li	t6, '\n'
	bne	t5, t6, asm_scan
	# Track newline
	lw	t6, L_LINE(s0)
	addi	t6, t6, 1
	sw	t6, L_LINE(s0)
	sub	t6, t2, t0
	sw	t6, L_COL_START(s0)
	j	asm_scan
asm_open:
	addi	t4, t4, 1
	j	asm_scan
asm_close:
	addi	t4, t4, -1
	bnez	t4, asm_scan
asm_scan_end:
	# t2 points past closing '}'. Set length and update lexer offset.
	sub	t5, t2, t0		# absolute offset past '}'
	lw	t6, N_LOC_OFF(s6)
	sub	t6, t5, t6
	addi	t6, t6, -1		# exclude closing '}'
	sw	t6, N_LOC_LEN(s6)
	sw	t5, L_OFF(s0)
	mv	a0, s4
	mv	a1, s6
	jal	append_child
	# Advance past the '}' we consumed manually
	jal	advance
	j	px_infix

	# --- Prefix: struct { fields } ---
px_struct:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_STRUCT
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'struct'
	li	a0, NK_LBRACE
	jal	expect
st_loop:
	lw	t0, N_KIND(s1)
	li	t1, NK_RBRACE
	beq	t0, t1, st_end
	li	t1, NK_TERM
	beq	t0, t1, st_end
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
st_semi:
	lw	t0, N_KIND(s1)
	li	t1, NK_SEMI
	bne	t0, t1, st_loop
	jal	advance
	j	st_semi
st_end:
	li	a0, NK_RBRACE
	jal	expect
	j	px_infix

	# --- Prefix: sizeof ( expr ) ---
px_sizeof:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_SIZEOF
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance			# consume 'sizeof'
	li	a0, NK_LPAREN
	jal	expect
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	li	a0, NK_RPAREN
	jal	expect
	j	px_infix

	# --- Prefix: closure |params| body ---
px_closure:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_CLOSURE
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance
cl_params:
	lw	t0, N_KIND(s1)
	li	t1, NK_PIPE
	beq	t0, t1, cl_body
	li	t1, NK_TERM
	beq	t0, t1, cl_body
	jal	alloc_node
	mv	s6, a0
	lw	t0, N_KIND(s1)
	sw	t0, N_KIND(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s4
	mv	a1, s6
	jal	append_child
	jal	advance
	lw	t0, N_KIND(s1)
	li	t1, NK_COMMA
	bne	t0, t1, cl_params
	jal	advance
	j	cl_params
cl_body:
	li	a0, NK_PIPE
	jal	expect
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	j	px_infix

	# --- Prefix: closure || body (zero params) ---
px_closure0:
	jal	alloc_node
	mv	s4, a0
	li	t0, NK_CLOSURE
	sw	t0, N_KIND(s4)
	mv	a0, s1
	mv	a1, s4
	jal	copy_loc
	jal	advance
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	j	px_infix

	# --- Infix loop (Pratt) ---
px_infix:
	# Peek at next token kind (already in s1 from advance/expect)
	lw	a0, N_KIND(s1)
	jal	get_prec
	mv	s6, a0			# s6 = next prec
	bge	s5, s6, px_done		# min_prec >= next_prec → stop

	# Save the operator token info
	lw	s3, N_KIND(s1)		# op kind
	jal	advance			# consume operator

	# --- Infix: assignment (right-associative) ---
	li	t0, P_ASSIGN
	bne	s6, t0, ix_ck_ternary
	jal	alloc_node
	mv	s6, a0
	li	t1, NK_ASSIGN
	sw	t1, N_KIND(s6)
	sw	s3, N_DATA(s6)		# op kind in data
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s6
	mv	a1, s4
	jal	append_child		# LHS
	mv	s4, s6
	li	a0, P_ASSIGN		# right-assoc: same prec
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child		# RHS
	j	px_infix

	# --- Infix: ternary ? : ---
ix_ck_ternary:
	li	t0, NK_QMARK
	bne	s3, t0, ix_ck_call
	jal	alloc_node
	mv	s6, a0
	li	t1, NK_TERNARY
	sw	t1, N_KIND(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s6
	mv	a1, s4
	jal	append_child		# condition
	mv	s4, s6
	li	a0, P_NONE
	jal	parse_expr		# then branch
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	# Optional else branch (: expr)
	lw	t0, N_KIND(s1)
	li	t1, NK_COLON
	bne	t0, t1, ix_no_else
	jal	advance
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	j	px_infix
ix_no_else:
	# Default else = 0
	jal	alloc_node
	mv	a1, a0
	li	t0, NK_NUMBER
	sw	t0, N_KIND(a1)
	sw	x0, N_LOC_LEN(a1)
	mv	a0, s4
	jal	append_child
	j	px_infix

	# --- Infix: call f(args) ---
ix_ck_call:
	li	t0, NK_LPAREN
	bne	s3, t0, ix_ck_index
	jal	alloc_node
	mv	s6, a0
	li	t1, NK_CALL
	sw	t1, N_KIND(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s6
	mv	a1, s4
	jal	append_child		# callee
	mv	s4, s6
call_args:
	lw	t0, N_KIND(s1)
	li	t1, NK_RPAREN
	beq	t0, t1, call_end
	li	t1, NK_TERM
	beq	t0, t1, call_end
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	lw	t0, N_KIND(s1)
	li	t1, NK_COMMA
	bne	t0, t1, call_args
	jal	advance			# skip comma
	j	call_args
call_end:
	li	a0, NK_RPAREN
	jal	expect
	j	px_infix

	# --- Infix: index a[b] ---
ix_ck_index:
	li	t0, NK_LBRACKET
	bne	s3, t0, ix_ck_member
	jal	alloc_node
	mv	s6, a0
	li	t1, NK_INDEX
	sw	t1, N_KIND(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s6
	mv	a1, s4
	jal	append_child		# base
	mv	s4, s6
	li	a0, P_NONE
	jal	parse_expr		# index
	mv	a1, a0
	mv	a0, s4
	jal	append_child
	li	a0, NK_RBRACKET
	jal	expect
	j	px_infix

	# --- Infix: member access a.b or a->b ---
ix_ck_member:
	li	t0, NK_DOT
	beq	s3, t0, ix_member
	li	t0, NK_ARROW
	bne	s3, t0, ix_ck_postfix
ix_member:
	jal	alloc_node
	mv	s6, a0
	li	t1, NK_BINOP
	sw	t1, N_KIND(s6)
	sw	s3, N_DATA(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s6
	mv	a1, s4
	jal	append_child		# LHS
	mv	s4, s6
	# RHS must be ident
	jal	alloc_node
	mv	s6, a0
	lw	t0, N_KIND(s1)
	sw	t0, N_KIND(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s4
	mv	a1, s6
	jal	append_child
	jal	advance			# consume ident
	j	px_infix

	# --- Infix: postfix ++ / -- ---
ix_ck_postfix:
	li	t0, NK_DBL_PLUS
	beq	s3, t0, ix_postfix
	li	t0, NK_DBL_HYPHEN
	bne	s3, t0, ix_binop
ix_postfix:
	jal	alloc_node
	mv	s6, a0
	li	t1, NK_POSTFIX
	sw	t1, N_KIND(s6)
	sw	s3, N_DATA(s6)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s6
	mv	a1, s4
	jal	append_child
	mv	s4, s6
	j	px_infix

	# --- Infix: binary operator (left-associative) ---
ix_binop:
	# s3 = op kind, s6 = prec. Save prec on stack before alloc clobbers s6.
	addi	sp, sp, -4
	sw	s6, 0(sp)		# save prec
	jal	alloc_node
	mv	s6, a0			# s6 = new binop node
	li	t1, NK_BINOP
	sw	t1, N_KIND(s6)
	sw	s3, N_DATA(s6)		# op kind (s3 still valid)
	mv	a0, s1
	mv	a1, s6
	jal	copy_loc
	mv	a0, s6
	mv	a1, s4
	jal	append_child		# LHS
	mv	s4, s6
	# Left-assoc: parse RHS with prec+1
	lw	a0, 0(sp)		# restore prec
	addi	sp, sp, 4
	addi	a0, a0, 1
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	append_child		# RHS
	j	px_infix

px_done:
	mv	a0, s4			# return node
	return

# ============================================================================
# AST printer (debug)
# ============================================================================

# print_ast: print AST rooted at a0, with indent level a1.
#   s2 = input buffer start (for printing source text).
print_ast:
	prologue s3 s4 s5 x0
	mv	s3, a0			# s3 = node
	mv	s4, a1			# s4 = indent level

	# Print indent
	mv	s5, s4
pa_indent:
	beqz	s5, pa_kind
	li	a0, 32
	jal	write_byte
	li	a0, 32
	jal	write_byte
	addi	s5, s5, -1
	j	pa_indent

pa_kind:
	# Print node kind
	lw	a0, N_KIND(s3)
	jal	print_dec

	# Print line:col
	li	a0, 32
	jal	write_byte
	lw	a0, N_LOC_LINE(s3)
	jal	print_dec
	li	a0, ':'
	jal	write_byte
	lw	a0, N_LOC_COL(s3)
	jal	print_dec

	# For atoms/idents/numbers/strings: print source text
	lw	t0, N_KIND(s3)
	li	t1, NK_IDENT
	beq	t0, t1, pa_text
	li	t1, NK_NUMBER
	beq	t0, t1, pa_text
	li	t1, NK_STR
	beq	t0, t1, pa_text
	li	t1, NK_CHAR
	beq	t0, t1, pa_text

	# For ops with N_DATA: print op kind
	li	t1, NK_BINOP
	beq	t0, t1, pa_data
	li	t1, NK_PREFIX
	beq	t0, t1, pa_data
	li	t1, NK_POSTFIX
	beq	t0, t1, pa_data
	li	t1, NK_ASSIGN
	beq	t0, t1, pa_data
	j	pa_nl

pa_text:
	li	a0, 32
	jal	write_byte
	lw	t0, N_LOC_OFF(s3)
	lw	t1, N_LOC_LEN(s3)
	add	a0, s2, t0
	add	a1, a0, t1
	jal	write_data
	j	pa_nl

pa_data:
	li	a0, 32
	jal	write_byte
	li	a0, 'o'
	jal	write_byte
	li	a0, 'p'
	jal	write_byte
	li	a0, '='
	jal	write_byte
	lw	a0, N_DATA(s3)
	jal	print_dec
	j	pa_nl

pa_nl:
	li	a0, '\n'
	jal	write_byte

	# Recurse on children
	lw	s3, N_FIRST_CHILD(s3)
pa_child:
	beqz	s3, pa_ret
	mv	a0, s3
	addi	a1, s4, 1
	jal	print_ast
	lw	s3, N_NEXT_SIB(s3)
	j	pa_child

pa_ret:
	return

# ============================================================================
# Codegen: instruction encoding helpers
# ============================================================================
# During codegen, register convention:
#   s0 = emit cursor (output buffer write pointer)
#   s1 = symbol table pointer
#   s2 = input buffer start (for reading source text from AST nodes)
#   s3-s7 = used per-function in gen_expr (saved by prologue)

# emit: store raw word a0 at [s0], advance s0 by 4
emit:
	sw	a0, 0(s0)
	addi	s0, s0, 4
	ret

# em_rtype: emit R-type instruction (opcode 0x33)
#   a0=funct7, a1=rs2, a2=rs1, a3=funct3, a4=rd
em_rtype:
	slli	a0, a0, 25
	slli	t0, a1, 20
	or	a0, a0, t0
	slli	t0, a2, 15
	or	a0, a0, t0
	slli	t0, a3, 12
	or	a0, a0, t0
	slli	t0, a4, 7
	or	a0, a0, t0
	ori	a0, a0, 0x33
	sw	a0, 0(s0)
	addi	s0, s0, 4
	ret

# em_itype: emit I-type instruction
#   a0=imm12, a1=rs1, a2=funct3, a3=rd, a4=opcode
em_itype:
	slli	a0, a0, 20
	slli	t0, a1, 15
	or	a0, a0, t0
	slli	t0, a2, 12
	or	a0, a0, t0
	slli	t0, a3, 7
	or	a0, a0, t0
	or	a0, a0, a4
	sw	a0, 0(s0)
	addi	s0, s0, 4
	ret

# em_stype: emit S-type instruction
#   a0=imm12, a1=rs2, a2=rs1, a3=funct3, a4=opcode
em_stype:
	mv	t0, a4
	andi	t1, a0, 0x1F
	slli	t1, t1, 7
	or	t0, t0, t1
	slli	t1, a3, 12
	or	t0, t0, t1
	slli	t1, a2, 15
	or	t0, t0, t1
	slli	t1, a1, 20
	or	t0, t0, t1
	srai	t1, a0, 5
	slli	t1, t1, 25
	or	t0, t0, t1
	sw	t0, 0(s0)
	addi	s0, s0, 4
	ret

# em_btype: emit B-type instruction (opcode 0x63)
#   a0=imm (byte offset), a1=rs1, a2=rs2, a3=funct3
em_btype:
	li	t0, 0x63
	srli	t1, a0, 11
	andi	t1, t1, 1
	slli	t1, t1, 7
	or	t0, t0, t1
	srli	t1, a0, 1
	andi	t1, t1, 0xF
	slli	t1, t1, 8
	or	t0, t0, t1
	slli	t1, a3, 12
	or	t0, t0, t1
	slli	t1, a1, 15
	or	t0, t0, t1
	slli	t1, a2, 20
	or	t0, t0, t1
	srli	t1, a0, 5
	andi	t1, t1, 0x3F
	slli	t1, t1, 25
	or	t0, t0, t1
	srli	t1, a0, 12
	andi	t1, t1, 1
	slli	t1, t1, 31
	or	t0, t0, t1
	sw	t0, 0(s0)
	addi	s0, s0, 4
	ret

# em_utype: emit U-type instruction
#   a0=imm20, a1=rd, a2=opcode
em_utype:
	slli	a0, a0, 12
	slli	t0, a1, 7
	or	a0, a0, t0
	or	a0, a0, a2
	sw	a0, 0(s0)
	addi	s0, s0, 4
	ret

# em_jtype: emit J-type instruction (opcode 0x6F)
#   a0=imm (byte offset, 21-bit signed), a1=rd
em_jtype:
	# Check offset fits in 21-bit signed (±1MB)
	srai	t0, a0, 20
	beqz	t0, ej_ok
	li	t1, -1
	beq	t0, t1, ej_ok
	j	ej_err
ej_ok:
	li	t0, 0x6F
	slli	t1, a1, 7
	or	t0, t0, t1
	srli	t1, a0, 12
	andi	t1, t1, 0xFF
	slli	t1, t1, 12
	or	t0, t0, t1
	srli	t1, a0, 11
	andi	t1, t1, 1
	slli	t1, t1, 20
	or	t0, t0, t1
	srli	t1, a0, 1
	andi	t1, t1, 0x3FF
	slli	t1, t1, 21
	or	t0, t0, t1
	srli	t1, a0, 20
	andi	t1, t1, 1
	slli	t1, t1, 31
	or	t0, t0, t1
	sw	t0, 0(s0)
	addi	s0, s0, 4
	ret

# em_li: emit load immediate (handles lui+addi for large values)
#   a0=rd, a1=value
em_li:
	prologue s3 s4 s5 x0
	mv	s3, a0
	mv	s4, a1
	# Check if value fits in 12-bit signed [-2048, 2047]
	li	t0, 2047
	blt	t0, s4, el_large
	li	t0, -2048
	blt	s4, t0, el_large
	# Small: addi rd, x0, value
	mv	a0, s4
	li	a1, R_ZERO
	li	a2, 0
	mv	a3, s3
	li	a4, 0x13
	jal	em_itype
	j	el_done
el_large:
	# lui + addi decomposition
	srli	s5, s4, 12
	srli	t0, s4, 11
	andi	t0, t0, 1
	add	s5, s5, t0
	# lui rd, upper
	mv	a0, s5
	mv	a1, s3
	li	a2, 0x37
	jal	em_utype
	# compute lower = value - (upper << 12)
	slli	t0, s5, 12
	sub	s5, s4, t0
	# skip addi if lower == 0
	beqz	s5, el_done
	# addi rd, rd, lower
	mv	a0, s5
	mv	a1, s3
	li	a2, 0
	mv	a3, s3
	li	a4, 0x13
	jal	em_itype
el_done:
	return

# em_push: emit push register onto stack with overflow check
#   a0 = register number
#   s8 = address of stack overflow handler in output buffer
em_push:
	prologue s3 x0
	mv	s3, a0
	# addi sp, sp, -4
	li	a0, -4
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	# bgeu sp, tp, +8 (no overflow, skip jal)
	li	a0, 8
	li	a1, R_SP
	li	a2, R_TP
	li	a3, 7
	jal	em_btype
	# jal x0, overflow_handler
	sub	a0, s8, s0
	li	a1, R_ZERO
	jal	em_jtype
	# sw reg, 0(sp)
	li	a0, 0
	mv	a1, s3
	li	a2, R_SP
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	return

# em_pop: emit pop from stack into register
#   a0 = register number
em_pop:
	prologue s3 x0
	mv	s3, a0
	# lw reg, 0(sp)
	li	a0, 0
	li	a1, R_SP
	li	a2, 2
	mv	a3, s3
	li	a4, 0x03
	jal	em_itype
	# addi sp, sp, 4
	li	a0, 4
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	return

# em_var_load: emit code to load word from variable slot into register
#   a0 = offset from frame pointer, a1 = dest register
#   Uses t2 as scratch for large offsets
em_var_load:
	prologue s3 s4 x0
	mv	s3, a0
	mv	s4, a1
	li	t0, 2047
	blt	t0, s3, evl_large
	li	t0, -2048
	blt	s3, t0, evl_large
	# Small offset: lw dest, offset(s0)
	mv	a0, s3
	li	a1, R_S0
	li	a2, 2
	mv	a3, s4
	li	a4, 0x03
	jal	em_itype
	j	evl_done
evl_large:
	# li t2, offset; add t2, s0, t2; lw dest, 0(t2)
	li	a0, R_T2
	mv	a1, s3
	jal	em_li
	li	a0, 0
	li	a1, R_T2
	li	a2, R_S0
	li	a3, 0
	li	a4, R_T2
	jal	em_rtype
	li	a0, 0
	li	a1, R_T2
	li	a2, 2
	mv	a3, s4
	li	a4, 0x03
	jal	em_itype
evl_done:
	return

# em_var_store: emit code to store register to variable slot
#   a0 = offset from frame pointer, a1 = source register
#   Uses t2 as scratch for large offsets
em_var_store:
	prologue s3 s4 x0
	mv	s3, a0
	mv	s4, a1
	li	t0, 2047
	blt	t0, s3, evs_large
	li	t0, -2048
	blt	s3, t0, evs_large
	# Small offset: sw src, offset(s0)
	mv	a0, s3
	mv	a1, s4
	li	a2, R_S0
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	j	evs_done
evs_large:
	# li t2, offset; add t2, s0, t2; sw src, 0(t2)
	li	a0, R_T2
	mv	a1, s3
	jal	em_li
	li	a0, 0
	li	a1, R_T2
	li	a2, R_S0
	li	a3, 0
	li	a4, R_T2
	jal	em_rtype
	li	a0, 0
	mv	a1, s4
	li	a2, R_T2
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
evs_done:
	return

# patch_jal: patch a JAL x0 instruction at address a0 with offset a1
#   Clobbers t0-t1
patch_jal:
	# Check offset fits in 21-bit signed
	srai	t0, a1, 20
	beqz	t0, pj_ok
	li	t1, -1
	beq	t0, t1, pj_ok
	j	ej_err
pj_ok:
	li	t0, 0x6F
	srli	t1, a1, 12
	andi	t1, t1, 0xFF
	slli	t1, t1, 12
	or	t0, t0, t1
	srli	t1, a1, 11
	andi	t1, t1, 1
	slli	t1, t1, 20
	or	t0, t0, t1
	srli	t1, a1, 1
	andi	t1, t1, 0x3FF
	slli	t1, t1, 21
	or	t0, t0, t1
	srli	t1, a1, 20
	andi	t1, t1, 1
	slli	t1, t1, 31
	or	t0, t0, t1
	sw	t0, 0(a0)
	ret

# ============================================================================
# Codegen: number and character parsing
# ============================================================================

# parse_int: parse integer from source text
#   a0 = pointer to first char, a1 = length
#   Returns a0 = value
parse_int:
	prologue s3 s4 s5 s6 x0
	mv	s3, a0
	add	s5, a0, a1
	li	s6, 0
	# Check for 0x or 0b prefix
	li	t0, 2
	blt	a1, t0, pi_dec
	lbu	t0, 0(s3)
	li	t1, '0'
	bne	t0, t1, pi_dec
	lbu	t0, 1(s3)
	li	t1, 'x'
	beq	t0, t1, pi_hex
	li	t1, 'X'
	beq	t0, t1, pi_hex
	li	t1, 'b'
	beq	t0, t1, pi_bin
	li	t1, 'B'
	beq	t0, t1, pi_bin
pi_dec:
	bgeu	s3, s5, pi_done
	lbu	t0, 0(s3)
	addi	t0, t0, -48
	# Overflow check: s6 must be <= 429496729 before *10
	li	t3, 429496729
	bltu	t3, s6, pi_ovf
	slli	t1, s6, 3
	slli	t2, s6, 1
	add	s6, t1, t2
	add	s6, s6, t0
	bltu	s6, t0, pi_ovf
	addi	s3, s3, 1
	j	pi_dec
pi_hex:
	addi	s3, s3, 2
pi_hex_loop:
	bgeu	s3, s5, pi_done
	lbu	t0, 0(s3)
	li	t1, 'a'
	bge	t0, t1, pi_hex_lo
	li	t1, 'A'
	bge	t0, t1, pi_hex_up
	addi	t0, t0, -48
	j	pi_hex_add
pi_hex_lo:
	addi	t0, t0, -87
	j	pi_hex_add
pi_hex_up:
	addi	t0, t0, -55
pi_hex_add:
	# Overflow check: top 4 bits must be clear before shift
	srli	t1, s6, 28
	bnez	t1, pi_ovf
	slli	s6, s6, 4
	add	s6, s6, t0
	bltu	s6, t0, pi_ovf
	addi	s3, s3, 1
	j	pi_hex_loop
pi_bin:
	addi	s3, s3, 2
pi_bin_loop:
	bgeu	s3, s5, pi_done
	lbu	t0, 0(s3)
	addi	t0, t0, -48
	# Overflow check: top bit must be clear before shift
	srli	t1, s6, 31
	bnez	t1, pi_ovf
	slli	s6, s6, 1
	add	s6, s6, t0
	addi	s3, s3, 1
	j	pi_bin_loop
pi_done:
	mv	a0, s6
	return
pi_ovf:
	li	a0, 'E'
	jal	write_byte
	li	a0, 'i'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit

# parse_char: parse character literal from source text
#   a0 = pointer to first char (including quotes), a1 = length
#   Returns a0 = character value
parse_char:
	lbu	t0, 1(a0)
	li	t1, 92
	bne	t0, t1, pc_done
	# Escape sequence
	lbu	t0, 2(a0)
	li	t1, 'n'
	beq	t0, t1, pc_nl
	li	t1, 't'
	beq	t0, t1, pc_tab
	li	t1, 'r'
	beq	t0, t1, pc_cr
	li	t1, '0'
	beq	t0, t1, pc_nul
	# '\'' or '\\' or unknown: use raw char
	mv	a0, t0
	ret
pc_nl:
	li	a0, 10
	ret
pc_tab:
	li	a0, 9
	ret
pc_cr:
	li	a0, 13
	ret
pc_nul:
	li	a0, 0
	ret
pc_done:
	mv	a0, t0
	ret

# ============================================================================
# Codegen: symbol table
# ============================================================================

# sym_init: allocate symbol table with initial capacity 256
#   Returns a0 = symbol table pointer
sym_init:
	prologue s3 x0
	# 12 header + 256 * 16 entries = 4108
	li	a0, 4108
	jal	alloc
	mv	s3, a0
	li	a1, 4108
	jal	memzero
	li	t0, 256
	sw	t0, ST_CAP(s3)
	mv	a0, s3
	return

# sym_def: define a new variable, growing table if needed
#   a0=name offset, a1=name length, s1=symtab
#   Returns a0 = stack slot offset (negative)
#   May update s1 if table is reallocated
sym_def:
	prologue s3 s4 s5 x0
	mv	s3, a0
	mv	s4, a1
	# Check if table is full
	lw	t0, ST_CNT(s1)
	lw	t1, ST_CAP(s1)
	blt	t0, t1, sd_ok
	# Grow: double capacity
	slli	s5, t1, 1
	slli	a0, s5, 4
	addi	a0, a0, ST_DATA
	jal	alloc
	mv	t3, a0
	# Copy header
	lw	t0, ST_CNT(s1)
	sw	t0, ST_CNT(t3)
	lw	t0, ST_NEXT(s1)
	sw	t0, ST_NEXT(t3)
	sw	s5, ST_CAP(t3)
	# Copy entries (count * 16 bytes)
	lw	t0, ST_CNT(s1)
	slli	t0, t0, 4
	addi	t1, s1, ST_DATA
	addi	t2, t3, ST_DATA
sd_copy:
	beqz	t0, sd_copied
	lw	t4, 0(t1)
	sw	t4, 0(t2)
	addi	t1, t1, 4
	addi	t2, t2, 4
	addi	t0, t0, -4
	j	sd_copy
sd_copied:
	mv	s1, t3
sd_ok:
	# Add entry
	lw	t0, ST_CNT(s1)
	slli	t1, t0, 4
	addi	t1, t1, ST_DATA
	add	t1, s1, t1
	sw	s3, SY_OFF(t1)
	sw	s4, SY_LEN(t1)
	lw	t2, ST_NEXT(s1)
	addi	t2, t2, -4
	sw	t2, ST_NEXT(s1)
	sw	t2, SY_SLOT(t1)
	addi	t0, t0, 1
	sw	t0, ST_CNT(s1)
	mv	a0, t2
	return

# sym_find: look up variable by name
#   a0=name offset, a1=name length, s1=symtab, s2=input base
#   Returns a0 = stack slot offset
sym_find:
	prologue s3 s4 s5 s6 s7 x0
	mv	s3, a0
	mv	s4, a1
	lw	s5, ST_CNT(s1)
	addi	s5, s5, -1
sf_loop:
	blt	s5, x0, sf_fail
	slli	t0, s5, 4
	addi	t0, t0, ST_DATA
	add	t0, s1, t0
	lw	t1, SY_LEN(t0)
	bne	s4, t1, sf_next
	lw	t1, SY_OFF(t0)
	add	t1, s2, t1
	add	t2, s2, s3
	mv	t3, s4
sf_cmp:
	beqz	t3, sf_found
	lbu	t4, 0(t1)
	lbu	t5, 0(t2)
	bne	t4, t5, sf_next
	addi	t1, t1, 1
	addi	t2, t2, 1
	addi	t3, t3, -1
	j	sf_cmp
sf_found:
	slli	t0, s5, 4
	addi	t0, t0, ST_DATA
	add	t0, s1, t0
	lw	a0, SY_SLOT(t0)
	return
sf_next:
	addi	s5, s5, -1
	j	sf_loop
sf_fail:
	li	a0, 'E'
	jal	write_byte
	li	a0, 'v'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit

# sym_try: like sym_find but returns -1 if not found
#   a0=name offset, a1=name length, s1=symtab, s2=input base
#   Returns a0 = stack slot offset, or -1 if not found
sym_try:
	prologue s3 s4 s5 s6 s7 x0
	mv	s3, a0
	mv	s4, a1
	lw	s5, ST_CNT(s1)
	addi	s5, s5, -1
sy_loop:
	blt	s5, x0, sy_fail
	slli	t0, s5, 4
	addi	t0, t0, ST_DATA
	add	t0, s1, t0
	lw	t1, SY_LEN(t0)
	bne	s4, t1, sy_next
	lw	t1, SY_OFF(t0)
	add	t1, s2, t1
	add	t2, s2, s3
	mv	t3, s4
sy_cmp:
	beqz	t3, sy_found
	lbu	t4, 0(t1)
	lbu	t5, 0(t2)
	bne	t4, t5, sy_next
	addi	t1, t1, 1
	addi	t2, t2, 1
	addi	t3, t3, -1
	j	sy_cmp
sy_found:
	slli	t0, s5, 4
	addi	t0, t0, ST_DATA
	add	t0, s1, t0
	lw	a0, SY_SLOT(t0)
	mv	a1, s5
	j	sy_done
sy_next:
	addi	s5, s5, -1
	j	sy_loop
sy_fail:
	li	a0, -1
sy_done:
	return

# ============================================================================
# Codegen: expression code generation
# ============================================================================

# gen_expr: generate code for an expression node
#   a0 = AST node pointer
#   s0 = emit cursor, s1 = symtab, s2 = input base
#   Emits code that pushes one value onto the runtime stack
gen_expr:
	prologue s3 s4 s5 s6 s7 x0
	mv	s3, a0
	lw	s4, N_KIND(s3)
	# Dispatch on node kind
	li	t0, NK_NUMBER
	beq	s4, t0, ge_num
	li	t0, NK_CHAR
	beq	s4, t0, ge_char
	li	t0, NK_IDENT
	beq	s4, t0, ge_ident
	li	t0, NK_BINOP
	beq	s4, t0, ge_binop
	li	t0, NK_PREFIX
	beq	s4, t0, ge_prefix
	li	t0, NK_ASSIGN
	beq	s4, t0, ge_assign
	li	t0, NK_BLOCK
	beq	s4, t0, ge_block
	li	t0, NK_LOOP
	beq	s4, t0, ge_loop
	li	t0, NK_TERNARY
	beq	s4, t0, ge_tern
	li	t0, NK_CALL
	beq	s4, t0, ge_call
	li	t0, NK_RETURN
	beq	s4, t0, ge_return
	li	t0, NK_POSTFIX
	beq	s4, t0, ge_postfix
	li	t0, NK_ASM
	beq	s4, t0, ge_asm
	li	t0, NK_STR
	beq	s4, t0, ge_str
	li	t0, NK_BREAK
	beq	s4, t0, ge_break
	li	t0, NK_CONTINUE
	beq	s4, t0, ge_cont
	li	t0, NK_CLOSURE
	beq	s4, t0, ge_closure
	j	cg_err

# --- Number literal ---
ge_num:
	lw	t0, N_LOC_OFF(s3)
	add	a0, s2, t0
	lw	a1, N_LOC_LEN(s3)
	jal	parse_int
	mv	s5, a0
	li	a0, R_T0
	mv	a1, s5
	jal	em_li
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Character literal ---
ge_char:
	lw	t0, N_LOC_OFF(s3)
	add	a0, s2, t0
	lw	a1, N_LOC_LEN(s3)
	jal	parse_char
	mv	s5, a0
	li	a0, R_T0
	mv	a1, s5
	jal	em_li
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- String literal ---
ge_str:
	lw	s5, N_LOC_OFF(s3)
	lw	s6, N_LOC_LEN(s3)
	add	s5, s2, s5
	add	s6, s5, s6
	# s5 = ptr to opening quote, s6 = ptr past closing quote
	addi	s5, s5, 1
	addi	s6, s6, -1
	# Emit: jal t0, past_string (t0 gets PC+4 = address of string data)
	# Save patch location, emit placeholder
	mv	s7, s0
	li	a0, 0
	li	a1, R_T0
	jal	em_jtype
	# Emit string bytes with escape processing
gs_loop:
	bgeu	s5, s6, gs_pad
	lbu	t0, 0(s5)
	addi	s5, s5, 1
	li	t1, 92
	bne	t0, t1, gs_raw
	# Escape sequence
	bgeu	s5, s6, gs_pad
	lbu	t0, 0(s5)
	addi	s5, s5, 1
	li	t1, 'n'
	beq	t0, t1, gs_nl
	li	t1, 't'
	beq	t0, t1, gs_tab
	li	t1, 'r'
	beq	t0, t1, gs_cr
	li	t1, '0'
	beq	t0, t1, gs_nul
	# Other escapes: emit raw char (\\, \", etc.)
	j	gs_raw
gs_nl:
	li	t0, 10
	j	gs_raw
gs_tab:
	li	t0, 9
	j	gs_raw
gs_cr:
	li	t0, 13
	j	gs_raw
gs_nul:
	li	t0, 0
gs_raw:
	sb	t0, 0(s0)
	addi	s0, s0, 1
	j	gs_loop
gs_pad:
	# Null terminator
	sb	x0, 0(s0)
	addi	s0, s0, 1
	# Align to 4 bytes
	addi	s0, s0, 3
	andi	s0, s0, -4
	# Backpatch: jal t0, offset (t0 gets PC+4 = string data addr)
	sub	a0, s0, s7
	li	a1, R_T0
	mv	t3, s0
	mv	s0, s7
	jal	em_jtype
	mv	s0, t3
	# Push t0 (string pointer)
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Identifier (variable reference) ---
ge_ident:
	lw	a0, N_LOC_OFF(s3)
	lw	a1, N_LOC_LEN(s3)
	jal	sym_try
	li	t0, -1
	beq	a0, t0, sf_fail
	mv	s5, a0
	# Check if outer variable (inside closure and index < boundary)
	beqz	s11, gi_local
	bge	a1, s11, gi_local
	# Outer variable: record capture scope boundary
	sw	s11, ST_CAPS(s1)
	# Emit lw t0, slot(s1)
	mv	a0, s5
	li	a1, R_S1
	li	a2, 2
	li	a3, R_T0
	li	a4, 0x03
	jal	em_itype
	j	gi_push
gi_local:
	mv	a0, s5
	li	a1, R_T0
	jal	em_var_load
gi_push:
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Binary operation ---
ge_binop:
	lw	s5, N_DATA(s3)
	# Generate LHS
	lw	a0, N_FIRST_CHILD(s3)
	jal	gen_expr
	# Generate RHS
	lw	t0, N_FIRST_CHILD(s3)
	lw	a0, N_NEXT_SIB(t0)
	jal	gen_expr
	# Pop RHS into t1, LHS into t0
	li	a0, R_T1
	jal	em_pop
	li	a0, R_T0
	jal	em_pop
	# Dispatch on operator kind
	li	t0, NK_PLUS
	beq	s5, t0, gbo_add
	li	t0, NK_HYPHEN
	beq	s5, t0, gbo_sub
	li	t0, NK_AMP
	beq	s5, t0, gbo_and
	li	t0, NK_PIPE
	beq	s5, t0, gbo_or
	li	t0, NK_CARET
	beq	s5, t0, gbo_xor
	li	t0, NK_LSHIFT
	beq	s5, t0, gbo_sll
	li	t0, NK_RSHIFT
	beq	s5, t0, gbo_srl
	li	t0, NK_LT
	beq	s5, t0, gbo_slt
	li	t0, NK_GT
	beq	s5, t0, gbo_gt
	li	t0, NK_LTE
	beq	s5, t0, gbo_lte
	li	t0, NK_GTE
	beq	s5, t0, gbo_gte
	li	t0, NK_DBL_EQUAL
	beq	s5, t0, gbo_eq
	li	t0, NK_NE
	beq	s5, t0, gbo_ne
	li	t0, NK_STAR
	beq	s5, t0, gbo_mul
	li	t0, NK_SLASH
	beq	s5, t0, gbo_div
	li	t0, NK_PERCENT
	beq	s5, t0, gbo_mod
	j	cg_err

gbo_add:
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 0
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_sub:
	li	a0, 0x20
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 0
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_and:
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 7
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_or:
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 6
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_xor:
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 4
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_sll:
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 1
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_srl:
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 5
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_slt:
	# a < b (unsigned): sltu t0, t0, t1
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 3
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_gt:
	# a > b (unsigned): sltu t0, t1, t0
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 3
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push
gbo_lte:
	# a <= b (unsigned): not(a > b) → sltu t0, t1, t0; xori t0, t0, 1
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 3
	li	a4, R_T0
	jal	em_rtype
	li	a0, 1
	li	a1, R_T0
	li	a2, 4
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	j	gbo_push
gbo_gte:
	# a >= b (unsigned): not(a < b) → sltu t0, t0, t1; xori t0, t0, 1
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 3
	li	a4, R_T0
	jal	em_rtype
	li	a0, 1
	li	a1, R_T0
	li	a2, 4
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	j	gbo_push
gbo_eq:
	# sub t0, t0, t1; sltiu t0, t0, 1 (seqz)
	li	a0, 0x20
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 0
	li	a4, R_T0
	jal	em_rtype
	li	a0, 1
	li	a1, R_T0
	li	a2, 3
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	j	gbo_push
gbo_ne:
	# sub t0, t0, t1; sltu t0, x0, t0 (snez)
	li	a0, 0x20
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 0
	li	a4, R_T0
	jal	em_rtype
	li	a0, 0
	li	a1, R_T0
	li	a2, R_ZERO
	li	a3, 3
	li	a4, R_T0
	jal	em_rtype
	j	gbo_push

# --- Multiply: t0 * t1 → t0 (shift-and-add) ---
gbo_mul:
	# Emit: li t2, 0; loop { if t1==0 break; if t1&1: t2+=t0; t0<<=1; t1>>=1 }; mv t0,t2
	# 9 instructions, 36 bytes inline. t3=x28 as scratch.
	li	a0, R_T2
	li	a1, 0
	jal	em_li
	# beq t1, zero, +28 (past loop)
	li	a0, 28
	li	a1, R_T1
	li	a2, R_ZERO
	li	a3, 0
	jal	em_btype
	# andi t3(x28), t1, 1
	li	a0, 1
	li	a1, R_T1
	li	a2, 7
	li	a3, 28
	li	a4, 0x13
	jal	em_itype
	# beq t3, zero, +8
	li	a0, 8
	li	a1, 28
	li	a2, R_ZERO
	li	a3, 0
	jal	em_btype
	# add t2, t2, t0
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T2
	li	a3, 0
	li	a4, R_T2
	jal	em_rtype
	# slli t0, t0, 1
	li	a0, 1
	li	a1, R_T0
	li	a2, 1
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	# srli t1, t1, 1
	li	a0, 1
	li	a1, R_T1
	li	a2, 5
	li	a3, R_T1
	li	a4, 0x13
	jal	em_itype
	# j -24 (back to beq t1,zero, skipping li t2,0)
	li	a0, -24
	li	a1, R_ZERO
	jal	em_jtype
	# mv t0, t2
	li	a0, 0
	li	a1, R_T2
	li	a2, 0
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	j	gbo_push

# --- Div/Mod helpers: emit binary long division inline ---
# t0=dividend, t1=divisor → t2=quotient, t3(x28)=remainder
# After: for /, mv t0,t2. For %, mv t0,t3.
gbo_div:
	jal	gbo_divmod
	# mv t0, t2 (quotient)
	li	a0, 0
	li	a1, R_T2
	li	a2, 0
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	j	gbo_push
gbo_mod:
	jal	gbo_divmod
	# mv t0, t3(x28) (remainder)
	li	a0, 0
	li	a1, 28
	li	a2, 0
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	j	gbo_push

# gbo_divmod: emit unsigned divmod (13 instructions, 52 bytes)
#   t2=quotient, t3(x28)=remainder, t4(x29)=counter, t5(x30)=scratch
gbo_divmod:
	prologue x0
	# li t2, 0 (quotient)
	li	a0, R_T2
	li	a1, 0
	jal	em_li
	# li t3(x28), 0 (remainder)
	li	a0, 28
	li	a1, 0
	jal	em_li
	# li t4(x29), 31
	li	a0, 29
	li	a1, 31
	jal	em_li
	# loop (offset 0 from here):
	# blt t4, zero, +44 (done = 11 instrs * 4, past the j)
	li	a0, 44
	li	a1, 29
	li	a2, R_ZERO
	li	a3, 4
	jal	em_btype
	# slli t3, t3, 1
	li	a0, 1
	li	a1, 28
	li	a2, 1
	li	a3, 28
	li	a4, 0x13
	jal	em_itype
	# srl t5(x30), t0, t4
	li	a0, 0
	li	a1, 29
	li	a2, R_T0
	li	a3, 5
	li	a4, 30
	jal	em_rtype
	# andi t5, t5, 1
	li	a0, 1
	li	a1, 30
	li	a2, 7
	li	a3, 30
	li	a4, 0x13
	jal	em_itype
	# or t3, t3, t5
	li	a0, 0
	li	a1, 30
	li	a2, 28
	li	a3, 6
	li	a4, 28
	jal	em_rtype
	# slli t2, t2, 1
	li	a0, 1
	li	a1, R_T2
	li	a2, 1
	li	a3, R_T2
	li	a4, 0x13
	jal	em_itype
	# bltu t3, t1, +12 (skip sub+or = 3 instrs * 4)
	li	a0, 12
	li	a1, 28
	li	a2, R_T1
	li	a3, 6
	jal	em_btype
	# sub t3, t3, t1
	li	a0, 0x20
	li	a1, R_T1
	li	a2, 28
	li	a3, 0
	li	a4, 28
	jal	em_rtype
	# ori t2, t2, 1
	li	a0, 1
	li	a1, R_T2
	li	a2, 6
	li	a3, R_T2
	li	a4, 0x13
	jal	em_itype
	# addi t4, t4, -1
	li	a0, -1
	li	a1, 29
	li	a2, 0
	li	a3, 29
	li	a4, 0x13
	jal	em_itype
	# j -40 (back to blt)
	li	a0, -40
	li	a1, R_ZERO
	jal	em_jtype
	# done: t2=quotient, t3(x28)=remainder
	return

gbo_push:
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Prefix unary ---
ge_prefix:
	lw	s5, N_DATA(s3)
	# Prefix ++/-- handled separately (don't gen_expr child)
	li	t0, NK_DBL_PLUS
	beq	s5, t0, gp_preinc
	li	t0, NK_DBL_HYPHEN
	beq	s5, t0, gp_preinc
	lw	a0, N_FIRST_CHILD(s3)
	jal	gen_expr
	li	t0, NK_STAR
	beq	s5, t0, gp_deref
	li	t0, NK_AT
	beq	s5, t0, gp_bderef
	li	t0, NK_HASH
	beq	s5, t0, gp_hderef
	li	t0, NK_HYPHEN
	beq	s5, t0, gp_neg
	li	t0, NK_BANG
	beq	s5, t0, gp_not
	li	t0, NK_TILDE
	beq	s5, t0, gp_bnot
	j	cg_err
gp_deref:
	# pop addr, lw t0, 0(t0), push
	li	a0, R_T0
	jal	em_pop
	li	a0, 0
	li	a1, R_T0
	li	a2, 2
	li	a3, R_T0
	li	a4, 0x03
	jal	em_itype
	li	a0, R_T0
	jal	em_push
	j	ge_done
gp_bderef:
	# pop addr, lbu t0, 0(t0), push
	li	a0, R_T0
	jal	em_pop
	li	a0, 0
	li	a1, R_T0
	li	a2, 4
	li	a3, R_T0
	li	a4, 0x03
	jal	em_itype
	li	a0, R_T0
	jal	em_push
	j	ge_done
gp_hderef:
	# pop addr, lhu t0, 0(t0), push
	li	a0, R_T0
	jal	em_pop
	li	a0, 0
	li	a1, R_T0
	li	a2, 5
	li	a3, R_T0
	li	a4, 0x03
	jal	em_itype
	li	a0, R_T0
	jal	em_push
	j	ge_done
gp_neg:
	# pop, sub t0, x0, t0, push
	li	a0, R_T0
	jal	em_pop
	li	a0, 0x20
	li	a1, R_T0
	li	a2, R_ZERO
	li	a3, 0
	li	a4, R_T0
	jal	em_rtype
	li	a0, R_T0
	jal	em_push
	j	ge_done
gp_not:
	# pop, sltiu t0, t0, 1, push
	li	a0, R_T0
	jal	em_pop
	li	a0, 1
	li	a1, R_T0
	li	a2, 3
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	li	a0, R_T0
	jal	em_push
	j	ge_done
gp_bnot:
	# pop, xori t0, t0, -1, push
	li	a0, R_T0
	jal	em_pop
	li	a0, -1
	li	a1, R_T0
	li	a2, 4
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Assignment ---
ge_assign:
	lw	s5, N_DATA(s3)
	mv	s4, s5
	lw	s6, N_FIRST_CHILD(s3)
	lw	s7, N_NEXT_SIB(s6)
	# Generate RHS
	mv	a0, s7
	jal	gen_expr
	# Check LHS kind
	lw	t0, N_KIND(s6)
	li	t1, NK_IDENT
	beq	t0, t1, ga_ident
	li	t1, NK_PREFIX
	beq	t0, t1, ga_deref
	j	cg_err
ga_ident:
	# Try to find existing variable first
	lw	a0, N_LOC_OFF(s6)
	lw	a1, N_LOC_LEN(s6)
	jal	sym_try
	li	t0, -1
	bne	a0, t0, ga_chk_out
	j	ga_newvar
ga_chk_out:
	# Check if outer variable. s7 = 1 if outer, 0 if local.
	li	s7, 0
	beqz	s11, ga_reassign
	bge	a1, s11, ga_reassign
	li	s7, 1
	j	ga_reassign
ga_newvar:
	# Variable not found — define new (both = and := declare)
	lw	a0, N_LOC_OFF(s6)
	lw	a1, N_LOC_LEN(s6)
	jal	sym_def
	mv	s5, a0
	# Mark if capturing closure (use last entry = ST_CNT-1)
	lw	t0, ST_CAPS(s1)
	lw	t1, ST_CNT(s1)
	addi	t1, t1, -1
	slli	t1, t1, 4
	addi	t1, t1, ST_DATA
	add	t1, s1, t1
	sw	t0, 12(t1)
	sw	x0, ST_CAPS(s1)
	# Pop RHS value first, THEN reserve slot
	li	a0, R_T0
	jal	em_pop
	# Reserve stack slot: emit addi sp, sp, -4
	li	a0, -4
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	# Stack overflow check: bgeu sp, tp, +8; jal x0, handler
	li	a0, 8
	li	a1, R_SP
	li	a2, R_TP
	li	a3, 7
	jal	em_btype
	sub	a0, s8, s0
	li	a1, R_ZERO
	jal	em_jtype
	# Store value and push result
	mv	a0, s5
	li	a1, R_T0
	jal	em_var_store
	li	a0, R_T0
	jal	em_push
	j	ge_done
ga_reassign:
	# Check: closure with captures escaping scope?
	# ST_CAPS = capture boundary (s11 value from closure). If > 0,
	# the closure has captures. If target var index < ST_CAPS,
	# the target outlives the captures → error.
	mv	s5, a0
	mv	s6, a1
	lw	t0, ST_CAPS(s1)
	beqz	t0, ga_ra_ok
	bge	s6, t0, ga_ra_ok
	# Error: closure captures escaping scope
	li	a0, 'E'
	jal	write_byte
	li	a0, 'c'
	jal	write_byte
	li	a0, 'e'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit
ga_ra_ok:
	# Mark variable if it holds a capturing closure
	lw	t0, ST_CAPS(s1)
	slli	t1, s6, 4
	addi	t1, t1, ST_DATA
	add	t1, s1, t1
	sw	t0, 12(t1)
	sw	x0, ST_CAPS(s1)
ga_store:
	# pop RHS value into t0
	li	a0, R_T0
	jal	em_pop
	# Check for compound assignment (s4 = op kind)
	li	t0, NK_EQUAL
	beq	s4, t0, ga_simple
	li	t0, NK_ASSIGN_MUT
	beq	s4, t0, ga_simple
	# Compound: load old value into t1, compute t0 = old OP rhs
	beqz	s7, ga_cmp_loc
	# Outer: lw t1, slot(s1)
	mv	a0, s5
	li	a1, R_S1
	li	a2, 2
	li	a3, R_T1
	li	a4, 0x03
	jal	em_itype
	j	ga_cmp_op
ga_cmp_loc:
	mv	a0, s5
	li	a1, R_T1
	jal	em_var_load
ga_cmp_op:
	# Dispatch on compound op
	li	t0, NK_PLUS_EQ
	beq	s4, t0, ga_c_add
	li	t0, NK_MINUS_EQ
	beq	s4, t0, ga_c_sub
	li	t0, NK_STAR_EQ
	beq	s4, t0, ga_c_mul
	li	t0, NK_SLASH_EQ
	beq	s4, t0, ga_c_div
	li	t0, NK_PERCENT_EQ
	beq	s4, t0, ga_c_mod
	li	t0, NK_AMP_EQ
	beq	s4, t0, ga_c_and
	li	t0, NK_PIPE_EQ
	beq	s4, t0, ga_c_or
	li	t0, NK_CARET_EQ
	beq	s4, t0, ga_c_xor
	li	t0, NK_LSHIFT_EQ
	beq	s4, t0, ga_c_sll
	li	t0, NK_RSHIFT_EQ
	beq	s4, t0, ga_c_srl
	j	cg_err
ga_c_add:
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 0
	li	a4, R_T0
	jal	em_rtype
	j	ga_simple
ga_c_sub:
	li	a0, 0x20
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 0
	li	a4, R_T0
	jal	em_rtype
	j	ga_simple
ga_c_and:
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 7
	li	a4, R_T0
	jal	em_rtype
	j	ga_simple
ga_c_or:
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 6
	li	a4, R_T0
	jal	em_rtype
	j	ga_simple
ga_c_xor:
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 4
	li	a4, R_T0
	jal	em_rtype
	j	ga_simple
ga_c_sll:
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 1
	li	a4, R_T0
	jal	em_rtype
	j	ga_simple
ga_c_srl:
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a3, 5
	li	a4, R_T0
	jal	em_rtype
	j	ga_simple
ga_c_mul:
ga_c_div:
ga_c_mod:
	j	cg_err
ga_simple:
	# store t0 at variable slot (s7=1 if outer)
	beqz	s7, ga_s_local
	# Outer: sw t0, slot(s1)
	mv	a0, s5
	li	a1, R_T0
	li	a2, R_S1
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	j	ga_s_push
ga_s_local:
	mv	a0, s5
	li	a1, R_T0
	jal	em_var_store
ga_s_push:
	li	a0, R_T0
	jal	em_push
	j	ge_done
ga_deref:
	# *addr, @addr, or #addr = val: RHS on stack, generate address
	lw	s5, N_DATA(s6)
	li	t1, NK_STAR
	beq	t1, s5, ga_do_st
	li	t1, NK_AT
	beq	t1, s5, ga_do_st
	li	t1, NK_HASH
	beq	t1, s5, ga_do_st
	j	cg_err
ga_do_st:
	lw	a0, N_FIRST_CHILD(s6)
	jal	gen_expr
	li	a0, R_T1
	jal	em_pop
	li	a0, R_T0
	jal	em_pop
	# sw/sh/sb: funct3=2 for *, 1 for #, 0 for @
	li	t0, NK_STAR
	beq	s5, t0, ga_sw
	li	t0, NK_HASH
	beq	s5, t0, ga_sh
	li	a3, 0
	j	ga_emit_st
ga_sh:
	li	a3, 1
	j	ga_emit_st
ga_sw:
	li	a3, 2
ga_emit_st:
	li	a0, 0
	li	a1, R_T0
	li	a2, R_T1
	li	a4, 0x23
	jal	em_stype
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Block ---
ge_block:
	# Save scope state
	lw	t0, ST_CNT(s1)
	lw	t1, ST_NEXT(s1)
	addi	sp, sp, -8
	sw	t0, 0(sp)
	sw	t1, 4(sp)
	lw	s5, N_FIRST_CHILD(s3)
	beqz	s5, gbl_empty
	# Find last child
	mv	s6, s5
gbl_last:
	lw	t0, N_NEXT_SIB(s6)
	beqz	t0, gbl_gen
	mv	s6, t0
	j	gbl_last
gbl_gen:
	# s6 = last child; generate all children
	mv	s7, s5
gbl_child:
	mv	a0, s7
	jal	gen_expr
	beq	s7, s6, gbl_end
	# pop intermediate value
	li	a0, R_T0
	jal	em_pop
	lw	s7, N_NEXT_SIB(s7)
	j	gbl_child
gbl_end:
	# Block value on stack. Reclaim inner variable slots if any.
	lw	t0, 4(sp)
	lw	t1, ST_NEXT(s1)
	sub	s5, t0, t1
	beqz	s5, gbl_scope
	# Pop value, emit sp reclaim, push value
	li	a0, R_T0
	jal	em_pop
	li	a0, R_T1
	mv	a1, s5
	jal	em_li
	li	a0, 0
	li	a1, R_T1
	li	a2, R_SP
	li	a3, 0
	li	a4, R_SP
	jal	em_rtype
	li	a0, R_T0
	jal	em_push
gbl_scope:
	# Restore symbol table state
	lw	t0, 0(sp)
	sw	t0, ST_CNT(s1)
	lw	t0, 4(sp)
	sw	t0, ST_NEXT(s1)
	addi	sp, sp, 8
	j	ge_done
gbl_empty:
	li	a0, R_T0
	li	a1, 0
	jal	em_li
	li	a0, R_T0
	jal	em_push
	# Restore scope (no vars to reclaim)
	lw	t0, 0(sp)
	sw	t0, ST_CNT(s1)
	lw	t0, 4(sp)
	sw	t0, ST_NEXT(s1)
	addi	sp, sp, 8
	j	ge_done

# --- Loop with break/continue ---
# Loop context (heap-allocated):
#   0: old s10   4: old s11
#   8: loop_start (emit addr)  12: sp-save slot offset
#   16: break count  20: break array ptr
ge_loop:
	# Allocate loop context
	li	a0, 24
	jal	alloc
	sw	s10, 0(a0)
	sw	s11, 4(a0)
	mv	s10, a0
	# Allocate break fixup array (max 64)
	li	a0, 256
	jal	alloc
	sw	a0, 20(s10)
	sw	x0, 16(s10)
	# Allocate hidden sp-save slot
	lw	t0, ST_NEXT(s1)
	addi	t0, t0, -4
	sw	t0, ST_NEXT(s1)
	sw	t0, 12(s10)
	# Emit: reserve slot (addi sp, sp, -4 + overflow check)
	li	a0, -4
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	li	a0, 8
	li	a1, R_SP
	li	a2, R_TP
	li	a3, 7
	jal	em_btype
	sub	a0, s8, s0
	li	a1, R_ZERO
	jal	em_jtype
	# loop_start: emit sw sp, slot(s0)
	sw	s0, 8(s10)
	lw	a0, 12(s10)
	li	a1, R_SP
	jal	em_var_store
	# Generate body
	lw	a0, N_FIRST_CHILD(s3)
	jal	gen_expr
	# Pop body result
	li	a0, R_T0
	jal	em_pop
	# j loop_start
	lw	t0, 8(s10)
	sub	a0, t0, s0
	li	a1, R_ZERO
	jal	em_jtype
	# Backpatch all breaks to here
	lw	t2, 16(s10)
	lw	t3, 20(s10)
gl_bpatch:
	beqz	t2, gl_bdone
	lw	a0, 0(t3)
	sub	a1, s0, a0
	addi	sp, sp, -8
	sw	t2, 0(sp)
	sw	t3, 4(sp)
	jal	patch_jal
	lw	t2, 0(sp)
	lw	t3, 4(sp)
	addi	sp, sp, 8
	addi	t3, t3, 4
	addi	t2, t2, -1
	j	gl_bpatch
gl_bdone:
	# Break already pushed its value onto the restored stack.
	# Restore old loop context
	lw	s11, 4(s10)
	lw	s10, 0(s10)
	j	ge_done

# --- Break ---
ge_break:
	# Check for break value (first child)
	lw	s5, N_FIRST_CHILD(s3)
	beqz	s5, gb_noval
	# Evaluate break value → on stack
	mv	a0, s5
	jal	gen_expr
	# Pop value into t0 before restoring sp
	li	a0, R_T0
	jal	em_pop
	j	gb_restore
gb_noval:
	# No value: load 0 into t0
	li	a0, R_T0
	li	a1, 0
	jal	em_li
gb_restore:
	# Restore sp from hidden slot
	lw	a0, 12(s10)
	li	a1, R_SP
	jal	em_var_load
	# Push break value (t0) — manually, no overflow check (sp is restored)
	li	a0, -4
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	li	a0, 0
	li	a1, R_T0
	li	a2, R_SP
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	# Record break fixup
	lw	t0, 16(s10)
	lw	t1, 20(s10)
	slli	t2, t0, 2
	add	t2, t1, t2
	sw	s0, 0(t2)
	addi	t0, t0, 1
	sw	t0, 16(s10)
	# Emit placeholder j loop_end
	li	a0, 0
	li	a1, R_ZERO
	jal	em_jtype
	# Push dummy (unreachable, maintains stack invariant)
	li	a0, R_T0
	li	a1, 0
	jal	em_li
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Continue ---
ge_cont:
	# Emit: lw sp, slot(s0) — restore sp to loop start
	lw	a0, 12(s10)
	li	a1, R_SP
	jal	em_var_load
	# j loop_start (backward jump)
	lw	t0, 8(s10)
	sub	a0, t0, s0
	li	a1, R_ZERO
	jal	em_jtype
	# Push dummy (unreachable)
	li	a0, R_T0
	li	a1, 0
	jal	em_li
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Ternary (cond ? then : else) ---
ge_tern:
	# children: cond, then_expr, else_expr
	lw	s5, N_FIRST_CHILD(s3)
	lw	s6, N_NEXT_SIB(s5)
	lw	s7, N_NEXT_SIB(s6)
	# generate condition
	mv	a0, s5
	jal	gen_expr
	li	a0, R_T0
	jal	em_pop
	# trampoline: bne t0, x0, +8; jal x0, else (placeholder)
	li	a0, 8
	li	a1, R_T0
	li	a2, R_ZERO
	li	a3, 1
	jal	em_btype
	mv	s5, s0
	li	a0, 0
	li	a1, R_ZERO
	jal	em_jtype
	# generate then
	mv	a0, s6
	jal	gen_expr
	# j past else (placeholder)
	mv	s6, s0
	li	a0, 0
	li	a1, R_ZERO
	jal	em_jtype
	# backpatch: jal to else start
	sub	a1, s0, s5
	mv	a0, s5
	jal	patch_jal
	# generate else
	mv	a0, s7
	jal	gen_expr
	# backpatch: j to merge point
	sub	a1, s0, s6
	mv	a0, s6
	jal	patch_jal
	j	ge_done

# --- Function call ---
ge_call:
	# first child = callee (ident), rest = args
	lw	s5, N_FIRST_CHILD(s3)
	# For now: push args into a0-a7, then jal to label
	# Count and generate args
	lw	s6, N_NEXT_SIB(s5)
	li	s7, 0
gc_args:
	beqz	s6, gc_emit
	mv	a0, s6
	jal	gen_expr
	addi	s7, s7, 1
	lw	s6, N_NEXT_SIB(s6)
	j	gc_args
gc_emit:
	# Pop args into a-regs (reverse order)
	mv	t2, s7
gc_pop_args:
	beqz	t2, gc_call
	addi	t2, t2, -1
	addi	a0, t2, R_A0
	addi	sp, sp, -4
	sw	t2, 0(sp)
	jal	em_pop
	lw	t2, 0(sp)
	addi	sp, sp, 4
	j	gc_pop_args
gc_call:
	# Look up callee in asm label table (s9)
	lw	a0, N_LOC_OFF(s5)
	lw	a1, N_LOC_LEN(s5)
	# Search asm label table
	lw	t3, AT_CNT(s9)
	li	t4, 0
gc_find:
	beq	t4, t3, gc_closure
	slli	t0, t4, 2
	slli	t1, t4, 3
	add	t0, t0, t1
	addi	t0, t0, AT_DATA
	add	t0, s9, t0
	lw	t1, AL_LEN(t0)
	bne	a1, t1, gc_fnext
	# Compare name bytes
	lw	t1, AL_OFF(t0)
	add	t1, s2, t1
	add	t2, s2, a0
	mv	t5, a1
gc_fcmp:
	beqz	t5, gc_found
	lbu	t6, 0(t1)
	lbu	a2, 0(t2)
	bne	t6, a2, gc_fnext
	addi	t1, t1, 1
	addi	t2, t2, 1
	addi	t5, t5, -1
	j	gc_fcmp
gc_fnext:
	addi	t4, t4, 1
	j	gc_find
gc_found:
	lw	t1, AL_ADDR(t0)
	# Emit: jal ra, offset
	sub	a0, t1, s0
	li	a1, 1
	jal	em_jtype
	# Push return value (a0)
	li	a0, R_A0
	jal	em_push
	j	ge_done

gc_closure:
	# Not in asm label table — try symbol table (closure variable)
	lw	a0, N_LOC_OFF(s5)
	lw	a1, N_LOC_LEN(s5)
	jal	sym_try
	li	t0, -1
	beq	a0, t0, sf_fail
	# If inside closure body (s11>0), check if callee has captures
	beqz	s11, gc_cl_ok
	slli	t0, a1, 4
	addi	t0, t0, ST_DATA
	add	t0, s1, t0
	lw	t1, 12(t0)
	beqz	t1, gc_cl_ok
	# Error: calling capturing closure from inside closure body
	li	a0, 'E'
	jal	write_byte
	li	a0, 'c'
	jal	write_byte
	li	a0, 'p'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit
gc_cl_ok:
	# Load code pointer (check outer variable like ge_ident)
	mv	s5, a0
	beqz	s11, gc_ld_loc
	bge	a1, s11, gc_ld_loc
	# Outer: lw t0, slot(s1)
	mv	a0, s5
	li	a1, R_S1
	li	a2, 2
	li	a3, R_T0
	li	a4, 0x03
	jal	em_itype
	j	gc_ld_done
gc_ld_loc:
	mv	a0, s5
	li	a1, R_T0
	jal	em_var_load
gc_ld_done:
	# Runtime check: if tag bit set AND inside closure (s0 != s1), error
	# Emit: andi t1, t0, 1; beqz t1, +12; beq s0, s1, +8; jal x0, handler
	li	a0, 1
	li	a1, R_T0
	li	a2, 7
	li	a3, R_T1
	li	a4, 0x13
	jal	em_itype
	li	a0, 12
	li	a1, R_T1
	li	a2, R_ZERO
	li	a3, 0
	jal	em_btype
	li	a0, 8
	li	a1, R_S0
	li	a2, R_S1
	li	a3, 0
	jal	em_btype
	sub	a0, s8, s0
	li	a1, R_ZERO
	jal	em_jtype
	# Emit: andi t0, t0, -2 (clear tag bit)
	li	a0, -2
	li	a1, R_T0
	li	a2, 7
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	# Emit: mv s1, s0 (pass outer frame to closure)
	li	a0, 0
	li	a1, R_S0
	li	a2, 0
	li	a3, R_S1
	li	a4, 0x13
	jal	em_itype
	# Emit: jalr ra, t0, 0 (indirect call)
	li	a0, 0
	li	a1, R_T0
	li	a2, 0
	li	a3, 1
	li	a4, 0x67
	jal	em_itype
	# Push return value (a0)
	li	a0, R_A0
	jal	em_push
	j	ge_done

# --- Asm block ---
ge_asm:
	# Children: optional NK_IDENT (label), NK_STR (body)
	lw	s5, N_FIRST_CHILD(s3)
	lw	t0, N_KIND(s5)
	li	t1, NK_IDENT
	bne	t0, t1, ga_nobody
	# Has label — s5 is the label node, body is next sib
	mv	s6, s5
	lw	s5, N_NEXT_SIB(s6)
	j	ga_body
ga_nobody:
	li	s6, 0
ga_body:
	# Emit j past_asm (placeholder)
	mv	s7, s0
	li	a0, 0
	li	a1, R_ZERO
	jal	em_jtype
	# Register asm label if present
	beqz	s6, ga_no_lbl
	lw	t0, AT_CNT(s9)
	slli	t1, t0, 2
	slli	t2, t0, 3
	add	t1, t1, t2
	addi	t1, t1, AT_DATA
	add	t1, s9, t1
	lw	t2, N_LOC_OFF(s6)
	sw	t2, AL_OFF(t1)
	lw	t2, N_LOC_LEN(s6)
	sw	t2, AL_LEN(t1)
	sw	s0, AL_ADDR(t1)
	addi	t0, t0, 1
	sw	t0, AT_CNT(s9)
ga_no_lbl:
	# Assemble body
	lw	t0, N_LOC_OFF(s5)
	add	a0, s2, t0
	lw	a1, N_LOC_LEN(s5)
	jal	asm_assemble
	# Backpatch j past_asm
	sub	a1, s0, s7
	mv	a0, s7
	jal	patch_jal
	# Asm block evaluates to 0
	li	a0, R_T0
	li	a1, 0
	jal	em_li
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Return ---
ge_return:
	lw	s5, N_FIRST_CHILD(s3)
	beqz	s5, gr_void
	mv	a0, s5
	jal	gen_expr
	li	a0, R_A0
	jal	em_pop
	j	gr_emit
gr_void:
	# return without value: a0 = 0
	li	a0, R_A0
	li	a1, 0
	jal	em_li
gr_emit:
	# TODO: emit epilogue (restore fp, ra, ret)
	# For now just emit ret (jalr x0, ra, 0)
	li	a0, 0
	li	a1, R_RA
	li	a2, 0
	li	a3, R_ZERO
	li	a4, 0x67
	jal	em_itype
	# Push dummy value (unreachable but maintains invariant)
	li	a0, R_T0
	li	a1, 0
	jal	em_li
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Postfix (++ / --) ---
ge_postfix:
	# child = operand (must be ident)
	lw	s5, N_DATA(s3)
	lw	s6, N_FIRST_CHILD(s3)
	lw	t0, N_KIND(s6)
	li	t1, NK_IDENT
	bne	t0, t1, cg_err
	# Look up variable and check outer
	lw	a0, N_LOC_OFF(s6)
	lw	a1, N_LOC_LEN(s6)
	jal	sym_try
	li	t0, -1
	beq	a0, t0, sf_fail
	mv	s7, a0
	li	s3, 0
	beqz	s11, gpo_ld
	bge	a1, s11, gpo_ld
	li	s3, 1
	# Outer: lw t0, slot(s1)
	mv	a0, s7
	li	a1, R_S1
	li	a2, 2
	li	a3, R_T0
	li	a4, 0x03
	jal	em_itype
	j	gpo_loaded
gpo_ld:
	mv	a0, s7
	li	a1, R_T0
	jal	em_var_load
gpo_loaded:
	# Push old value (postfix returns pre-increment)
	li	a0, R_T0
	jal	em_push
	# Compute new value: addi t0, t0, 1 or -1
	li	t0, NK_DBL_PLUS
	beq	s5, t0, gpo_inc
	li	a0, -1
	j	gpo_store
gpo_inc:
	li	a0, 1
gpo_store:
	li	a1, R_T0
	li	a2, 0
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	# Store back (s3=1 if outer)
	beqz	s3, gpo_sloc
	mv	a0, s7
	li	a1, R_T0
	li	a2, R_S1
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	j	ge_done
gpo_sloc:
	mv	a0, s7
	li	a1, R_T0
	jal	em_var_store
	j	ge_done

# --- Closure |params| body ---
ge_closure:
	# Children: param idents..., body (last child)
	# Stack: [0]=jal_patch [4]=ST_CNT [8]=ST_NEXT [12]=old_s11
	addi	sp, sp, -16
	sw	s0, 0(sp)
	sw	s11, 12(sp)
	li	a0, 0
	li	a1, R_T0
	jal	em_jtype
	# Emit prologue: save ra, s0, s1; set s0=sp (with tp check)
	li	a0, -12
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	li	a0, 8
	li	a1, R_SP
	li	a2, R_TP
	li	a3, 7
	jal	em_btype
	sub	a0, s8, s0
	li	a1, R_ZERO
	jal	em_jtype
	li	a0, 8
	li	a1, 1
	li	a2, R_SP
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	li	a0, 4
	li	a1, R_S0
	li	a2, R_SP
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	li	a0, 0
	li	a1, R_S1
	li	a2, R_SP
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	li	a0, 0
	li	a1, R_SP
	li	a2, 0
	li	a3, R_S0
	li	a4, 0x13
	jal	em_itype
	# Save scope. Set s11 = boundary (outer var count). Don't reset ST_CNT.
	lw	t0, ST_CNT(s1)
	sw	t0, 4(sp)
	mv	s11, t0
	lw	t0, ST_NEXT(s1)
	sw	t0, 8(sp)
	sw	x0, ST_NEXT(s1)
	# Find last child (body) and define param variables
	lw	s5, N_FIRST_CHILD(s3)
	mv	s6, s5
gc_last:
	lw	t0, N_NEXT_SIB(s6)
	beqz	t0, gc_params
	mv	s6, t0
	j	gc_last
gc_params:
	# s6 = body (last child). Walk params from s5 to s6.
	mv	s7, s5
	li	s5, 0
gc_ploop:
	beq	s7, s6, gc_body
	# Save param index and AST node ptr
	addi	sp, sp, -8
	sw	s5, 0(sp)
	sw	s7, 4(sp)
	# Define param variable
	lw	a0, N_LOC_OFF(s7)
	lw	a1, N_LOC_LEN(s7)
	jal	sym_def
	mv	s7, a0
	# Reserve slot (with tp check)
	li	a0, -4
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	li	a0, 8
	li	a1, R_SP
	li	a2, R_TP
	li	a3, 7
	jal	em_btype
	sub	a0, s8, s0
	li	a1, R_ZERO
	jal	em_jtype
	# Store a_n at slot
	mv	a0, s7
	lw	t0, 0(sp)
	addi	a1, t0, R_A0
	jal	em_var_store
	# Restore and advance
	lw	s5, 0(sp)
	lw	s7, 4(sp)
	addi	sp, sp, 8
	addi	s5, s5, 1
	lw	s7, N_NEXT_SIB(s7)
	j	gc_ploop
gc_body:
	# Compile body expression
	mv	a0, s6
	jal	gen_expr
	# Pop result into a0 (return value)
	li	a0, R_A0
	jal	em_pop
	# Emit epilogue: mv sp,s0; lw s1,0(sp); lw s0,4(sp); lw ra,8(sp); addi sp,12; ret
	li	a0, 0
	li	a1, R_S0
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	li	a0, 0
	li	a1, R_SP
	li	a2, 2
	li	a3, R_S1
	li	a4, 0x03
	jal	em_itype
	li	a0, 4
	li	a1, R_SP
	li	a2, 2
	li	a3, R_S0
	li	a4, 0x03
	jal	em_itype
	li	a0, 8
	li	a1, R_SP
	li	a2, 2
	li	a3, 1
	li	a4, 0x03
	jal	em_itype
	li	a0, 12
	li	a1, R_SP
	li	a2, 0
	li	a3, R_SP
	li	a4, 0x13
	jal	em_itype
	li	a0, 0
	li	a1, 1
	li	a2, 0
	li	a3, R_ZERO
	li	a4, 0x67
	jal	em_itype
	# Restore compiler scope + s11
	lw	t0, 4(sp)
	sw	t0, ST_CNT(s1)
	lw	t0, 8(sp)
	sw	t0, ST_NEXT(s1)
	lw	s11, 12(sp)
	# Backpatch jal t0 to here
	lw	s5, 0(sp)
	sub	a0, s0, s5
	li	a1, R_T0
	mv	t3, s0
	mv	s0, s5
	jal	em_jtype
	mv	s0, t3
	addi	sp, sp, 16
	# If closure has captures, tag code pointer (set bit 0)
	lw	t0, ST_CAPS(s1)
	beqz	t0, gc_no_tag
	# Emit: ori t0, t0, 1 (tag the code pointer)
	li	a0, 1
	li	a1, R_T0
	li	a2, 6
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
gc_no_tag:
	# Push t0 (code pointer, possibly tagged)
	li	a0, R_T0
	jal	em_push
	j	ge_done

# --- Prefix ++/-- (returns new value) ---
gp_preinc:
	lw	s6, N_FIRST_CHILD(s3)
	lw	t0, N_KIND(s6)
	li	t1, NK_IDENT
	bne	t0, t1, cg_err
	lw	a0, N_LOC_OFF(s6)
	lw	a1, N_LOC_LEN(s6)
	jal	sym_try
	li	t0, -1
	beq	a0, t0, sf_fail
	mv	s7, a0
	# Check outer (save flag in s3, available since we dispatched)
	li	s3, 0
	beqz	s11, gpi_ld
	bge	a1, s11, gpi_ld
	li	s3, 1
	mv	a0, s7
	li	a1, R_S1
	li	a2, 2
	li	a3, R_T0
	li	a4, 0x03
	jal	em_itype
	j	gpi_loaded
gpi_ld:
	mv	a0, s7
	li	a1, R_T0
	jal	em_var_load
gpi_loaded:
	# Increment or decrement
	li	t0, NK_DBL_PLUS
	beq	s5, t0, gpi_inc
	li	a0, -1
	j	gpi_emit
gpi_inc:
	li	a0, 1
gpi_emit:
	li	a1, R_T0
	li	a2, 0
	li	a3, R_T0
	li	a4, 0x13
	jal	em_itype
	# Store back (s3=1 if outer)
	beqz	s3, gpi_st_loc
	mv	a0, s7
	li	a1, R_T0
	li	a2, R_S1
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	j	gpi_push
gpi_st_loc:
	mv	a0, s7
	li	a1, R_T0
	jal	em_var_store
gpi_push:
	# Push new value
	li	a0, R_T0
	jal	em_push
	j	ge_done

ge_done:
	return

# --- Jump offset overflow error ---
ej_err:
	li	a0, 'E'
	jal	write_byte
	li	a0, 'j'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit

# --- Codegen error ---
cg_err:
	li	a0, 'E'
	jal	write_byte
	li	a0, 'c'
	jal	write_byte
	li	a0, 'g'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit

# ============================================================================
# Asm block assembler
# ============================================================================

# asm_reg: parse register name from token
#   a0 = token ptr, a1 = token length
#   Returns a0 = register number (0-31)
asm_reg:
	lbu	t0, 0(a0)
	li	t1, 'x'
	beq	t0, t1, ar_x
	li	t1, 'a'
	beq	t0, t1, ar_a
	li	t1, 't'
	beq	t0, t1, ar_t
	li	t1, 's'
	beq	t0, t1, ar_s
	li	t1, 'z'
	beq	t0, t1, ar_zero
	li	t1, 'r'
	beq	t0, t1, ar_ra
	li	t1, 'g'
	beq	t0, t1, ar_gp
	li	t1, 'f'
	beq	t0, t1, ar_fp
	j	asm_err
ar_x:
	addi	a0, a0, 1
	addi	a1, a1, -1
	j	parse_int
ar_a:
	lbu	t0, 1(a0)
	addi	a0, t0, -38
	ret
ar_t:
	lbu	t0, 1(a0)
	li	t1, 'p'
	beq	t0, t1, ar_tp
	addi	t0, t0, -48
	li	t1, 3
	blt	t0, t1, ar_t_lo
	addi	a0, t0, 25
	ret
ar_t_lo:
	addi	a0, t0, 5
	ret
ar_tp:
	li	a0, 4
	ret
ar_s:
	lbu	t0, 1(a0)
	li	t1, 'p'
	beq	t0, t1, ar_sp
	li	t1, 3
	blt	a1, t1, ar_s1d
	# s10 or s11
	lbu	t1, 2(a0)
	li	t2, '0'
	beq	t1, t2, ar_s10
	li	a0, 27
	ret
ar_s10:
	li	a0, 26
	ret
ar_s1d:
	addi	t0, t0, -48
	li	t1, 2
	blt	t0, t1, ar_s_lo
	addi	a0, t0, 16
	ret
ar_s_lo:
	addi	a0, t0, 8
	ret
ar_sp:
	li	a0, 2
	ret
ar_zero:
	li	a0, 0
	ret
ar_ra:
	li	a0, 1
	ret
ar_gp:
	li	a0, 3
	ret
ar_fp:
	li	a0, 8
	ret

# asm_skip: skip whitespace and commas, advance s3
#   s3 = current ptr, s4 = end ptr
asm_skip:
	bgeu	s3, s4, as_done
	lbu	t0, 0(s3)
	li	t1, 32
	beq	t0, t1, as_adv
	li	t1, 9
	beq	t0, t1, as_adv
	li	t1, ','
	beq	t0, t1, as_adv
	li	t1, 13
	beq	t0, t1, as_adv
as_done:
	ret
as_adv:
	addi	s3, s3, 1
	j	asm_skip

# asm_tok: read next token, return ptr and length
#   s3 = current ptr (advanced past token), s4 = end
#   Returns a0 = token ptr, a1 = token length
asm_tok:
	mv	a0, s3
at_loop:
	bgeu	s3, s4, at_done
	lbu	t0, 0(s3)
	# Stop on whitespace, comma, paren, colon, newline, comment
	li	t1, 32
	beq	t0, t1, at_done
	li	t1, 9
	beq	t0, t1, at_done
	li	t1, ','
	beq	t0, t1, at_done
	li	t1, '('
	beq	t0, t1, at_done
	li	t1, ')'
	beq	t0, t1, at_done
	li	t1, ':'
	beq	t0, t1, at_done
	li	t1, '\n'
	beq	t0, t1, at_done
	li	t1, 13
	beq	t0, t1, at_done
	addi	s3, s3, 1
	j	at_loop
at_done:
	sub	a1, s3, a0
	ret

# asm_skip_nl: skip to next line
#   s3 = current ptr, s4 = end
asm_skip_nl:
	bgeu	s3, s4, asn_done
	lbu	t0, 0(s3)
	addi	s3, s3, 1
	li	t1, '\n'
	bne	t0, t1, asm_skip_nl
asn_done:
	ret

# asm_imm: parse immediate value (decimal, hex, or negative)
#   s3 = current ptr (advanced past number), s4 = end
#   Returns a0 = value
asm_imm:
	# Manual save (avoid prologue to stay within 5-level nesting)
	addi	sp, sp, -8
	sw	ra, 4(sp)
	sw	s5, 0(sp)
	li	s5, 0
	bgeu	s3, s4, ai_call
	lbu	t0, 0(s3)
	li	t1, '-'
	bne	t0, t1, ai_call
	li	s5, 1
	addi	s3, s3, 1
ai_call:
	jal	asm_tok
	jal	parse_int
	beqz	s5, ai_done
	neg	a0, a0
ai_done:
	lw	s5, 0(sp)
	lw	ra, 4(sp)
	addi	sp, sp, 8
	ret

# asm_mnem: look up mnemonic in table
#   a0 = mnemonic ptr, a1 = mnemonic length
#   Returns a0 = table entry ptr, or 0 if not found
asm_mnem:
	# Manual save (avoid prologue to stay within 5-level nesting)
	addi	sp, sp, -16
	sw	ra, 12(sp)
	sw	s5, 0(sp)
	sw	s6, 4(sp)
	sw	s7, 8(sp)
	mv	s5, a0
	mv	s6, a1
	lla	s7, asm_mnem_tbl
am_scan:
	lbu	t0, 0(s7)
	beqz	t0, am_fail
	mv	t0, s5
	mv	t1, s7
	mv	t2, s6
am_cmp:
	beqz	t2, am_ck_end
	lbu	t3, 0(t0)
	lbu	t4, 0(t1)
	bne	t3, t4, am_next
	addi	t0, t0, 1
	addi	t1, t1, 1
	addi	t2, t2, -1
	j	am_cmp
am_ck_end:
	lbu	t3, 0(t1)
	bnez	t3, am_next
	mv	a0, s7
	j	am_done
am_next:
	addi	s7, s7, 12
	j	am_scan
am_fail:
	li	a0, 0
am_done:
	lw	s5, 0(sp)
	lw	s6, 4(sp)
	lw	s7, 8(sp)
	lw	ra, 12(sp)
	addi	sp, sp, 16
	ret

# asm_assemble: assemble asm body text into machine code
#   a0 = body text ptr, a1 = body text length
#   s0 = emit cursor, s2 = input base
#   Uses s3-s7 internally (saved by prologue)
asm_assemble:
	prologue s3 s4 s5 s6 s7 x0
	mv	s3, a0
	add	s4, a0, a1
	# Allocate local label table (max 64 labels)
	li	a0, 776
	jal	alloc
	mv	s5, a0
	sw	x0, 0(s5)
	# Allocate fixup table (max 128 fixups)
	li	a0, 2052
	jal	alloc
	mv	s6, a0
	sw	x0, 0(s6)

aa_line:
	bgeu	s3, s4, aa_fix
	jal	asm_skip
	bgeu	s3, s4, aa_fix
	# Check for newline
	lbu	t0, 0(s3)
	li	t1, '\n'
	beq	t0, t1, aa_nl
	# Check for // comment
	li	t1, '/'
	bne	t0, t1, aa_instr
	addi	t1, s3, 1
	bgeu	t1, s4, aa_instr
	lbu	t1, 1(s3)
	li	t2, '/'
	beq	t1, t2, aa_cmt
aa_instr:
	# Read mnemonic/label token
	jal	asm_tok
	# a0=ptr, a1=len. Check if followed by ':'
	mv	t3, a0
	mv	t4, a1
	bgeu	s3, s4, aa_mnem
	lbu	t0, 0(s3)
	li	t1, ':'
	bne	t0, t1, aa_mnem
	# Label definition: record address
	addi	s3, s3, 1
	lw	t0, 0(s5)
	slli	t1, t0, 2
	slli	t2, t0, 3
	add	t1, t1, t2
	addi	t1, t1, 4
	add	t1, s5, t1
	sw	t3, LL_OFF(t1)
	sw	t4, LL_LEN(t1)
	sw	s0, LL_ADDR(t1)
	addi	t0, t0, 1
	sw	t0, 0(s5)
	j	aa_line
aa_mnem:
	# Look up mnemonic
	mv	a0, t3
	mv	a1, t4
	jal	asm_mnem
	beqz	a0, asm_err
	# Load class, funct3, funct7
	lbu	t5, 8(a0)
	lbu	t6, 9(a0)
	lbu	t3, 10(a0)
	# Save on stack: [0]=class [4]=funct3 [8]=funct7 [12..20]=operands
	addi	sp, sp, -24
	sw	t5, 0(sp)
	sw	t6, 4(sp)
	sw	t3, 8(sp)
	# Dispatch on class
	li	t0, MC_RTYPE
	beq	t5, t0, aa_r
	li	t0, MC_IARITH
	beq	t5, t0, aa_ia
	li	t0, MC_ISHIFT
	beq	t5, t0, aa_is
	li	t0, MC_ILOAD
	beq	t5, t0, aa_il
	li	t0, MC_STYPE
	beq	t5, t0, aa_st
	li	t0, MC_BTYPE
	beq	t5, t0, aa_br
	li	t0, MC_LUI
	beq	t5, t0, aa_lui
	li	t0, MC_AUIPC
	beq	t5, t0, aa_lui
	li	t0, MC_JAL
	beq	t5, t0, aa_jal
	li	t0, MC_JALR
	beq	t5, t0, aa_jalr
	li	t0, MC_LI
	beq	t5, t0, aa_li
	li	t0, MC_MV
	beq	t5, t0, aa_mv
	li	t0, MC_RET
	beq	t5, t0, aa_ret
	li	t0, MC_J
	beq	t5, t0, aa_j
	li	t0, MC_NOP
	beq	t5, t0, aa_nop
	li	t0, MC_NOT
	beq	t5, t0, aa_2reg
	li	t0, MC_NEG
	beq	t5, t0, aa_2reg
	li	t0, MC_SEQZ
	beq	t5, t0, aa_2reg
	li	t0, MC_SNEZ
	beq	t5, t0, aa_2reg
	li	t0, MC_JR
	beq	t5, t0, aa_jr
	li	t0, MC_WFI
	beq	t5, t0, aa_wfi
	addi	sp, sp, 24
	j	asm_err

# --- R-type: rd, rs1, rs2 ---
aa_r:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 16(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	mv	a1, a0
	lw	a0, 8(sp)
	lw	a2, 16(sp)
	lw	a3, 4(sp)
	lw	a4, 12(sp)
	addi	sp, sp, 24
	jal	em_rtype
	j	aa_line

# --- I-type arithmetic: rd, rs1, imm ---
aa_ia:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 16(sp)
	jal	asm_skip
	jal	asm_imm
	lw	a1, 16(sp)
	lw	a2, 4(sp)
	lw	a3, 12(sp)
	addi	sp, sp, 24
	li	a4, 0x13
	jal	em_itype
	j	aa_line

# --- I-type shift: rd, rs1, shamt ---
aa_is:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 16(sp)
	jal	asm_skip
	jal	asm_imm
	lw	t0, 8(sp)
	slli	t0, t0, 5
	or	a0, a0, t0
	lw	a1, 16(sp)
	lw	a2, 4(sp)
	lw	a3, 12(sp)
	addi	sp, sp, 24
	li	a4, 0x13
	jal	em_itype
	j	aa_line

# --- I-type load: rd, imm(rs1) ---
aa_il:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_imm
	sw	a0, 16(sp)
	lbu	t0, 0(s3)
	li	t1, '('
	bne	t0, t1, asm_err
	addi	s3, s3, 1
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	mv	a1, a0
	lbu	t0, 0(s3)
	li	t1, ')'
	bne	t0, t1, asm_err
	addi	s3, s3, 1
	lw	a0, 16(sp)
	lw	a2, 4(sp)
	lw	a3, 12(sp)
	addi	sp, sp, 24
	li	a4, 0x03
	jal	em_itype
	j	aa_line

# --- S-type: rs2, imm(rs1) ---
aa_st:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_imm
	sw	a0, 16(sp)
	lbu	t0, 0(s3)
	li	t1, '('
	bne	t0, t1, asm_err
	addi	s3, s3, 1
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	mv	a2, a0
	lbu	t0, 0(s3)
	li	t1, ')'
	bne	t0, t1, asm_err
	addi	s3, s3, 1
	lw	a0, 16(sp)
	lw	a1, 12(sp)
	lw	a3, 4(sp)
	addi	sp, sp, 24
	li	a4, 0x23
	jal	em_stype
	j	aa_line

# --- B-type: rs1, rs2, label ---
aa_br:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 16(sp)
	jal	asm_skip
	jal	asm_tok
	lw	t0, 0(s6)
	slli	t1, t0, 4
	addi	t1, t1, 4
	add	t1, s6, t1
	sw	a0, FX_OFF(t1)
	sw	a1, FX_LEN(t1)
	sw	s0, FX_ADDR(t1)
	sw	x0, FX_TYPE(t1)
	addi	t0, t0, 1
	sw	t0, 0(s6)
	lw	a1, 12(sp)
	lw	a2, 16(sp)
	lw	a3, 4(sp)
	addi	sp, sp, 24
	li	a0, 0
	jal	em_btype
	j	aa_line

# --- U-type (lui/auipc): rd, imm ---
aa_lui:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_imm
	lw	a1, 12(sp)
	lw	t0, 0(sp)
	addi	sp, sp, 24
	li	t1, MC_AUIPC
	beq	t0, t1, aa_auipc
	li	a2, 0x37
	jal	em_utype
	j	aa_line
aa_auipc:
	li	a2, 0x17
	jal	em_utype
	j	aa_line

# --- jal: rd, label ---
aa_jal:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	lw	t0, 0(s6)
	slli	t1, t0, 4
	addi	t1, t1, 4
	add	t1, s6, t1
	sw	a0, FX_OFF(t1)
	sw	a1, FX_LEN(t1)
	sw	s0, FX_ADDR(t1)
	li	t2, 1
	sw	t2, FX_TYPE(t1)
	addi	t0, t0, 1
	sw	t0, 0(s6)
	lw	a1, 12(sp)
	addi	sp, sp, 24
	li	a0, 0
	jal	em_jtype
	j	aa_line

# --- jalr: rd, rs1, imm ---
aa_jalr:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 16(sp)
	jal	asm_skip
	jal	asm_imm
	lw	a1, 16(sp)
	li	a2, 0
	lw	a3, 12(sp)
	addi	sp, sp, 24
	li	a4, 0x67
	jal	em_itype
	j	aa_line

# --- Pseudos ---
aa_li:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_imm
	mv	a1, a0
	lw	a0, 12(sp)
	addi	sp, sp, 24
	jal	em_li
	j	aa_line

aa_mv:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	mv	a1, a0
	lw	a3, 12(sp)
	addi	sp, sp, 24
	li	a0, 0
	li	a2, 0
	li	a4, 0x13
	jal	em_itype
	j	aa_line

aa_ret:
	addi	sp, sp, 24
	li	a0, 0
	li	a1, 1
	li	a2, 0
	li	a3, 0
	li	a4, 0x67
	jal	em_itype
	j	aa_line

aa_j:
	jal	asm_skip
	jal	asm_tok
	lw	t0, 0(s6)
	slli	t1, t0, 4
	addi	t1, t1, 4
	add	t1, s6, t1
	sw	a0, FX_OFF(t1)
	sw	a1, FX_LEN(t1)
	sw	s0, FX_ADDR(t1)
	li	t2, 1
	sw	t2, FX_TYPE(t1)
	addi	t0, t0, 1
	sw	t0, 0(s6)
	addi	sp, sp, 24
	li	a0, 0
	li	a1, 0
	jal	em_jtype
	j	aa_line

aa_jr:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	mv	a1, a0
	addi	sp, sp, 24
	li	a0, 0
	li	a2, 0
	li	a3, 0
	li	a4, 0x67
	jal	em_itype
	j	aa_line

aa_nop:
	addi	sp, sp, 24
	li	a0, 0x13
	sw	a0, 0(s0)
	addi	s0, s0, 4
	j	aa_line

aa_wfi:
	addi	sp, sp, 24
	li	a0, 0x10500073
	sw	a0, 0(s0)
	addi	s0, s0, 4
	j	aa_line

# --- 2-reg pseudos: not, neg, seqz, snez ---
aa_2reg:
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	sw	a0, 12(sp)
	jal	asm_skip
	jal	asm_tok
	jal	asm_reg
	# Load all values before freeing stack
	mv	t4, a0
	lw	t5, 0(sp)
	lw	t3, 12(sp)
	addi	sp, sp, 24
	# t3=rd, t4=rs, t5=class
	li	t0, MC_NOT
	beq	t5, t0, a2r_not
	li	t0, MC_NEG
	beq	t5, t0, a2r_neg
	li	t0, MC_SEQZ
	beq	t5, t0, a2r_seqz
	# snez: sltu rd, x0, rs
	li	a0, 0
	mv	a1, t4
	li	a2, 0
	li	a3, 3
	mv	a4, t3
	jal	em_rtype
	j	aa_line
a2r_not:
	# xori rd, rs, -1
	li	a0, -1
	mv	a1, t4
	li	a2, 4
	mv	a3, t3
	li	a4, 0x13
	jal	em_itype
	j	aa_line
a2r_neg:
	# sub rd, x0, rs
	li	a0, 0x20
	mv	a1, t4
	li	a2, 0
	li	a3, 0
	mv	a4, t3
	jal	em_rtype
	j	aa_line
a2r_seqz:
	# sltiu rd, rs, 1
	li	a0, 1
	mv	a1, t4
	li	a2, 3
	mv	a3, t3
	li	a4, 0x13
	jal	em_itype
	j	aa_line

aa_nl:
	addi	s3, s3, 1
	j	aa_line

aa_cmt:
	jal	asm_skip_nl
	j	aa_line

# --- Resolve fixups ---
aa_fix:
	lw	t5, 0(s6)
	beqz	t5, aa_fdone
	li	t6, 0
af_loop:
	beq	t6, t5, aa_fdone
	slli	t0, t6, 4
	addi	t0, t0, 4
	add	t0, s6, t0
	lw	a0, FX_OFF(t0)
	lw	a1, FX_LEN(t0)
	lw	t1, FX_ADDR(t0)
	lw	t2, FX_TYPE(t0)
	# Look up label in local label table
	lw	t3, 0(s5)
	li	t4, 0
af_lbl:
	beq	t4, t3, asm_err
	slli	t0, t4, 2
	slli	a2, t4, 3
	add	t0, t0, a2
	addi	t0, t0, 4
	add	t0, s5, t0
	lw	a2, LL_LEN(t0)
	bne	a1, a2, af_lnext
	lw	a2, LL_OFF(t0)
	mv	a3, a0
	mv	a4, a1
af_lcmp:
	beqz	a4, af_lmatch
	lbu	a5, 0(a2)
	lbu	a6, 0(a3)
	bne	a5, a6, af_lnext
	addi	a2, a2, 1
	addi	a3, a3, 1
	addi	a4, a4, -1
	j	af_lcmp
af_lmatch:
	lw	a3, LL_ADDR(t0)
	sub	a0, a3, t1
	# Patch based on type: 0=B, 1=J
	bnez	t2, af_jtype
	# B-type: re-encode at t1
	# Need rs1, rs2, funct3 from the existing instruction
	lw	t3, 0(t1)
	srli	a1, t3, 15
	andi	a1, a1, 0x1F
	srli	a2, t3, 20
	andi	a2, a2, 0x1F
	srli	a3, t3, 12
	andi	a3, a3, 7
	mv	t3, s0
	mv	s0, t1
	jal	em_btype
	mv	s0, t3
	j	af_lnext2
af_jtype:
	mv	a1, a0
	mv	a0, t1
	jal	patch_jal
af_lnext2:
	addi	t6, t6, 1
	# Reload fixup count (might have been clobbered)
	lw	t5, 0(s6)
	j	af_loop
af_lnext:
	addi	t4, t4, 1
	j	af_lbl

aa_fdone:
	return

# --- Asm error ---
asm_err:
	li	a0, 'E'
	jal	write_byte
	li	a0, 'a'
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit

# ============================================================================
# Codegen: top-level entry point
# ============================================================================

# codegen: generate machine code from AST
#   a0=AST root, a1=output buffer start, a2=input buffer start
#   Returns a0=output start, a1=output end
codegen:
	prologue s0 s1 s2 s3 s4 s5 s6 s7 s8 s9 x0
	mv	s3, a0
	# Align output buffer start to 4 bytes
	addi	a1, a1, 3
	andi	a1, a1, -4
	mv	s0, a1
	mv	s2, a2
	mv	s4, a1

	# Initialize symbol table
	jal	sym_init
	mv	s1, a0

	# No closure scope initially
	li	s11, 0

	# Initialize asm label table (s9)
	li	a0, 772
	jal	alloc
	mv	s9, a0
	sw	x0, AT_CNT(s9)

	# Emit NOP (success magic)
	li	a0, 0x13
	sw	a0, 0(s0)
	addi	s0, s0, 4

	# Emit: lui sp, 0x88000 (sp = top of 128MB RAM)
	li	a0, 0x88000
	li	a1, R_SP
	li	a2, 0x37
	jal	em_utype

	# Emit: mv s0, sp (frame pointer = sp in generated code)
	li	a0, 0
	li	a1, R_SP
	li	a2, 0
	li	a3, R_S0
	li	a4, 0x13
	jal	em_itype
	# Emit: mv s1, s0 (initialize s1 = s0 for closure safety check)
	li	a0, 0
	li	a1, R_S0
	li	a2, 0
	li	a3, R_S1
	li	a4, 0x13
	jal	em_itype

	# Placeholder for gp setup (backpatched after codegen)
	mv	s7, s0
	li	a0, 0x13
	sw	a0, 0(s0)
	addi	s0, s0, 4
	sw	a0, 0(s0)
	addi	s0, s0, 4

	# Emit: li tp, 0 (default: no stack limit)
	li	a0, R_TP
	li	a1, 0
	jal	em_li

	# Emit: j past_handler (skip over overflow handler)
	mv	s6, s0
	li	a0, 0
	li	a1, R_ZERO
	jal	em_jtype

	# Stack overflow handler — s8 = its address for backpatch refs
	mv	s8, s0
	# sb 'S', 0(uart) — print 'S' to UART
	li	a0, 0x10000
	li	a1, R_T0
	li	a2, 0x37
	jal	em_utype
	li	a0, R_T1
	li	a1, 83
	jal	em_li
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 0
	li	a4, 0x23
	jal	em_stype
	# Write FAIL (0x3333) to test device
	li	a0, 0x100
	li	a1, R_T0
	li	a2, 0x37
	jal	em_utype
	li	a0, 3
	li	a1, R_T1
	li	a2, 0x37
	jal	em_utype
	li	a0, 0x333
	li	a1, R_T1
	li	a2, 0
	li	a3, R_T1
	li	a4, 0x13
	jal	em_itype
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	# wfi; j -4
	li	a0, 0x10500073
	sw	a0, 0(s0)
	addi	s0, s0, 4
	li	a0, -4
	li	a1, R_ZERO
	jal	em_jtype

	# Backpatch: j past_handler
	sub	a1, s0, s6
	mv	a0, s6
	jal	patch_jal

	# Generate code for each top-level expression
	lw	s5, N_FIRST_CHILD(s3)
cg_top_loop:
	beqz	s5, cg_top_done
	mv	a0, s5
	jal	gen_expr
	lw	s6, N_NEXT_SIB(s5)
	beqz	s6, cg_top_last
	# Pop intermediate result
	li	a0, R_T0
	jal	em_pop
	mv	s5, s6
	j	cg_top_loop
cg_top_last:
	# Last expression: pop into a0
	li	a0, R_A0
	jal	em_pop
	mv	s5, s6
	j	cg_top_loop
cg_top_done:
	# Emit exit sequence
	# lui t0, 0x100 (test finisher device)
	li	a0, 0x100
	li	a1, R_T0
	li	a2, 0x37
	jal	em_utype
	# lui t1, 5
	li	a0, 5
	li	a1, R_T1
	li	a2, 0x37
	jal	em_utype
	# addi t1, t1, 0x555
	li	a0, 0x555
	li	a1, R_T1
	li	a2, 0
	li	a3, R_T1
	li	a4, 0x13
	jal	em_itype
	# sw t1, 0(t0)
	li	a0, 0
	li	a1, R_T1
	li	a2, R_T0
	li	a3, 2
	li	a4, 0x23
	jal	em_stype
	# wfi
	li	a0, 0x10500073
	sw	a0, 0(s0)
	addi	s0, s0, 4
	# j -4 (loop back to wfi)
	li	a0, -4
	li	a1, R_ZERO
	jal	em_jtype

	# Backpatch gp: point to end of code, aligned to 16
	# gp_value = 0x80000000 + (emit_cursor - output_start), aligned
	sub	s3, s0, s4
	lui	t0, 0x80000
	add	s3, t0, s3
	addi	s3, s3, 15
	andi	s3, s3, -16

	# Decompose gp_value for lui+addi
	srli	s6, s3, 12
	srli	t0, s3, 11
	andi	t0, t0, 1
	add	s6, s6, t0

	# Emit lui gp, upper at patch address
	mv	s5, s0
	mv	s0, s7
	mv	a0, s6
	li	a1, R_GP
	li	a2, 0x37
	jal	em_utype

	# Emit addi gp, gp, lower
	slli	t0, s6, 12
	sub	a0, s3, t0
	li	a1, R_GP
	li	a2, 0
	li	a3, R_GP
	li	a4, 0x13
	jal	em_itype

	# Restore emit cursor
	mv	s0, s5

	# Return output range
	mv	a0, s4
	mv	a1, s0
	return

# ============================================================================
# Compile: entry point for the compilation pipeline
# ============================================================================

# compile: a0=input start, a1=input end
#   Returns a0=output start, a1=output end
compile:
	prologue s0 s1 s2 s3 s4 x0
	mv	s2, a0			# input start
	mv	s3, a1			# input end
	mv	s4, a1			# output buffer start = input end

	# Init lexer
	mv	a0, s2
	mv	a1, s3
	jal	lexer_init
	mv	s0, a0			# s0 = lexer

	# Allocate token node (reused by advance)
	li	a0, N_SZ
	jal	alloc
	mv	s1, a0			# s1 = token node
	li	a1, N_SZ
	jal	memzero

	# Build AST: parse as program (list of top-level expressions)
	jal	alloc_node
	mv	s3, a0
	li	t0, NK_PROGRAM
	sw	t0, N_KIND(s3)

	# Prime the lexer (first advance)
	jal	advance

cmp_loop:
	lw	t0, N_KIND(s1)
	li	t1, NK_TERM
	beq	t0, t1, cmp_done
	li	a0, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s3
	jal	append_child
	# Skip optional semicolons between top-level exprs
cmp_semi:
	lw	t0, N_KIND(s1)
	li	t1, NK_SEMI
	bne	t0, t1, cmp_loop
	jal	advance
	j	cmp_semi

cmp_done:
	# Codegen: generate machine code from AST
	mv	a0, s3			# AST root
	mv	a1, s4			# output buffer start
	mv	a2, s2			# input buffer start
	jal	codegen			# returns a0=start, a1=end
	return

main:
	# Setup gp and stack pointer
	lla	gp, heap
	addi	gp, gp, 15
	andi	gp, gp, -16
	li	sp, 0x4000000
	add	sp, sp, gp

	# tp points to top of stack
	mv	tp, sp
	mv	s0, tp			# save start of data buffer
	jal	read_data		# a0 = byte count
	add	s1, s0, a0		# end = start + count
	mv	a0, s0
	mv	a1, s1

	# pass a0=start/a1=end of the input buffer, update a0/a1 to start/end output
	jal	compile
	# now print results
	jal	write_data

	j	exit

# ============================================================================
# Token string constants
# ============================================================================

# 3-char operators
tok_lshift_eq:
	.ascii	"<<="
tok_rshift_eq:
	.ascii	">>="

# 2-char operators
tok_dbl_plus:
	.ascii	"++"
tok_dbl_hyphen:
	.ascii	"--"
tok_assign_mut:
	.ascii	":="
tok_plus_eq:
	.ascii	"+="
tok_minus_eq:
	.ascii	"-="
tok_star_eq:
	.ascii	"*="
tok_slash_eq:
	.ascii	"/="
tok_pct_eq:
	.ascii	"%="
tok_dbl_equal:
	.ascii	"=="
tok_ne:
	.ascii	"!="
tok_lte:
	.ascii	"<="
tok_gte:
	.ascii	">="
tok_amp_amp:
	.ascii	"&&"
tok_pipe_pipe:
	.ascii	"||"
tok_lshift:
	.ascii	"<<"
tok_rshift:
	.ascii	">>"
tok_arrow:
	.ascii	"->"
tok_fat_arrow:
	.ascii	"=>"
tok_amp_eq:
	.ascii	"&="
tok_pipe_eq:
	.ascii	"|="
tok_caret_eq:
	.ascii	"^="

# 1-char operators
tok_semi:
	.ascii	";"
tok_comma:
	.ascii	","
tok_colon:
	.ascii	":"
tok_dot:
	.ascii	"."
tok_plus:
	.ascii	"+"
tok_hyphen:
	.ascii	"-"
tok_star:
	.ascii	"*"
tok_slash:
	.ascii	"/"
tok_percent:
	.ascii	"%"
tok_equal:
	.ascii	"="
tok_bang:
	.ascii	"!"
tok_tilde:
	.ascii	"~"
tok_amp:
	.ascii	"&"
tok_pipe:
	.ascii	"|"
tok_caret:
	.ascii	"^"
tok_lt:
	.ascii	"<"
tok_gt:
	.ascii	">"
tok_qmark:
	.ascii	"?"
tok_lparen:
	.ascii	"("
tok_rparen:
	.ascii	")"
tok_lbrace:
	.ascii	"{"
tok_rbrace:
	.ascii	"}"
tok_lbracket:
	.ascii	"["
tok_rbracket:
	.ascii	"]"
tok_at:
	.ascii	"@"
tok_hash:
	.ascii	"#"

# Keywords
kw_loop:
	.ascii	"loop"
kw_break:
	.ascii	"break"
kw_continue:
	.ascii	"continue"
kw_switch:
	.ascii	"switch"
kw_return:
	.ascii	"return"
kw_asm:
	.ascii	"asm"
kw_struct:
	.ascii	"struct"
kw_sizeof:
	.ascii	"sizeof"

# Asm mnemonic table: 8-byte name + class, funct3, funct7, pad = 12 bytes each
asm_mnem_tbl:
	# Format: 8-byte name (ascii+zero pad) + .word (class | funct3<<8 | funct7<<16)
	# R-type: add sub and or xor sll srl sra slt sltu
	.ascii	"add"
	.zero	5
	.word	0x000001
	.ascii	"sub"
	.zero	5
	.word	0x200001
	.ascii	"and"
	.zero	5
	.word	0x000701
	.ascii	"or"
	.zero	6
	.word	0x000601
	.ascii	"xor"
	.zero	5
	.word	0x000401
	.ascii	"sll"
	.zero	5
	.word	0x000101
	.ascii	"srl"
	.zero	5
	.word	0x000501
	.ascii	"sra"
	.zero	5
	.word	0x200501
	.ascii	"slt"
	.zero	5
	.word	0x000201
	.ascii	"sltu"
	.zero	4
	.word	0x000301
	# I-arith: addi andi ori xori slti sltiu
	.ascii	"addi"
	.zero	4
	.word	0x000002
	.ascii	"andi"
	.zero	4
	.word	0x000702
	.ascii	"ori"
	.zero	5
	.word	0x000602
	.ascii	"xori"
	.zero	4
	.word	0x000402
	.ascii	"slti"
	.zero	4
	.word	0x000202
	.ascii	"sltiu"
	.zero	3
	.word	0x000302
	# I-shift: slli srli srai
	.ascii	"slli"
