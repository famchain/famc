# UART constants
.equ	UART, 0x10000

# ── Node kinds (lexer tokens + AST nodes) ────────────────────────────
# Single-char punctuators
.equ	NK_ERROR,	0
.equ	NK_TERM,	1
.equ	NK_SEMI,	2
.equ	NK_COMMA,	3
.equ	NK_COLON,	4
.equ	NK_QMARK,	5
.equ	NK_LPAREN,	6
.equ	NK_RPAREN,	7
.equ	NK_LBRACE,	8
.equ	NK_RBRACE,	9
.equ	NK_LBRACKET,	10
.equ	NK_RBRACKET,	11
.equ	NK_DOT,		12
.equ	NK_AT,		13
.equ	NK_HASH,	14

# Operators
.equ	NK_PLUS,	15
.equ	NK_MINUS,	16
.equ	NK_STAR,	17
.equ	NK_SLASH,	18
.equ	NK_PERCENT,	19
.equ	NK_AMP,		20
.equ	NK_PIPE,	21
.equ	NK_CARET,	22
.equ	NK_TILDE,	23
.equ	NK_BANG,	24
.equ	NK_ASSIGN,	25
.equ	NK_LT,		26
.equ	NK_GT,		27

# Multi-char operators
.equ	NK_FAT_ARROW,	28
.equ	NK_EQ,		29
.equ	NK_NEQ,		30
.equ	NK_LTE,		31
.equ	NK_GTE,		32
.equ	NK_AND,		33
.equ	NK_OR,		34
.equ	NK_SHL,		35
.equ	NK_SHR,		36
.equ	NK_DOTDOT,	37
.equ	NK_DOTDOT_EQ,	38
.equ	NK_LTU,		39
.equ	NK_GTU,		40
.equ	NK_LTEU,	41
.equ	NK_GTEU,	42
.equ	NK_INC,		43
.equ	NK_DEC,		44
.equ	NK_ASSIGN_MUT,	45
.equ	NK_PLUS_EQ,	46
.equ	NK_MINUS_EQ,	47
.equ	NK_STAR_EQ,	48
.equ	NK_SLASH_EQ,	49
.equ	NK_PERCENT_EQ,	50
.equ	NK_AMP_EQ,	51
.equ	NK_PIPE_EQ,	52
.equ	NK_CARET_EQ,	53
.equ	NK_SHL_EQ,	54
.equ	NK_SHR_EQ,	55

# Keywords
.equ	NK_LOOP,	60
.equ	NK_BREAK,	61
.equ	NK_FOR,		62
.equ	NK_IN,		63
.equ	NK_RETURN,	64
.equ	NK_CONTINUE,	65
.equ	NK_STRUCT,	66
.equ	NK_SWITCH,	67
.equ	NK_ASM,		68
.equ	NK_SIZEOF,	69
.equ	NK_SELF,	70
.equ	NK_MACRO,	71

# Literals / identifiers
.equ	NK_IDENT,	80
.equ	NK_NUMBER,	81
.equ	NK_STRING,	82
.equ	NK_CHAR,	83

# Asm-specific nodes
.equ	NK_ASM_BIND,	90
.equ	NK_ASM_INSN,	91
.equ	NK_ASM_LABEL,	92

# Asm instruction classes (from mnemonic table)
.equ	AC_R,		1
.equ	AC_I_ARITH,	2
.equ	AC_I_SHIFT,	3
.equ	AC_I_LOAD,	4
.equ	AC_S,		5
.equ	AC_B,		6
.equ	AC_U_LUI,	7
.equ	AC_U_AUIPC,	8
.equ	AC_J_JAL,	9
.equ	AC_JALR,	10
.equ	AC_PS_LI,	11
.equ	AC_PS_MV,	12
.equ	AC_PS_RET,	13
.equ	AC_PS_J,	14
.equ	AC_PS_NOP,	15
.equ	AC_PS_NOT,	16
.equ	AC_PS_NEG,	17
.equ	AC_PS_SEQZ,	18
.equ	AC_PS_SNEZ,	19
.equ	AC_PS_JR,	20
.equ	AC_PS_WFI,	21
.equ	AC_CSR,		22
.equ	AC_CSRI,	23
.equ	AC_MRET,	24
.equ	AC_SRET,	25
.equ	AC_SFENCE,	26
.equ	AC_FENCE,	27
.equ	AC_FENCEI,	28
.equ	AC_PS_BEQZ,	30
.equ	AC_PS_BNEZ,	31
.equ	AC_PS_BGT,	32
.equ	AC_PS_BLE,	33
.equ	AC_PS_BGTU,	34
.equ	AC_PS_BLEU,	35
.equ	AC_PS_BLTZ,	36
.equ	AC_PS_BGEZ,	37
.equ	AC_PS_CALL,	38
.equ	AC_PS_TAIL,	39

# ── Trie node struct (1036 bytes) ────────────────────────────────────
.equ	T_KIND,		0
.equ	T_LEN,		4
.equ	T_RESERVED,	8
.equ	T_CHILDREN,	12
.equ	T_NODE_SZ,	1036

# ── Lexer state struct (24 bytes + root trie node) ───────────────────
.equ	L_IN,		0
.equ	L_END,		4
.equ	L_OFF,		8
.equ	L_LINE,		12
.equ	L_LINE_OFF,	16
.equ	L_COL_START,	20
.equ	L_ROOT,		24
.equ	L_SZ,		1060

# ── Node struct (44 bytes) ───────────────────────────────────────────
.equ	N_KIND,		0
.equ	N_LOC_OFF,	4
.equ	N_LOC_LEN,	8
.equ	N_LOC_LINE,	12
.equ	N_LOC_COL,	16
.equ	N_PARENT,	20
.equ	N_FIRST_CHILD,	24
.equ	N_LAST_CHILD,	28
.equ	N_NEXT_SIB,	32
.equ	N_PREV_SIB,	36
.equ	N_DATA,		40
.equ	N_SZ,		44

# Precedence levels (higher = tighter binding, gaps of 2 for Pratt +1)
.equ	P_NONE,		0
.equ	P_ASSIGN,	2
.equ	P_TERNARY,	4
.equ	P_OR,		6
.equ	P_AND,		8
.equ	P_EQUAL,	10
.equ	P_COMPARE,	12
.equ	P_BIT_OR,	14
.equ	P_BIT_XOR,	16
.equ	P_BIT_AND,	18
.equ	P_SHIFT,	20
.equ	P_ADD,		22
.equ	P_MUL,		24
.equ	P_UNARY,	26
.equ	P_POSTFIX,	28
.equ	P_CALL,		30

_start:
	j	main

# write_byte: write byte in a0 to UART. Spins until TX ready.
write_byte:
	prologue	t0 t1 x0
	lui	t0, UART
1:
	lbu	t1, 5(t0)
	andi	t1, t1, 0x20
	beqz	t1, 1b
	sb	a0, 0(t0)
	return

# read_byte: read one byte from UART into a0. Spins until RX ready.
read_byte:
	prologue	t0 t1 x0
	lui	t0, UART
rb_poll:
	lbu	t1, 5(t0)
	andi	t1, t1, 1		# RX data ready (bit 0 of LSR)
	beqz	t1, rb_poll
	lbu	a0, 0(t0)
	return

# print_hex: print 32-bit value in a0 as "0xHHHHHHHH"
print_hex:
	prologue	s0 s1 t0 t1 t2 x0
	mv	s0, a0			# save value
	li	s1, 28			# shift (28,24,...,0)
	li	a0, '0'
	jal	write_byte
	li	a0, 'x'
	jal	write_byte
ph_digit:
	blt	s1, x0, ph_done
	srl	a0, s0, s1
	andi	a0, a0, 0xF
	li	t0, 10
	blt	a0, t0, ph_dec
	addi	a0, a0, 55		# 'A'-10
	j	ph_out
ph_dec:
	addi	a0, a0, '0'
ph_out:
	jal	write_byte
	addi	s1, s1, -4
	j	ph_digit
ph_done:
	return

# exit the app with QEMU specific values (wfi as backup)
exit:
	lui	t0, 0x100
	lui	t1, 5
	addi	t1, t1, 0x555
	sw	t1, 0(t0)
1:
	wfi
	j	1b

# ══════════════════════════════════════════════════════════════════════
#  Error reporting
# ══════════════════════════════════════════════════════════════════════

# print_str: a0 = null-terminated string ptr. Prints to UART.
print_str:
	prologue	s0 x0
	mv	s0, a0
1:
	lbu	a0, 0(s0)
	beqz	a0, 2f
	jal	write_byte
	addi	s0, s0, 1
	j	1b
2:
	return

# print_dec: a0 = unsigned value. Prints decimal to UART.
print_dec:
	prologue	s0 s1 x0
	mv	s0, a0
	li	s1, 0			# digit count
	beqz	s0, pd_zero
pd_loop:
	beqz	s0, pd_emit
	li	t0, 10
	li	t1, 0
pd_div:
	blt	s0, t0, pd_rem
	sub	s0, s0, t0
	addi	t1, t1, 1
	j	pd_div
pd_rem:
	addi	t2, s0, '0'
	addi	sp, sp, -4
	sb	t2, 0(sp)
	addi	s1, s1, 1
	mv	s0, t1
	j	pd_loop
pd_emit:
	beqz	s1, pd_done
	lbu	a0, 0(sp)
	addi	sp, sp, 4
	jal	write_byte
	addi	s1, s1, -1
	j	pd_emit
pd_zero:
	li	a0, '0'
	jal	write_byte
pd_done:
	return

# err_at: report error at a node's location and halt.
# a0 = node (with N_LOC_LINE/N_LOC_COL), a1 = message (null-terminated string)
err_at:
	prologue	s0 s1 x0
	mv	s0, a0			# node
	mv	s1, a1			# message

	# "error:"
	lla	a0, str_error
	jal	print_str

	# line number
	lw	a0, N_LOC_LINE(s0)
	jal	print_dec

	# ":"
	li	a0, ':'
	jal	write_byte

	# column
	lw	a0, N_LOC_COL(s0)
	jal	print_dec

	# ": "
	li	a0, ':'
	jal	write_byte
	li	a0, ' '
	jal	write_byte

	# message
	mv	a0, s1
	jal	print_str

	# newline
	li	a0, '\n'
	jal	write_byte

	j	exit

# err_expect: "expected X, found Y" error at current token
# a0 = expected description (string), a1 = node with actual token, a2 = lexer
err_expect:
	prologue	s0 s1 s2 x0
	mv	s0, a0			# expected string
	mv	s1, a1			# actual node
	mv	s2, a2			# lexer

	lla	a0, str_error
	jal	print_str
	lw	a0, N_LOC_LINE(s1)
	jal	print_dec
	li	a0, ':'
	jal	write_byte
	lw	a0, N_LOC_COL(s1)
	jal	print_dec
	li	a0, ':'
	jal	write_byte
	li	a0, ' '
	jal	write_byte

	# "expected "
	lla	a0, str_expected
	jal	print_str
	mv	a0, s0
	jal	print_str

	# ", found '"
	lla	a0, str_found
	jal	print_str

	# print token text from input
	lw	t0, N_LOC_LEN(s1)
	beqz	t0, ee_no_text
	lw	t1, N_LOC_OFF(s1)
	lw	t2, L_IN(s2)		# input base from lexer
	add	t1, t2, t1		# text ptr
ee_text:
	beqz	t0, ee_close
	lbu	a0, 0(t1)
	jal	write_byte
	addi	t1, t1, 1
	addi	t0, t0, -1
	j	ee_text
ee_no_text:
	# EOF — print "EOF"
	lla	a0, str_eof
	jal	print_str
ee_close:
	li	a0, '\''
	jal	write_byte
	li	a0, '\n'
	jal	write_byte
	j	exit

str_error:
	.ascii	"error:"
	.zero	2
str_expected:
	.ascii	"expected "
	.zero	3
str_found:
	.ascii	", found '"
	.zero	3
str_eof:
	.ascii	"EOF"
	.zero	1
str_rparen:
	.ascii	")"
	.zero	3
str_rbracket:
	.ascii	"]"
	.zero	3
str_rbrace:
	.ascii	"}"
	.zero	3
str_pipe:
	.ascii	"|"
	.zero	3
str_colon:
	.ascii	":"
	.zero	3
str_fat_arrow:
	.ascii	"=>"
	.zero	2
str_lparen:
	.ascii	"("
	.zero	3
str_lbrace:
	.ascii	"{"
	.zero	3
str_assign:
	.ascii	"="
	.zero	3
str_in_kw:
	.ascii	"in"
	.zero	2
str_comma_rparen:
	.ascii	", or )"
	.zero	2
str_comma_pipe:
	.ascii	", or |"
	.zero	2
str_mix_fields:
	.ascii	"cannot mix named and positional fields"
	.zero	2
str_ident:
	.ascii	"identifier"
	.zero	2
str_semi:
	.ascii	";"
	.zero	3
str_expr:
	.ascii	"expression"
	.zero	2

# expect_tok: consume next token, error if not the expected kind.
# a0 = lexer, a1 = expected NK_* kind, a2 = description string
# Returns the consumed node in a0.
expect_tok:
	prologue	s0 s1 s2 s3 x0
	mv	s0, a0			# lexer
	mv	s1, a1			# expected kind
	mv	s2, a2			# description
	jal	node_alloc
	mv	s3, a0			# node
	mv	a0, s0
	mv	a1, s3
	li	a2, 0
	jal	lex_next
	bne	a0, s1, et_err
	mv	a0, s3
	return
et_err:
	mv	a0, s2			# expected description
	mv	a1, s3			# actual node
	mv	a2, s0			# lexer
	j	err_expect		# does not return

read_data:
	prologue	s0 s1 s2 x0
	li	s0, 4
	mv	s1, a0
	mv	s2, s1

1:
	jal	read_byte
	beq	a0, s0, 2f
	sb	a0, 0(s1)
	addi	s1, s1, 1
	j	1b
2:
	sub	a0, s1, s2
	return

# write_data: write bytes from a0 (start) to a1 (end) to UART.
write_data:
	prologue	s0 s1 x0
	mv	s0, a0			# cursor
	mv	s1, a1			# end

1:
	bgeu	s0, s1, 2f
	lbu	a0, 0(s0)
	jal	write_byte
	addi	s0, s0, 1
	j	1b
2:
	return

# ══════════════════════════════════════════════════════════════════════
#  alloc: bump-allocate a0 bytes from heap (gp). Returns a0 = ptr.
# ══════════════════════════════════════════════════════════════════════
alloc:
	mv	t0, gp
	add	gp, gp, a0
	addi	gp, gp, 3
	andi	gp, gp, -4		# align to 4
	mv	a0, t0
	ret

# ══════════════════════════════════════════════════════════════════════
#  trie_alloc: allocate and zero a trie node. Returns a0 = ptr.
# ══════════════════════════════════════════════════════════════════════
trie_alloc:
	prologue	s0 x0
	li	a0, T_NODE_SZ
	jal	alloc
	mv	s0, a0
	# Zero it (T_NODE_SZ = 1036 bytes, multiple of 4)
	mv	t0, a0
	li	t1, T_NODE_SZ
	add	t1, t0, t1
1:
	beq	t0, t1, 2f
	sw	zero, 0(t0)
	addi	t0, t0, 4
	j	1b
2:
	mv	a0, s0
	return

# ══════════════════════════════════════════════════════════════════════
#  trie_insert: a0=root, a1=str, a2=len, a3=kind
#  Walk/create trie path, set kind on final node.
# ══════════════════════════════════════════════════════════════════════
trie_insert:
	prologue	s0 s1 s2 s3 x0
	mv	s0, a0			# current node
	mv	s1, a1			# str ptr
	mv	s2, a2			# remaining len
	mv	s3, a3			# kind
ti_loop:
	beqz	s2, ti_set
	lbu	t0, 0(s1)		# current char
	slli	t0, t0, 2		# *4 for word offset
	addi	t1, s0, T_CHILDREN
	add	t1, t1, t0		# &children[ch]
	lw	t2, 0(t1)		# child ptr
	bnez	t2, ti_advance
	# Allocate new child node
	jal	trie_alloc
	mv	t2, a0
	# Recompute &children[ch] (trie_alloc clobbered t-regs)
	lbu	t0, 0(s1)
	slli	t0, t0, 2
	addi	t1, s0, T_CHILDREN
	add	t1, t1, t0
	sw	t2, 0(t1)		# store child ptr
ti_advance:
	mv	s0, t2			# advance to child
	addi	s1, s1, 1
	addi	s2, s2, -1
	j	ti_loop
ti_set:
	sw	s3, T_KIND(s0)		# set token kind
	return

# ══════════════════════════════════════════════════════════════════════
#  lexer_init: a0=input_start, a1=input_len
#  Allocates lexer state, registers all tokens. Returns a0 = lexer ptr.
# ══════════════════════════════════════════════════════════════════════
lexer_init:
	prologue	s0 s1 s2 x0
	mv	s1, a0			# input start
	mv	s2, a1			# input len

	# Allocate lexer state (includes embedded root trie node)
	li	a0, L_SZ
	jal	alloc
	mv	s0, a0			# s0 = lexer ptr

	# Zero the whole struct
	mv	t0, s0
	li	t1, L_SZ
	add	t1, t0, t1
1:
	beq	t0, t1, 2f
	sw	zero, 0(t0)
	addi	t0, t0, 4
	j	1b
2:
	# Initialize fields
	sw	s1, L_IN(s0)
	add	t0, s1, s2
	sw	t0, L_END(s0)
	sw	s1, L_OFF(s0)
	li	t0, 1
	sw	t0, L_LINE(s0)
	sw	s1, L_LINE_OFF(s0)	# line starts at input start

	# Register tokens from table
	lla	s1, tok_table
li_reg_loop:
	lbu	t0, 0(s1)		# kind
	beqz	t0, li_reg_done
	lbu	t1, 1(s1)		# len
	addi	a0, s0, L_ROOT		# root node
	addi	a1, s1, 2		# string ptr
	mv	a2, t1			# len
	mv	a3, t0			# kind
	jal	trie_insert
	addi	s1, s1, 12		# next entry (12 bytes each)
	j	li_reg_loop
li_reg_done:
	mv	a0, s0
	return

# ══════════════════════════════════════════════════════════════════════
#  lex_next: a0=lexer, a1=node_ptr, a2=peek (if nonzero, don't advance)
#  Fills node, returns kind in a0.
# ══════════════════════════════════════════════════════════════════════
lex_next:
	prologue	s0 s1 s2 s3 s4 s5 s6 x0
	mv	s0, a0			# lexer
	mv	s1, a1			# node ptr
	mv	s6, a2			# peek flag
	lw	s2, L_IN(s0)		# input base
	lw	s3, L_END(s0)		# input end
	lw	s4, L_OFF(s0)		# current offset
	lw	s5, L_LINE(s0)		# save line for peek restore
	sw	s4, N_DATA(s1)		# save original offset in node.data for peek
	lw	t0, L_LINE_OFF(s0)
	sw	t0, N_PARENT(s1)	# save line_off for peek restore

	# ── Skip whitespace and comments ──
ln_skip:
	beq	s4, s3, ln_eof
	lbu	t0, 0(s4)
	li	t1, ' '
	beq	t0, t1, ln_ws
	li	t1, '\t'
	beq	t0, t1, ln_ws
	li	t1, '\r'
	beq	t0, t1, ln_ws
	li	t1, '\n'
	beq	t0, t1, ln_newline
	# Check for // line comment
	li	t1, '/'
	bne	t0, t1, ln_start
	addi	t2, s4, 1
	beq	t2, s3, ln_start
	lbu	t1, 0(t2)
	li	t3, '/'
	beq	t1, t3, ln_line_comment
	li	t3, '*'
	beq	t1, t3, ln_block_comment
	j	ln_start

	# ── // line comment ──
ln_line_comment:
	addi	s4, s4, 2
ln_lc_lp:
	beq	s4, s3, ln_skip
	lbu	t0, 0(s4)
	addi	s4, s4, 1
	li	t1, '\n'
	bne	t0, t1, ln_lc_lp
	lw	t0, L_LINE(s0)
	addi	t0, t0, 1
	sw	t0, L_LINE(s0)
	sw	s4, L_LINE_OFF(s0)
	j	ln_skip

	# ── /* */ nested block comment ──
ln_block_comment:
	addi	s4, s4, 2		# skip /*
	li	t4, 1			# nesting depth
ln_bc_lp:
	beq	s4, s3, ln_skip		# unterminated → treat as done
	lbu	t0, 0(s4)
	addi	s4, s4, 1
	li	t1, '\n'
	bne	t0, t1, ln_bc_not_nl
	lw	t0, L_LINE(s0)
	addi	t0, t0, 1
	sw	t0, L_LINE(s0)
	sw	s4, L_LINE_OFF(s0)
	j	ln_bc_lp
ln_bc_not_nl:
	li	t1, '/'
	bne	t0, t1, ln_bc_not_open
	beq	s4, s3, ln_bc_lp
	lbu	t0, 0(s4)
	li	t1, '*'
	bne	t0, t1, ln_bc_lp
	addi	s4, s4, 1		# skip * after /
	addi	t4, t4, 1		# depth++
	j	ln_bc_lp
ln_bc_not_open:
	li	t1, '*'
	bne	t0, t1, ln_bc_lp
	beq	s4, s3, ln_bc_lp
	lbu	t0, 0(s4)
	li	t1, '/'
	bne	t0, t1, ln_bc_lp
	addi	s4, s4, 1		# skip / after *
	addi	t4, t4, -1		# depth--
	bnez	t4, ln_bc_lp		# still nested
	j	ln_skip

ln_ws:
	addi	s4, s4, 1
	j	ln_skip
ln_newline:
	addi	s4, s4, 1
	lw	t0, L_LINE(s0)
	addi	t0, t0, 1
	sw	t0, L_LINE(s0)
	sw	s4, L_LINE_OFF(s0)
	j	ln_skip

	# ── EOF ──
ln_eof:
	# Don't update offset for EOF — peek or not, EOF is idempotent
	li	t0, NK_TERM
	sw	t0, N_KIND(s1)
	sw	zero, N_LOC_LEN(s1)
	mv	a0, t0
	j	ln_ret

	# ── Start of token ──
ln_start:
	# Record token start position
	sub	t0, s4, s2
	sw	t0, N_LOC_OFF(s1)	# offset from input start
	lw	t0, L_LINE(s0)
	sw	t0, N_LOC_LINE(s1)
	lw	t0, L_LINE_OFF(s0)	# compute column
	sub	t0, s4, t0
	sw	t0, N_LOC_COL(s1)

	lbu	t0, 0(s4)

	# ── String literal ──
	li	t1, '"'
	beq	t0, t1, ln_string

	# ── Char literal ──
	li	t1, '\''
	beq	t0, t1, ln_char

	# ── Number literal ──
	li	t1, '0'
	blt	t0, t1, ln_trie
	li	t1, '9'+1
	blt	t0, t1, ln_number

	# ── Try trie match ──
ln_trie:
	addi	t2, s0, L_ROOT		# trie cursor = root
	mv	t3, s4			# scan pos
	li	a2, 0			# best_kind
	li	a3, 0			# best_len
ln_trie_walk:
	beq	t3, s3, ln_trie_done	# end of input
	lbu	t0, 0(t3)
	slli	t1, t0, 2
	addi	t4, t2, T_CHILDREN
	add	t4, t4, t1
	lw	t4, 0(t4)		# child ptr
	beqz	t4, ln_trie_done	# no child
	mv	t2, t4			# advance
	addi	t3, t3, 1
	lw	t5, T_KIND(t2)		# check kind
	beqz	t5, ln_trie_walk	# no match yet
	mv	a2, t5			# best_kind
	sub	a3, t3, s4		# best_len
	j	ln_trie_walk

ln_trie_done:
	beqz	a2, ln_ident_chk	# no trie match

	# Check if keyword swallowed by identifier:
	# If first char is alpha/_ AND next char after match is alpha/digit/_,
	# then this is an identifier, not a keyword.
	lbu	t0, 0(s4)		# first char of token
	jal	is_ident_start
	beqz	a0, ln_trie_accept	# punctuator — always accept
	add	t0, s4, a3		# pos after match
	beq	t0, s3, ln_trie_accept	# at EOF — accept
	lbu	t0, 0(t0)		# next char
	jal	is_ident_cont
	bnez	a0, ln_ident		# continues identifier — fall through

ln_trie_accept:
	sw	a2, N_KIND(s1)
	sw	a3, N_LOC_LEN(s1)
	add	s4, s4, a3
	sw	s4, L_OFF(s0)
	mv	a0, a2
	j	ln_ret

	# ── Identifier check ──
ln_ident_chk:
	lbu	t0, 0(s4)
	jal	is_ident_start
	beqz	a0, ln_unknown

	# ── Scan identifier ──
ln_ident:
	mv	t3, s4
ln_ident_lp:
	beq	t3, s3, ln_ident_done
	lbu	t0, 0(t3)
	jal	is_ident_cont
	beqz	a0, ln_ident_done
	addi	t3, t3, 1
	j	ln_ident_lp
ln_ident_done:
	li	t0, NK_IDENT
	sw	t0, N_KIND(s1)
	sub	t0, t3, s4
	sw	t0, N_LOC_LEN(s1)
	mv	s4, t3
	sw	s4, L_OFF(s0)
	li	a0, NK_IDENT
	j	ln_ret

	# ── Number literal ──
ln_number:
	mv	t3, s4
	# Check for 0x/0b/octal prefix
	lbu	t0, 0(t3)
	li	t1, '0'
	bne	t0, t1, ln_num_dec
	addi	t4, t3, 1
	beq	t4, s3, ln_num_dec	# just "0"
	lbu	t0, 0(t4)
	li	t1, 'x'
	beq	t0, t1, ln_num_hex
	li	t1, 'X'
	beq	t0, t1, ln_num_hex
	li	t1, 'b'
	beq	t0, t1, ln_num_bin
	li	t1, 'B'
	beq	t0, t1, ln_num_bin
	# Check if next char is octal digit (0-7) → octal
	li	t1, '0'
	blt	t0, t1, ln_num_dec
	li	t1, '8'
	blt	t0, t1, ln_num_oct
	j	ln_num_dec		# 08, 09 etc → decimal

	# ── Hex: 0x[0-9a-fA-F]+ ──
ln_num_hex:
	addi	t3, t4, 1		# skip "0x"
ln_num_hex_lp:
	beq	t3, s3, ln_num_done
	lbu	t0, 0(t3)
	li	t1, '0'
	blt	t0, t1, ln_num_done
	li	t1, '9'+1
	blt	t0, t1, ln_num_hex_go
	li	t1, 'a'
	blt	t0, t1, ln_num_hex_uc
	li	t1, 'f'+1
	blt	t0, t1, ln_num_hex_go
	j	ln_num_done
ln_num_hex_uc:
	li	t1, 'A'
	blt	t0, t1, ln_num_done
	li	t1, 'F'+1
	blt	t0, t1, ln_num_hex_go
	j	ln_num_done
ln_num_hex_go:
	addi	t3, t3, 1
	j	ln_num_hex_lp

	# ── Binary: 0b[01]+ ──
ln_num_bin:
	addi	t3, t4, 1		# skip "0b"
ln_num_bin_lp:
	beq	t3, s3, ln_num_done
	lbu	t0, 0(t3)
	li	t1, '0'
	blt	t0, t1, ln_num_done
	li	t1, '2'
	bge	t0, t1, ln_num_done
	addi	t3, t3, 1
	j	ln_num_bin_lp

	# ── Octal: 0[0-7]+ ──
ln_num_oct:
	mv	t3, t4			# start from digit after '0'
ln_num_oct_lp:
	beq	t3, s3, ln_num_done
	lbu	t0, 0(t3)
	li	t1, '0'
	blt	t0, t1, ln_num_done
	li	t1, '8'
	bge	t0, t1, ln_num_done
	addi	t3, t3, 1
	j	ln_num_oct_lp

	# ── Decimal: [0-9]+ ──
ln_num_dec:
	beq	t3, s3, ln_num_done
	lbu	t0, 0(t3)
	li	t1, '0'
	blt	t0, t1, ln_num_done
	li	t1, '9'+1
	bge	t0, t1, ln_num_done
	addi	t3, t3, 1
	j	ln_num_dec
ln_num_done:
	li	t0, NK_NUMBER
	sw	t0, N_KIND(s1)
	sub	t0, t3, s4
	sw	t0, N_LOC_LEN(s1)
	mv	s4, t3
	sw	s4, L_OFF(s0)
	li	a0, NK_NUMBER
	j	ln_ret

	# ── String literal ──
ln_string:
	addi	t3, s4, 1		# skip opening '"'
ln_str_lp:
	beq	t3, s3, ln_str_end	# unterminated
	lbu	t0, 0(t3)
	li	t1, '\\'
	beq	t0, t1, ln_str_esc
	li	t1, '"'
	beq	t0, t1, ln_str_close
	addi	t3, t3, 1
	j	ln_str_lp
ln_str_esc:
	addi	t3, t3, 2		# skip backslash + next char
	j	ln_str_lp
ln_str_close:
	addi	t3, t3, 1		# include closing '"'
ln_str_end:
	li	t0, NK_STRING
	sw	t0, N_KIND(s1)
	sub	t0, t3, s4
	sw	t0, N_LOC_LEN(s1)
	mv	s4, t3
	sw	s4, L_OFF(s0)
	li	a0, NK_STRING
	j	ln_ret

	# ── Char literal: 'x' or '\x' ──
ln_char:
	addi	t3, s4, 1		# skip opening '\''
ln_char_lp:
	beq	t3, s3, ln_char_end	# unterminated
	lbu	t0, 0(t3)
	li	t1, '\\'
	beq	t0, t1, ln_char_esc
	li	t1, '\''
	beq	t0, t1, ln_char_close
	addi	t3, t3, 1
	j	ln_char_lp
ln_char_esc:
	addi	t3, t3, 2		# skip backslash + next char
	j	ln_char_lp
ln_char_close:
	addi	t3, t3, 1		# include closing '\''
ln_char_end:
	# Validate: len must be 3 ('x') or 4 ('\x')
	sub	t0, t3, s4
	li	t1, 3
	beq	t0, t1, ln_char_ok
	li	t1, 4
	beq	t0, t1, ln_char_ok
	li	t0, NK_ERROR
	j	ln_char_set
ln_char_ok:
	li	t0, NK_CHAR
ln_char_set:
	sw	t0, N_KIND(s1)
	sub	t0, t3, s4
	sw	t0, N_LOC_LEN(s1)
	mv	s4, t3
	sw	s4, L_OFF(s0)
	lw	a0, N_KIND(s1)		# return whatever was set (CHAR or ERROR)
	j	ln_ret

	# ── Unknown char ──
ln_unknown:
	li	t0, NK_ERROR
	sw	t0, N_KIND(s1)
	li	t0, 1
	sw	t0, N_LOC_LEN(s1)
	addi	s4, s4, 1
	sw	s4, L_OFF(s0)
	li	a0, NK_ERROR
ln_ret:
	# If peeking, restore lexer state (don't advance)
	beqz	s6, ln_done
	lw	t0, N_DATA(s1)		# saved original offset
	sw	t0, L_OFF(s0)
	sw	s5, L_LINE(s0)		# saved original line
	lw	t0, N_PARENT(s1)	# saved original line_off
	sw	t0, L_LINE_OFF(s0)
ln_done:
	return

# ── Character classification helpers ─────────────────────────────────
# is_ident_start: t0=char → a0=1 if [a-zA-Z_], else 0
is_ident_start:
	li	a0, 1
	li	t1, '_'
	beq	t0, t1, iis_yes
	li	t1, 'a'
	blt	t0, t1, iis_upper
	li	t1, 'z'+1
	blt	t0, t1, iis_yes
iis_upper:
	li	t1, 'A'
	blt	t0, t1, iis_no
	li	t1, 'Z'+1
	blt	t0, t1, iis_yes
iis_no:
	li	a0, 0
iis_yes:
	ret

# is_ident_cont: t0=char → a0=1 if [a-zA-Z0-9_], else 0
is_ident_cont:
	li	a0, 1
	li	t1, '_'
	beq	t0, t1, iic_yes
	li	t1, '0'
	blt	t0, t1, iic_no
	li	t1, '9'+1
	blt	t0, t1, iic_yes
	li	t1, 'a'
	blt	t0, t1, iic_upper
	li	t1, 'z'+1
	blt	t0, t1, iic_yes
iic_upper:
	li	t1, 'A'
	blt	t0, t1, iic_no
	li	t1, 'Z'+1
	blt	t0, t1, iic_yes
iic_no:
	li	a0, 0
iic_yes:
	ret

# ══════════════════════════════════════════════════════════════════════
#  Token registration table
#  Each entry: kind(1), len(1), string(10 bytes, null-padded) = 12 bytes
#  Terminated by kind=0
# ══════════════════════════════════════════════════════════════════════
tok_table:
# Single-char punctuators
	.byte	NK_SEMI, 1
	.ascii	";"
	.zero	9
	.byte	NK_COMMA, 1
	.ascii	","
	.zero	9
	.byte	NK_COLON, 1
	.ascii	":"
	.zero	9
	.byte	NK_QMARK, 1
	.ascii	"?"
	.zero	9
	.byte	NK_LPAREN, 1
	.ascii	"("
	.zero	9
	.byte	NK_RPAREN, 1
	.ascii	")"
	.zero	9
	.byte	NK_LBRACE, 1
	.ascii	"{"
	.zero	9
	.byte	NK_RBRACE, 1
	.ascii	"}"
	.zero	9
	.byte	NK_LBRACKET, 1
	.ascii	"["
	.zero	9
	.byte	NK_RBRACKET, 1
	.ascii	"]"
	.zero	9
	.byte	NK_DOT, 1
	.ascii	"."
	.zero	9
	.byte	NK_AT, 1
	.ascii	"@"
	.zero	9
	.byte	NK_HASH, 1
	.ascii	"#"
	.zero	9
	.byte	NK_TILDE, 1
	.ascii	"~"
	.zero	9

# Operators (1 char)
	.byte	NK_PLUS, 1
	.ascii	"+"
	.zero	9
	.byte	NK_MINUS, 1
	.ascii	"-"
	.zero	9
	.byte	NK_STAR, 1
	.ascii	"*"
	.zero	9
	.byte	NK_SLASH, 1
	.ascii	"/"
	.zero	9
	.byte	NK_PERCENT, 1
	.ascii	"%"
	.zero	9
	.byte	NK_AMP, 1
	.ascii	"&"
	.zero	9
	.byte	NK_PIPE, 1
	.ascii	"|"
	.zero	9
	.byte	NK_CARET, 1
	.ascii	"^"
	.zero	9
	.byte	NK_BANG, 1
	.ascii	"!"
	.zero	9
	.byte	NK_ASSIGN, 1
	.ascii	"="
	.zero	9
	.byte	NK_LT, 1
	.ascii	"<"
	.zero	9
	.byte	NK_GT, 1
	.ascii	">"
	.zero	9

# Multi-char operators
	.byte	NK_INC, 2
	.ascii	"++"
	.zero	8
	.byte	NK_DEC, 2
	.ascii	"--"
	.zero	8
	.byte	NK_FAT_ARROW, 2
	.ascii	"=>"
	.zero	8
	.byte	NK_EQ, 2
	.ascii	"=="
	.zero	8
	.byte	NK_NEQ, 2
	.ascii	"!="
	.zero	8
	.byte	NK_LTE, 2
	.ascii	"<="
	.zero	8
	.byte	NK_GTE, 2
	.ascii	">="
	.zero	8
	.byte	NK_AND, 2
	.ascii	"&&"
	.zero	8
	.byte	NK_OR, 2
	.ascii	"||"
	.zero	8
	.byte	NK_SHL, 2
	.ascii	"<<"
	.zero	8
	.byte	NK_SHR, 2
	.ascii	">>"
	.zero	8
	.byte	NK_DOTDOT, 2
	.ascii	".."
	.zero	8
	.byte	NK_LTU, 2
	.ascii	"<u"
	.zero	8
	.byte	NK_GTU, 2
	.ascii	">u"
	.zero	8
	.byte	NK_ASSIGN_MUT, 2
	.ascii	":="
	.zero	8
	.byte	NK_PLUS_EQ, 2
	.ascii	"+="
	.zero	8
	.byte	NK_MINUS_EQ, 2
	.ascii	"-="
	.zero	8
	.byte	NK_STAR_EQ, 2
	.ascii	"*="
	.zero	8
	.byte	NK_SLASH_EQ, 2
	.ascii	"/="
	.zero	8
	.byte	NK_PERCENT_EQ, 2
	.ascii	"%="
	.zero	8
	.byte	NK_AMP_EQ, 2
	.ascii	"&="
	.zero	8
	.byte	NK_PIPE_EQ, 2
	.ascii	"|="
	.zero	8
	.byte	NK_CARET_EQ, 2
	.ascii	"^="
	.zero	8
	.byte	NK_DOTDOT_EQ, 3
	.ascii	"..="
	.zero	7
	.byte	NK_LTEU, 3
	.ascii	"<=u"
	.zero	7
	.byte	NK_GTEU, 3
	.ascii	">=u"
	.zero	7
	.byte	NK_SHL_EQ, 3
	.ascii	"<<="
	.zero	7
	.byte	NK_SHR_EQ, 3
	.ascii	">>="
	.zero	7

# Keywords
	.byte	NK_IN, 2
	.ascii	"in"
	.zero	8
	.byte	NK_FOR, 3
	.ascii	"for"
	.zero	7
	.byte	NK_ASM, 3
	.ascii	"asm"
	.zero	7
	.byte	NK_LOOP, 4
	.ascii	"loop"
	.zero	6
	.byte	NK_SELF, 4
	.ascii	"self"
	.zero	6
	.byte	NK_BREAK, 5
	.ascii	"break"
	.zero	5
	.byte	NK_MACRO, 5
	.ascii	"macro"
	.zero	5
	.byte	NK_RETURN, 6
	.ascii	"return"
	.zero	4
	.byte	NK_STRUCT, 6
	.ascii	"struct"
	.zero	4
	.byte	NK_SWITCH, 6
	.ascii	"switch"
	.zero	4
	.byte	NK_SIZEOF, 6
	.ascii	"sizeof"
	.zero	4
	.byte	NK_CONTINUE, 8
	.ascii	"continue"
	.zero	2

# Sentinel
	.byte	0, 0
	.zero	10

# ══════════════════════════════════════════════════════════════════════
#  Parser: Pratt expression parser
# ══════════════════════════════════════════════════════════════════════

# node_alloc: allocate and zero an AST node. Returns a0 = ptr.
node_alloc:
	prologue	s0 x0
	li	a0, N_SZ
	jal	alloc
	mv	s0, a0
	mv	t0, a0
	addi	t1, a0, N_SZ
1:
	beq	t0, t1, 2f
	sw	zero, 0(t0)
	addi	t0, t0, 4
	j	1b
2:
	mv	a0, s0
	return

# node_add_child: a0=parent, a1=child. Appends child to parent's child list.
node_add_child:
	sw	a0, N_PARENT(a1)	# child.parent = parent
	lw	t0, N_LAST_CHILD(a0)	# prev_last = parent.last_child
	beqz	t0, nac_first
	# Append after prev_last
	sw	a1, N_NEXT_SIB(t0)	# prev_last.next = child
	sw	t0, N_PREV_SIB(a1)	# child.prev = prev_last
	sw	a1, N_LAST_CHILD(a0)	# parent.last = child
	ret
nac_first:
	sw	a1, N_FIRST_CHILD(a0)
	sw	a1, N_LAST_CHILD(a0)
	ret

# get_bp: a0=token_kind → a0=infix binding power (left), a1=right bp
# Returns 0 for tokens that aren't infix operators.
get_bp:
	# Assignment (right-assoc): = := += -= *= /= %= &= |= ^= <<= >>=
	li	t0, NK_ASSIGN
	beq	a0, t0, bp_assign
	li	t0, NK_ASSIGN_MUT
	beq	a0, t0, bp_assign
	li	t0, NK_PLUS_EQ
	blt	a0, t0, bp_not_assign_eq
	li	t0, NK_SHR_EQ+1
	blt	a0, t0, bp_assign
bp_not_assign_eq:
	# Ternary (right-assoc): ?
	li	t0, NK_QMARK
	beq	a0, t0, bp_ternary
	# Logical or: ||
	li	t0, NK_OR
	beq	a0, t0, bp_or
	# Logical and: &&
	li	t0, NK_AND
	beq	a0, t0, bp_and
	# Equality: == !=
	li	t0, NK_EQ
	beq	a0, t0, bp_equal
	li	t0, NK_NEQ
	beq	a0, t0, bp_equal
	# Comparison: < > <= >= <u >u <=u >=u
	li	t0, NK_LT
	beq	a0, t0, bp_cmp
	li	t0, NK_GT
	beq	a0, t0, bp_cmp
	li	t0, NK_LTE
	beq	a0, t0, bp_cmp
	li	t0, NK_GTE
	beq	a0, t0, bp_cmp
	li	t0, NK_LTU
	beq	a0, t0, bp_cmp
	li	t0, NK_GTU
	beq	a0, t0, bp_cmp
	li	t0, NK_LTEU
	beq	a0, t0, bp_cmp
	li	t0, NK_GTEU
	beq	a0, t0, bp_cmp
	# Bitwise or: |
	li	t0, NK_PIPE
	beq	a0, t0, bp_bitor
	# Bitwise xor: ^
	li	t0, NK_CARET
	beq	a0, t0, bp_bitxor
	# Bitwise and: &
	li	t0, NK_AMP
	beq	a0, t0, bp_bitand
	# Shift: << >>
	li	t0, NK_SHL
	beq	a0, t0, bp_shift
	li	t0, NK_SHR
	beq	a0, t0, bp_shift
	# Add: + -
	li	t0, NK_PLUS
	beq	a0, t0, bp_add
	li	t0, NK_MINUS
	beq	a0, t0, bp_add
	# Mul: * / %
	li	t0, NK_STAR
	beq	a0, t0, bp_mul
	li	t0, NK_SLASH
	beq	a0, t0, bp_mul
	li	t0, NK_PERCENT
	beq	a0, t0, bp_mul
	# Range: .. ..=
	li	t0, NK_DOTDOT
	beq	a0, t0, bp_cmp
	li	t0, NK_DOTDOT_EQ
	beq	a0, t0, bp_cmp
	# Postfix: . [ ( { ++ --
	li	t0, NK_DOT
	beq	a0, t0, bp_postfix
	li	t0, NK_LBRACKET
	beq	a0, t0, bp_postfix
	li	t0, NK_LPAREN
	beq	a0, t0, bp_call
	li	t0, NK_LBRACE
	beq	a0, t0, bp_call
	li	t0, NK_INC
	beq	a0, t0, bp_postfix
	li	t0, NK_DEC
	beq	a0, t0, bp_postfix
	# Not an infix operator
	li	a0, P_NONE
	li	a1, P_NONE
	ret
bp_assign:
	li	a0, P_ASSIGN
	li	a1, P_ASSIGN		# right-assoc: same prec
	ret
bp_ternary:
	li	a0, P_TERNARY
	li	a1, P_TERNARY		# right-assoc
	ret
bp_or:
	li	a0, P_OR
	li	a1, P_OR+1
	ret
bp_and:
	li	a0, P_AND
	li	a1, P_AND+1
	ret
bp_equal:
	li	a0, P_EQUAL
	li	a1, P_EQUAL+1
	ret
bp_cmp:
	li	a0, P_COMPARE
	li	a1, P_COMPARE+1
	ret
bp_bitor:
	li	a0, P_BIT_OR
	li	a1, P_BIT_OR+1
	ret
bp_bitxor:
	li	a0, P_BIT_XOR
	li	a1, P_BIT_XOR+1
	ret
bp_bitand:
	li	a0, P_BIT_AND
	li	a1, P_BIT_AND+1
	ret
bp_shift:
	li	a0, P_SHIFT
	li	a1, P_SHIFT+1
	ret
bp_add:
	li	a0, P_ADD
	li	a1, P_ADD+1
	ret
bp_mul:
	li	a0, P_MUL
	li	a1, P_MUL+1
	ret
bp_postfix:
	li	a0, P_POSTFIX
	li	a1, P_POSTFIX+1
	ret
bp_call:
	li	a0, P_CALL
	li	a1, P_CALL+1
	ret

# ── parse_expr: Pratt parser core ────────────────────────────────────
# a0=lexer, a1=min_prec → a0=AST node
parse_expr:
	prologue	s0 s1 s2 s3 s4 s5 x0
	mv	s0, a0			# lexer
	mv	s1, a1			# min_prec

	# Allocate token node for prefix
	jal	node_alloc
	mv	s2, a0			# s2 = token/node

	# Read next token
	mv	a0, s0
	mv	a1, s2
	li	a2, 0
	jal	lex_next
	mv	s3, a0			# s3 = token kind

	# Check for lexer error
	li	t0, NK_ERROR
	bne	s3, t0, px_no_err
	lla	a0, str_expr
	mv	a1, s2
	mv	a2, s0
	j	err_expect
px_no_err:

	# ── Prefix dispatch ──

	# Literals: ident, number, string, char
	li	t0, NK_IDENT
	beq	s3, t0, px_atom
	li	t0, NK_NUMBER
	beq	s3, t0, px_atom
	li	t0, NK_STRING
	beq	s3, t0, px_atom
	li	t0, NK_CHAR
	beq	s3, t0, px_atom

	# Unary prefix: - ! ~ & * @ # ++ --
	li	t0, NK_MINUS
	beq	s3, t0, px_unary
	li	t0, NK_BANG
	beq	s3, t0, px_unary
	li	t0, NK_TILDE
	beq	s3, t0, px_unary
	li	t0, NK_AMP
	beq	s3, t0, px_unary
	li	t0, NK_STAR
	beq	s3, t0, px_unary
	li	t0, NK_AT
	beq	s3, t0, px_unary
	li	t0, NK_HASH
	beq	s3, t0, px_unary
	li	t0, NK_INC
	beq	s3, t0, px_unary
	li	t0, NK_DEC
	beq	s3, t0, px_unary

	# Grouped: ( expr )
	li	t0, NK_LPAREN
	beq	s3, t0, px_group

	# Block: { stmts }
	li	t0, NK_LBRACE
	beq	s3, t0, px_block

	# Closure: | params | body  OR  || body (empty params)
	li	t0, NK_PIPE
	beq	s3, t0, px_closure
	li	t0, NK_OR
	beq	s3, t0, px_closure_empty

	# Loop
	li	t0, NK_LOOP
	beq	s3, t0, px_loop

	# For
	li	t0, NK_FOR
	beq	s3, t0, px_for

	# Switch
	li	t0, NK_SWITCH
	beq	s3, t0, px_switch

	# Return / break / continue (with optional value)
	li	t0, NK_RETURN
	beq	s3, t0, px_return
	li	t0, NK_BREAK
	beq	s3, t0, px_return
	li	t0, NK_CONTINUE
	beq	s3, t0, px_atom

	# Self keyword (atom)
	li	t0, NK_SELF
	beq	s3, t0, px_atom

	# Struct definition
	li	t0, NK_STRUCT
	beq	s3, t0, px_struct

	# Sizeof
	li	t0, NK_SIZEOF
	beq	s3, t0, px_unary

	# Macro: macro { body }
	li	t0, NK_MACRO
	beq	s3, t0, px_macro

	# Asm block
	li	t0, NK_ASM
	beq	s3, t0, px_asm

	# Error: unexpected token
	lla	a0, str_expr
	mv	a1, s2			# the unexpected token node
	mv	a2, s0			# lexer
	j	err_expect		# does not return

	# ── Prefix handlers ──
px_atom:
	# Node already filled by lex_next. Just use it.
	j	px_done

px_unary:
	# Parse operand at P_UNARY
	mv	a0, s0
	li	a1, P_UNARY
	jal	parse_expr
	mv	a1, a0			# child
	mv	a0, s2			# parent (the unary op node)
	jal	node_add_child
	j	px_done

px_group:
	# ( expr ) — parse inner, consume )
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	s2, a0
	# Expect closing )
	mv	a0, s0
	li	a1, NK_RPAREN
	lla	a2, str_rparen
	jal	expect_tok
	j	px_done

px_block:
	# { stmt; stmt; ... expr }
	# Parse statements until }
px_block_lp:
	# Peek at next token
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_RBRACE
	beq	a0, t0, px_block_close
	li	t0, NK_TERM
	beq	a0, t0, px_block_close
	# Parse expression/statement
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	s3, a0			# s3 = parsed expr
	# Check for semicolon
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_SEMI
	bne	a0, t0, px_block_return	# no semi = return expr
	# Has semicolon — consume it
	jal	node_alloc
	mv	s4, a0			# scratch node
	mv	a1, s4
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume ;
	# Create semi wrapper node
	jal	node_alloc
	mv	s4, a0
	li	t0, NK_SEMI
	sw	t0, N_KIND(s4)
	mv	a0, s4
	mv	a1, s3			# the expression
	jal	node_add_child
	# Add wrapped statement to block
	mv	a0, s2
	mv	a1, s4
	jal	node_add_child
	j	px_block_lp
px_block_return:
	# No semicolon — this is the return expression (add unwrapped)
	mv	a0, s2
	mv	a1, s3
	jal	node_add_child
	# Next must be } (no more expressions without ;)
	j	px_block_lp
px_block_close:
	mv	a0, s0
	li	a1, NK_RBRACE
	lla	a2, str_rbrace
	jal	expect_tok
	j	px_done

px_closure:
	# |params| body
	# s2 already has NK_PIPE node, reuse as closure node
	# Parse param list until |
px_clos_params:
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_PIPE
	beq	a0, t0, px_clos_body
	li	t0, NK_OR
	beq	a0, t0, px_clos_empty	# || = empty params + immediate close
	li	t0, NK_TERM
	bne	a0, t0, px_clos_read_param
	# Missing closing | — error
	lla	a0, str_pipe
	mv	a1, s4
	mv	a2, s0
	j	err_expect
px_clos_read_param:
	# Read param (identifier)
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next
	mv	a1, s4
	mv	a0, s2
	jal	node_add_child
	# Expect comma or |
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 1
	jal	lex_next
	li	t0, NK_COMMA
	beq	a0, t0, px_clos_comma
	li	t0, NK_PIPE
	beq	a0, t0, px_clos_params	# closing | — will be consumed there
	li	t0, NK_TERM
	beq	a0, t0, px_clos_params	# EOF — error caught there
	# Error: expected , or |
	lla	a0, str_comma_pipe
	mv	a1, s4
	mv	a2, s0
	j	err_expect
px_clos_comma:
	# Consume comma
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next
	j	px_clos_params
px_closure_empty:
	# || was consumed as the prefix token (NK_OR). s2 is the node.
	# Just parse body — no params.
	j	px_clos_expr

px_clos_empty:
	# || seen inside |...| parsing — consume it
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next
	j	px_clos_expr
px_clos_body:
	mv	a0, s0
	li	a1, NK_PIPE
	lla	a2, str_pipe
	jal	expect_tok
px_clos_expr:
	# Parse body expression
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s2
	jal	node_add_child
	j	px_done

px_struct:
	# struct Name { field, field, ... }
	# s2 = struct token node. Read name, then fields.
	# Name
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next		# read name ident
	mv	a0, s2
	mv	a1, s4
	jal	node_add_child
	# Expect {
	mv	a0, s0
	li	a1, NK_LBRACE
	lla	a2, str_lbrace
	jal	expect_tok
	# Read fields until }
px_struct_lp:
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_RBRACE
	beq	a0, t0, px_struct_close
	li	t0, NK_TERM
	beq	a0, t0, px_struct_close
	# Read field name (must be identifier)
	mv	a0, s0
	li	a1, NK_IDENT
	lla	a2, str_ident
	jal	expect_tok
	mv	s4, a0
	mv	a0, s2
	mv	a1, s4
	jal	node_add_child
	# Optional comma
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1
	jal	lex_next
	li	t0, NK_COMMA
	bne	a0, t0, px_struct_lp
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume comma
	j	px_struct_lp
px_struct_close:
	mv	a0, s0
	li	a1, NK_RBRACE
	lla	a2, str_rbrace
	jal	expect_tok
	j	px_done

px_macro:
	# macro { body } — parse body as child expression
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s2
	jal	node_add_child
	j	px_done

px_loop:
	# loop { body }
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr		# parse the block
	mv	a1, a0
	mv	a0, s2
	jal	node_add_child
	j	px_done

px_for:
	# for <binding> in <iter> { body }
	# Parse binding
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# read binding ident
	mv	a1, a1			# the node
	mv	a0, s2
	jal	node_add_child
	# Expect 'in'
	mv	a0, s0
	li	a1, NK_IN
	lla	a2, str_in_kw
	jal	expect_tok
	# Parse iterator expr (stop before { body)
	mv	a0, s0
	li	a1, P_CALL+1
	jal	parse_expr
	mv	a1, a0
	mv	a0, s2
	jal	node_add_child
	# Parse body
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s2
	jal	node_add_child
	j	px_done

px_switch:
	# switch <expr> { <arms> }
	# Parse scrutinee (stop before { which has P_CALL binding power)
	mv	a0, s0
	li	a1, P_CALL+1
	jal	parse_expr
	mv	a1, a0
	mv	a0, s2
	jal	node_add_child
	# Expect { — consume it
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next
	# Parse arms: pattern => expr, ...
px_sw_arm:
	jal	node_alloc
	mv	s4, a0			# fresh scratch for peek
	mv	a0, s0
	mv	a1, s4
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_RBRACE
	beq	a0, t0, px_sw_close
	li	t0, NK_TERM
	beq	a0, t0, px_sw_close
	# Create arm node: consume => to use as the arm container
	# First parse pattern
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	s4, a0			# s4 = pattern node (save temporarily)
	# Expect => (arm node)
	mv	a0, s0
	li	a1, NK_FAT_ARROW
	lla	a2, str_fat_arrow
	jal	expect_tok
	mv	s3, a0			# s3 = arm node (=> token)
	# Add pattern as first child of arm
	mv	a0, s3
	mv	a1, s4
	jal	node_add_child
	# Parse value expr
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s3
	jal	node_add_child
	# Add arm to switch node
	mv	a1, s3
	mv	a0, s2
	jal	node_add_child
	# Optional comma
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1
	jal	lex_next
	li	t0, NK_COMMA
	bne	a0, t0, px_sw_arm
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume comma
	j	px_sw_arm
px_sw_close:
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume }
	j	px_done

px_return:
	# return/break with optional value
	# Peek — if next token can start an expr, parse it
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 1
	jal	lex_next
	# If next is ; or } or TERM, no value
	li	t0, NK_SEMI
	beq	a0, t0, px_done
	li	t0, NK_RBRACE
	beq	a0, t0, px_done
	li	t0, NK_TERM
	beq	a0, t0, px_done
	# Parse value
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s2
	jal	node_add_child
	j	px_done

px_done:
	# ── Infix loop ──
px_infix:
	# Allocate fresh scratch node for each peek (s4 may be the operator node)
	jal	node_alloc
	mv	a1, a0			# scratch for peek
	mv	a0, s0
	li	a2, 1			# peek
	jal	lex_next
	mv	s5, a0			# s5 = peeked kind

	# Get binding power
	mv	a0, s5
	jal	get_bp
	mv	s3, a0			# s3 = left bp
	mv	s5, a1			# s5 = right bp

	# If left bp == 0 (not an infix op) or < min_prec, stop
	beqz	s3, px_ret
	blt	s3, s1, px_ret

	# Consume the operator token into a new node
	jal	node_alloc
	mv	s4, a0			# s4 = operator node
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next
	mv	s3, a0			# s3 = operator kind
	mv	a1, s2			# LHS as first child
	mv	a0, s4
	jal	node_add_child

	# ── Special infix handlers ──

	# Postfix ++/--: LHS ++ or LHS -- (no RHS)
	li	t0, NK_INC
	beq	s3, t0, ix_postfix_unary
	li	t0, NK_DEC
	beq	s3, t0, ix_postfix_unary

	# Ternary: LHS ? then_expr : else_expr
	li	t0, NK_QMARK
	beq	s3, t0, ix_ternary

	# Dot: LHS . ident
	li	t0, NK_DOT
	beq	s3, t0, ix_dot

	# Index: LHS [ expr ]
	li	t0, NK_LBRACKET
	beq	s3, t0, ix_index

	# Struct init: LHS { fields }
	li	t0, NK_LBRACE
	beq	s3, t0, ix_struct_init

	# Call: LHS ( args )
	li	t0, NK_LPAREN
	beq	s3, t0, ix_call

	# Regular binary: parse RHS
	mv	a0, s0
	mv	a1, s5			# right bp
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	node_add_child
	mv	s2, s4			# operator becomes new LHS
	j	px_infix

ix_postfix_unary:
	# LHS is already first child of s4. No RHS to parse.
	mv	s2, s4
	j	px_infix

ix_ternary:
	# Parse then-expr
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	node_add_child
	# Check for : (else branch)
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_COLON
	bne	a0, t0, ix_tern_done
	# Consume : and parse else-expr
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume :
	mv	a0, s0
	li	a1, P_TERNARY		# right-assoc
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	node_add_child
ix_tern_done:
	mv	s2, s4
	j	px_infix

ix_dot:
	# Parse member name (just consume next token)
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next
	mv	a1, a1
	mv	a0, s4
	jal	node_add_child
	mv	s2, s4
	j	px_infix

ix_index:
	# Parse index expr, consume ]
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	node_add_child
	# Expect ]
	mv	a0, s0
	li	a1, NK_RBRACKET
	lla	a2, str_rbracket
	jal	expect_tok
	mv	s2, s4
	j	px_infix

ix_struct_init:
	# LHS { field: value, ... } or LHS { val, val, ... }
	# s4 = the '{' node (struct init container), LHS already first child
	# Parse fields until }
	li	t0, -1
	sw	t0, N_DATA(s4)		# field mode: -1=unset, 0=positional, 1=named
ix_si_lp:
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_RBRACE
	beq	a0, t0, ix_si_close
	li	t0, NK_TERM
	beq	a0, t0, ix_si_close
	# Parse value/field expression
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	# Check if next token is ':' (named field)
	mv	s3, a0			# save parsed expr
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_COLON
	bne	a0, t0, ix_si_positional
	# Named field — verify name is an identifier
	lw	t0, N_KIND(s3)
	li	t1, NK_IDENT
	beq	t0, t1, ix_si_named
	# Not an identifier before ':'
	lla	a0, str_ident
	mv	a1, s3
	mv	a2, s0
	j	err_expect
ix_si_named:
	# Check mode consistency
	lw	t0, N_DATA(s4)
	beqz	t0, ix_si_mix_err	# was positional → error
	li	t0, 1
	sw	t0, N_DATA(s4)		# set mode = named
	# Named field: consume ':', wrap name:value in a colon node
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume ':'
	# Create colon node with name and value as children
	jal	node_alloc
	mv	s5, a0			# s5 = colon pair node
	li	t0, NK_COLON
	sw	t0, N_KIND(s5)
	mv	a0, s5
	mv	a1, s3			# name (the parsed expr)
	jal	node_add_child
	# Parse value
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s5
	jal	node_add_child
	# Add colon pair to struct init
	mv	a1, s5
	mv	a0, s4
	jal	node_add_child
	j	ix_si_comma
ix_si_mix_err:
	mv	a0, s3			# node for location
	lla	a1, str_mix_fields	# message
	j	err_at

ix_si_positional:
	# Check mode consistency
	lw	t0, N_DATA(s4)
	li	t1, 1
	beq	t0, t1, ix_si_mix_err	# was named → error
	sw	zero, N_DATA(s4)	# set mode = positional
	# Positional: just add the value directly
	mv	a1, s3
	mv	a0, s4
	jal	node_add_child
ix_si_comma:
	# Optional comma
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1
	jal	lex_next
	li	t0, NK_COMMA
	bne	a0, t0, ix_si_lp
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume comma
	j	ix_si_lp
ix_si_close:
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume }
	mv	s2, s4
	j	px_infix

ix_call:
	# Parse args until )
ix_call_lp:
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_RPAREN
	beq	a0, t0, ix_call_close
	li	t0, NK_TERM
	beq	a0, t0, ix_call_close
	# Parse arg
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s4
	jal	node_add_child
	# Expect comma or )
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1
	jal	lex_next
	li	t0, NK_COMMA
	beq	a0, t0, ix_call_comma
	li	t0, NK_RPAREN
	beq	a0, t0, ix_call_close
	li	t0, NK_TERM
	beq	a0, t0, ix_call_close
	# Error: expected , or )
	lla	a0, str_comma_rparen
	mv	a2, s0
	j	err_expect
ix_call_comma:
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume comma
	j	ix_call_lp
ix_call_close:
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume )
	mv	s2, s4
	j	px_infix

px_ret:
	mv	a0, s2
	return

# ── parse_program: parse semicolon-separated top-level expressions ───
# a0=lexer → a0=program node (NK_LBRACE reused as program)
parse_program:
	prologue	s0 s1 s2 x0
	mv	s0, a0			# lexer
	jal	node_alloc
	mv	s1, a0			# program node
	li	t0, NK_LBRACE		# reuse as "block/program"
	sw	t0, N_KIND(s1)
pp_loop:
	# Peek
	jal	node_alloc
	mv	s2, a0
	mv	a0, s0
	mv	a1, s2
	li	a2, 1
	jal	lex_next
	li	t0, NK_TERM
	beq	a0, t0, pp_done
	# Parse expression
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s1
	jal	node_add_child
	# Expect semicolon, EOF, or } after expression
	jal	node_alloc
	mv	s2, a0
	mv	a0, s0
	mv	a1, s2
	li	a2, 1
	jal	lex_next
	li	t0, NK_SEMI
	beq	a0, t0, pp_semi
	li	t0, NK_TERM
	beq	a0, t0, pp_done
	li	t0, NK_RBRACE
	beq	a0, t0, pp_done
	# Error: missing semicolon
	lla	a0, str_semi
	mv	a1, s2
	mv	a2, s0
	j	err_expect
pp_semi:
	mv	a0, s0
	mv	a1, s2
	li	a2, 0
	jal	lex_next		# consume ;
	j	pp_loop
pp_done:
	mv	a0, s1
	return

# ══════════════════════════════════════════════════════════════════════
#  Asm support: mnemonic table, lookup, register checker, parser
# ══════════════════════════════════════════════════════════════════════

# asm_mnem_tbl: 12 bytes per entry (8-byte name + class:f3:f7:pad)
asm_mnem_tbl:
.ascii	"add"
.zero	5
.word	0x000001
.ascii	"sub"
.zero	5
.word	0x200001
.ascii	"and"
