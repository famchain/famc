.equ	UART, 0x10000

# Note labels not indented
_start:
	lui	t0, UART		# Note 2 tabs (same dist for all comments)

# Loop
loop:
	lbu	t1, 5(t0)		# lbu Note tab after lbu
	andi	t1, t1, 0x20
	beqz	t1, loop		# Repeat
	li	t2, 67
	sb	t2, 0(t0)
	lui	t0, 0x100
	lui	t1, 5
	addi	t1, t1, 0x555
	sw	t1, 0(t0)

hang:					# single space before label
	wfi
	j	hang			# ok
