# ══════════════════════════════════════════════════════════════════════════════
# famc.fam3 — first-pass reference compiler (rewrite, pass 1)
# ══════════════════════════════════════════════════════════════════════════════
#
# Grammar:
#   program := stmt*
#   stmt    := lvalue '=' expr ';'
#   lvalue  := IDENT | '*' expr | '@' expr
#   expr    := term ('+' term)*
#   term    := derefop? primary
#   derefop := '*' | '@'                # '*' = word, '@' = byte
#   primary := NUM | IDENT
#   IDENT   := [a-zA-Z_][a-zA-Z_0-9]*
#   NUM     := dec | 0[xX][0-9a-fA-F]+
#
# Example source:
#   x = 1;
#   y = x + 48;
#   @0x10000000 = y;                  # writes byte '1' to the UART
#
# Compiled-program prologue (11 instructions, 44 bytes):
#
#   0:  nop                           # q32 magic
#   4:  auipc gp, 0                   # gp = &auipc
#   8:  addi  gp, gp, <patched>       # gp = data_end  (patched by Phase 5)
#  12:  addi  gp, gp, 3                # align ...
#  16:  andi  gp, gp, -4                # ... to 4 bytes
#  20:  lui   sp, 0x10                  # sp = 0x10000 (= 64 KiB)
#  24:  add   sp, sp, gp                # sp = gp + 64 KiB (stack top)
#  28:  lui   t0, <patched hi20>        # frame allocator, upper 20 bits
#  32:  addi  t0, t0, <patched lo12>    # frame allocator, lower 12 bits
#  36:  sub   sp, sp, t0                # sp -= frame_size (reserve locals)
#  40:  addi  fp, sp, 0                 # fp = sp (fp pinned to base of frame)
#  44:  <compiled statements ...>
#   N:  lui   t0, 0x100                  # QEMU poweroff sequence:
# N+4:  lui   t1, 0x5                    #   *0x100000 = 0x5555
# N+8:  addi  t1, t1, 0x555
# N+12: sw    t1, 0(t0)
# N+16: jal   zero, 0                   # safety hang after poweroff
# N+20: data_end:
#
# Patch points (all applied in Phase 5 after compile_loop ends):
#   offset 8   addi gp imm12  → (data_end - auipc_pc)
#   offset 28  lui  t0 imm20  → upper20 of frame_size
#   offset 32  addi t0 imm12  → lower12 of frame_size (sign-extended)
#
# The frame allocator is always 3 instructions regardless of frame size, so it
# handles anything from 0 bytes up to ~2 GiB without a special case. Pass 2
# can replace tiny frames with a single `addi sp, sp, -N` as an optimization.
#
# Design contract:
#   - famc's prologue sets gp = data_end, sp = top of stack, fp = base of frame.
#   - Frame size is computed dynamically from variable declarations and
#     patched into the prologue's lui/addi pair at end of compilation. No
#     hard-coded 2 KiB ceiling — arrays and large structs will Just Work.
#   - No alloc / no heap manager baked in; dynamic allocation is stdlib's job.
#   - famc itself uses a stack + a bump-allocated heap (pointed to by tp).
#   - No ret / jalr / jr in any of our outputs. Static dispatch only.
#
# Variables live at POSITIVE offsets from fp:
#   offset 0(fp) = first local, 4(fp) = second, ..., (frame_size-4)(fp) = last.
# fp does not move after the prologue; sp moves freely below fp during
# expression evaluation (stack-machine push/pop). Since sp < fp throughout,
# pushes never collide with the variable frame.
#
# Compiled-program register usage:
#   a0  — current expression value
#   t0  — pop destination in the stack-machine pop pattern
#   fp  — frame pointer (s0; base of the current function's locals)
#   gp  — data_end pointer (reserved for stdlib/user — famc doesn't touch it)
#   sp  — expression spill stack; moves freely below fp
#
# ── famc's own runtime layout ──────────────────────────────────────────────
#
#   [high RAM]
#         │  [output buffer — grows up]        s4 = s3 after read
#         │  [input buffer  — grows up]        s1 = sp_initial
#   sp_0  ├──  `lui sp, 0x4000; add sp, sp, tp`   (sp = tp + 64 MiB)
#         │  [token buffer, 32 B on stack]     s10 = sp after `addi sp, sp, -32`
#         │  [free stack, grows down ...]
#         ┆                                     (dispatch gp save/restore)
#         │  [free heap ...]                   (grows upward)
#         │  [symtab — 32 entries initially]    s7, s8 write ptr, s0 end ptr
#   tp_0  ├──  `lla tp, data` then `andi tp, tp, -4`
#         │  [famc code + data, label `data:` at the end]
#   0x80000000
#
# ── famc's own runtime registers ───────────────────────────────────────────
#   s0  = symtab end ptr (= s7 + capacity_in_bytes; triggers grow when s8 hits)
#   s1  = input buf base           s2  = input read ptr
#   s3  = input end ptr            s4  = output buf base
#   s5  = output write ptr         s6  = UART base
#   s7  = symtab base              s8  = symtab write ptr
#   s9  = current frame size in bytes (= next free byte offset for new locals)
#                                     s10 = token buf base
#   s11 = current token length     sp  = famc's stack
#   tp  = heap bump pointer (famc's heap — initially `data`, grows upward)
#   gp  = return-site id (dispatch — same convention as fam2/fam3)
# ══════════════════════════════════════════════════════════════════════════════

.equ SYMTAB_INIT_BYTES, 1280	# 32 entries × 40 bytes

_start:
	nop				# q32 magic for fam3's own output

	# ── Set up heap and stack ─────────────────────────────────────────
	lla	tp, data		# tp = end of famc image
	addi	tp, tp, 3
	andi	tp, tp, -4		# 4-byte align
	lui	sp, 0x4000		# 0x04000000 = 64 MiB
	add	sp, sp, tp		# sp = tp + 64 MiB

	lui	s6, 0x10000		# UART

	# ── Input buffer = initial sp, grows upward ───────────────────────
	addi	s1, sp, 0
	addi	s2, s1, 0

	# ── Token buffer: 32 bytes on the stack ──────────────────────────
	addi	sp, sp, -32
	addi	s10, sp, 0

	# ── Symtab: initial 32 entries on the heap at tp ─────────────────
	addi	s7, tp, 0		# symtab base
	addi	s8, s7, 0		# symtab write ptr
	addi	t0, zero, SYMTAB_INIT_BYTES
	add	tp, tp, t0		# bump heap
	addi	s0, s7, SYMTAB_INIT_BYTES	# symtab end (capacity marker)

	addi	s9, zero, 0		# next var slot
	addi	s11, zero, 0		# token length

# ── Phase 1: read all source text from UART into input buffer ──────────────
	addi	s3, s1, 0
rd_loop:
	lbu	t1, 5(s6)
	andi	t1, t1, 1
	beqz	t1, rd_loop
	lbu	t0, 0(s6)
	addi	t2, zero, 4
	beq	t0, t2, rd_done
	sb	t0, 0(s3)
	addi	s3, s3, 1
	j	rd_loop
rd_done:
	# Output buffer starts immediately after input
	addi	s4, s3, 0
	addi	s5, s4, 0

# ── Phase 2: emit prologue (7 words, 28 bytes) ──────────────────────────────
	# nop = addi x0, x0, 0 = 0x00000013
	lui	a0, 0
	addi	a0, a0, 0x13
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# auipc gp, 0    →  opcode=0x17, rd=gp=3, imm20=0
	# word = (0 << 12) | (3 << 7) | 0x17 = 0x00000197
	lui	a0, 0
	addi	a0, a0, 0x197
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi gp, gp, 0     (immediate patched later to reach data_end)
	# opcode=0x13, rd=gp=3, rs1=gp=3, f3=0, imm=0
	# word = (0 << 20) | (3 << 15) | (0 << 12) | (3 << 7) | 0x13
	#      = 0x00018193
	lui	a0, 0x18
	addi	a0, a0, 0x193
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi gp, gp, 3     (align up)
	# word = (3 << 20) | (3 << 15) | 0 | (3 << 7) | 0x13 = 0x00318193
	lui	a0, 0x318
	addi	a0, a0, 0x193
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# andi gp, gp, -4    (align down to 4)
	# opcode=0x13, f3=7, rd=3, rs1=3, imm=-4 (=0xFFC in 12-bit)
	# word = (0xFFC << 20) | (3 << 15) | (7 << 12) | (3 << 7) | 0x13
	#      = 0xFFC << 20 = 0xFFC00000
	#      | 0x18000 | 0x7000 | 0x180 | 0x13
	#      = 0xFFC00000 | 0x0001F193
	#      = 0xFFC1F193
	lui	a0, 0xFFC1F
	addi	a0, a0, 0x193
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# lui sp, 0x10      →  opcode=0x37, rd=sp=2, imm20=0x10
	# word = (0x10 << 12) | (2 << 7) | 0x37
	#      = 0x00010000 | 0x100 | 0x37 = 0x00010137
	lui	a0, 0x10
	addi	a0, a0, 0x137
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# add sp, sp, gp    →  R-type, opcode=0x33, f3=0, f7=0,
	#                       rd=sp=2, rs1=sp=2, rs2=gp=3
	# word = (3 << 20) | (2 << 15) | (0 << 12) | (2 << 7) | 0x33
	#      = 0x00300000 | 0x10000 | 0x100 | 0x33
	#      = 0x00310133
	lui	a0, 0x310
	addi	a0, a0, 0x133
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# Frame allocator — 3 instructions, always emitted, always patched in
	# Phase 5 with the real frame_size computed during statement compilation.
	#
	#   lui  t0, 0           # 0x000002B7 (imm20 patched to upper20(frame))
	#   addi t0, t0, 0       # 0x00028293 (imm12 patched to lower12(frame))
	#   sub  sp, sp, t0      # 0x40510133
	#
	# With t0 = frame_size (as loaded by the patched lui+addi), we reserve
	# frame_size bytes below the current sp. The pattern handles any size
	# from 0 to ~2 GiB without a special case.

	# lui t0, 0          →  opcode=0x37, rd=t0=5, imm20=0
	#   word = 0x37 | (5 << 7) = 0x000002B7
	lui	a0, 0
	addi	a0, a0, 0x2B7
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi t0, t0, 0     →  opcode=0x13, rd=t0=5, rs1=t0=5, f3=0, imm=0
	#   word = 0x13 | (5 << 7) | (5 << 15) = 0x13 | 0x280 | 0x28000 = 0x00028293
	lui	a0, 0x28
	addi	a0, a0, 0x293
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# sub sp, sp, t0     →  R-type, opcode=0x33, f3=0, f7=0x20,
	#                        rd=sp=2, rs1=sp=2, rs2=t0=5
	#   word = 0x33 | (2<<7) | (2<<15) | (5<<20) | (0x20<<25)
	#        = 0x33 | 0x100 | 0x10000 | 0x500000 | 0x40000000
	#        = 0x40510133
	lui	a0, 0x40510
	addi	a0, a0, 0x133
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi fp, sp, 0     →  fp = sp (fp pinned to base of frame)
	#   opcode=0x13, rd=s0=8, rs1=sp=2, f3=0, imm=0
	#   word = 0x13 | (8<<7) | (2<<15) = 0x13 | 0x400 | 0x10000 = 0x00010413
	lui	a0, 0x10
	addi	a0, a0, 0x413
	sw	a0, 0(s5)
	addi	s5, s5, 4

# ── Phase 3: compile all statements ────────────────────────────────────────
compile_loop:
	addi	gp, zero, 0
	j	skip_ws
sw_cl:
	bge	s2, s3, compile_done
	j	compile_stmt
cs_after:
	j	compile_loop
compile_done:

# ── Phase 4: emit epilogue — QEMU-virt poweroff + safety hang ──────────────
# Writes the magic value 0x5555 to the "test" device at 0x00100000, which
# causes qemu-system-riscv32 -machine virt to exit.  Followed by `j .` as a
# safety net in case we're running on something that doesn't honour the test
# device (the CPU will then just park there).
#
#   lui  t0, 0x100        # t0 = 0x00100000 (test device)     0x001002B7
#   lui  t1, 0x5          # t1 = 0x00005000                    0x00005337
#   addi t1, t1, 0x555    # t1 = 0x00005555                    0x55530313
#   sw   t1, 0(t0)                                             0x0062A023
#   jal  zero, 0          # j .  (safety hang)                 0x0000006F

	# lui t0, 0x100
	lui	a0, 0x100
	addi	a0, a0, 0x2B7
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# lui t1, 0x5
	lui	a0, 0x5
	addi	a0, a0, 0x337
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi t1, t1, 0x555
	lui	a0, 0x55530
	addi	a0, a0, 0x313
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# sw t1, 0(t0)
	lui	a0, 0x62A
	addi	a0, a0, 0x023
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# jal zero, 0 — safety hang
	lui	a0, 0
	addi	a0, a0, 0x6F
	sw	a0, 0(s5)
	addi	s5, s5, 4

# ── Phase 5: patch the prologue (data_end + frame_size) ────────────────────

	# Patch 1 — addi gp, gp, imm at prologue offset 8, so gp = data_end.
	#   auipc_pc = s4 + 4, addi_pc = s4 + 8, data_end = s5
	#   imm12 = data_end - auipc_pc = s5 - (s4 + 4)
	sub	t0, s5, s4
	addi	t0, t0, -4		# t0 = imm12 (signed)
	slli	t0, t0, 20		# place in bits 31:20 (naturally truncates)
	lui	t1, 0x18
	addi	t1, t1, 0x193		# base 0x00018193 (addi gp, gp, 0)
	or	t1, t1, t0
	sw	t1, 8(s4)

	# Patch 2 — lui  t0, upper20  at prologue offset 28
	# Patch 3 — addi t0, t0, lo12 at prologue offset 32
	# Together they set t0 = s9 = frame_size in bytes.
	#
	#   lower12 = sign-extended low 12 bits of s9
	#   upper20 = (s9 - lower12) >> 12
	#
	# For s9 = 0 the pair becomes `lui 0 ; addi t0, 0` which is a no-op (t0=0),
	# and `sub sp, sp, t0` leaves sp alone — correct for a zero-local program.
	slli	t0, s9, 20		# t0 = s9 << 20 (bits 31:20 = low 12 of s9)
	srai	t0, t0, 20		# t0 = lower12 (sign-extended to 32)
	sub	t1, s9, t0		# t1 = s9 - lower12  (always a multiple of 4096)
	srai	t1, t1, 12		# t1 = upper20

	# lui t0, upper20 word:  (upper20 << 12) | 0x000002B7
	slli	t2, t1, 12
	addi	t3, zero, 0x2B7
	or	t2, t2, t3
	sw	t2, 28(s4)

	# addi t0, t0, lower12 word:  (lower12 << 20) | 0x00028293
	# (slli naturally keeps only the low 12 bits of t0 in the imm slot)
	slli	t2, t0, 20
	lui	t3, 0x28
	addi	t3, t3, 0x293
	or	t2, t2, t3
	sw	t2, 32(s4)

# ── Phase 6: stream output buffer to UART, then poweroff ───────────────────
out_loop:
	beq	s4, s5, poweroff
	lbu	t0, 0(s4)
	addi	s4, s4, 1
tx_wait:
	lbu	t1, 5(s6)
	andi	t1, t1, 0x20
	beqz	t1, tx_wait
	sb	t0, 0(s6)
	j	out_loop

poweroff:
	lui	t0, 0x100
	lui	t1, 0x5
	addi	t1, t1, 0x555
	sw	t1, 0(t0)
pwr_hang:
	j	pwr_hang

halt_err:
	j	halt_err

# ══════════════════════════════════════════════════════════════════════════════
# skip_ws — advance s2 past chars with code < 33.
#
# Call sites (each has a uniquely-named return label):
#   0: sw_cl          (compile_loop top)
#   1: sw_ct_pre      (compile_term — initial ws skip)
#   2: sw_ct_star     (compile_term — after consuming '*')
#   3: sw_ct_at       (compile_term — after consuming '@')
#   4: sw_ca_plus     (compile_add — before checking for '+'/'-')
#   5: sw_cs_eq1      (compile_stmt — after IDENT, before '=')
#   6: sw_cs_semi1    (compile_stmt — after IDENT/expr, before ';')
#   7: sw_cs_eq2      (compile_stmt — '*' path, after addr expr, before '=')
#   8: sw_cs_semi2    (compile_stmt — '*' path, after store, before ';')
#   9: sw_cs_eq3      (compile_stmt — '@' path, after addr expr, before '=')
#  10: sw_cs_semi3    (compile_stmt — '@' path, after store, before ';')
#  11: sw_ce_xor      (compile_expr — before checking for '^')
#  12: sw_ct_pp       (compile_unary — after consuming prefix '++')
#  13: sw_ct_mm       (compile_unary — after consuming prefix '--')
#  14: sw_ct_post     (compile_unary — after IDENT+lw, before peek postfix)
#  15: sw_cs_semi_stmt (compile_stmt — before trailing ';' for compound/inc-dec stmts)
#  16: sw_cs_pp_id    (compile_stmt — after bare '++', before IDENT)
#  17: sw_cs_mm_id    (compile_stmt — after bare '--', before IDENT)
#  18: sw_csh_op      (compile_shift — before peeking for '<<' or '>>')
#  19: sw_cand_and    (compile_and — before peeking for '&')
#  20: sw_cor_or      (compile_expr/or — before peeking for '|')
#  21: sw_ct_rparen   (compile_unary — after parenthesized expr, before ')')
#  22: sw_ccmp_op     (compile_rel — before peeking for relational op)
#  23: sw_ceq_op      (compile_expr — before peeking for '==' / '!=')
#  24: sw_cmul_op     (compile_mul — before peeking for '*')
#  25: sw_cland_op    (compile_land — before peeking for '&&')
#  26: sw_clor_op     (compile_expr — before peeking for '||')
#  27: sw_ctern_op    (compile_expr — after || loop, before peeking '?')
#  28: sw_ctern_colon (compile_expr — after middle, before peeking ':')
#  29: sw_cep_op      (compile_expr_p — at loop top, before peeking binop)
#  30: sw_cep_tern_colon (compile_expr_p — after ternary middle, before ':')
# ══════════════════════════════════════════════════════════════════════════════
skip_ws:
sw_loop:
	bge	s2, s3, sw_done
	lbu	t0, 0(s2)
	addi	t1, zero, 33
	bge	t0, t1, sw_done
	addi	s2, s2, 1
	j	sw_loop
sw_done:
	j	skip_ws_disp

skip_ws_disp:
	bnez	gp, sw_d1
	j	sw_cl
sw_d1:
	addi	gp, gp, -1
	bnez	gp, sw_d2
	j	sw_ct_pre
sw_d2:
	addi	gp, gp, -1
	bnez	gp, sw_d3
	j	sw_ct_star
sw_d3:
	addi	gp, gp, -1
	bnez	gp, sw_d4
	j	sw_ct_at
sw_d4:
	addi	gp, gp, -1
	bnez	gp, sw_d5
	j	sw_ca_plus
sw_d5:
	addi	gp, gp, -1
	bnez	gp, sw_d6
	j	sw_cs_eq1
sw_d6:
	addi	gp, gp, -1
	bnez	gp, sw_d7
	j	sw_cs_semi1
sw_d7:
	addi	gp, gp, -1
	bnez	gp, sw_d8
	j	sw_cs_eq2
sw_d8:
	addi	gp, gp, -1
	bnez	gp, sw_d9
	j	sw_cs_semi2
sw_d9:
	addi	gp, gp, -1
	bnez	gp, sw_d10
	j	sw_cs_eq3
sw_d10:
	addi	gp, gp, -1
	bnez	gp, sw_d11
	j	sw_cs_semi3
sw_d11:
	addi	gp, gp, -1
	bnez	gp, sw_d12
	j	sw_ce_xor
sw_d12:
	addi	gp, gp, -1
	bnez	gp, sw_d13
	j	sw_ct_pp
sw_d13:
	addi	gp, gp, -1
	bnez	gp, sw_d14
	j	sw_ct_mm
sw_d14:
	addi	gp, gp, -1
	bnez	gp, sw_d15
	j	sw_ct_post
sw_d15:
	addi	gp, gp, -1
	bnez	gp, sw_d16
	j	sw_cs_semi_stmt
sw_d16:
	addi	gp, gp, -1
	bnez	gp, sw_d17
	j	sw_cs_pp_id
sw_d17:
	addi	gp, gp, -1
	bnez	gp, sw_d18
	j	sw_cs_mm_id
sw_d18:
	addi	gp, gp, -1
	bnez	gp, sw_d19
	j	sw_csh_op
sw_d19:
	addi	gp, gp, -1
	bnez	gp, sw_d20
	j	sw_cand_and
sw_d20:
	addi	gp, gp, -1
	bnez	gp, sw_d21
	j	sw_cor_or
sw_d21:
	addi	gp, gp, -1
	bnez	gp, sw_d22
	j	sw_ct_rparen
sw_d22:
	addi	gp, gp, -1
	bnez	gp, sw_d23
	j	sw_ccmp_op
sw_d23:
	addi	gp, gp, -1
	bnez	gp, sw_d24
	j	sw_ceq_op
sw_d24:
	addi	gp, gp, -1
	bnez	gp, sw_d25
	j	sw_cmul_op
sw_d25:
	addi	gp, gp, -1
	bnez	gp, sw_d26
	j	sw_cland_op
sw_d26:
	addi	gp, gp, -1
	bnez	gp, sw_d27
	j	sw_clor_op
sw_d27:
	addi	gp, gp, -1
	bnez	gp, sw_d28
	j	sw_ctern_op
sw_d28:
	addi	gp, gp, -1
	bnez	gp, sw_d29
	j	sw_ctern_colon
sw_d29:
	addi	gp, gp, -1
	bnez	gp, sw_d30
	j	sw_cep_op
sw_d30:
	addi	gp, gp, -1
	bnez	gp, sw_d31
	j	sw_cep_tern_colon
sw_d31:
	j	sw_ct_blk_sep

# ══════════════════════════════════════════════════════════════════════════════
# emit_word — store a0 as 4 bytes at s5, advance s5.
#
# Call sites:
#    0: ew_li_s     (emit_li, single-addi path)
#    1: ew_li_lui   (emit_li, lui of big-imm path)
#    2: ew_li_add   (emit_li, addi of big-imm path)
#    3: ew_lws      (emit_lw_sp)
#    4: ew_sws      (emit_sw_sp)
#    5: ew_lwd      (emit_lw_deref)
#    6: ew_lbud     (emit_lbu_deref)
#    7: ew_push_addi (emit_push_a0 — addi sp,sp,-4)
#    8: ew_push_sw   (emit_push_a0 — sw a0,0(sp))
#    9: ew_pop_lw    (emit_pop_t0 — lw t0,0(sp))
#   10: ew_pop_addi  (emit_pop_t0 — addi sp,sp,4)
#   11: ew_add       (emit_add — add a0,t0,a0)
#   12: ew_sw_d      (emit_sw_deref — sw a0,0(t0))
#   13: ew_sb_d      (emit_sb_deref — sb a0,0(t0))
#   14: ew_sub       (emit_sub — sub a0,t0,a0)
#   15: ew_xor       (emit_xor — xor a0,t0,a0)
#   16: ew_addi1     (emit_addi_a0_1  — addi a0,a0,1)
#   17: ew_addim1    (emit_addi_a0_m1 — addi a0,a0,-1)
#   18: ew_sll       (emit_sll — sll a0,t0,a0)
#   19: ew_sra       (emit_sra — sra a0,t0,a0)
#   20: ew_and       (emit_and — and a0,t0,a0)
#   21: ew_or        (emit_or  — or  a0,t0,a0)
#   22: ew_xori_m1   (emit_xori_m1 — xori a0,a0,-1)
#   23: ew_neg       (emit_neg_a0 — sub a0,zero,a0)
#   24: ew_cmp       (emit_cmp_word — caller-supplied comparison word)
#   25: ew_srl       (emit_srl — srl a0,t0,a0)
#   26: ew_mul       (emit_mul — loop emitting the 11-word inline mul seq)
#   27: ew_divmod    (emit_divmod_body — loop emitting the 24-word divmod body)
#   28: ew_udivmod   (emit_udivmod_body — loop emitting the 13-word udivmod body)
# ══════════════════════════════════════════════════════════════════════════════
emit_word:
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	emit_word_disp

emit_word_disp:
	bnez	gp, ewd_1
	j	ew_li_s
ewd_1:
	addi	gp, gp, -1
	bnez	gp, ewd_2
	j	ew_li_lui
ewd_2:
	addi	gp, gp, -1
	bnez	gp, ewd_3
	j	ew_li_add
ewd_3:
	addi	gp, gp, -1
	bnez	gp, ewd_4
	j	ew_lws
ewd_4:
	addi	gp, gp, -1
	bnez	gp, ewd_5
	j	ew_sws
ewd_5:
	addi	gp, gp, -1
	bnez	gp, ewd_6
	j	ew_lwd
ewd_6:
	addi	gp, gp, -1
	bnez	gp, ewd_7
	j	ew_lbud
ewd_7:
	addi	gp, gp, -1
	bnez	gp, ewd_8
	j	ew_push_addi
ewd_8:
	addi	gp, gp, -1
	bnez	gp, ewd_9
	j	ew_push_sw
ewd_9:
	addi	gp, gp, -1
	bnez	gp, ewd_10
	j	ew_pop_lw
ewd_10:
	addi	gp, gp, -1
	bnez	gp, ewd_11
	j	ew_pop_addi
ewd_11:
	addi	gp, gp, -1
	bnez	gp, ewd_12
	j	ew_add
ewd_12:
	addi	gp, gp, -1
	bnez	gp, ewd_13
	j	ew_sw_d
ewd_13:
	addi	gp, gp, -1
	bnez	gp, ewd_14
	j	ew_sb_d
ewd_14:
	addi	gp, gp, -1
	bnez	gp, ewd_15
	j	ew_sub
ewd_15:
	addi	gp, gp, -1
	bnez	gp, ewd_16
	j	ew_xor
ewd_16:
	addi	gp, gp, -1
	bnez	gp, ewd_17
	j	ew_addi1
ewd_17:
	addi	gp, gp, -1
	bnez	gp, ewd_18
	j	ew_addim1
ewd_18:
	addi	gp, gp, -1
	bnez	gp, ewd_19
	j	ew_sll
ewd_19:
	addi	gp, gp, -1
	bnez	gp, ewd_20
	j	ew_sra
ewd_20:
	addi	gp, gp, -1
	bnez	gp, ewd_21
	j	ew_and
ewd_21:
	addi	gp, gp, -1
	bnez	gp, ewd_22
	j	ew_or
ewd_22:
	addi	gp, gp, -1
	bnez	gp, ewd_23
	j	ew_xori_m1
ewd_23:
	addi	gp, gp, -1
	bnez	gp, ewd_24
	j	ew_neg
ewd_24:
	addi	gp, gp, -1
	bnez	gp, ewd_25
	j	ew_cmp
ewd_25:
	addi	gp, gp, -1
	bnez	gp, ewd_26
	j	ew_srl
ewd_26:
	addi	gp, gp, -1
	bnez	gp, ewd_27
	j	ew_mul
ewd_27:
	addi	gp, gp, -1
	bnez	gp, ewd_28
	j	ew_divmod
ewd_28:
	j	ew_udivmod

# ══════════════════════════════════════════════════════════════════════════════
# parse_ident — reads an identifier at s2 into token buffer.
#   Call sites:  0: pi_ct    (compile_unary — IDENT primary)
#                1: pi_cs    (compile_stmt — IDENT-LHS dispatch)
#                2: pi_cs_pp (compile_stmt — '++IDENT;')
#                3: pi_cs_mm (compile_stmt — '--IDENT;')
# ══════════════════════════════════════════════════════════════════════════════
parse_ident:
	addi	s11, zero, 0
pi_loop:
	bge	s2, s3, pi_done
	lbu	t0, 0(s2)
	addi	t1, zero, 'a'
	blt	t0, t1, pi_uc
	addi	t1, zero, 123
	blt	t0, t1, pi_take
pi_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, pi_dig
	addi	t1, zero, 91
	blt	t0, t1, pi_take
pi_dig:
	addi	t1, zero, '0'
	blt	t0, t1, pi_us
	addi	t1, zero, 58
	blt	t0, t1, pi_take
pi_us:
	addi	t1, zero, '_'
	beq	t0, t1, pi_take
	j	pi_done
pi_take:
	add	t2, s10, s11
	sb	t0, 0(t2)
	addi	s11, s11, 1
	addi	s2, s2, 1
	j	pi_loop
pi_done:
	j	parse_ident_disp

parse_ident_disp:
	bnez	gp, pid_1
	j	pi_ct
pid_1:
	addi	gp, gp, -1
	bnez	gp, pid_2
	j	pi_cs
pid_2:
	addi	gp, gp, -1
	bnez	gp, pid_3
	j	pi_cs_pp
pid_3:
	j	pi_cs_mm

# ══════════════════════════════════════════════════════════════════════════════
# parse_num — parse decimal or hex at s2, returns value in a0.
#   Single caller:  pn_ct (compile_term)
# ══════════════════════════════════════════════════════════════════════════════
parse_num:
	addi	a0, zero, 0
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	bne	t0, t1, pn_dec
	addi	t2, s2, 1
	bge	t2, s3, pn_dec
	lbu	t0, 0(t2)
	addi	t1, zero, 'x'
	beq	t0, t1, pn_hex_begin
	addi	t1, zero, 'X'
	beq	t0, t1, pn_hex_begin
	j	pn_dec

pn_hex_begin:
	addi	s2, s2, 2
pn_hex_loop:
	bge	s2, s3, pn_done
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	blt	t0, t1, pn_done
	addi	t1, zero, 58
	blt	t0, t1, pn_hex_09
	addi	t1, zero, 'A'
	blt	t0, t1, pn_done
	addi	t1, zero, 71
	blt	t0, t1, pn_hex_uc
	addi	t1, zero, 'a'
	blt	t0, t1, pn_done
	addi	t1, zero, 103
	blt	t0, t1, pn_hex_lc
	j	pn_done
pn_hex_09:
	addi	t0, t0, -48
	j	pn_hex_acc
pn_hex_uc:
	addi	t0, t0, -65
	addi	t0, t0, 10
	j	pn_hex_acc
pn_hex_lc:
	addi	t0, t0, -97
	addi	t0, t0, 10
pn_hex_acc:
	slli	a0, a0, 4
	or	a0, a0, t0
	addi	s2, s2, 1
	j	pn_hex_loop

pn_dec:
pn_dec_loop:
	bge	s2, s3, pn_done
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	blt	t0, t1, pn_done
	addi	t1, zero, 58
	bge	t0, t1, pn_done
	addi	t0, t0, -48
	slli	t1, a0, 3
	slli	t2, a0, 1
	add	a0, t1, t2
	add	a0, a0, t0
	addi	s2, s2, 1
	j	pn_dec_loop

pn_done:
	j	pn_ct

# ══════════════════════════════════════════════════════════════════════════════
# lookup_or_alloc — find/allocate a variable slot.
#   Call sites:  0: la_ct (compile_term),  1: la_cs (compile_stmt)
# ══════════════════════════════════════════════════════════════════════════════
lookup_or_alloc:
	addi	t0, s7, 0		# scan ptr
la_scan:
	beq	t0, s8, la_new
	addi	t1, zero, 0
la_cmp:
	addi	t2, zero, 32
	beq	t1, t2, la_match
	add	t3, t0, t1
	lbu	t4, 0(t3)
	blt	t1, s11, la_in_tok
	bnez	t4, la_next
	addi	t1, t1, 1
	j	la_cmp
la_in_tok:
	add	t5, s10, t1
	lbu	t6, 0(t5)
	bne	t4, t6, la_next
	addi	t1, t1, 1
	j	la_cmp
la_match:
	lw	a0, 32(t0)
	j	lookup_or_alloc_disp
la_next:
	addi	t0, t0, 40
	j	la_scan

la_new:
	# Grow symtab if full (s8 has reached s0).
	# Growing doubles the capacity and copies the existing entries to a
	# fresh heap block at tp. No free — old block is leaked (bump alloc).
	bne	s8, s0, la_new_body
	sub	t0, s0, s7		# old_cap (bytes)
	slli	t1, t0, 1		# new_cap = 2 * old_cap
	addi	t2, tp, 0		# new_base = tp
	addi	t3, s7, 0		# src
	addi	t4, t2, 0		# dst
la_grow_cp:
	beq	t3, s8, la_grow_done
	lw	t5, 0(t3)
	sw	t5, 0(t4)
	addi	t3, t3, 4
	addi	t4, t4, 4
	j	la_grow_cp
la_grow_done:
	sub	t6, s8, s7		# used bytes
	addi	s7, t2, 0		# s7 = new base
	add	s8, s7, t6		# s8 = new write ptr
	add	s0, s7, t1		# s0 = new end
	add	tp, tp, t1		# bump heap past the new block
la_new_body:
	addi	t1, zero, 0
la_zero:
	addi	t2, zero, 40
	beq	t1, t2, la_zero_done
	add	t3, s8, t1
	sb	zero, 0(t3)
	addi	t1, t1, 1
	j	la_zero
la_zero_done:
	addi	t1, zero, 0
la_cp:
	beq	t1, s11, la_cp_done
	add	t2, s10, t1
	lbu	t3, 0(t2)
	add	t4, s8, t1
	sb	t3, 0(t4)
	addi	t1, t1, 1
	j	la_cp
la_cp_done:
	# New entry: store byte offset of this local in the frame (= current
	# frame_size), plus its size in bytes in the (formerly pad) size field.
	# All vars are 4 bytes today; arrays/structs will pass a size later.
	sw	s9, 32(s8)		# offset field = s9 (= next free byte offset)
	addi	t0, zero, 4		# size in bytes (hardcoded int = 4 for now)
	sw	t0, 36(s8)		# size field (was pad)
	addi	a0, s9, 0		# return byte offset
	addi	s9, s9, 4		# advance frame_size by this var's size
	addi	s8, s8, 40
	j	lookup_or_alloc_disp

lookup_or_alloc_disp:
	bnez	gp, la_d1
	j	la_ct
la_d1:
	addi	gp, gp, -1
	bnez	gp, la_d2
	j	la_cs
la_d2:
	addi	gp, gp, -1
	bnez	gp, la_d3
	j	la_cs_pp
la_d3:
	j	la_cs_mm

# ══════════════════════════════════════════════════════════════════════════════
# emit_li — emit "li a0, imm". imm passed in a0.
#   Single caller:  eli_ret (compile_term)
# ══════════════════════════════════════════════════════════════════════════════
emit_li:
	addi	sp, sp, -4
	sw	a0, 0(sp)		# save imm
	lw	t0, 0(sp)
	addi	t1, zero, 2047
	bgt	t0, t1, eli_big
	addi	t1, zero, -2048
	blt	t0, t1, eli_big

	# addi a0, zero, imm   —   word = 0x00000013 | (rd=10 << 7) | (imm << 20)
	lw	t2, 0(sp)
	andi	t2, t2, 0xFFF
	slli	t2, t2, 20
	lui	a0, 0
	addi	a0, a0, 0x513		# 0x13 | (10 << 7) = 0x513
	or	a0, a0, t2
	addi	gp, zero, 0		# ew site 0 = ew_li_s
	j	emit_word
ew_li_s:
	j	eli_pop

eli_big:
	# upper20 = (imm + 0x800) >>> 12 (arith shift)
	lw	t0, 0(sp)
	lui	t1, 0x1
	srli	t1, t1, 1		# 0x800
	add	t2, t0, t1
	srai	t2, t2, 12		# upper

	# lui a0, upper   —   word = 0x00000037 | (rd=10 << 7) | (upper << 12)
	lui	a0, 0
	addi	a0, a0, 0x537		# 0x37 | (10<<7) = 0x537
	slli	t2, t2, 12
	or	a0, a0, t2
	addi	gp, zero, 1		# ew site 1 = ew_li_lui
	j	emit_word
ew_li_lui:

	# addi a0, a0, lower12
	lw	t0, 0(sp)
	slli	t0, t0, 20
	srai	t0, t0, 20
	andi	t0, t0, 0xFFF
	slli	t0, t0, 20
	# word = 0x00050513   (addi a0, a0, 0) | imm
	lui	a0, 0x50
	addi	a0, a0, 0x513
	or	a0, a0, t0
	addi	gp, zero, 2		# ew site 2 = ew_li_add
	j	emit_word
ew_li_add:

eli_pop:
	addi	sp, sp, 4
	j	eli_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_lw_sp — emit "lw a0, offset(fp)". offset (bytes, positive) in a0.
#   Loads the local whose byte offset from fp is a0. fp never moves, so this
#   is unaffected by push/pop during expression evaluation.
#   Multi-caller — caller must set gp to its dispatch site.
#   Call sites:  0: elws_ret          (compile_unary ct_id)
#                1: elws_cs_inc_stmt  (compile_stmt '++' inc in place)
#                2: elws_cs_dec_stmt  (compile_stmt '--' dec in place)
#                3: elws_cs_plus      (compile_stmt '+=')
#                4: elws_cs_minus     (compile_stmt '-=')
#                5: elws_cs_xor       (compile_stmt '^=')
#                6: elws_cs_lshift    (compile_stmt '<<=')
#                7: elws_cs_rshift    (compile_stmt '>>=')
#                8: elws_cs_and       (compile_stmt '&=')
#                9: elws_cs_or        (compile_stmt '|=')
#               10: elws_cs_mul       (compile_stmt '*=')
#               11: elws_cs_div       (compile_stmt '/=')
#               12: elws_cs_mod       (compile_stmt '%=')
# ══════════════════════════════════════════════════════════════════════════════
emit_lw_sp:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# a0 = byte offset (0..frame_size-4, always positive)
	slli	t0, a0, 20		# imm12 → bits 31:20 (hi bits truncate)
	# Base lw a0, 0(fp):
	#   opcode=0x03, rd=10, f3=2, rs1=8(fp)
	#   word = 0x03 | (10<<7) | (2<<12) | (8<<15)
	#        = 0x03 | 0x500 | 0x2000 | 0x40000 = 0x00042503
	lui	a0, 0x42
	addi	a0, a0, 0x503
	or	a0, a0, t0
	addi	gp, zero, 3		# ew site 3 = ew_lws
	j	emit_word
ew_lws:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_lw_sp_disp

emit_lw_sp_disp:
	bnez	gp, elws_d1
	j	elws_ret
elws_d1:
	addi	gp, gp, -1
	bnez	gp, elws_d2
	j	elws_cs_inc_stmt
elws_d2:
	addi	gp, gp, -1
	bnez	gp, elws_d3
	j	elws_cs_dec_stmt
elws_d3:
	addi	gp, gp, -1
	bnez	gp, elws_d4
	j	elws_cs_plus
elws_d4:
	addi	gp, gp, -1
	bnez	gp, elws_d5
	j	elws_cs_minus
elws_d5:
	addi	gp, gp, -1
	bnez	gp, elws_d6
	j	elws_cs_xor
elws_d6:
	addi	gp, gp, -1
	bnez	gp, elws_d7
	j	elws_cs_lshift
elws_d7:
	addi	gp, gp, -1
	bnez	gp, elws_d8
	j	elws_cs_rshift
elws_d8:
	addi	gp, gp, -1
	bnez	gp, elws_d9
	j	elws_cs_and
elws_d9:
	addi	gp, gp, -1
	bnez	gp, elws_d10
	j	elws_cs_or
elws_d10:
	addi	gp, gp, -1
	bnez	gp, elws_d11
	j	elws_cs_mul
elws_d11:
	addi	gp, gp, -1
	bnez	gp, elws_d12
	j	elws_cs_div
elws_d12:
	j	elws_cs_mod

# ══════════════════════════════════════════════════════════════════════════════
# emit_sw_sp — emit "sw a0, offset(fp)". offset (bytes, positive) in a0.
#   Stores a0 into the local whose byte offset from fp is passed in.
#   Multi-caller — caller must set gp to its dispatch site.
#   Call sites:  0: esws_ret           (compile_stmt IDENT = expr)
#                1: esws_pre_inc       (compile_unary prefix '++')
#                2: esws_pre_dec       (compile_unary prefix '--')
#                3: esws_post_inc      (compile_unary postfix '++')
#                4: esws_post_dec      (compile_unary postfix '--')
#                5: esws_cs_inc_stmt   (compile_stmt '++IDENT;' / 'IDENT++;')
#                6: esws_cs_dec_stmt   (compile_stmt '--IDENT;' / 'IDENT--;')
#                7: esws_cs_plus       (compile_stmt 'IDENT += expr;')
#                8: esws_cs_minus      (compile_stmt 'IDENT -= expr;')
#                9: esws_cs_xor        (compile_stmt 'IDENT ^= expr;')
#               10: esws_cs_lshift     (compile_stmt 'IDENT <<= expr;')
#               11: esws_cs_rshift     (compile_stmt 'IDENT >>= expr;')
#               12: esws_cs_and        (compile_stmt 'IDENT &= expr;')
#               13: esws_cs_or         (compile_stmt 'IDENT |= expr;')
#               14: esws_cs_mul        (compile_stmt 'IDENT *= expr;')
#               15: esws_cs_div        (compile_stmt 'IDENT /= expr;')
#               16: esws_cs_mod        (compile_stmt 'IDENT %= expr;')
#               17: esws_cep_asg       (compile_expr_p 'IDENT = expr')
# ══════════════════════════════════════════════════════════════════════════════
emit_sw_sp:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# a0 = byte offset (0..frame_size-4, positive)
	# Base sw a0, 0(fp): opcode=0x23, f3=2, rs1=8(fp), rs2=10(a0)
	#   word = 0x23 | (2<<12) | (8<<15) | (10<<20)
	#        = 0x23 | 0x2000 | 0x40000 | 0xA00000 = 0x00A42023
	lui	t0, 0xA42
	addi	t0, t0, 0x023
	# imm[4:0] → bits[11:7]
	andi	t1, a0, 0x1F
	slli	t1, t1, 7
	or	t0, t0, t1
	# imm[11:5] → bits[31:25]   (positive offset, srai == srli here)
	srli	t1, a0, 5
	andi	t1, t1, 0x7F
	slli	t1, t1, 25
	or	t0, t0, t1
	addi	a0, t0, 0
	addi	gp, zero, 4		# ew site 4 = ew_sws
	j	emit_word
ew_sws:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sw_sp_disp

emit_sw_sp_disp:
	bnez	gp, esws_d1
	j	esws_ret
esws_d1:
	addi	gp, gp, -1
	bnez	gp, esws_d2
	j	esws_pre_inc
esws_d2:
	addi	gp, gp, -1
	bnez	gp, esws_d3
	j	esws_pre_dec
esws_d3:
	addi	gp, gp, -1
	bnez	gp, esws_d4
	j	esws_post_inc
esws_d4:
	addi	gp, gp, -1
	bnez	gp, esws_d5
	j	esws_post_dec
esws_d5:
	addi	gp, gp, -1
	bnez	gp, esws_d6
	j	esws_cs_inc_stmt
esws_d6:
	addi	gp, gp, -1
	bnez	gp, esws_d7
	j	esws_cs_dec_stmt
esws_d7:
	addi	gp, gp, -1
	bnez	gp, esws_d8
	j	esws_cs_plus
esws_d8:
	addi	gp, gp, -1
	bnez	gp, esws_d9
	j	esws_cs_minus
esws_d9:
	addi	gp, gp, -1
	bnez	gp, esws_d10
	j	esws_cs_xor
esws_d10:
	addi	gp, gp, -1
	bnez	gp, esws_d11
	j	esws_cs_lshift
esws_d11:
	addi	gp, gp, -1
	bnez	gp, esws_d12
	j	esws_cs_rshift
esws_d12:
	addi	gp, gp, -1
	bnez	gp, esws_d13
	j	esws_cs_and
esws_d13:
	addi	gp, gp, -1
	bnez	gp, esws_d14
	j	esws_cs_or
esws_d14:
	addi	gp, gp, -1
	bnez	gp, esws_d15
	j	esws_cs_mul
esws_d15:
	addi	gp, gp, -1
	bnez	gp, esws_d16
	j	esws_cs_div
esws_d16:
	addi	gp, gp, -1
	bnez	gp, esws_d17
	j	esws_cs_mod
esws_d17:
	j	esws_cep_asg

# ══════════════════════════════════════════════════════════════════════════════
# emit_lw_deref  — emit "lw a0, 0(a0)"
# ══════════════════════════════════════════════════════════════════════════════
emit_lw_deref:
	# opcode=0x03, rd=10, f3=2, rs1=10, imm=0
	# word = 0x03 | (10<<7) | (2<<12) | (10<<15) = 0x03 | 0x500 | 0x2000 | 0x50000
	#      = 0x00052503
	lui	a0, 0x52
	addi	a0, a0, 0x503
	addi	gp, zero, 5		# ew site 5 = ew_lwd
	j	emit_word
ew_lwd:
	j	elwd_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_lbu_deref — emit "lbu a0, 0(a0)"
# ══════════════════════════════════════════════════════════════════════════════
emit_lbu_deref:
	# opcode=0x03, f3=4, rd=10, rs1=10, imm=0
	# word = 0x03 | (10<<7) | (4<<12) | (10<<15) = 0x03 | 0x500 | 0x4000 | 0x50000
	#      = 0x00054503
	lui	a0, 0x54
	addi	a0, a0, 0x503
	addi	gp, zero, 6		# ew site 6 = ew_lbud
	j	emit_word
ew_lbud:
	j	elbud_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_push_a0 — emit "addi sp,sp,-4 ; sw a0,0(sp)"   (pushes a0 onto the
#   compiled program's stack).  Multi-caller (compile_expr, cs_star, cs_at),
#   so we save/restore gp around the inner emit_word calls.
#
# Call sites:  0: push_ca (compile_add '+'/'-' loop)
#              1: push_cs_star (cs_star, save address)
#              2: push_cs_at   (cs_at, save address)
#              3: push_ce     (compile_expr '^' loop)
#              4: push_cs_plus  (compile_stmt '+=' — save old LHS)
#              5: push_cs_minus (compile_stmt '-=' — save old LHS)
#              6: push_cs_xor   (compile_stmt '^=' — save old LHS)
#              7: push_csh      (compile_shift '<<'/'>>' loop)
#              8: push_cs_lshift (compile_stmt '<<=')
#              9: push_cs_rshift (compile_stmt '>>=')
#             10: push_cand     (compile_and '&' loop)
#             11: push_cs_and   (compile_stmt '&=')
#             12: push_cor      (compile_or '|' loop)
#             13: push_cs_or    (compile_stmt '|=')
#             14: push_ccmp     (compile_rel comparison loop)
#             15: push_ceq      (compile_expr equality '==' / '!=' loop)
#             16: push_cmul     (compile_mul '*' / '/' / '%' loop)
#             17: push_cs_mul   (compile_stmt '*=')
#             18: push_cs_div   (compile_stmt '/=')
#             19: push_cs_mod   (compile_stmt '%=')
#             20: push_cep      (compile_expr_p — Pratt binop pre-rhs)
#             21: push_cep_asg  (compile_expr_p — '@expr = val' / '*expr = val')
# ══════════════════════════════════════════════════════════════════════════════
emit_push_a0:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# addi sp, sp, -4  in the compiled program
	# opcode=0x13, rd=sp=2, rs1=sp=2, f3=0, imm=-4 (0xFFC)
	# word = 0x13 | (2<<7) | (2<<15) | (0xFFC<<20)
	#      = 0x13 | 0x100 | 0x10000 | 0xFFC00000 = 0xFFC10113
	lui	a0, 0xFFC10
	addi	a0, a0, 0x113
	addi	gp, zero, 7		# ew site 7 = ew_push_addi
	j	emit_word
ew_push_addi:
	# sw a0, 0(sp)  in the compiled program
	# opcode=0x23, rs1=sp=2, rs2=a0=10, f3=2, imm=0
	# word = 0x23 | (2<<12) | (2<<15) | (10<<20) = 0x00A12023
	lui	a0, 0xA12
	addi	a0, a0, 0x023
	addi	gp, zero, 8		# ew site 8 = ew_push_sw
	j	emit_word
ew_push_sw:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_push_a0_disp

emit_push_a0_disp:
	bnez	gp, epa_d1
	j	push_ca
epa_d1:
	addi	gp, gp, -1
	bnez	gp, epa_d2
	j	push_cs_star
epa_d2:
	addi	gp, gp, -1
	bnez	gp, epa_d3
	j	push_cs_at
epa_d3:
	addi	gp, gp, -1
	bnez	gp, epa_d4
	j	push_ce
epa_d4:
	addi	gp, gp, -1
	bnez	gp, epa_d5
	j	push_cs_plus
epa_d5:
	addi	gp, gp, -1
	bnez	gp, epa_d6
	j	push_cs_minus
epa_d6:
	addi	gp, gp, -1
	bnez	gp, epa_d7
	j	push_cs_xor
epa_d7:
	addi	gp, gp, -1
	bnez	gp, epa_d8
	j	push_csh
epa_d8:
	addi	gp, gp, -1
	bnez	gp, epa_d9
	j	push_cs_lshift
epa_d9:
	addi	gp, gp, -1
	bnez	gp, epa_d10
	j	push_cs_rshift
epa_d10:
	addi	gp, gp, -1
	bnez	gp, epa_d11
	j	push_cand
epa_d11:
	addi	gp, gp, -1
	bnez	gp, epa_d12
	j	push_cs_and
epa_d12:
	addi	gp, gp, -1
	bnez	gp, epa_d13
	j	push_cor
epa_d13:
	addi	gp, gp, -1
	bnez	gp, epa_d14
	j	push_cs_or
epa_d14:
	addi	gp, gp, -1
	bnez	gp, epa_d15
	j	push_ccmp
epa_d15:
	addi	gp, gp, -1
	bnez	gp, epa_d16
	j	push_ceq
epa_d16:
	addi	gp, gp, -1
	bnez	gp, epa_d17
	j	push_cmul
epa_d17:
	addi	gp, gp, -1
	bnez	gp, epa_d18
	j	push_cs_mul
epa_d18:
	addi	gp, gp, -1
	bnez	gp, epa_d19
	j	push_cs_div
epa_d19:
	addi	gp, gp, -1
	bnez	gp, epa_d20
	j	push_cs_mod
epa_d20:
	addi	gp, gp, -1
	bnez	gp, epa_d21
	j	push_cep
epa_d21:
	j	push_cep_asg

# ══════════════════════════════════════════════════════════════════════════════
# emit_pop_t0 — emit "lw t0,0(sp) ; addi sp,sp,4"  (pops top of the compiled
#   program's stack into its t0 register).  Multi-caller.
#
# Call sites:  0: pop_ca (compile_add, pop LHS for add/sub)
#              1: pop_cs_star (cs_star, pop address before sw)
#              2: pop_cs_at   (cs_at, pop address before sb)
#              3: pop_ce     (compile_expr '^' loop)
#              4: pop_cs_plus  (compile_stmt '+=' — pop old LHS)
#              5: pop_cs_minus (compile_stmt '-=' — pop old LHS)
#              6: pop_cs_xor   (compile_stmt '^=' — pop old LHS)
#              7: pop_csh      (compile_shift '<<'/'>>' loop)
#              8: pop_cs_lshift (compile_stmt '<<=')
#              9: pop_cs_rshift (compile_stmt '>>=')
#             10: pop_cand     (compile_and '&' loop)
#             11: pop_cs_and   (compile_stmt '&=')
#             12: pop_cor      (compile_or '|' loop)
#             13: pop_cs_or    (compile_stmt '|=')
#             14: pop_ccmp     (compile_rel comparison loop)
#             15: pop_ceq      (compile_expr equality '==' / '!=' loop)
#             16: pop_cmul     (compile_mul '*' / '/' / '%' loop)
#             17: pop_cs_mul   (compile_stmt '*=')
#             18: pop_cs_div   (compile_stmt '/=')
#             19: pop_cs_mod   (compile_stmt '%=')
#             20: pop_cep      (compile_expr_p — Pratt binop post-rhs)
#             21: pop_cep_asg  (compile_expr_p — deref assign, pop address)
# ══════════════════════════════════════════════════════════════════════════════
emit_pop_t0:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# lw t0, 0(sp)  in the compiled program
	# opcode=0x03, rd=t0=5, rs1=sp=2, f3=2, imm=0
	# word = 0x03 | (5<<7) | (2<<12) | (2<<15) = 0x03|0x280|0x2000|0x10000
	#      = 0x00012283
	lui	a0, 0x12
	addi	a0, a0, 0x283
	addi	gp, zero, 9		# ew site 9 = ew_pop_lw
	j	emit_word
ew_pop_lw:
	# addi sp, sp, 4  in the compiled program
	# opcode=0x13, rd=sp=2, rs1=sp=2, f3=0, imm=4
	# word = 0x13 | (2<<7) | (2<<15) | (4<<20) = 0x00410113
	lui	a0, 0x410
	addi	a0, a0, 0x113
	addi	gp, zero, 10		# ew site 10 = ew_pop_addi
	j	emit_word
ew_pop_addi:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_pop_t0_disp

emit_pop_t0_disp:
	bnez	gp, ept_d1
	j	pop_ca
ept_d1:
	addi	gp, gp, -1
	bnez	gp, ept_d2
	j	pop_cs_star
ept_d2:
	addi	gp, gp, -1
	bnez	gp, ept_d3
	j	pop_cs_at
ept_d3:
	addi	gp, gp, -1
	bnez	gp, ept_d4
	j	pop_ce
ept_d4:
	addi	gp, gp, -1
	bnez	gp, ept_d5
	j	pop_cs_plus
ept_d5:
	addi	gp, gp, -1
	bnez	gp, ept_d6
	j	pop_cs_minus
ept_d6:
	addi	gp, gp, -1
	bnez	gp, ept_d7
	j	pop_cs_xor
ept_d7:
	addi	gp, gp, -1
	bnez	gp, ept_d8
	j	pop_csh
ept_d8:
	addi	gp, gp, -1
	bnez	gp, ept_d9
	j	pop_cs_lshift
ept_d9:
	addi	gp, gp, -1
	bnez	gp, ept_d10
	j	pop_cs_rshift
ept_d10:
	addi	gp, gp, -1
	bnez	gp, ept_d11
	j	pop_cand
ept_d11:
	addi	gp, gp, -1
	bnez	gp, ept_d12
	j	pop_cs_and
ept_d12:
	addi	gp, gp, -1
	bnez	gp, ept_d13
	j	pop_cor
ept_d13:
	addi	gp, gp, -1
	bnez	gp, ept_d14
	j	pop_cs_or
ept_d14:
	addi	gp, gp, -1
	bnez	gp, ept_d15
	j	pop_ccmp
ept_d15:
	addi	gp, gp, -1
	bnez	gp, ept_d16
	j	pop_ceq
ept_d16:
	addi	gp, gp, -1
	bnez	gp, ept_d17
	j	pop_cmul
ept_d17:
	addi	gp, gp, -1
	bnez	gp, ept_d18
	j	pop_cs_mul
ept_d18:
	addi	gp, gp, -1
	bnez	gp, ept_d19
	j	pop_cs_div
ept_d19:
	addi	gp, gp, -1
	bnez	gp, ept_d20
	j	pop_cs_mod
ept_d20:
	addi	gp, gp, -1
	bnez	gp, ept_d21
	j	pop_cep
ept_d21:
	j	pop_cep_asg

# ══════════════════════════════════════════════════════════════════════════════
# emit_add — emit "add a0, t0, a0"    (caller just popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=0, f7=0
#   word = 0x00A28533
# Call sites: 0: ea_ret      (compile_add '+' loop)
#             1: ea_cs_plus  (compile_stmt '+=')
#             2: ea_cep      (compile_expr_p '+' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_add:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA28
	addi	a0, a0, 0x533
	addi	gp, zero, 11		# ew site 11 = ew_add
	j	emit_word
ew_add:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_add_disp

emit_add_disp:
	bnez	gp, ead_1
	j	ea_ret
ead_1:
	addi	gp, gp, -1
	bnez	gp, ead_2
	j	ea_cs_plus
ead_2:
	j	ea_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_sub — emit "sub a0, t0, a0"    (caller popped LHS into t0).
#   R-type: word = 0x40A28533
# Call sites: 0: es_ret       (compile_add '-' loop)
#             1: es_cs_minus  (compile_stmt '-=')
#             2: es_cep       (compile_expr_p '-' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_sub:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0x40A28
	addi	a0, a0, 0x533
	addi	gp, zero, 14		# ew site 14 = ew_sub
	j	emit_word
ew_sub:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sub_disp

emit_sub_disp:
	bnez	gp, esd_1
	j	es_ret
esd_1:
	addi	gp, gp, -1
	bnez	gp, esd_2
	j	es_cs_minus
esd_2:
	j	es_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_xor — emit "xor a0, t0, a0"    (caller popped LHS into t0).
#   R-type: word = 0x00A2C533
# Call sites: 0: ex_ret     (compile_expr '^' loop)
#             1: ex_cs_xor  (compile_stmt '^=')
#             2: ex_cep     (compile_expr_p '^' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_xor:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA2C
	addi	a0, a0, 0x533
	addi	gp, zero, 15		# ew site 15 = ew_xor
	j	emit_word
ew_xor:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_xor_disp

emit_xor_disp:
	bnez	gp, exd_1
	j	ex_ret
exd_1:
	addi	gp, gp, -1
	bnez	gp, exd_2
	j	ex_cs_xor
exd_2:
	j	ex_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_sll — emit "sll a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=1, f7=0
#   word = 0x33 | (10<<7) | (1<<12) | (5<<15) | (10<<20) = 0x00A29533
# Call sites: 0: esll_csh_ret   (compile_shift '<<' path)
#             1: esll_cs_lshift (compile_stmt '<<=')
#             2: esll_cep       (compile_expr_p '<<' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_sll:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA29
	addi	a0, a0, 0x533
	addi	gp, zero, 18		# ew site 18 = ew_sll
	j	emit_word
ew_sll:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sll_disp

emit_sll_disp:
	bnez	gp, esll_d1
	j	esll_csh_ret
esll_d1:
	addi	gp, gp, -1
	bnez	gp, esll_d2
	j	esll_cs_lshift
esll_d2:
	j	esll_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_sra — emit "sra a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=5, f7=0x20
#   word = 0x33 | (10<<7) | (5<<12) | (5<<15) | (10<<20) | (0x20<<25) = 0x40A2D533
# Call sites: 0: esra_csh_ret   (compile_shift '>>' path)
#             1: esra_cs_rshift (compile_stmt '>>=')
#             2: esra_cep       (compile_expr_p '>>' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_sra:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0x40A2D
	addi	a0, a0, 0x533
	addi	gp, zero, 19		# ew site 19 = ew_sra
	j	emit_word
ew_sra:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sra_disp

emit_sra_disp:
	bnez	gp, esra_d1
	j	esra_csh_ret
esra_d1:
	addi	gp, gp, -1
	bnez	gp, esra_d2
	j	esra_cs_rshift
esra_d2:
	j	esra_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_srl — emit "srl a0, t0, a0"    (logical/unsigned right shift).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=5, f7=0
#   word = 0x33 | (10<<7) | (5<<12) | (5<<15) | (10<<20) = 0x00A2D533
# Call sites: 0: esrl_csh_ret  (compile_shift '>>u' path)
#             1: esrl_cep      (compile_expr_p '>>u' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_srl:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA2D
	addi	a0, a0, 0x533
	addi	gp, zero, 25		# ew site 25 = ew_srl
	j	emit_word
ew_srl:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_srl_disp

emit_srl_disp:
	bnez	gp, esrl_d1
	j	esrl_csh_ret
esrl_d1:
	j	esrl_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_and — emit "and a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=7, f7=0
#   word = 0x33 | (10<<7) | (7<<12) | (5<<15) | (10<<20) = 0x00A2F533
# Call sites: 0: ean_cand_ret (compile_and '&' loop)
#             1: ean_cs_and   (compile_stmt '&=')
#             2: ean_cep      (compile_expr_p '&' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_and:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA2F
	addi	a0, a0, 0x533
	addi	gp, zero, 20		# ew site 20 = ew_and
	j	emit_word
ew_and:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_and_disp

emit_and_disp:
	bnez	gp, eand_d1
	j	ean_cand_ret
eand_d1:
	addi	gp, gp, -1
	bnez	gp, eand_d2
	j	ean_cs_and
eand_d2:
	j	ean_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_or — emit "or a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=6, f7=0
#   word = 0x33 | (10<<7) | (6<<12) | (5<<15) | (10<<20) = 0x00A2E533
# Call sites: 0: eor_cor_ret (compile_expr/or '|' loop)
#             1: eor_cs_or   (compile_stmt '|=')
#             2: eor_cep     (compile_expr_p '|' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_or:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA2E
	addi	a0, a0, 0x533
	addi	gp, zero, 21		# ew site 21 = ew_or
	j	emit_word
ew_or:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_or_disp

emit_or_disp:
	bnez	gp, eor_d1
	j	eor_cor_ret
eor_d1:
	addi	gp, gp, -1
	bnez	gp, eor_d2
	j	eor_cs_or
eor_d2:
	j	eor_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_xori_m1 — emit "xori a0, a0, -1"   (bitwise NOT of a0).
#   opcode=0x13, rd=10, f3=4, rs1=10, imm=0xFFF (-1 sign-extended)
#   word = 0x13 | (10<<7) | (4<<12) | (10<<15) | (0xFFF<<20) = 0xFFF54513
# Single caller: exori_ret (compile_unary cu_bnot).
# ══════════════════════════════════════════════════════════════════════════════
emit_xori_m1:
	lui	a0, 0xFFF54
	addi	a0, a0, 0x513
	addi	gp, zero, 22		# ew site 22 = ew_xori_m1
	j	emit_word
ew_xori_m1:
	j	exori_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_neg_a0 — emit "sub a0, zero, a0"   (two's-complement negation of a0).
#   R-type: opcode=0x33, rd=10, rs1=0(zero), rs2=10(a0), f3=0, f7=0x20
#   word = 0x33 | (10<<7) | (0<<15) | (10<<20) | (0x20<<25) = 0x40A00533
# Single caller: eneg_ret (compile_unary cu_uneg).
# ══════════════════════════════════════════════════════════════════════════════
emit_neg_a0:
	lui	a0, 0x40A00
	addi	a0, a0, 0x533
	addi	gp, zero, 23		# ew site 23 = ew_neg
	j	emit_word
ew_neg:
	j	eneg_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_cmp_word — store the instruction word in a0 and return to one of
#   several per-step continuations in compile_cmp. Used so comparisons can
#   emit 1- or 2-instruction sequences without needing a separate ew_* site
#   per step.
#
# Call sites (each is one step in a comparison's emit sequence):
#    0: ecw_lt_done   ('<'  after slt)
#    1: ecw_le_slt    ('<=' after slt-rev, before xori)
#    2: ecw_le_done   ('<=' after xori)
#    3: ecw_gt_done   ('>'  after slt-rev)
#    4: ecw_ge_slt    ('>=' after slt, before xori)
#    5: ecw_ge_done   ('>=' after xori)
#    6: ecw_eq_xor    ('==' after xor, before sltiu)
#    7: ecw_eq_done   ('==' after sltiu)
#    8: ecw_ne_xor    ('!=' after xor, before sltu)
#    9: ecw_ne_done   ('!=' after sltu)
#   10: ecw_ltu_done  ('<u' after sltu)
#   11: ecw_leu_sltu  ('<=u' after sltu-rev, before xori)
#   12: ecw_leu_done  ('<=u' after xori)
#   13: ecw_gtu_done  ('>u' after sltu-rev)
#   14: ecw_geu_sltu  ('>=u' after sltu, before xori)
#   15: ecw_geu_done  ('>=u' after xori)
#   16: ecw_cdiv_mv   (compile_mul '/' — after mv a0,t1)
#   17: ecw_cmod_mv   (compile_mul '%' — after mv a0,t2)
#   18: ecw_cs_div_mv (compile_stmt '/=' — after mv a0,t1)
#   19: ecw_cs_mod_mv (compile_stmt '%=' — after mv a0,t2)
#   20: ecw_cdivu_mv  (compile_mul '/u' — after mv a0,t1)
#   21: ecw_cmodu_mv  (compile_mul '%u' — after mv a0,t2)
#   22: ecw_cland_bne    (compile_land — after fixed bne +8)
#   23: ecw_cland_jal_sf (compile_land — after jal to SHORT_FALSE placeholder)
#   24: ecw_cland_sltu   (compile_land — after sltu normalize)
#   25: ecw_cland_jal_end (compile_land — after jal to END placeholder)
#   26: ecw_cland_addi   (compile_land — after addi a0,zero,0)
#   27: ecw_clor_beq     (compile_expr/|| — after fixed beq +8)
#   28: ecw_clor_jal_st  (compile_expr/|| — after jal to SHORT_TRUE placeholder)
#   29: ecw_clor_sltu    (compile_expr/|| — after sltu normalize)
#   30: ecw_clor_jal_end (compile_expr/|| — after jal to END placeholder)
#   31: ecw_clor_addi    (compile_expr/|| — after addi a0,zero,1)
#   32: ecw_ctern_bne     (compile_expr ternary — after fixed bne +8)
#   33: ecw_ctern_jal_else(compile_expr ternary — after jal to ELSE placeholder)
#   34: ecw_ctern_jal_end (compile_expr ternary — after jal to END placeholder)
#   35: ecw_ctern_addi    (compile_expr ternary — after addi for missing ':')
#   36: ecw_cep_div_mv    (compile_expr_p '/' — after mv a0,t1)
#   37: ecw_cep_mod_mv    (compile_expr_p '%' — after mv a0,t2)
#   38: ecw_cep_divu_mv   (compile_expr_p '/u' — after mv a0,t1)
#   39: ecw_cep_modu_mv   (compile_expr_p '%u' — after mv a0,t2)
#   40..55: Pratt comparison ops (each op's emit sequence done step-by-step)
#   40: ecw_cep_lt_done     (slt for '<')
#   41: ecw_cep_le_slt      (slt-rev for '<='; needs xori)
#   42: ecw_cep_le_done     (after xori for '<=')
#   43: ecw_cep_gt_done     (slt-rev for '>')
#   44: ecw_cep_ge_slt      (slt for '>='; needs xori)
#   45: ecw_cep_ge_done     (after xori for '>=')
#   46: ecw_cep_ltu_done    (sltu for '<u')
#   47: ecw_cep_leu_sltu    (sltu-rev for '<=u'; needs xori)
#   48: ecw_cep_leu_done    (after xori for '<=u')
#   49: ecw_cep_gtu_done    (sltu-rev for '>u')
#   50: ecw_cep_geu_sltu    (sltu for '>=u'; needs xori)
#   51: ecw_cep_geu_done    (after xori for '>=u')
#   52: ecw_cep_eq_xor      (xor for '=='; needs sltiu)
#   53: ecw_cep_eq_done     (after sltiu for '==')
#   54: ecw_cep_ne_xor      (xor for '!='; needs sltu-zero)
#   55: ecw_cep_ne_done     (after sltu-zero for '!=')
#   56..65: Pratt short-circuit && / ||
#   56: ecw_cep_land_bne    (&& — after fixed bne)
#   57: ecw_cep_land_jal_sf (&& — after jal SHORT_FALSE placeholder)
#   58: ecw_cep_land_sltu   (&& — after sltu normalize)
#   59: ecw_cep_land_jal_end(&& — after jal END placeholder)
#   60: ecw_cep_land_addi   (&& — after addi 0 for false-tail)
#   61: ecw_cep_lor_beq     (|| — after fixed beq)
#   62: ecw_cep_lor_jal_st  (|| — after jal SHORT_TRUE placeholder)
#   63: ecw_cep_lor_sltu    (|| — after sltu normalize)
#   64: ecw_cep_lor_jal_end (|| — after jal END placeholder)
#   65: ecw_cep_lor_addi    (|| — after addi 1 for true-tail)
#   66..69: Pratt ternary
#   66: ecw_cep_tern_bne    (? — after fixed bne)
#   67: ecw_cep_tern_jal_else (? — after jal ELSE placeholder)
#   68: ecw_cep_tern_jal_end  (? — after jal END placeholder)
#   69: ecw_cep_tern_addi   (? — after addi 0 for missing ':')
# ══════════════════════════════════════════════════════════════════════════════
emit_cmp_word:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	addi	gp, zero, 24		# ew site 24 = ew_cmp
	j	emit_word
ew_cmp:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_cmp_word_disp

emit_cmp_word_disp:
	bnez	gp, ecw_d1
	j	ecw_lt_done
ecw_d1:
	addi	gp, gp, -1
	bnez	gp, ecw_d2
	j	ecw_le_slt
ecw_d2:
	addi	gp, gp, -1
	bnez	gp, ecw_d3
	j	ecw_le_done
ecw_d3:
	addi	gp, gp, -1
	bnez	gp, ecw_d4
	j	ecw_gt_done
ecw_d4:
	addi	gp, gp, -1
	bnez	gp, ecw_d5
	j	ecw_ge_slt
ecw_d5:
	addi	gp, gp, -1
	bnez	gp, ecw_d6
	j	ecw_ge_done
ecw_d6:
	addi	gp, gp, -1
	bnez	gp, ecw_d7
	j	ecw_eq_xor
ecw_d7:
	addi	gp, gp, -1
	bnez	gp, ecw_d8
	j	ecw_eq_done
ecw_d8:
	addi	gp, gp, -1
	bnez	gp, ecw_d9
	j	ecw_ne_xor
ecw_d9:
	addi	gp, gp, -1
	bnez	gp, ecw_d10
	j	ecw_ne_done
ecw_d10:
	addi	gp, gp, -1
	bnez	gp, ecw_d11
	j	ecw_ltu_done
ecw_d11:
	addi	gp, gp, -1
	bnez	gp, ecw_d12
	j	ecw_leu_sltu
ecw_d12:
	addi	gp, gp, -1
	bnez	gp, ecw_d13
	j	ecw_leu_done
ecw_d13:
	addi	gp, gp, -1
	bnez	gp, ecw_d14
	j	ecw_gtu_done
ecw_d14:
	addi	gp, gp, -1
	bnez	gp, ecw_d15
	j	ecw_geu_sltu
ecw_d15:
	addi	gp, gp, -1
	bnez	gp, ecw_d16
	j	ecw_geu_done
ecw_d16:
	addi	gp, gp, -1
	bnez	gp, ecw_d17
	j	ecw_cdiv_mv
ecw_d17:
	addi	gp, gp, -1
	bnez	gp, ecw_d18
	j	ecw_cmod_mv
ecw_d18:
	addi	gp, gp, -1
	bnez	gp, ecw_d19
	j	ecw_cs_div_mv
ecw_d19:
	addi	gp, gp, -1
	bnez	gp, ecw_d20
	j	ecw_cs_mod_mv
ecw_d20:
	addi	gp, gp, -1
	bnez	gp, ecw_d21
	j	ecw_cdivu_mv
ecw_d21:
	addi	gp, gp, -1
	bnez	gp, ecw_d22
	j	ecw_cmodu_mv
ecw_d22:
	addi	gp, gp, -1
	bnez	gp, ecw_d23
	j	ecw_cland_bne
ecw_d23:
	addi	gp, gp, -1
	bnez	gp, ecw_d24
	j	ecw_cland_jal_sf
ecw_d24:
	addi	gp, gp, -1
	bnez	gp, ecw_d25
	j	ecw_cland_sltu
ecw_d25:
	addi	gp, gp, -1
	bnez	gp, ecw_d26
	j	ecw_cland_jal_end
ecw_d26:
	addi	gp, gp, -1
	bnez	gp, ecw_d27
	j	ecw_cland_addi
ecw_d27:
	addi	gp, gp, -1
	bnez	gp, ecw_d28
	j	ecw_clor_beq
ecw_d28:
	addi	gp, gp, -1
	bnez	gp, ecw_d29
	j	ecw_clor_jal_st
ecw_d29:
	addi	gp, gp, -1
	bnez	gp, ecw_d30
	j	ecw_clor_sltu
ecw_d30:
	addi	gp, gp, -1
	bnez	gp, ecw_d31
	j	ecw_clor_jal_end
ecw_d31:
	addi	gp, gp, -1
	bnez	gp, ecw_d32
	j	ecw_clor_addi
ecw_d32:
	addi	gp, gp, -1
	bnez	gp, ecw_d33
	j	ecw_ctern_bne
ecw_d33:
	addi	gp, gp, -1
	bnez	gp, ecw_d34
	j	ecw_ctern_jal_else
ecw_d34:
	addi	gp, gp, -1
	bnez	gp, ecw_d35
	j	ecw_ctern_jal_end
ecw_d35:
	addi	gp, gp, -1
	bnez	gp, ecw_d36
	j	ecw_ctern_addi
ecw_d36:
	addi	gp, gp, -1
	bnez	gp, ecw_d37
	j	ecw_cep_div_mv
ecw_d37:
	addi	gp, gp, -1
	bnez	gp, ecw_d38
	j	ecw_cep_mod_mv
ecw_d38:
	addi	gp, gp, -1
	bnez	gp, ecw_d39
	j	ecw_cep_divu_mv
ecw_d39:
	addi	gp, gp, -1
	bnez	gp, ecw_d40
	j	ecw_cep_modu_mv
ecw_d40:
	addi	gp, gp, -1
	bnez	gp, ecw_d41
	j	ecw_cep_lt_done
ecw_d41:
	addi	gp, gp, -1
	bnez	gp, ecw_d42
	j	ecw_cep_le_slt
ecw_d42:
	addi	gp, gp, -1
	bnez	gp, ecw_d43
	j	ecw_cep_le_done
ecw_d43:
	addi	gp, gp, -1
	bnez	gp, ecw_d44
	j	ecw_cep_gt_done
ecw_d44:
	addi	gp, gp, -1
	bnez	gp, ecw_d45
	j	ecw_cep_ge_slt
ecw_d45:
	addi	gp, gp, -1
	bnez	gp, ecw_d46
	j	ecw_cep_ge_done
ecw_d46:
	addi	gp, gp, -1
	bnez	gp, ecw_d47
	j	ecw_cep_ltu_done
ecw_d47:
	addi	gp, gp, -1
	bnez	gp, ecw_d48
	j	ecw_cep_leu_sltu
ecw_d48:
	addi	gp, gp, -1
	bnez	gp, ecw_d49
	j	ecw_cep_leu_done
ecw_d49:
	addi	gp, gp, -1
	bnez	gp, ecw_d50
	j	ecw_cep_gtu_done
ecw_d50:
	addi	gp, gp, -1
	bnez	gp, ecw_d51
	j	ecw_cep_geu_sltu
ecw_d51:
	addi	gp, gp, -1
	bnez	gp, ecw_d52
	j	ecw_cep_geu_done
ecw_d52:
	addi	gp, gp, -1
	bnez	gp, ecw_d53
	j	ecw_cep_eq_xor
ecw_d53:
	addi	gp, gp, -1
	bnez	gp, ecw_d54
	j	ecw_cep_eq_done
ecw_d54:
	addi	gp, gp, -1
	bnez	gp, ecw_d55
	j	ecw_cep_ne_xor
ecw_d55:
	addi	gp, gp, -1
	bnez	gp, ecw_d56
	j	ecw_cep_ne_done
ecw_d56:
	addi	gp, gp, -1
	bnez	gp, ecw_d57
	j	ecw_cep_land_bne
ecw_d57:
	addi	gp, gp, -1
	bnez	gp, ecw_d58
	j	ecw_cep_land_jal_sf
ecw_d58:
	addi	gp, gp, -1
	bnez	gp, ecw_d59
	j	ecw_cep_land_sltu
ecw_d59:
	addi	gp, gp, -1
	bnez	gp, ecw_d60
	j	ecw_cep_land_jal_end
ecw_d60:
	addi	gp, gp, -1
	bnez	gp, ecw_d61
	j	ecw_cep_land_addi
ecw_d61:
	addi	gp, gp, -1
	bnez	gp, ecw_d62
	j	ecw_cep_lor_beq
ecw_d62:
	addi	gp, gp, -1
	bnez	gp, ecw_d63
	j	ecw_cep_lor_jal_st
ecw_d63:
	addi	gp, gp, -1
	bnez	gp, ecw_d64
	j	ecw_cep_lor_sltu
ecw_d64:
	addi	gp, gp, -1
	bnez	gp, ecw_d65
	j	ecw_cep_lor_jal_end
ecw_d65:
	addi	gp, gp, -1
	bnez	gp, ecw_d66
	j	ecw_cep_lor_addi
ecw_d66:
	addi	gp, gp, -1
	bnez	gp, ecw_d67
	j	ecw_cep_tern_bne
ecw_d67:
	addi	gp, gp, -1
	bnez	gp, ecw_d68
	j	ecw_cep_tern_jal_else
ecw_d68:
	addi	gp, gp, -1
	bnez	gp, ecw_d69
	j	ecw_cep_tern_jal_end
ecw_d69:
	j	ecw_cep_tern_addi

# ══════════════════════════════════════════════════════════════════════════════
# emit_addi_a0_1 — emit "addi a0, a0, 1"
#   opcode=0x13, rd=10, f3=0, rs1=10, imm=1
#   word = 0x13 | (10<<7) | (10<<15) | (1<<20) = 0x00150513
# Multi-caller. Call sites:
#   0: eaa1_pre_inc       (compile_unary prefix '++')
#   1: eaa1_post_inc      (compile_unary postfix '++' — emit new value)
#   2: eaa1_post_dec_undo (compile_unary postfix '--' — restore old value)
#   3: eaa1_cs_inc_stmt   (compile_stmt '++IDENT;' / 'IDENT++;')
# ══════════════════════════════════════════════════════════════════════════════
emit_addi_a0_1:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0x150
	addi	a0, a0, 0x513
	addi	gp, zero, 16		# ew site 16 = ew_addi1
	j	emit_word
ew_addi1:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_addi_a0_1_disp

emit_addi_a0_1_disp:
	bnez	gp, eaa1_d1
	j	eaa1_pre_inc
eaa1_d1:
	addi	gp, gp, -1
	bnez	gp, eaa1_d2
	j	eaa1_post_inc
eaa1_d2:
	addi	gp, gp, -1
	bnez	gp, eaa1_d3
	j	eaa1_post_dec_undo
eaa1_d3:
	j	eaa1_cs_inc_stmt

# ══════════════════════════════════════════════════════════════════════════════
# emit_addi_a0_m1 — emit "addi a0, a0, -1"
#   opcode=0x13, rd=10, f3=0, rs1=10, imm=0xFFF (-1 sign-extended)
#   word = 0x13 | (10<<7) | (10<<15) | (0xFFF<<20) = 0xFFF50513
# Multi-caller. Call sites:
#   0: eaam1_pre_dec       (compile_unary prefix '--')
#   1: eaam1_post_inc_undo (compile_unary postfix '++' — restore old value)
#   2: eaam1_post_dec      (compile_unary postfix '--' — emit new value)
#   3: eaam1_cs_dec_stmt   (compile_stmt '--IDENT;' / 'IDENT--;')
# ══════════════════════════════════════════════════════════════════════════════
emit_addi_a0_m1:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xFFF50
	addi	a0, a0, 0x513
	addi	gp, zero, 17		# ew site 17 = ew_addim1
	j	emit_word
ew_addim1:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_addi_a0_m1_disp

emit_addi_a0_m1_disp:
	bnez	gp, eaam1_d1
	j	eaam1_pre_dec
eaam1_d1:
	addi	gp, gp, -1
	bnez	gp, eaam1_d2
	j	eaam1_post_inc_undo
eaam1_d2:
	addi	gp, gp, -1
	bnez	gp, eaam1_d3
	j	eaam1_post_dec
eaam1_d3:
	j	eaam1_cs_dec_stmt

# ══════════════════════════════════════════════════════════════════════════════
# emit_sw_deref — emit "sw a0, 0(t0)"   (caller just popped addr into t0).
#   opcode=0x23, f3=2, rs1=5(t0), rs2=10(a0), imm=0
#   word = 0x23 | (2<<12) | (5<<15) | (10<<20) = 0x00A2A023
# Call sites: 0: esw_ret      (compile_stmt cs_star)
#             1: esw_cep_asg  (compile_expr_p '*expr = val')
# ══════════════════════════════════════════════════════════════════════════════
emit_sw_deref:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA2A
	addi	a0, a0, 0x023
	addi	gp, zero, 12		# ew site 12 = ew_sw_d
	j	emit_word
ew_sw_d:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sw_deref_disp

emit_sw_deref_disp:
	bnez	gp, esw_d1
	j	esw_ret
esw_d1:
	j	esw_cep_asg

# ══════════════════════════════════════════════════════════════════════════════
# emit_sb_deref — emit "sb a0, 0(t0)"
#   opcode=0x23, f3=0, rs1=5(t0), rs2=10(a0), imm=0
#   word = 0x23 | (0<<12) | (5<<15) | (10<<20) = 0x00A28023
# Call sites: 0: esb_ret      (compile_stmt cs_at)
#             1: esb_cep_asg  (compile_expr_p '@expr = val')
# ══════════════════════════════════════════════════════════════════════════════
emit_sb_deref:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xA28
	addi	a0, a0, 0x023
	addi	gp, zero, 13		# ew site 13 = ew_sb_d
	j	emit_word
ew_sb_d:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sb_deref_disp

emit_sb_deref_disp:
	bnez	gp, esb_d1
	j	esb_ret
esb_d1:
	j	esb_cep_asg

# ══════════════════════════════════════════════════════════════════════════════
# Expression compilation — precedence-climbing, three layers:
#
#   compile_expr  := compile_add ('^' compile_add)*            # xor layer
#   compile_add   := compile_unary (('+' | '-') compile_unary)*# additive layer
#   compile_unary := ('*' | '@') compile_unary | primary       # unary layer
#   primary       := NUM | IDENT
#
# Sub-step A (now): the three layers exist but only `+` is implemented (in
# compile_add). compile_expr is a degenerate wrapper with no body and
# compile_unary has the current compile_term logic. Sub-steps B/C/D/E will
# fill in `-`, `^`, `++`/`--`, and compound assignment.
#
# Dispatch site namespaces:
#   compile_unary:  cu_ca_first (from compile_add, before loop)
#                   cu_ca_next  (from compile_add, loop body)
#   compile_add:    ca_ce_first (from compile_expr; only one site today)
#   compile_expr:   ce_cs_rhs, ce_cs_addr1, ce_cs_val1, ce_cs_addr2, ce_cs_val2
# ══════════════════════════════════════════════════════════════════════════════

# ── compile_unary ────────────────────────────────────────────────────────────
# emits code that leaves a unary's value in a0.
#   unary := ('*' | '@' | '++' | '--' | '~' | '-') unary
#          | primary ('++' | '--')?
# Prefix/postfix '++'/'--' apply to bare identifiers only. Unary '~' and '-'
# re-enter compile_unary and emit their op after the nested call returns, so
# they compose and chain naturally (e.g. `-~x`, `~~x`).
#
# Frame (12 bytes):
#   0(sp): saved gp
#   4(sp): deref_kind   (0=none, 1=word '*', 2=byte '@')
#   8(sp): incdec_kind  (0=none, 1=prefix++, 2=prefix--)
#
# Call sites:  0: cu_cmul_first (compile_mul, first unary)
#              1: cu_cmul_next  (compile_mul, unary after '*')
#              2: cu_uneg       (compile_unary, after unary '-' recursion)
#              3: cu_bnot       (compile_unary, after unary '~' recursion)
#              4: cu_cep_nud    (compile_expr_p — Pratt nud call)
compile_unary:
	addi	sp, sp, -12
	sw	gp, 0(sp)
	sw	zero, 4(sp)
	sw	zero, 8(sp)

	# Reset the lvalue marker at entry. It'll be set to 1/2/3 below if the
	# primary we parse turns out to be a simple lvalue form (IDENT / @expr /
	# *expr) with no prefix/postfix operators that would invalidate it.
	lla	t0, lv_kind
	sw	zero, 0(t0)

	addi	gp, zero, 1
	j	skip_ws
sw_ct_pre:
	bge	s2, s3, ct_bad

	lbu	t0, 0(s2)
	addi	t1, zero, 42		# '*'
	beq	t0, t1, ct_is_star
	addi	t1, zero, 64		# '@'
	beq	t0, t1, ct_is_at
	addi	t1, zero, '+'
	beq	t0, t1, ct_chk_pp
	addi	t1, zero, '-'
	beq	t0, t1, ct_chk_minus
	addi	t1, zero, '~'
	beq	t0, t1, ct_uneg_tilde
	j	ct_primary

ct_is_star:
	addi	s2, s2, 1
	addi	t1, zero, 1
	sw	t1, 4(sp)
	addi	gp, zero, 2
	j	skip_ws
sw_ct_star:
	j	ct_primary

ct_is_at:
	addi	s2, s2, 1
	addi	t1, zero, 2
	sw	t1, 4(sp)
	addi	gp, zero, 3
	j	skip_ws
sw_ct_at:
	j	ct_primary

ct_chk_pp:
	# Need s2+1 < s3 and s2[1] == '+'; otherwise bare '+' is a parse error
	# (we have no unary plus).
	addi	t2, s2, 1
	bge	t2, s3, ct_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '+'
	bne	t0, t1, ct_bad
	addi	s2, s2, 2
	addi	t1, zero, 1
	sw	t1, 8(sp)		# incdec_kind = 1 (prefix ++)
	addi	gp, zero, 12		# skip_ws site 12 = sw_ct_pp
	j	skip_ws
sw_ct_pp:
	j	ct_primary

ct_chk_minus:
	# Lookahead: '--' is prefix decrement, otherwise unary negation.
	addi	t2, s2, 1
	bge	t2, s3, ct_uneg
	lbu	t0, 0(t2)
	addi	t1, zero, '-'
	beq	t0, t1, ct_chk_mm
	j	ct_uneg

ct_chk_mm:
	addi	s2, s2, 2
	addi	t1, zero, 2
	sw	t1, 8(sp)		# incdec_kind = 2 (prefix --)
	addi	gp, zero, 13		# skip_ws site 13 = sw_ct_mm
	j	skip_ws
sw_ct_mm:
	j	ct_primary

ct_uneg:
	# Unary '-' : consume, recurse compile_unary, then emit neg.
	addi	s2, s2, 1
	addi	gp, zero, 2		# cu site 2 = cu_uneg
	j	compile_unary
cu_uneg:
	j	emit_neg_a0
eneg_ret:
	j	ct_done

ct_uneg_tilde:
	# Unary '~' : consume, recurse compile_unary, then emit bitwise NOT.
	addi	s2, s2, 1
	addi	gp, zero, 3		# cu site 3 = cu_bnot
	j	compile_unary
cu_bnot:
	j	emit_xori_m1
exori_ret:
	j	ct_done

ct_primary:
	bge	s2, s3, ct_bad
	lbu	t0, 0(s2)
	# Digit?
	addi	t1, zero, '0'
	blt	t0, t1, ct_not_num
	addi	t1, zero, 58
	blt	t0, t1, ct_num
ct_not_num:
	# Letter or underscore?
	addi	t1, zero, 'a'
	blt	t0, t1, ct_not_lc
	addi	t1, zero, 123
	blt	t0, t1, ct_id
ct_not_lc:
	addi	t1, zero, 'A'
	blt	t0, t1, ct_not_uc
	addi	t1, zero, 91
	blt	t0, t1, ct_id
ct_not_uc:
	addi	t1, zero, '_'
	beq	t0, t1, ct_id
	addi	t1, zero, '('
	beq	t0, t1, ct_lparen
	addi	t1, zero, '{'
	beq	t0, t1, ct_lbrace
	j	ct_bad

ct_num:
	# '++'/'--' are invalid on numeric literals.
	lw	t0, 8(sp)
	bnez	t0, ct_bad_literal_pp
	j	parse_num
pn_ct:
	j	emit_li
eli_ret:
	j	ct_deref

ct_id:
	addi	gp, zero, 0
	j	parse_ident
pi_ct:
	addi	gp, zero, 0
	j	lookup_or_alloc
la_ct:
	# a0 = byte offset of the variable. Stash it for potential reuse by
	# prefix/postfix '++'/'--' (emit_lw_sp/emit_sw_sp both clobber a0).
	# Frame shift by +4: gp@4, deref_kind@8, incdec_kind@12, saved off@0.
	addi	sp, sp, -4
	sw	a0, 0(sp)
	addi	gp, zero, 0		# elws site 0 = elws_ret
	j	emit_lw_sp
elws_ret:
	# Was there a prefix '++' or '--'?
	lw	t0, 12(sp)
	bnez	t0, ct_id_prefix_emit
	# No prefix. A deref prefix ('*'/'@') means we ignore any '++'/'--'
	# after the ident and fall through to the deref emitter.
	lw	t0, 8(sp)
	bnez	t0, ct_id_pop_then_deref
	# Otherwise check for postfix '++'/'--'.
	addi	gp, zero, 14		# skip_ws site 14 = sw_ct_post
	j	skip_ws
sw_ct_post:
	bge	s2, s3, ct_id_nopf
	lbu	t0, 0(s2)
	addi	t1, zero, '+'
	beq	t0, t1, ct_pf_chkpp
	addi	t1, zero, '-'
	beq	t0, t1, ct_pf_chkmm
	j	ct_id_nopf
ct_pf_chkpp:
	addi	t2, s2, 1
	bge	t2, s3, ct_id_nopf
	lbu	t0, 0(t2)
	addi	t1, zero, '+'
	bne	t0, t1, ct_id_nopf
	addi	s2, s2, 2
	j	ct_do_post_inc
ct_pf_chkmm:
	addi	t2, s2, 1
	bge	t2, s3, ct_id_nopf
	lbu	t0, 0(t2)
	addi	t1, zero, '-'
	bne	t0, t1, ct_id_nopf
	addi	s2, s2, 2
	j	ct_do_post_dec

ct_id_nopf:
	# No postfix; pure IDENT lvalue. Record slot offset and mark lv_kind = 1.
	lw	t0, 0(sp)
	addi	sp, sp, 4
	lla	t1, lv_slot
	sw	t0, 0(t1)
	lla	t1, lv_kind
	addi	t0, zero, 1
	sw	t0, 0(t1)
	j	ct_done

ct_id_pop_then_deref:
	# Prefix '*'/'@' active; discard saved offset and emit the deref.
	addi	sp, sp, 4
	j	ct_deref

ct_id_prefix_emit:
	# t0 holds incdec_kind (1 = ++, 2 = --). If a deref prefix is also
	# set, the combination isn't supported in this pass.
	lw	t1, 8(sp)
	bnez	t1, ct_bad_prefix_combo
	addi	t2, zero, 1
	beq	t0, t2, ct_pre_inc_emit
	j	ct_pre_dec_emit

ct_pre_inc_emit:
	addi	gp, zero, 0		# eaa1 site 0 = eaa1_pre_inc
	j	emit_addi_a0_1
eaa1_pre_inc:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 1		# esws site 1 = esws_pre_inc
	j	emit_sw_sp
esws_pre_inc:
	j	ct_done

ct_pre_dec_emit:
	addi	gp, zero, 0		# eaam1 site 0 = eaam1_pre_dec
	j	emit_addi_a0_m1
eaam1_pre_dec:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 2		# esws site 2 = esws_pre_dec
	j	emit_sw_sp
esws_pre_dec:
	j	ct_done

ct_do_post_inc:
	# Runtime seq: a0 = old x; addi a0,a0,1; sw a0,off(fp); addi a0,a0,-1.
	addi	gp, zero, 1		# eaa1 site 1 = eaa1_post_inc
	j	emit_addi_a0_1
eaa1_post_inc:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 3		# esws site 3 = esws_post_inc
	j	emit_sw_sp
esws_post_inc:
	addi	gp, zero, 1		# eaam1 site 1 = eaam1_post_inc_undo
	j	emit_addi_a0_m1
eaam1_post_inc_undo:
	j	ct_done

ct_do_post_dec:
	# Runtime seq: a0 = old x; addi a0,a0,-1; sw a0,off(fp); addi a0,a0,1.
	addi	gp, zero, 2		# eaam1 site 2 = eaam1_post_dec
	j	emit_addi_a0_m1
eaam1_post_dec:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 4		# esws site 4 = esws_post_dec
	j	emit_sw_sp
esws_post_dec:
	addi	gp, zero, 2		# eaa1 site 2 = eaa1_post_dec_undo
	j	emit_addi_a0_1
eaa1_post_dec_undo:
	j	ct_done

ct_lparen:
	# '(' expr ')' as a primary. Consume '(', compile expr, then expect ')'.
	# A preceding '*'/'@' deref_kind (if any) is applied on the way out via
	# ct_deref. '++'/'--' never reach ct_primary with a valid incdec_kind set
	# against a paren, because those prefix handlers fall into ct_num/ct_id
	# only paths; any such pairing errors at ct_primary itself.
	addi	s2, s2, 1
	addi	t6, zero, 0		# min_bp = 0: any expr allowed inside parens
	addi	gp, zero, 12		# compile_expr site 12 = ce_ct_paren
	j	compile_expr_p
ce_ct_paren:
	addi	gp, zero, 21		# skip_ws site 21 = sw_ct_rparen
	j	skip_ws
sw_ct_rparen:
	bge	s2, s3, ct_bad_rparen
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	bne	t0, t1, ct_bad_rparen
	addi	s2, s2, 1
	j	ct_deref

ct_lbrace:
	# '{' expr (';' expr)* '}'
	# Rust-style block: value is that of the last expression. Each non-final
	# expression's value is simply overwritten in a0 by the next one (no stack
	# cleanup needed since values live only in a0).
	addi	s2, s2, 1
ct_blk_loop:
	addi	t6, zero, 0		# min_bp = 0: full expression allowed
	addi	gp, zero, 25		# compile_expr site 25 = ce_ct_blk_rec
	j	compile_expr_p
ce_ct_blk_rec:
	addi	gp, zero, 31		# skip_ws site 31 = sw_ct_blk_sep
	j	skip_ws
sw_ct_blk_sep:
	bge	s2, s3, ct_bad_brace_sep
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, ct_blk_end
	addi	t1, zero, ';'
	bne	t0, t1, ct_bad_brace_sep
	addi	s2, s2, 1
	j	ct_blk_loop
ct_blk_end:
	addi	s2, s2, 1
	# The block result is never an lvalue (even if its last expr was an
	# IDENT) — reset lv_kind so `{ x } = 5` isn't silently accepted.
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	ct_deref

ct_deref:
	lw	t0, 4(sp)
	beqz	t0, ct_done
	addi	t1, zero, 1
	beq	t0, t1, ct_deref_w
	j	emit_lbu_deref
elbud_ret:
	# Byte deref is an lvalue: `@expr = val` is valid. Mark lv_kind = 2.
	# (The address was in a0 before the lbu we just emitted; the assignment
	# handler will un-emit the lbu to recover that address.)
	lla	t0, lv_kind
	addi	t1, zero, 2
	sw	t1, 0(t0)
	j	ct_done
ct_deref_w:
	j	emit_lw_deref
elwd_ret:
	# Word deref is an lvalue: `*expr = val` is valid. Mark lv_kind = 3.
	lla	t0, lv_kind
	addi	t1, zero, 3
	sw	t1, 0(t0)
	j	ct_done

ct_bad:
	addi	a0, zero, 5		# err 5: expected expression
	j	report_err
ct_bad_rparen:
	addi	a0, zero, 2		# err 2: expected ')'
	j	report_err
ct_bad_brace_sep:
	addi	a0, zero, 3		# err 3: expected '}' or ';'
	j	report_err
ct_bad_literal_pp:
	addi	a0, zero, 21		# err 21: '++'/'--' requires an lvalue
	j	report_err
ct_bad_prefix_combo:
	addi	a0, zero, 22		# err 22: cannot combine deref and ++/--
	j	report_err

ct_done:
	lw	gp, 0(sp)
	addi	sp, sp, 12
	j	compile_unary_disp

compile_unary_disp:
	bnez	gp, cud_1
	j	cu_cmul_first
cud_1:
	addi	gp, gp, -1
	bnez	gp, cud_2
	j	cu_cmul_next
cud_2:
	addi	gp, gp, -1
	bnez	gp, cud_3
	j	cu_uneg
cud_3:
	addi	gp, gp, -1
	bnez	gp, cud_4
	j	cu_bnot
cud_4:
	j	cu_cep_nud

# ══════════════════════════════════════════════════════════════════════════════
# Dead-parser compatibility stubs — labels referenced by dispatch-table entries
# whose sites are never set by the Pratt parser or any live caller. They exist
# solely so the fam3 assembler can resolve references in those (unreachable)
# dispatch entries. All halt via halt_err if ever reached.
# ══════════════════════════════════════════════════════════════════════════════
ce_tern_else:
ce_tern_mid:
cu_cmul_first:
cu_cmul_next:
ean_cand_ret:
ea_ret:
ecw_cdiv_mv:
ecw_cdivu_mv:
ecw_cland_addi:
ecw_cland_bne:
ecw_cland_jal_end:
ecw_cland_jal_sf:
ecw_cland_sltu:
ecw_clor_addi:
ecw_clor_beq:
ecw_clor_jal_end:
ecw_clor_jal_st:
ecw_clor_sltu:
ecw_cmod_mv:
ecw_cmodu_mv:
ecw_ctern_addi:
ecw_ctern_bne:
ecw_ctern_jal_else:
ecw_ctern_jal_end:
ecw_eq_done:
ecw_eq_xor:
ecw_ge_done:
ecw_ge_slt:
ecw_geu_done:
ecw_geu_sltu:
ecw_gt_done:
ecw_gtu_done:
ecw_le_done:
ecw_le_slt:
ecw_leu_done:
ecw_leu_sltu:
ecw_lt_done:
ecw_ltu_done:
ecw_ne_done:
ecw_ne_xor:
edmb_cdiv_ret:
edmb_cmod_ret:
emul_cmul_ret:
eor_cor_ret:
esll_csh_ret:
esra_csh_ret:
es_ret:
esrl_csh_ret:
eudmb_cdivu_ret:
eudmb_cmodu_ret:
ex_ret:
pjt_cland_end:
pjt_cland_sf:
pjt_clor_end:
pjt_clor_st:
pjt_ctern_else:
pjt_ctern_end:
pop_ca:
pop_cand:
pop_ccmp:
pop_ce:
pop_ceq:
pop_cmul:
pop_cor:
pop_csh:
push_ca:
push_cand:
push_ccmp:
push_ce:
push_ceq:
push_cmul:
push_cor:
push_csh:
sw_cand_and:
sw_ca_plus:
sw_ccmp_op:
sw_ceq_op:
sw_ce_xor:
sw_cland_op:
sw_clor_op:
sw_cmul_op:
sw_cor_or:
sw_csh_op:
sw_ctern_colon:
sw_ctern_op:
	j	halt_err

compile_expr_disp:
	bnez	gp, ced_1
	j	ce_cs_rhs
ced_1:
	addi	gp, gp, -1
	bnez	gp, ced_2
	j	ce_cs_addr1
ced_2:
	addi	gp, gp, -1
	bnez	gp, ced_3
	j	ce_cs_val1
ced_3:
	addi	gp, gp, -1
	bnez	gp, ced_4
	j	ce_cs_addr2
ced_4:
	addi	gp, gp, -1
	bnez	gp, ced_5
	j	ce_cs_val2
ced_5:
	addi	gp, gp, -1
	bnez	gp, ced_6
	j	ce_cs_plus
ced_6:
	addi	gp, gp, -1
	bnez	gp, ced_7
	j	ce_cs_minus
ced_7:
	addi	gp, gp, -1
	bnez	gp, ced_8
	j	ce_cs_xor
ced_8:
	addi	gp, gp, -1
	bnez	gp, ced_9
	j	ce_cs_lshift
ced_9:
	addi	gp, gp, -1
	bnez	gp, ced_10
	j	ce_cs_rshift
ced_10:
	addi	gp, gp, -1
	bnez	gp, ced_11
	j	ce_cs_and
ced_11:
	addi	gp, gp, -1
	bnez	gp, ced_12
	j	ce_cs_or
ced_12:
	addi	gp, gp, -1
	bnez	gp, ced_13
	j	ce_ct_paren
ced_13:
	addi	gp, gp, -1
	bnez	gp, ced_14
	j	ce_cs_mul
ced_14:
	addi	gp, gp, -1
	bnez	gp, ced_15
	j	ce_cs_div
ced_15:
	addi	gp, gp, -1
	bnez	gp, ced_16
	j	ce_cs_mod
ced_16:
	addi	gp, gp, -1
	bnez	gp, ced_17
	j	ce_tern_mid
ced_17:
	addi	gp, gp, -1
	bnez	gp, ced_18
	j	ce_tern_else
ced_18:
	addi	gp, gp, -1
	bnez	gp, ced_19
	j	ce_cep_rec
ced_19:
	addi	gp, gp, -1
	bnez	gp, ced_20
	j	ce_cep_tern_mid
ced_20:
	addi	gp, gp, -1
	bnez	gp, ced_21
	j	ce_cep_tern_else
ced_21:
	addi	gp, gp, -1
	bnez	gp, ced_22
	j	ce_cep_land_rhs
ced_22:
	addi	gp, gp, -1
	bnez	gp, ced_23
	j	ce_cep_lor_rhs
ced_23:
	addi	gp, gp, -1
	bnez	gp, ced_24
	j	ce_cep_asg_rhs
ced_24:
	addi	gp, gp, -1
	bnez	gp, ced_25
	j	ce_cs_exprstmt
ced_25:
	j	ce_ct_blk_rec

# ══════════════════════════════════════════════════════════════════════════════
# compile_expr_p — Pratt (top-down operator-precedence) expression parser.
#
# Replaces the layered parser (compile_or/xor/and/shift/add/mul/rel/eq/land).
# compile_unary is kept as the "null denotation" (nud): it parses primaries
# with prefix/postfix operators. compile_expr_p loops on binary operators,
# consuming those whose left binding power is at least the caller's min_bp.
#
# Caller contract:
#   t6 = min_bp        (minimum binding power this call accepts)
#   gp = return site   (dispatched via compile_expr_disp at exit)
#   On return: a0 = runtime value of the expression.
#
# Frame (24 bytes):
#   0(sp):  saved caller gp
#   4(sp):  saved caller min_bp (for comparing against l_bp of candidate ops)
#   8(sp):  op_kind (currently-processing operator, kept across recurse)
#   12(sp): r_bp    (right binding power for the recursive call)
#   16(sp): scratch1 (first jal placeholder addr for &&/||; jal_else for ?)
#   20(sp): scratch2 (second jal placeholder addr; jal_end for all branches)
#
# Operator kinds (matches the big dispatch in the post-rhs emit stage):
#   1  OP_MUL  '*'       l=20 r=21
#   2  OP_DIV  '/'       l=20 r=21
#   3  OP_MOD  '%'       l=20 r=21
#   4  OP_DIVU '/u'      l=20 r=21
#   5  OP_MODU '%u'      l=20 r=21
#   6  OP_ADD  '+'       l=18 r=19
#   7  OP_SUB  '-'       l=18 r=19
#   8  OP_SHL  '<<'      l=16 r=17
#   9  OP_SAR  '>>'      l=16 r=17
#  10  OP_SRL  '>>u'     l=16 r=17
#  11  OP_AND  '&'       l=14 r=15
#  12  OP_XOR  '^'       l=12 r=13
#  13  OP_OR   '|'       l=10 r=11
#  (relational/equality/short-circuit/ternary/assignment added in later turns)
#
# This is a WORK-IN-PROGRESS — it handles the simple binary ops listed above
# and isn't wired up yet. Short-circuit, ternary, and assignment come next.
# ══════════════════════════════════════════════════════════════════════════════
compile_expr_p:
	addi	sp, sp, -24
	sw	gp, 0(sp)
	sw	t6, 4(sp)		# save caller's min_bp

	# Parse the nud: a primary with any prefix/postfix operators.
	addi	gp, zero, 4
	j	compile_unary
cu_cep_nud:

	# a0 = lhs value (runtime). Enter the operator loop.
	# (The nud already set lv_kind if this primary is a simple lvalue,
	# so we fall through directly to cep_loop without clobbering it.)

cep_loop:
	# Peek next token (after ws). Identify the binary operator, compare
	# its l_bp to min_bp, and if it beats min_bp, consume and recurse.
	addi	gp, zero, 29		# skip_ws site 29 = sw_cep_op
	j	skip_ws
sw_cep_op:
	bge	s2, s3, cep_done
	lbu	t0, 0(s2)

	# Decision tree on the first char. Each arm sets:
	#   t2 = op_kind, t3 = l_bp, t4 = r_bp, t1 = char count
	# then jumps to cep_bp_check.
	addi	t1, zero, '*'
	beq	t0, t1, cep_op_star
	addi	t1, zero, '/'
	beq	t0, t1, cep_op_slash
	addi	t1, zero, '%'
	beq	t0, t1, cep_op_percent
	addi	t1, zero, '+'
	beq	t0, t1, cep_op_plus
	addi	t1, zero, '-'
	beq	t0, t1, cep_op_minus
	addi	t1, zero, '<'
	beq	t0, t1, cep_op_lt
	addi	t1, zero, '>'
	beq	t0, t1, cep_op_gt
	addi	t1, zero, '&'
	beq	t0, t1, cep_op_amp
	addi	t1, zero, '^'
	beq	t0, t1, cep_op_caret
	addi	t1, zero, '|'
	beq	t0, t1, cep_op_pipe
	addi	t1, zero, '='
	beq	t0, t1, cep_op_eq
	addi	t1, zero, '!'
	beq	t0, t1, cep_op_bang
	addi	t1, zero, '?'
	beq	t0, t1, cep_op_question
	j	cep_done

# — '*' : unconditional multiplication ————————————————————————————————————————
cep_op_star:
	addi	t2, zero, 1		# op = MUL
	addi	t3, zero, 20		# l_bp
	addi	t4, zero, 21		# r_bp
	addi	t1, zero, 1		# chars
	j	cep_bp_check

# — '/' or '/u' ————————————————————————————————————————————————————————————————
cep_op_slash:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_slash_signed
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_slash_unsigned
cep_op_slash_signed:
	addi	t2, zero, 2		# op = DIV
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_slash_unsigned:
	addi	t2, zero, 4		# op = DIVU
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 2
	j	cep_bp_check

# — '%' or '%u' ————————————————————————————————————————————————————————————————
cep_op_percent:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_percent_signed
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_percent_unsigned
cep_op_percent_signed:
	addi	t2, zero, 3		# op = MOD
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_percent_unsigned:
	addi	t2, zero, 5		# op = MODU
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 2
	j	cep_bp_check

# — '+' ————————————————————————————————————————————————————————————————————————
cep_op_plus:
	addi	t2, zero, 6		# op = ADD
	addi	t3, zero, 18
	addi	t4, zero, 19
	addi	t1, zero, 1
	j	cep_bp_check

# — '-' ————————————————————————————————————————————————————————————————————————
cep_op_minus:
	addi	t2, zero, 7		# op = SUB
	addi	t3, zero, 18
	addi	t4, zero, 19
	addi	t1, zero, 1
	j	cep_bp_check

# — '<' : '<' '<=' '<u' '<=u' '<<' ————————————————————————————————————————————
cep_op_lt:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_lt_alone
	lbu	t0, 0(t5)
	addi	t1, zero, '<'
	beq	t0, t1, cep_op_shl
	addi	t1, zero, '='
	beq	t0, t1, cep_op_le_or_leu
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_ltu
cep_op_lt_alone:
	addi	t2, zero, 14		# op = LT
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_shl:
	addi	t2, zero, 8		# op = SHL
	addi	t3, zero, 16
	addi	t4, zero, 17
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_le_or_leu:
	addi	t5, s2, 2
	bge	t5, s3, cep_op_le
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_leu
cep_op_le:
	addi	t2, zero, 15		# op = LE
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_leu:
	addi	t2, zero, 19		# op = LEU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_ltu:
	addi	t2, zero, 18		# op = LTU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check

# — '>' : '>' '>=' '>u' '>=u' '>>' '>>u' —————————————————————————————————————
cep_op_gt:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_gt_alone
	lbu	t0, 0(t5)
	addi	t1, zero, '>'
	beq	t0, t1, cep_op_sar_or_srl
	addi	t1, zero, '='
	beq	t0, t1, cep_op_ge_or_geu
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_gtu
cep_op_gt_alone:
	addi	t2, zero, 16		# op = GT
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_sar_or_srl:
	addi	t5, s2, 2
	bge	t5, s3, cep_op_sar
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_srl
cep_op_sar:
	addi	t2, zero, 9		# op = SAR
	addi	t3, zero, 16
	addi	t4, zero, 17
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_srl:
	addi	t2, zero, 10		# op = SRL
	addi	t3, zero, 16
	addi	t4, zero, 17
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_ge_or_geu:
	addi	t5, s2, 2
	bge	t5, s3, cep_op_ge
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_geu
cep_op_ge:
	addi	t2, zero, 17		# op = GE
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_geu:
	addi	t2, zero, 21		# op = GEU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_gtu:
	addi	t2, zero, 20		# op = GTU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check

# — '&' : '&' or '&&' ————————————————————————————————————————————————————————
cep_op_amp:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_amp_single
	lbu	t0, 0(t5)
	addi	t1, zero, '&'
	beq	t0, t1, cep_op_land
cep_op_amp_single:
	addi	t2, zero, 11		# op = AND
	addi	t3, zero, 14
	addi	t4, zero, 15
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_land:
	addi	t2, zero, 24		# op = LAND
	addi	t3, zero, 4
	addi	t4, zero, 5
	addi	t1, zero, 2
	j	cep_bp_check

# — '^' ————————————————————————————————————————————————————————————————————————
cep_op_caret:
	addi	t2, zero, 12		# op = XOR
	addi	t3, zero, 12
	addi	t4, zero, 13
	addi	t1, zero, 1
	j	cep_bp_check

# — '|' : '|' or '||' ————————————————————————————————————————————————————————
cep_op_pipe:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_pipe_single
	lbu	t0, 0(t5)
	addi	t1, zero, '|'
	beq	t0, t1, cep_op_lor
cep_op_pipe_single:
	addi	t2, zero, 13		# op = OR
	addi	t3, zero, 10
	addi	t4, zero, 11
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_lor:
	addi	t2, zero, 25		# op = LOR
	addi	t3, zero, 2
	addi	t4, zero, 3
	addi	t1, zero, 2
	j	cep_bp_check

# — '=' : '==' (equality) or bare '=' (assignment) ———————————————————————————
cep_op_eq:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_assign
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_eq_eq
	j	cep_op_assign
cep_op_eq_eq:
	addi	t2, zero, 22		# op = EQ
	addi	t3, zero, 6
	addi	t4, zero, 7
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_assign:
	# op = ASSIGN (bare '='). Lowest precedence, right-associative.
	addi	t2, zero, 27		# op = ASSIGN
	addi	t3, zero, 0		# l_bp = 0
	addi	t4, zero, -1		# r_bp = -1 (right-assoc)
	addi	t1, zero, 1
	j	cep_bp_check

# — '!' : only '!=' recognized (no unary '!' in the language today) ——————————
cep_op_bang:
	addi	t5, s2, 1
	bge	t5, s3, cep_done
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	bne	t0, t1, cep_done
	addi	t2, zero, 23		# op = NE
	addi	t3, zero, 6
	addi	t4, zero, 7
	addi	t1, zero, 2
	j	cep_bp_check

# — '?' : ternary — handled via a dedicated path in cep_bp_check ———————————————
cep_op_question:
	addi	t2, zero, 26		# op = TERN
	addi	t3, zero, 1		# l_bp = 1 (looser than '||' at 2)
	addi	t4, zero, 0		# r_bp (unused; ternary uses custom flow)
	addi	t1, zero, 1
	j	cep_bp_check

# ── Binding power check & binop dispatch ─────────────────────────────────────
# Inputs: t1 = chars to consume, t2 = op_kind, t3 = l_bp, t4 = r_bp
cep_bp_check:
	lw	t5, 4(sp)		# caller's min_bp
	blt	t3, t5, cep_done	# l_bp < min_bp → don't consume, return
	# Consume the operator chars.
	add	s2, s2, t1
	# Save op_kind and r_bp across the recurse.
	sw	t2, 8(sp)
	sw	t4, 12(sp)

	# Short-circuit / ternary / assignment take custom paths that diverge
	# from the standard "push lhs, recurse, pop, emit binop" pattern.
	addi	t1, zero, 24
	beq	t2, t1, cep_pre_land
	addi	t1, zero, 25
	beq	t2, t1, cep_pre_lor
	addi	t1, zero, 26
	beq	t2, t1, cep_pre_tern
	addi	t1, zero, 27
	beq	t2, t1, cep_pre_assign

	# Standard binary operator: push lhs, recurse, pop, emit.
	addi	gp, zero, 20		# push site 20 = push_cep
	j	emit_push_a0
push_cep:

	# Recurse for RHS with new min_bp = r_bp.
	lw	t6, 12(sp)
	addi	gp, zero, 18		# compile_expr site 18 = ce_cep_rec
	j	compile_expr_p
ce_cep_rec:

	# Pop lhs into t0 (runtime).
	addi	gp, zero, 20		# pop site 20 = pop_cep
	j	emit_pop_t0
pop_cep:

	# Dispatch on saved op_kind to emit the binop.
	lw	t5, 8(sp)
	addi	t1, zero, 1
	beq	t5, t1, cep_em_mul
	addi	t1, zero, 2
	beq	t5, t1, cep_em_div
	addi	t1, zero, 3
	beq	t5, t1, cep_em_mod
	addi	t1, zero, 4
	beq	t5, t1, cep_em_divu
	addi	t1, zero, 5
	beq	t5, t1, cep_em_modu
	addi	t1, zero, 6
	beq	t5, t1, cep_em_add
	addi	t1, zero, 7
	beq	t5, t1, cep_em_sub
	addi	t1, zero, 8
	beq	t5, t1, cep_em_shl
	addi	t1, zero, 9
	beq	t5, t1, cep_em_sar
	addi	t1, zero, 10
	beq	t5, t1, cep_em_srl
	addi	t1, zero, 11
	beq	t5, t1, cep_em_and
	addi	t1, zero, 12
	beq	t5, t1, cep_em_xor
	addi	t1, zero, 13
	beq	t5, t1, cep_em_or
	addi	t1, zero, 14
	beq	t5, t1, cep_em_lt
	addi	t1, zero, 15
	beq	t5, t1, cep_em_le
	addi	t1, zero, 16
	beq	t5, t1, cep_em_gt
	addi	t1, zero, 17
	beq	t5, t1, cep_em_ge
	addi	t1, zero, 18
	beq	t5, t1, cep_em_ltu
	addi	t1, zero, 19
	beq	t5, t1, cep_em_leu
	addi	t1, zero, 20
	beq	t5, t1, cep_em_gtu
	addi	t1, zero, 21
	beq	t5, t1, cep_em_geu
	addi	t1, zero, 22
	beq	t5, t1, cep_em_eq
	j	cep_em_ne

# — Per-op emitters. Each ends with `j cep_loop`. ————————————————————————————
cep_em_add:
	addi	gp, zero, 2		# ea site 2 = ea_cep
	j	emit_add
ea_cep:
	j	cep_post_emit

cep_em_sub:
	addi	gp, zero, 2		# es site 2 = es_cep
	j	emit_sub
es_cep:
	j	cep_post_emit

cep_em_mul:
	addi	gp, zero, 2		# emul site 2 = emul_cep_ret
	j	emit_mul
emul_cep_ret:
	j	cep_post_emit

cep_em_div:
	addi	gp, zero, 4		# edmb site 4 = edmb_cep_div_ret
	j	emit_divmod_body
edmb_cep_div_ret:
	lui	a0, 0x30
	addi	a0, a0, 0x513
	addi	gp, zero, 36		# ecw site 36 = ecw_cep_div_mv
	j	emit_cmp_word
ecw_cep_div_mv:
	j	cep_post_emit

cep_em_mod:
	addi	gp, zero, 5
	j	emit_divmod_body
edmb_cep_mod_ret:
	lui	a0, 0x38
	addi	a0, a0, 0x513
	addi	gp, zero, 37		# ecw site 37 = ecw_cep_mod_mv
	j	emit_cmp_word
ecw_cep_mod_mv:
	j	cep_post_emit

cep_em_divu:
	addi	gp, zero, 2		# eudmb site 2 = eudmb_cep_divu_ret
	j	emit_udivmod_body
eudmb_cep_divu_ret:
	lui	a0, 0x30
	addi	a0, a0, 0x513
	addi	gp, zero, 38		# ecw site 38 = ecw_cep_divu_mv
	j	emit_cmp_word
ecw_cep_divu_mv:
	j	cep_post_emit

cep_em_modu:
	addi	gp, zero, 3
	j	emit_udivmod_body
eudmb_cep_modu_ret:
	lui	a0, 0x38
	addi	a0, a0, 0x513
	addi	gp, zero, 39		# ecw site 39 = ecw_cep_modu_mv
	j	emit_cmp_word
ecw_cep_modu_mv:
	j	cep_post_emit

cep_em_shl:
	addi	gp, zero, 2		# esll site 2 = esll_cep
	j	emit_sll
esll_cep:
	j	cep_post_emit

cep_em_sar:
	addi	gp, zero, 2		# esra site 2 = esra_cep
	j	emit_sra
esra_cep:
	j	cep_post_emit

cep_em_srl:
	addi	gp, zero, 1		# esrl site 1 = esrl_cep
	j	emit_srl
esrl_cep:
	j	cep_post_emit

cep_em_and:
	addi	gp, zero, 2		# ean site 2 = ean_cep
	j	emit_and
ean_cep:
	j	cep_post_emit

cep_em_xor:
	addi	gp, zero, 2		# ex site 2 = ex_cep
	j	emit_xor
ex_cep:
	j	cep_post_emit

cep_em_or:
	addi	gp, zero, 2		# eor site 2 = eor_cep
	j	emit_or
eor_cep:
	j	cep_post_emit

# ── Comparison emitters ──────────────────────────────────────────────────────
# All comparisons leave 0 or 1 in a0. The emit sequences mirror compile_rel
# and compile_eq from the layered parser.

# '<' : slt a0, t0, a0  (word 0x00A2A533)
cep_em_lt:
	lui	a0, 0xA2A
	addi	a0, a0, 0x533
	addi	gp, zero, 40
	j	emit_cmp_word
ecw_cep_lt_done:
	j	cep_post_emit

# '<=' : slt a0, a0, t0 (word 0x00552533) ; xori a0, a0, 1 (word 0x00154513)
cep_em_le:
	lui	a0, 0x552
	addi	a0, a0, 0x533
	addi	gp, zero, 41
	j	emit_cmp_word
ecw_cep_le_slt:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 42
	j	emit_cmp_word
ecw_cep_le_done:
	j	cep_post_emit

# '>' : slt a0, a0, t0 (word 0x00552533)
cep_em_gt:
	lui	a0, 0x552
	addi	a0, a0, 0x533
	addi	gp, zero, 43
	j	emit_cmp_word
ecw_cep_gt_done:
	j	cep_post_emit

# '>=' : slt a0, t0, a0 ; xori a0, a0, 1
cep_em_ge:
	lui	a0, 0xA2A
	addi	a0, a0, 0x533
	addi	gp, zero, 44
	j	emit_cmp_word
ecw_cep_ge_slt:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 45
	j	emit_cmp_word
ecw_cep_ge_done:
	j	cep_post_emit

# '<u' : sltu a0, t0, a0 (word 0x00A2B533)
cep_em_ltu:
	lui	a0, 0xA2B
	addi	a0, a0, 0x533
	addi	gp, zero, 46
	j	emit_cmp_word
ecw_cep_ltu_done:
	j	cep_post_emit

# '<=u' : sltu a0, a0, t0 (word 0x00553533) ; xori a0, a0, 1
cep_em_leu:
	lui	a0, 0x553
	addi	a0, a0, 0x533
	addi	gp, zero, 47
	j	emit_cmp_word
ecw_cep_leu_sltu:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 48
	j	emit_cmp_word
ecw_cep_leu_done:
	j	cep_post_emit

# '>u' : sltu a0, a0, t0
cep_em_gtu:
	lui	a0, 0x553
	addi	a0, a0, 0x533
	addi	gp, zero, 49
	j	emit_cmp_word
ecw_cep_gtu_done:
	j	cep_post_emit

# '>=u' : sltu a0, t0, a0 ; xori a0, a0, 1
cep_em_geu:
	lui	a0, 0xA2B
	addi	a0, a0, 0x533
	addi	gp, zero, 50
	j	emit_cmp_word
ecw_cep_geu_sltu:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 51
	j	emit_cmp_word
ecw_cep_geu_done:
	j	cep_post_emit

# '==' : xor a0, t0, a0 (0x00A2C533) ; sltiu a0, a0, 1 (0x00153513)
cep_em_eq:
	lui	a0, 0xA2C
	addi	a0, a0, 0x533
	addi	gp, zero, 52
	j	emit_cmp_word
ecw_cep_eq_xor:
	lui	a0, 0x153
	addi	a0, a0, 0x513
	addi	gp, zero, 53
	j	emit_cmp_word
ecw_cep_eq_done:
	j	cep_post_emit

# '!=' : xor a0, t0, a0 ; sltu a0, zero, a0 (0x00A03533)
cep_em_ne:
	lui	a0, 0xA2C
	addi	a0, a0, 0x533
	addi	gp, zero, 54
	j	emit_cmp_word
ecw_cep_ne_xor:
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	addi	gp, zero, 55
	j	emit_cmp_word
ecw_cep_ne_done:
	j	cep_post_emit

# ── Short-circuit '&&' ───────────────────────────────────────────────────────
# Pattern mirrors compile_land: bne+jal trampoline, recurse, sltu, jal, patch.
cep_pre_land:
	# Emit bne a0, zero, +8 (word 0x00051463).
	lui	a0, 0x51
	addi	a0, a0, 0x463
	addi	gp, zero, 56
	j	emit_cmp_word
ecw_cep_land_bne:
	# Save future jal_sf addr to 16(sp).
	sw	s5, 16(sp)
	# Emit placeholder jal zero, 0.
	addi	a0, zero, 0x6F
	addi	gp, zero, 57
	j	emit_cmp_word
ecw_cep_land_jal_sf:
	# Recurse for RHS with r_bp = 5.
	lw	t6, 12(sp)
	addi	gp, zero, 21		# ce site 21 = ce_cep_land_rhs
	j	compile_expr_p
ce_cep_land_rhs:
	# Emit sltu a0, zero, a0 (word 0x00A03533).
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	addi	gp, zero, 58
	j	emit_cmp_word
ecw_cep_land_sltu:
	# Save future jal_end addr to 20(sp).
	sw	s5, 20(sp)
	# Emit placeholder jal zero, 0.
	addi	a0, zero, 0x6F
	addi	gp, zero, 59
	j	emit_cmp_word
ecw_cep_land_jal_end:
	# Patch jal_sf (stashed at 16(sp)) to current s5.
	lw	t5, 16(sp)
	addi	t6, s5, 0
	addi	gp, zero, 6		# patch_jtype site 6 = pjt_cep_land_sf
	j	patch_jtype
pjt_cep_land_sf:
	# Emit addi a0, zero, 0 (false-tail value).
	lui	a0, 0
	addi	a0, a0, 0x513
	addi	gp, zero, 60
	j	emit_cmp_word
ecw_cep_land_addi:
	# Patch jal_end (stashed at 20(sp)) to current s5.
	lw	t5, 20(sp)
	addi	t6, s5, 0
	addi	gp, zero, 7		# patch_jtype site 7 = pjt_cep_land_end
	j	patch_jtype
pjt_cep_land_end:
	j	cep_post_emit

# ── Short-circuit '||' ───────────────────────────────────────────────────────
cep_pre_lor:
	# Emit beq a0, zero, +8 (word 0x00050463).
	lui	a0, 0x50
	addi	a0, a0, 0x463
	addi	gp, zero, 61
	j	emit_cmp_word
ecw_cep_lor_beq:
	sw	s5, 16(sp)
	addi	a0, zero, 0x6F
	addi	gp, zero, 62
	j	emit_cmp_word
ecw_cep_lor_jal_st:
	lw	t6, 12(sp)
	addi	gp, zero, 22		# ce site 22 = ce_cep_lor_rhs
	j	compile_expr_p
ce_cep_lor_rhs:
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	addi	gp, zero, 63
	j	emit_cmp_word
ecw_cep_lor_sltu:
	sw	s5, 20(sp)
	addi	a0, zero, 0x6F
	addi	gp, zero, 64
	j	emit_cmp_word
ecw_cep_lor_jal_end:
	lw	t5, 16(sp)
	addi	t6, s5, 0
	addi	gp, zero, 8		# patch_jtype site 8 = pjt_cep_lor_st
	j	patch_jtype
pjt_cep_lor_st:
	# Emit addi a0, zero, 1 (true-tail value, word 0x00100513).
	lui	a0, 0x100
	addi	a0, a0, 0x513
	addi	gp, zero, 65
	j	emit_cmp_word
ecw_cep_lor_addi:
	lw	t5, 20(sp)
	addi	t6, s5, 0
	addi	gp, zero, 9		# patch_jtype site 9 = pjt_cep_lor_end
	j	patch_jtype
pjt_cep_lor_end:
	j	cep_post_emit

# ── Ternary '?' ──────────────────────────────────────────────────────────────
# Uses condition (lhs) in a0, branches, compiles middle, emits jal, patches,
# optionally compiles else (or emits addi 0), patches, done.
cep_pre_tern:
	# Emit bne a0, zero, +8 (skip jal when cond true).
	lui	a0, 0x51
	addi	a0, a0, 0x463
	addi	gp, zero, 66
	j	emit_cmp_word
ecw_cep_tern_bne:
	sw	s5, 16(sp)		# future jal_else addr
	addi	a0, zero, 0x6F
	addi	gp, zero, 67
	j	emit_cmp_word
ecw_cep_tern_jal_else:
	# Recurse for middle with min_bp = 0 (full expression allowed).
	addi	t6, zero, 0
	addi	gp, zero, 19		# ce site 19 = ce_cep_tern_mid
	j	compile_expr_p
ce_cep_tern_mid:
	sw	s5, 20(sp)		# future jal_end addr
	addi	a0, zero, 0x6F
	addi	gp, zero, 68
	j	emit_cmp_word
ecw_cep_tern_jal_end:
	# Patch jal_else (16(sp)) to current s5 (start of ELSE block).
	lw	t5, 16(sp)
	addi	t6, s5, 0
	addi	gp, zero, 10		# patch_jtype site 10 = pjt_cep_tern_else
	j	patch_jtype
pjt_cep_tern_else:
	# Peek for ':'. If present, recurse for else; else emit addi 0.
	addi	gp, zero, 30		# sw_cep_tern_colon
	j	skip_ws
sw_cep_tern_colon:
	bge	s2, s3, cep_tern_no_else
	lbu	t0, 0(s2)
	addi	t1, zero, ':'
	bne	t0, t1, cep_tern_no_else
	addi	s2, s2, 1
	addi	t6, zero, 0
	addi	gp, zero, 20		# ce site 20 = ce_cep_tern_else
	j	compile_expr_p
ce_cep_tern_else:
	j	cep_tern_patch_end
cep_tern_no_else:
	# Emit addi a0, zero, 0 as the missing else's value.
	lui	a0, 0
	addi	a0, a0, 0x513
	addi	gp, zero, 69
	j	emit_cmp_word
ecw_cep_tern_addi:
cep_tern_patch_end:
	lw	t5, 20(sp)
	addi	t6, s5, 0
	addi	gp, zero, 11		# patch_jtype site 11 = pjt_cep_tern_end
	j	patch_jtype
pjt_cep_tern_end:
	j	cep_post_emit

# ── Assignment '=' ───────────────────────────────────────────────────────────
# Uses the lvalue marker (lv_kind / lv_slot) set by compile_unary. The last
# emitted instruction is a load from the lvalue; we rewind s5 by 4 to un-emit
# it (peephole), then emit the appropriate store after compiling the RHS.
#
#   lv_kind = 1 (IDENT): un-emit `lw a0, off(fp)`, compile RHS, emit sw.
#   lv_kind = 2 (@expr): un-emit `lbu a0, 0(a0)` — address is still in a0 at
#                         runtime because the preceding instructions left it
#                         there. Emit push a0, compile RHS, pop t0, sb.
#   lv_kind = 3 (*expr): same with `lw`/`sw`.
#
# Right-associative: recurses with min_bp = -1 so `a = b = 5` → `a = (b = 5)`.
cep_pre_assign:
	lla	t0, lv_kind
	lw	t1, 0(t0)
	beqz	t1, cep_bad_lvalue	# not an lvalue → halt
	sw	t1, 16(sp)		# save kind in frame scratch1
	lla	t0, lv_slot
	lw	t1, 0(t0)
	sw	t1, 20(sp)		# save slot in frame scratch2

	# Un-emit the last load (peephole: rewind s5 by 4).
	addi	s5, s5, -4

	# If kind == 1 (IDENT), no push needed; just recurse and emit sw.
	# If kind == 2 or 3 (deref), push a0 to save the address across RHS.
	lw	t1, 16(sp)
	addi	t2, zero, 1
	beq	t1, t2, cep_asg_recurse
	addi	gp, zero, 21		# push site 21 = push_cep_asg
	j	emit_push_a0
push_cep_asg:

cep_asg_recurse:
	# Recurse for RHS with min_bp = -1 (right-associative).
	addi	t6, zero, -1
	addi	gp, zero, 23		# compile_expr site 23 = ce_cep_asg_rhs
	j	compile_expr_p
ce_cep_asg_rhs:
	# Dispatch on saved lv_kind to emit the store.
	lw	t1, 16(sp)
	addi	t2, zero, 1
	beq	t1, t2, cep_asg_em_ident
	# kind 2 or 3 — pop address into t0, then dispatch for sb / sw.
	addi	gp, zero, 21		# pop site 21 = pop_cep_asg
	j	emit_pop_t0
pop_cep_asg:
	lw	t1, 16(sp)
	addi	t2, zero, 2
	beq	t1, t2, cep_asg_em_sb
	j	cep_asg_em_sw

cep_asg_em_ident:
	# Reload slot offset; emit sw a0, off(fp).
	lw	a0, 20(sp)
	addi	gp, zero, 17		# esws site 17 = esws_cep_asg
	j	emit_sw_sp
esws_cep_asg:
	j	cep_post_emit

cep_asg_em_sb:
	addi	gp, zero, 1		# esb site 1 = esb_cep_asg
	j	emit_sb_deref
esb_cep_asg:
	j	cep_post_emit

cep_asg_em_sw:
	addi	gp, zero, 1		# esw site 1 = esw_cep_asg
	j	emit_sw_deref
esw_cep_asg:
	j	cep_post_emit

cep_bad_lvalue:
	addi	a0, zero, 20		# err 20: left of '=' is not an lvalue
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# cep_post_emit — shared tail after any binop/ternary/short-circuit completes.
# Resets lv_kind (result of a binop is never an lvalue) and re-enters cep_loop.
# ══════════════════════════════════════════════════════════════════════════════
cep_post_emit:
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	cep_loop

cep_done:
	lw	gp, 0(sp)
	addi	sp, sp, 24
	# Dispatch back to caller via the shared compile_expr_disp. Both
	# compile_expr and compile_expr_p reach the same external return
	# sites (ce_cs_rhs, …, ce_ct_paren), so we alias the dispatch table.
	j	compile_expr_disp

# ══════════════════════════════════════════════════════════════════════════════
# compile_stmt — compile one statement. Non-ws known to be at s2.
#
# Grammar:
#   stmt := '*' expr '=' expr ';'
#         | '@' expr '=' expr ';'
#         | '++' IDENT ';'
#         | '--' IDENT ';'
#         | IDENT '='  expr ';'
#         | IDENT '+=' expr ';'
#         | IDENT '-=' expr ';'
#         | IDENT '^=' expr ';'
#         | IDENT '++' ';'
#         | IDENT '--' ';'
#
# Single caller: cs_after (compile_loop)
# ══════════════════════════════════════════════════════════════════════════════
compile_stmt:
	# Push the entry s2 onto famc's own stack so that cs_bad can rewind and
	# retry the statement as an expression-statement. Reentrant-safe: each
	# compile_stmt invocation gets its own frame slot, no global state.
	addi	sp, sp, -4
	sw	s2, 0(sp)
	lbu	t0, 0(s2)
	addi	t1, zero, 42		# '*'
	beq	t0, t1, cs_star
	addi	t1, zero, 64		# '@'
	beq	t0, t1, cs_at
	addi	t1, zero, '+'
	beq	t0, t1, cs_chk_pre_pp
	addi	t1, zero, '-'
	beq	t0, t1, cs_chk_pre_mm

	# IDENT <op> ... ';'
	addi	gp, zero, 1
	j	parse_ident
pi_cs:
	addi	gp, zero, 1
	j	lookup_or_alloc
la_cs:
	# Spill slot to famc's stack.
	addi	sp, sp, -4
	sw	a0, 0(sp)

	addi	gp, zero, 5
	j	skip_ws
sw_cs_eq1:
	bge	s2, s3, cs_bad
	lbu	t0, 0(s2)
	addi	t1, zero, '='
	beq	t0, t1, cs_op_eq
	addi	t1, zero, '+'
	beq	t0, t1, cs_op_plus
	addi	t1, zero, '-'
	beq	t0, t1, cs_op_minus
	addi	t1, zero, '^'
	beq	t0, t1, cs_op_xor
	addi	t1, zero, '<'
	beq	t0, t1, cs_op_lshift
	addi	t1, zero, '>'
	beq	t0, t1, cs_op_rshift
	addi	t1, zero, '&'
	beq	t0, t1, cs_op_and
	addi	t1, zero, '|'
	beq	t0, t1, cs_op_or
	addi	t1, zero, '*'
	beq	t0, t1, cs_op_mul
	addi	t1, zero, '/'
	beq	t0, t1, cs_op_div
	addi	t1, zero, '%'
	beq	t0, t1, cs_op_mod
	j	cs_bad

cs_op_eq:
	addi	s2, s2, 1
	addi	t6, zero, 0
	addi	gp, zero, 0
	j	compile_expr_p
ce_cs_rhs:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 0		# esws site 0 = esws_ret
	j	emit_sw_sp
esws_ret:
	addi	gp, zero, 6
	j	skip_ws
sw_cs_semi1:
	# la_cs's spill slot was already popped in ce_cs_rhs, so sp is back at
	# compile_stmt's entry frame. Any failure here goes direct to cs_fb, not
	# via cs_bad (which would double-pop).
	bge	s2, s3, cs_fb
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_fb
	addi	s2, s2, 1
	j	cs_done

# ── '+' after IDENT: distinguish '+=' and '++' ───────────────────────────────
cs_op_plus:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	beq	t0, t1, cs_compound_add
	addi	t1, zero, '+'
	beq	t0, t1, cs_ident_post_inc
	j	cs_bad

cs_op_minus:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	beq	t0, t1, cs_compound_sub
	addi	t1, zero, '-'
	beq	t0, t1, cs_ident_post_dec
	j	cs_bad

cs_op_xor:
	# Must be '^=' (bare '^' isn't a statement operator).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_xor

cs_op_lshift:
	# Must be '<<=' (three chars).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '<'
	bne	t0, t1, cs_bad
	addi	t2, s2, 2
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_lshift

cs_op_rshift:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '>'
	bne	t0, t1, cs_bad
	addi	t2, s2, 2
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_rshift

cs_op_and:
	# Must be '&=' (bare '&' isn't a statement operator).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_and

cs_op_or:
	# Must be '|=' (bare '|' isn't a statement operator).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_or

cs_op_mul:
	# Must be '*=' (bare '*' isn't a statement operator after an IDENT).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_mul

cs_op_div:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_div

cs_op_mod:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_mod

# ── IDENT '+=' expr ; ────────────────────────────────────────────────────────
cs_compound_add:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 3		# elws site 3 = elws_cs_plus
	j	emit_lw_sp
elws_cs_plus:
	addi	gp, zero, 4		# push site 4 = push_cs_plus
	j	emit_push_a0
push_cs_plus:
	addi	t6, zero, 0
	addi	gp, zero, 5		# ce site 5 = ce_cs_plus
	j	compile_expr_p
ce_cs_plus:
	addi	gp, zero, 4		# pop site 4 = pop_cs_plus
	j	emit_pop_t0
pop_cs_plus:
	addi	gp, zero, 1		# ea site 1 = ea_cs_plus
	j	emit_add
ea_cs_plus:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 7		# esws site 7 = esws_cs_plus
	j	emit_sw_sp
esws_cs_plus:
	addi	gp, zero, 15		# skip_ws site 15 = sw_cs_semi_stmt
	j	skip_ws

# ── IDENT '-=' expr ; ────────────────────────────────────────────────────────
cs_compound_sub:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 4		# elws site 4 = elws_cs_minus
	j	emit_lw_sp
elws_cs_minus:
	addi	gp, zero, 5		# push site 5 = push_cs_minus
	j	emit_push_a0
push_cs_minus:
	addi	t6, zero, 0
	addi	gp, zero, 6		# ce site 6 = ce_cs_minus
	j	compile_expr_p
ce_cs_minus:
	addi	gp, zero, 5		# pop site 5 = pop_cs_minus
	j	emit_pop_t0
pop_cs_minus:
	addi	gp, zero, 1		# es site 1 = es_cs_minus
	j	emit_sub
es_cs_minus:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 8		# esws site 8 = esws_cs_minus
	j	emit_sw_sp
esws_cs_minus:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '^=' expr ; ────────────────────────────────────────────────────────
cs_compound_xor:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 5		# elws site 5 = elws_cs_xor
	j	emit_lw_sp
elws_cs_xor:
	addi	gp, zero, 6		# push site 6 = push_cs_xor
	j	emit_push_a0
push_cs_xor:
	addi	t6, zero, 0
	addi	gp, zero, 7		# ce site 7 = ce_cs_xor
	j	compile_expr_p
ce_cs_xor:
	addi	gp, zero, 6		# pop site 6 = pop_cs_xor
	j	emit_pop_t0
pop_cs_xor:
	addi	gp, zero, 1		# ex site 1 = ex_cs_xor
	j	emit_xor
ex_cs_xor:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 9		# esws site 9 = esws_cs_xor
	j	emit_sw_sp
esws_cs_xor:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '<<=' expr ; ───────────────────────────────────────────────────────
cs_compound_lshift:
	addi	s2, s2, 3
	lw	a0, 0(sp)
	addi	gp, zero, 6		# elws site 6 = elws_cs_lshift
	j	emit_lw_sp
elws_cs_lshift:
	addi	gp, zero, 8		# push site 8 = push_cs_lshift
	j	emit_push_a0
push_cs_lshift:
	addi	t6, zero, 0
	addi	gp, zero, 8		# ce site 8 = ce_cs_lshift
	j	compile_expr_p
ce_cs_lshift:
	addi	gp, zero, 8		# pop site 8 = pop_cs_lshift
	j	emit_pop_t0
pop_cs_lshift:
	addi	gp, zero, 1		# esll site 1 = esll_cs_lshift
	j	emit_sll
esll_cs_lshift:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 10		# esws site 10 = esws_cs_lshift
	j	emit_sw_sp
esws_cs_lshift:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '>>=' expr ; ───────────────────────────────────────────────────────
cs_compound_rshift:
	addi	s2, s2, 3
	lw	a0, 0(sp)
	addi	gp, zero, 7		# elws site 7 = elws_cs_rshift
	j	emit_lw_sp
elws_cs_rshift:
	addi	gp, zero, 9		# push site 9 = push_cs_rshift
	j	emit_push_a0
push_cs_rshift:
	addi	t6, zero, 0
	addi	gp, zero, 9		# ce site 9 = ce_cs_rshift
	j	compile_expr_p
ce_cs_rshift:
	addi	gp, zero, 9		# pop site 9 = pop_cs_rshift
	j	emit_pop_t0
pop_cs_rshift:
	addi	gp, zero, 1		# esra site 1 = esra_cs_rshift
	j	emit_sra
esra_cs_rshift:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 11		# esws site 11 = esws_cs_rshift
	j	emit_sw_sp
esws_cs_rshift:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '&=' expr ; ────────────────────────────────────────────────────────
cs_compound_and:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 8		# elws site 8 = elws_cs_and
	j	emit_lw_sp
elws_cs_and:
	addi	gp, zero, 11		# push site 11 = push_cs_and
	j	emit_push_a0
push_cs_and:
	addi	t6, zero, 0
	addi	gp, zero, 10		# ce site 10 = ce_cs_and
	j	compile_expr_p
ce_cs_and:
	addi	gp, zero, 11		# pop site 11 = pop_cs_and
	j	emit_pop_t0
pop_cs_and:
	addi	gp, zero, 1		# ean site 1 = ean_cs_and
	j	emit_and
ean_cs_and:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 12		# esws site 12 = esws_cs_and
	j	emit_sw_sp
esws_cs_and:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '|=' expr ; ────────────────────────────────────────────────────────
cs_compound_or:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 9		# elws site 9 = elws_cs_or
	j	emit_lw_sp
elws_cs_or:
	addi	gp, zero, 13		# push site 13 = push_cs_or
	j	emit_push_a0
push_cs_or:
	addi	t6, zero, 0
	addi	gp, zero, 11		# ce site 11 = ce_cs_or
	j	compile_expr_p
ce_cs_or:
	addi	gp, zero, 13		# pop site 13 = pop_cs_or
	j	emit_pop_t0
pop_cs_or:
	addi	gp, zero, 1		# eor site 1 = eor_cs_or
	j	emit_or
eor_cs_or:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 13		# esws site 13 = esws_cs_or
	j	emit_sw_sp
esws_cs_or:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '*=' expr ; ────────────────────────────────────────────────────────
cs_compound_mul:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 10		# elws site 10 = elws_cs_mul
	j	emit_lw_sp
elws_cs_mul:
	addi	gp, zero, 17		# push site 17 = push_cs_mul
	j	emit_push_a0
push_cs_mul:
	addi	t6, zero, 0
	addi	gp, zero, 13		# ce site 13 = ce_cs_mul
	j	compile_expr_p
ce_cs_mul:
	addi	gp, zero, 17		# pop site 17 = pop_cs_mul
	j	emit_pop_t0
pop_cs_mul:
	addi	gp, zero, 1		# emul site 1 = emul_cs_mul_ret
	j	emit_mul
emul_cs_mul_ret:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 14		# esws site 14 = esws_cs_mul
	j	emit_sw_sp
esws_cs_mul:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '/=' expr ; ────────────────────────────────────────────────────────
cs_compound_div:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 11		# elws site 11 = elws_cs_div
	j	emit_lw_sp
elws_cs_div:
	addi	gp, zero, 18		# push site 18 = push_cs_div
	j	emit_push_a0
push_cs_div:
	addi	t6, zero, 0
	addi	gp, zero, 14		# ce site 14 = ce_cs_div
	j	compile_expr_p
ce_cs_div:
	addi	gp, zero, 18		# pop site 18 = pop_cs_div
	j	emit_pop_t0
pop_cs_div:
	addi	gp, zero, 2		# edmb site 2 = edmb_cs_div_ret
	j	emit_divmod_body
edmb_cs_div_ret:
	lui	a0, 0x30
	addi	a0, a0, 0x513
	addi	gp, zero, 18		# ecw site 18 = ecw_cs_div_mv
	j	emit_cmp_word
ecw_cs_div_mv:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 15		# esws site 15 = esws_cs_div
	j	emit_sw_sp
esws_cs_div:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '%=' expr ; ────────────────────────────────────────────────────────
cs_compound_mod:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 12		# elws site 12 = elws_cs_mod
	j	emit_lw_sp
elws_cs_mod:
	addi	gp, zero, 19		# push site 19 = push_cs_mod
	j	emit_push_a0
push_cs_mod:
	addi	t6, zero, 0
	addi	gp, zero, 15		# ce site 15 = ce_cs_mod
	j	compile_expr_p
ce_cs_mod:
	addi	gp, zero, 19		# pop site 19 = pop_cs_mod
	j	emit_pop_t0
pop_cs_mod:
	addi	gp, zero, 3		# edmb site 3 = edmb_cs_mod_ret
	j	emit_divmod_body
edmb_cs_mod_ret:
	lui	a0, 0x38
	addi	a0, a0, 0x513
	addi	gp, zero, 19		# ecw site 19 = ecw_cs_mod_mv
	j	emit_cmp_word
ecw_cs_mod_mv:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 16		# esws site 16 = esws_cs_mod
	j	emit_sw_sp
esws_cs_mod:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '++' ; (postfix, value discarded) ──────────────────────────────────
cs_ident_post_inc:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 1		# elws site 1 = elws_cs_inc_stmt
	j	emit_lw_sp

# ── IDENT '--' ; (postfix, value discarded) ──────────────────────────────────
cs_ident_post_dec:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 2		# elws site 2 = elws_cs_dec_stmt
	j	emit_lw_sp

# Shared tail for '++x;' / 'x++;' (load already emitted, offset at 0(sp)).
elws_cs_inc_stmt:
	addi	gp, zero, 3		# eaa1 site 3 = eaa1_cs_inc_stmt
	j	emit_addi_a0_1
eaa1_cs_inc_stmt:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 5		# esws site 5 = esws_cs_inc_stmt
	j	emit_sw_sp
esws_cs_inc_stmt:
	addi	gp, zero, 15
	j	skip_ws

# Shared tail for '--x;' / 'x--;'.
elws_cs_dec_stmt:
	addi	gp, zero, 3		# eaam1 site 3 = eaam1_cs_dec_stmt
	j	emit_addi_a0_m1
eaam1_cs_dec_stmt:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 6		# esws site 6 = esws_cs_dec_stmt
	j	emit_sw_sp
esws_cs_dec_stmt:
	addi	gp, zero, 15
	j	skip_ws

# Shared trailing-';' check for every path that jumps to skip_ws site 15.
# Reached after a compound assign has popped its intermediate stack frame,
# so sp = entry_sp - 4 (compile_stmt's frame only). Fallback goes to cs_fb.
sw_cs_semi_stmt:
	bge	s2, s3, cs_fb
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_fb
	addi	s2, s2, 1
	j	cs_done

# ── '++' IDENT ; (bare prefix statement) ─────────────────────────────────────
cs_chk_pre_pp:
	addi	t2, s2, 1
	bge	t2, s3, cs_fb
	lbu	t0, 0(t2)
	addi	t1, zero, '+'
	bne	t0, t1, cs_fb
	addi	s2, s2, 2
	addi	gp, zero, 16		# skip_ws site 16 = sw_cs_pp_id
	j	skip_ws
sw_cs_pp_id:
	addi	gp, zero, 2		# parse_ident site 2 = pi_cs_pp
	j	parse_ident
pi_cs_pp:
	addi	gp, zero, 2		# lookup_or_alloc site 2 = la_cs_pp
	j	lookup_or_alloc
la_cs_pp:
	addi	sp, sp, -4
	sw	a0, 0(sp)
	addi	gp, zero, 1		# elws site 1 = elws_cs_inc_stmt (shared)
	j	emit_lw_sp

# ── '--' IDENT ; (bare prefix statement) ─────────────────────────────────────
cs_chk_pre_mm:
	addi	t2, s2, 1
	bge	t2, s3, cs_fb
	lbu	t0, 0(t2)
	addi	t1, zero, '-'
	bne	t0, t1, cs_fb
	addi	s2, s2, 2
	addi	gp, zero, 17		# skip_ws site 17 = sw_cs_mm_id
	j	skip_ws
sw_cs_mm_id:
	addi	gp, zero, 3		# parse_ident site 3 = pi_cs_mm
	j	parse_ident
pi_cs_mm:
	addi	gp, zero, 3		# lookup_or_alloc site 3 = la_cs_mm
	j	lookup_or_alloc
la_cs_mm:
	addi	sp, sp, -4
	sw	a0, 0(sp)
	addi	gp, zero, 2		# elws site 2 = elws_cs_dec_stmt (shared)
	j	emit_lw_sp

cs_star:
	addi	s2, s2, 1
	addi	t6, zero, 1
	addi	gp, zero, 1
	j	compile_expr_p
ce_cs_addr1:
	# Push the address onto the compiled program's stack.
	addi	gp, zero, 1		# push site 1 = push_cs_star
	j	emit_push_a0
push_cs_star:

	addi	gp, zero, 7
	j	skip_ws
sw_cs_eq2:
	lbu	t0, 0(s2)
	addi	t1, zero, '='
	bne	t0, t1, cs_fb
	addi	s2, s2, 1

	addi	t6, zero, 0
	addi	gp, zero, 2
	j	compile_expr_p
ce_cs_val1:
	# Pop the address into t0 in the compiled program, then sw.
	addi	gp, zero, 1		# pop site 1 = pop_cs_star
	j	emit_pop_t0
pop_cs_star:
	addi	gp, zero, 0		# esw site 0 = esw_ret
	j	emit_sw_deref
esw_ret:

	addi	gp, zero, 8
	j	skip_ws
sw_cs_semi2:
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_fb
	addi	s2, s2, 1
	j	cs_done

cs_at:
	addi	s2, s2, 1
	addi	t6, zero, 1
	addi	gp, zero, 3
	j	compile_expr_p
ce_cs_addr2:
	addi	gp, zero, 2		# push site 2 = push_cs_at
	j	emit_push_a0
push_cs_at:

	addi	gp, zero, 9
	j	skip_ws
sw_cs_eq3:
	lbu	t0, 0(s2)
	addi	t1, zero, '='
	bne	t0, t1, cs_fb
	addi	s2, s2, 1

	addi	t6, zero, 0
	addi	gp, zero, 4
	j	compile_expr_p
ce_cs_val2:
	addi	gp, zero, 2		# pop site 2 = pop_cs_at
	j	emit_pop_t0
pop_cs_at:
	addi	gp, zero, 0		# esb site 0 = esb_ret
	j	emit_sb_deref
esb_ret:

	addi	gp, zero, 10
	j	skip_ws
sw_cs_semi3:
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_fb
	addi	s2, s2, 1
	j	cs_done

cs_bad:
	# IDENT-path fallback. la_cs pushed +4 on top of compile_stmt's entry
	# frame (4 bytes), so sp = entry_sp - 8 here. Pop la_cs's slot and
	# fall through to cs_fb, which expects sp = entry_sp - 4.
	addi	sp, sp, 4
	# Fall through.

cs_fb:
	# Expression-statement fallback. sp = entry_sp - 4, with the entry s2
	# saved at 0(sp). Rewind s2, call compile_expr_p, expect trailing ';'.
	lw	s2, 0(sp)
	addi	t6, zero, 0
	addi	gp, zero, 24		# compile_expr site 24 = ce_cs_exprstmt
	j	compile_expr_p
ce_cs_exprstmt:
	# compile_expr_p leaves s2 at the first non-op char — should be ';'.
	bge	s2, s3, cs_halt
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_halt
	addi	s2, s2, 1
	j	cs_done

cs_halt:
	addi	a0, zero, 1		# err 1: expected ';'
	j	report_err

cs_done:
	addi	sp, sp, 4		# pop compile_stmt's entry frame
	j	cs_after

# ══════════════════════════════════════════════════════════════════════════════
# emit_mul — emit the 11-instruction inline signed-multiply sequence.
#
# Runtime contract (i.e. what the emitted instructions expect at runtime):
#   t0 = LHS (just popped by caller), a0 = RHS.
#   On exit: a0 = product (low 32 bits). t1, t2, t3, t4 clobbered.
#
# Emission works by looping over `mul_code` (a table of 11 pre-assembled
# instruction words) and calling emit_word once per entry. Signed and
# unsigned multiplication produce identical low-32-bit results in two's
# complement, so a single shift-and-add loop handles both.
#
# Multi-caller. Call sites:
#   0: emul_cmul_ret    (compile_mul '*' loop)
#   1: emul_cs_mul_ret  (compile_stmt '*=')
#   2: emul_cep_ret     (compile_expr_p '*' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_mul:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, mul_code
	lla	t1, mul_code_end
emul_loop:
	bge	t0, t1, emul_done
	lw	a0, 0(t0)
	addi	sp, sp, -8
	sw	t0, 0(sp)
	sw	t1, 4(sp)
	addi	gp, zero, 26		# ew site 26 = ew_mul
	j	emit_word
ew_mul:
	lw	t0, 0(sp)
	lw	t1, 4(sp)
	addi	sp, sp, 8
	addi	t0, t0, 4
	j	emul_loop
emul_done:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_mul_disp

emit_mul_disp:
	bnez	gp, emul_d1
	j	emul_cmul_ret
emul_d1:
	addi	gp, gp, -1
	bnez	gp, emul_d2
	j	emul_cs_mul_ret
emul_d2:
	j	emul_cep_ret

# The compiled-program mul loop template. Each entry is one RV32I instruction.
# Offsets inside the template (relative to the start of the emitted block):
#    0:  addi t1, a0, 0       # t1 = multiplier (RHS)
#    4:  addi t2, t0, 0       # t2 = multiplicand (LHS)
#    8:  addi a0, zero, 0     # a0 = accumulator
#   12:  addi t3, zero, 32    # t3 = bit counter
#   16:  andi t4, t1, 1       ← LOOP
#   20:  beq  t4, zero, +8    # skip add if low bit of multiplier is 0
#   24:  add  a0, a0, t2
#   28:  slli t2, t2, 1       (skip lands here)
#   32:  srli t1, t1, 1
#   36:  addi t3, t3, -1
#   40:  bnez t3, -24         # branch back to LOOP (offset -24)
#   44:  (fall through: a0 holds product)
mul_code:
	.word	0x00050313
	.word	0x00028393
	.word	0x00000513
	.word	0x02000E13
	.word	0x00137E93
	.word	0x000E8463
	.word	0x00750533
	.word	0x00139393
	.word	0x00135313
	.word	0xFFFE0E13
	.word	0xFE0E14E3
mul_code_end:

# ══════════════════════════════════════════════════════════════════════════════
# emit_divmod_body — emit the 24-instruction shared divmod body.
#
# Runtime contract:
#   t0 = LHS (dividend), a0 = RHS (divisor).
#   On exit: t1 = signed quotient, t2 = signed remainder.
#   Clobbers: t0, a0, t3, t4, t5, t6.
#
# The body does: save signs → absolute value → unsigned shift-and-subtract
# division loop → sign fixup for quotient (xor of signs) and remainder
# (sign of dividend). After this helper returns, the caller must emit one
# more instruction: either `mv a0, t1` (for /, /=) or `mv a0, t2` (for %, %=).
#
# Divide-by-zero: follows RISC-V M-extension convention (quotient = -1,
# remainder = dividend) because r=0 stays 0 against divisor=0, so all
# 32 quotient bits are set (-1 signed) and r=|dividend| then gets the
# dividend's sign back.
#
# Multi-caller. Call sites:
#   0: edmb_cdiv_ret     (compile_mul '/' loop)
#   1: edmb_cmod_ret     (compile_mul '%' loop)
#   2: edmb_cs_div_ret   (compile_stmt '/=')
#   3: edmb_cs_mod_ret   (compile_stmt '%=')
#   4: edmb_cep_div_ret  (compile_expr_p '/' Pratt op)
#   5: edmb_cep_mod_ret  (compile_expr_p '%' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_divmod_body:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, divmod_code
	lla	t1, divmod_code_end
edmb_loop:
	bge	t0, t1, edmb_done
	lw	a0, 0(t0)
	addi	sp, sp, -8
	sw	t0, 0(sp)
	sw	t1, 4(sp)
	addi	gp, zero, 27		# ew site 27 = ew_divmod
	j	emit_word
ew_divmod:
	lw	t0, 0(sp)
	lw	t1, 4(sp)
	addi	sp, sp, 8
	addi	t0, t0, 4
	j	edmb_loop
edmb_done:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_divmod_body_disp

emit_divmod_body_disp:
	bnez	gp, edmb_d1
	j	edmb_cdiv_ret
edmb_d1:
	addi	gp, gp, -1
	bnez	gp, edmb_d2
	j	edmb_cmod_ret
edmb_d2:
	addi	gp, gp, -1
	bnez	gp, edmb_d3
	j	edmb_cs_div_ret
edmb_d3:
	addi	gp, gp, -1
	bnez	gp, edmb_d4
	j	edmb_cs_mod_ret
edmb_d4:
	addi	gp, gp, -1
	bnez	gp, edmb_d5
	j	edmb_cep_div_ret
edmb_d5:
	j	edmb_cep_mod_ret

# The compiled-program divmod loop template (24 instructions).
# Layout (byte offsets inside the emitted block):
#    0:  srai  t5, t0, 31         # t5 = lhs sign mask
#    4:  srai  t6, a0, 31         # t6 = rhs sign mask
#    8:  xor   t0, t0, t5
#   12:  sub   t0, t0, t5         # t0 = |LHS|
#   16:  xor   a0, a0, t6
#   20:  sub   a0, a0, t6         # a0 = |RHS|
#   24:  addi  t1, zero, 0        # q = 0
#   28:  addi  t2, zero, 0        # r = 0
#   32:  addi  t3, zero, 32       # counter
#   36:  srli  t4, t0, 31         ← LOOP
#   40:  slli  t2, t2, 1          # r <<= 1
#   44:  or    t2, t2, t4         # r |= top bit
#   48:  slli  t0, t0, 1          # dividend <<= 1
#   52:  slli  t1, t1, 1          # q <<= 1
#   56:  bltu  t2, a0, +12        # if r<divisor skip sub/set
#   60:  sub   t2, t2, a0
#   64:  addi  t1, t1, 1
#   68:  addi  t3, t3, -1
#   72:  bnez  t3, -36            # loop back
#   76:  xor   t4, t5, t6         # quotient sign = lhs_sign ^ rhs_sign
#   80:  xor   t1, t1, t4
#   84:  sub   t1, t1, t4         # signed quotient
#   88:  xor   t2, t2, t5         # remainder sign = lhs_sign
#   92:  sub   t2, t2, t5         # signed remainder
divmod_code:
	.word	0x41F2DF13
	.word	0x41F55F93
	.word	0x01E2C2B3
	.word	0x41E282B3
	.word	0x01F54533
	.word	0x41F50533
# udivmod_start: unsigned divmod body starts here. Re-used by emit_udivmod_body
# for '/u' and '%u'. The 13 words in this range compute q = t0/a0, r = t0%a0
# using an unsigned shift-and-subtract loop; signed wrappers around the edge
# (above and below) handle absolute value and sign fixup.
udivmod_start:
	.word	0x00000313
	.word	0x00000393
	.word	0x02000E13
	.word	0x01F2DE93
	.word	0x00139393
	.word	0x01D3E3B3
	.word	0x00129293
	.word	0x00131313
	.word	0x00A3E663
	.word	0x40A383B3
	.word	0x00130313
	.word	0xFFFE0E13
	.word	0xFC0E1EE3
udivmod_end:
	.word	0x01FF4EB3
	.word	0x01D34333
	.word	0x41D30333
	.word	0x01E3C3B3
	.word	0x41E383B3
divmod_code_end:

# ══════════════════════════════════════════════════════════════════════════════
# emit_udivmod_body — emit the 13-instruction unsigned divmod body.
#
# Runtime contract:
#   t0 = LHS (dividend), a0 = RHS (divisor), both interpreted as unsigned.
#   On exit: t1 = quotient, t2 = remainder (both unsigned).
#   Clobbers: t0, a0, t3, t4.
#
# Emits the middle range of divmod_code (from udivmod_start to udivmod_end),
# which is exactly the init + unsigned shift-and-subtract loop with no sign
# handling. After this helper, the caller emits one `mv a0, t1` (for /u) or
# `mv a0, t2` (for %u).
#
# Multi-caller. Call sites:
#   0: eudmb_cdivu_ret    (compile_mul '/u' loop)
#   1: eudmb_cmodu_ret    (compile_mul '%u' loop)
#   2: eudmb_cep_divu_ret (compile_expr_p '/u' Pratt op)
#   3: eudmb_cep_modu_ret (compile_expr_p '%u' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_udivmod_body:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, udivmod_start
	lla	t1, udivmod_end
eudmb_loop:
	bge	t0, t1, eudmb_done
	lw	a0, 0(t0)
	addi	sp, sp, -8
	sw	t0, 0(sp)
	sw	t1, 4(sp)
	addi	gp, zero, 28		# ew site 28 = ew_udivmod
	j	emit_word
ew_udivmod:
	lw	t0, 0(sp)
	lw	t1, 4(sp)
	addi	sp, sp, 8
	addi	t0, t0, 4
	j	eudmb_loop
eudmb_done:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_udivmod_body_disp

emit_udivmod_body_disp:
	bnez	gp, eudmb_d1
	j	eudmb_cdivu_ret
eudmb_d1:
	addi	gp, gp, -1
	bnez	gp, eudmb_d2
	j	eudmb_cmodu_ret
eudmb_d2:
	addi	gp, gp, -1
	bnez	gp, eudmb_d3
	j	eudmb_cep_divu_ret
eudmb_d3:
	j	eudmb_cep_modu_ret

# ══════════════════════════════════════════════════════════════════════════════
# patch_jtype — OR the J-type offset bits for `(t6 - t5)` into the word at t5.
#
# Inputs (famc registers):
#   t5 = address of the jal instruction in famc memory (inside compiled bin)
#   t6 = target address in famc memory
# Clobbers: t0, t1, t2
#
# The placeholder was emitted with imm=0, so OR-ing the offset bits into the
# existing word is sufficient (no need to clear first). J-type's 21-bit signed
# range gives ±1 MiB reach, comfortably more than a single RHS will need.
#
# Multi-caller. Call sites:
#   0: pjt_cland_sf  (compile_land — jal to SHORT_FALSE)
#   1: pjt_cland_end (compile_land — jal to END)
#   2: pjt_clor_st   (compile_expr/|| — jal to SHORT_TRUE)
#   3: pjt_clor_end  (compile_expr/|| — jal to END)
#   4: pjt_ctern_else (compile_expr ternary — jal to ELSE block)
#   5: pjt_ctern_end  (compile_expr ternary — jal to END)
#   6: pjt_cep_land_sf  (compile_expr_p '&&' — jal to SHORT_FALSE)
#   7: pjt_cep_land_end (compile_expr_p '&&' — jal to END)
#   8: pjt_cep_lor_st   (compile_expr_p '||' — jal to SHORT_TRUE)
#   9: pjt_cep_lor_end  (compile_expr_p '||' — jal to END)
#  10: pjt_cep_tern_else (compile_expr_p '?' — jal to ELSE)
#  11: pjt_cep_tern_end  (compile_expr_p '?' — jal to END)
# ══════════════════════════════════════════════════════════════════════════════
patch_jtype:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	sub	t2, t6, t5		# offset = target - addr
	lw	t0, 0(t5)

	# imm[20] at bit 31
	srli	t1, t2, 20
	andi	t1, t1, 1
	slli	t1, t1, 31
	or	t0, t0, t1

	# imm[19:12] at bits 19:12
	srli	t1, t2, 12
	andi	t1, t1, 0xFF
	slli	t1, t1, 12
	or	t0, t0, t1

	# imm[11] at bit 20
	srli	t1, t2, 11
	andi	t1, t1, 1
	slli	t1, t1, 20
	or	t0, t0, t1

	# imm[10:1] at bits 30:21
	srli	t1, t2, 1
	andi	t1, t1, 0x3FF
	slli	t1, t1, 21
	or	t0, t0, t1

	sw	t0, 0(t5)
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	patch_jtype_disp

patch_jtype_disp:
	bnez	gp, pjt_d1
	j	pjt_cland_sf
pjt_d1:
	addi	gp, gp, -1
	bnez	gp, pjt_d2
	j	pjt_cland_end
pjt_d2:
	addi	gp, gp, -1
	bnez	gp, pjt_d3
	j	pjt_clor_st
pjt_d3:
	addi	gp, gp, -1
	bnez	gp, pjt_d4
	j	pjt_clor_end
pjt_d4:
	addi	gp, gp, -1
	bnez	gp, pjt_d5
	j	pjt_ctern_else
pjt_d5:
	addi	gp, gp, -1
	bnez	gp, pjt_d6
	j	pjt_ctern_end
pjt_d6:
	addi	gp, gp, -1
	bnez	gp, pjt_d7
	j	pjt_cep_land_sf
pjt_d7:
	addi	gp, gp, -1
	bnez	gp, pjt_d8
	j	pjt_cep_land_end
pjt_d8:
	addi	gp, gp, -1
	bnez	gp, pjt_d9
	j	pjt_cep_lor_st
pjt_d9:
	addi	gp, gp, -1
	bnez	gp, pjt_d10
	j	pjt_cep_lor_end
pjt_d10:
	addi	gp, gp, -1
	bnez	gp, pjt_d11
	j	pjt_cep_tern_else
pjt_d11:
	j	pjt_cep_tern_end

# ══════════════════════════════════════════════════════════════════════════════
# Error reporting. On any parse error, the site sets a0 = error code and jumps
# to report_err, which prints
#
#     Error:<line>:<col> Expected <X> found '<Y>'
#     Error:<line>:<col> Expected <X> at end of input
#     Error:<line>:<col> <raw message>
#
# and then poweroffs. Line/col is computed on demand by walking s1..s2.
#
# Error-code table `err_tbl` has 32-byte slots indexed by code:
#   byte 0: kind  (0 = "Expected X found Y", 1 = raw phrase)
#   byte 1: len   (length of template/phrase text)
#   bytes 2..: text (up to 30 chars, rest zero-padded)
#
# ee_str / emit_dec are helpers used by report_err (and nothing else).
# ══════════════════════════════════════════════════════════════════════════════

# ── ee_str — emit `a1` bytes from `a0` to UART, return via gp dispatch ───────
ee_str:
ee_loop:
	beqz	a1, ee_done
ee_wait:
	lbu	t0, 5(s6)
	andi	t0, t0, 0x20
	beqz	t0, ee_wait
	lbu	t0, 0(a0)
	sb	t0, 0(s6)
	addi	a0, a0, 1
	addi	a1, a1, -1
	j	ee_loop
ee_done:
	j	ee_disp

ee_disp:
	bnez	gp, ee_d1
	j	ee_dec_ret
ee_d1:
	addi	gp, gp, -1
	bnez	gp, ee_d2
	j	re_after_error
ee_d2:
	addi	gp, gp, -1
	bnez	gp, ee_d3
	j	re_after_colon
ee_d3:
	addi	gp, gp, -1
	bnez	gp, ee_d4
	j	re_after_expected
ee_d4:
	addi	gp, gp, -1
	bnez	gp, ee_d5
	j	re_after_template
ee_d5:
	addi	gp, gp, -1
	bnez	gp, ee_d6
	j	re_after_found
ee_d6:
	addi	gp, gp, -1
	bnez	gp, ee_d7
	j	re_after_char
ee_d7:
	addi	gp, gp, -1
	bnez	gp, ee_d8
	j	re_after_tail
ee_d8:
	addi	gp, gp, -1
	bnez	gp, ee_d9
	j	re_after_eof
ee_d9:
	addi	gp, gp, -1
	bnez	gp, ee_d10
	j	re_after_raw_space
ee_d10:
	addi	gp, gp, -1
	bnez	gp, ee_d11
	j	re_after_raw_text
ee_d11:
	j	re_after_raw_nl

# ── emit_dec — emit unsigned a0 as decimal digits, return via gp dispatch ────
# Uses a stack buffer to reverse digits, then calls ee_str to print them.
emit_dec:
	addi	sp, sp, -20
	sw	gp, 0(sp)
	addi	t3, sp, 16		# write ptr = end of 12-byte buffer
	bnez	a0, ed_conv
	# Special case: a0 == 0 → emit single '0'.
	addi	t0, zero, '0'
	addi	t3, t3, -1
	sb	t0, 0(t3)
	j	ed_done
ed_conv:
ed_loop:
	# Divide a0 by 10 via repeated subtraction.
	addi	t5, zero, 0		# quotient
ed_d10:
	addi	t1, a0, -10
	bltz	t1, ed_d10_done
	addi	a0, a0, -10
	addi	t5, t5, 1
	j	ed_d10
ed_d10_done:
	# a0 = remainder (0..9), t5 = quotient.
	addi	t0, a0, 48		# '0' + digit
	addi	t3, t3, -1
	sb	t0, 0(t3)
	addi	a0, t5, 0
	bnez	a0, ed_loop
ed_done:
	# Digit string at [t3 .. sp+16). Emit via ee_str.
	addi	a0, t3, 0
	addi	t4, sp, 16
	sub	a1, t4, t3
	addi	gp, zero, 0		# ee_str site 0 = ee_dec_ret
	j	ee_str
ee_dec_ret:
	lw	gp, 0(sp)
	addi	sp, sp, 20
	bnez	gp, ed_r1
	j	re_after_line
ed_r1:
	j	re_after_col

# ── report_err — format and print the error, then poweroff ───────────────────
# Input: a0 = error code (1..N, see err_tbl).
report_err:
	addi	sp, sp, -16
	sw	a0, 0(sp)		# [0]: err_code

	# Walk s1..s2 counting newlines to compute line/col.
	addi	t2, s1, 0
	addi	t3, zero, 1		# line
	addi	t4, zero, 1		# col
lc_loop:
	bge	t2, s2, lc_done
	lbu	t0, 0(t2)
	addi	t1, zero, 10
	beq	t0, t1, lc_nl
	addi	t4, t4, 1
	j	lc_next
lc_nl:
	addi	t3, t3, 1
	addi	t4, zero, 1
lc_next:
	addi	t2, t2, 1
	j	lc_loop
lc_done:
	sw	t3, 4(sp)		# [4]: line
	sw	t4, 8(sp)		# [8]: col

	# Emit "Error:"
	lla	a0, es_error
	addi	a1, zero, 6
	addi	gp, zero, 1		# ee_str site 1
	j	ee_str
re_after_error:
	# Emit line number.
	lw	a0, 4(sp)
	addi	gp, zero, 0		# emit_dec site 0
	j	emit_dec
re_after_line:
	# Emit ":"
	lla	a0, es_colon
	addi	a1, zero, 1
	addi	gp, zero, 2		# ee_str site 2
	j	ee_str
re_after_colon:
	# Emit col number.
	lw	a0, 8(sp)
	addi	gp, zero, 1		# emit_dec site 1
	j	emit_dec
re_after_col:
	# Look up error-table slot: err_tbl + (err_code << 5).
	lw	t5, 0(sp)
	slli	t5, t5, 5
	lla	t0, err_tbl
	add	t5, t0, t5
	lbu	t1, 0(t5)		# kind
	# Branch on kind: raw (1) skips the " Expected " prefix.
	bnez	t1, re_raw_msg

	# ── Expected/found path ─────────────────────────────────────────
	lla	a0, es_expected
	addi	a1, zero, 10
	addi	gp, zero, 3		# ee_str site 3
	j	ee_str
re_after_expected:
	# Emit template text (from slot[2..2+len]).
	lw	t5, 0(sp)
	slli	t5, t5, 5
	lla	t0, err_tbl
	add	t5, t0, t5
	lbu	a1, 1(t5)
	addi	a0, t5, 2
	addi	gp, zero, 4		# ee_str site 4
	j	ee_str
re_after_template:
	# Decide between " found 'X'" and " at end of input".
	bge	s2, s3, re_eof_path
	lla	a0, es_found
	addi	a1, zero, 8
	addi	gp, zero, 5		# ee_str site 5
	j	ee_str
re_after_found:
	# Emit the offending char (a copy buffered at 12(sp)).
	lbu	t0, 0(s2)
	sb	t0, 12(sp)
	addi	a0, sp, 12
	addi	a1, zero, 1
	addi	gp, zero, 6		# ee_str site 6
	j	ee_str
re_after_char:
	lla	a0, es_tail
	addi	a1, zero, 2
	addi	gp, zero, 7		# ee_str site 7
	j	ee_str
re_after_tail:
	j	poweroff

re_eof_path:
	lla	a0, es_eof
	addi	a1, zero, 17
	addi	gp, zero, 8		# ee_str site 8
	j	ee_str
re_after_eof:
	j	poweroff

	# ── Raw message path ────────────────────────────────────────────
re_raw_msg:
	lla	a0, es_space
	addi	a1, zero, 1
	addi	gp, zero, 9		# ee_str site 9
	j	ee_str
re_after_raw_space:
	lw	t5, 0(sp)
	slli	t5, t5, 5
	lla	t0, err_tbl
	add	t5, t0, t5
	lbu	a1, 1(t5)
	addi	a0, t5, 2
	addi	gp, zero, 10		# ee_str site 10
	j	ee_str
re_after_raw_text:
	lla	a0, es_nl
	addi	a1, zero, 1
	addi	gp, zero, 11		# ee_str site 11
	j	ee_str
re_after_raw_nl:
	j	poweroff

# ══════════════════════════════════════════════════════════════════════════════
# Lvalue marker — written by compile_unary at the end of each primary parse,
# read by the Pratt compile_expr's assignment handler.
#
#   lv_kind:  0 = not an lvalue (literal, paren-arith, ~/-, ++/-- result, …)
#             1 = local variable; the slot offset is in lv_slot
#             2 = byte deref; address was left in a0 before the `lbu` we just
#                 emitted (so un-emitting the lbu restores the address)
#             3 = word deref; same but with `lw`
#
# Binary/ternary/assignment operators in compile_expr reset lv_kind to 0 after
# their post-rhs emit, because arithmetic results are never lvalues.
# ══════════════════════════════════════════════════════════════════════════════
lv_kind:
	.word	0
lv_slot:
	.word	0

# ── Error message literals ──────────────────────────────────────────────────
es_error:
	.ascii	"Error:"
es_colon:
	.ascii	":"
es_expected:
	.ascii	" Expected "
es_found:
	.ascii	" found '"
es_tail:
	.ascii	"'\n"
es_eof:
	.ascii	" at end of input\n"
es_space:
	.ascii	" "
es_nl:
	.ascii	"\n"

# ── Error code table ────────────────────────────────────────────────────────
# 32-byte slots indexed by error code. Slot layout:
#   byte 0: kind   (0 = "Expected X found Y", 1 = raw phrase)
#   byte 1: len    (length of template/phrase text)
#   bytes 2..:     text, zero-padded to 32 bytes total
#
# Codes:
#    0  reserved (unused)
#    1  ';'
#    2  ')'
#    3  '}' or ';'
#    4  ':'
#    5  expression
#    6  identifier
#    7  '=' or compound-assign operator
#    8  end of statement
#   20  raw: assignment target is not an lvalue
#   21  raw: cannot '++' or '--' a literal
#   22  raw: '*'/'@' deref cannot combine with '++' or '--'
err_tbl:
	# slot 0 — reserved
	.byte	0, 0
	.zero	30
	# slot 1 — ';'
	.byte	0, 3
	.ascii	"';'"
	.zero	27
	# slot 2 — ')'
	.byte	0, 3
	.ascii	"')'"
	.zero	27
	# slot 3 — '}' or ';'
	.byte	0, 10
	.ascii	"'}' or ';'"
	.zero	20
	# slot 4 — ':'
	.byte	0, 3
	.ascii	"':'"
	.zero	27
	# slot 5 — expression
	.byte	0, 10
	.ascii	"expression"
	.zero	20
	# slot 6 — identifier
	.byte	0, 10
	.ascii	"identifier"
	.zero	20
	# slot 7 — '=' or compound-assign operator
	.byte	0, 25
	.ascii	"'=' or compound-assign op"
	.zero	5
	# slot 8 — end of statement
	.byte	0, 16
	.ascii	"end of statement"
	.zero	14
	# slots 9..19 — reserved
	.zero	352
	# slot 20 — raw: not an lvalue
	.byte	1, 28
	.ascii	"left of '=' is not an lvalue"
	.zero	2
	# slot 21 — raw: literal ++/--
	.byte	1, 28
	.ascii	"'++'/'--' requires an lvalue"
	.zero	2
	# slot 22 — raw: combo
	.byte	1, 30
	.ascii	"cannot combine deref and ++/--"
	.zero	0

# ══════════════════════════════════════════════════════════════════════════════
# End of famc image.  `tp` is initialized from this label at startup — every
# heap allocation (symtab, future dynamic state) bumps `tp` forward from here.
# Naturally 4-byte aligned because every preceding instruction is exactly 4 B.
# ══════════════════════════════════════════════════════════════════════════════
data:
