# asm_lookup: look up mnemonic in asm table
# a0=text_ptr (in input), a1=text_len → a0=table_entry_ptr or 0
# Copies token to a zero-padded 8-byte stack buffer for comparison.
asm_lookup:
	# Build zero-padded 8-byte name on stack
	addi	sp, sp, -8
	sw	zero, 0(sp)
	sw	zero, 4(sp)
	mv	t0, sp
	mv	t1, a0			# src
	mv	t2, a1			# len
al_copy:
	beqz	t2, al_search
	lbu	t3, 0(t1)
	sb	t3, 0(t0)
	addi	t0, t0, 1
	addi	t1, t1, 1
	addi	t2, t2, -1
	j	al_copy
al_search:
	lla	t0, asm_mnem_tbl
al_next:
	lbu	t1, 0(t0)
	beqz	t1, al_fail		# sentinel
	# Compare 8 bytes
	mv	t2, sp			# our padded buffer
	mv	t3, t0			# entry name
	li	t4, 8
al_cmp:
	lbu	t5, 0(t2)
	lbu	t6, 0(t3)
	bne	t5, t6, al_skip
	addi	t2, t2, 1
	addi	t3, t3, 1
	addi	t4, t4, -1
	bnez	t4, al_cmp
	# Match
	mv	a0, t0
	addi	sp, sp, 8
	ret
al_skip:
	addi	t0, t0, 12
	j	al_next
al_fail:
	li	a0, 0
	addi	sp, sp, 8
	ret

# is_reg_name: deferred to codegen — parser captures tokens as-is

# ── px_asm: parse asm [name] { body } ────────────────────────────────
# s2 = the NK_ASM node from lex_next
px_asm:
	# Check for optional name (peek for identifier before '{')
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_IDENT
	bne	a0, t0, px_asm_no_name
	# Has a name — consume it and add as child
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next
	mv	a1, s4
	mv	a0, s2
	jal	node_add_child
px_asm_no_name:
	# Consume '{'
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next

	# Parse asm body until '}'
px_asm_lp:
	# Peek next token
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 1
	jal	lex_next
	li	t0, NK_RBRACE
	beq	a0, t0, px_asm_close
	li	t0, NK_TERM
	beq	a0, t0, px_asm_close

	# Check for binding: '(' starts a binding
	li	t0, NK_LPAREN
	beq	a0, t0, px_asm_bind

	# Check for numeric label: number followed by ':'
	li	t0, NK_NUMBER
	beq	a0, t0, px_asm_maybe_label

	# Must be an instruction mnemonic
	j	px_asm_insn

# ── Asm binding: (reg=expr) or (var=reg) ──
px_asm_bind:
	# Consume '('
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next

	# Create bind node
	jal	node_alloc
	mv	s3, a0
	li	t0, NK_ASM_BIND
	sw	t0, N_KIND(s3)

	# Read left side (reg or var name)
	jal	node_alloc
	mv	s4, a0
	mv	a0, s0
	mv	a1, s4
	li	a2, 0
	jal	lex_next
	mv	a1, s4
	mv	a0, s3
	jal	node_add_child

	# Expect '='
	mv	a0, s0
	li	a1, NK_ASSIGN
	lla	a2, str_assign
	jal	expect_tok

	# Read right side — could be simple ident or expression
	mv	a0, s0
	li	a1, P_NONE
	jal	parse_expr
	mv	a1, a0
	mv	a0, s3
	jal	node_add_child

	# Expect ')'
	mv	a0, s0
	li	a1, NK_RPAREN
	lla	a2, str_rparen
	jal	expect_tok

	# Add bind node to asm
	mv	a1, s3
	mv	a0, s2
	jal	node_add_child
	j	px_asm_lp

# ── Asm numeric label: N: ──
px_asm_maybe_label:
	# Peek at the token AFTER the number to see if it's ':'
	# First consume the number
	jal	node_alloc
	mv	s3, a0
	mv	a0, s0
	mv	a1, s3
	li	a2, 0
	jal	lex_next		# consume number token

	# Peek for ':'
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1
	jal	lex_next
	li	t0, NK_COLON
	bne	a0, t0, px_asm_insn_from_token
	# It's a label — consume ':'
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next

	# Create label node with the number as child
	jal	node_alloc
	mv	s4, a0
	li	t0, NK_ASM_LABEL
	sw	t0, N_KIND(s4)
	mv	a0, s4
	mv	a1, s3			# number token
	jal	node_add_child
	# Add to asm
	mv	a1, s4
	mv	a0, s2
	jal	node_add_child
	j	px_asm_lp

# ── Got a token that's not label — treat as instruction start ──
px_asm_insn_from_token:
	# s3 has the already-consumed token (was thought to be a number for label)
	# This shouldn't normally happen (numbers aren't mnemonics)
	# Just add it as an error/atom
	mv	a1, s3
	mv	a0, s2
	jal	node_add_child
	j	px_asm_lp

# ── Asm instruction: mnemonic [operands] ──
px_asm_insn:
	# Consume mnemonic token
	jal	node_alloc
	mv	s3, a0
	mv	a0, s0
	mv	a1, s3
	li	a2, 0
	jal	lex_next

	# Create instruction node
	jal	node_alloc
	mv	s4, a0
	li	t0, NK_ASM_INSN
	sw	t0, N_KIND(s4)
	# Copy mnemonic location info
	lw	t0, N_LOC_OFF(s3)
	sw	t0, N_LOC_OFF(s4)
	lw	t0, N_LOC_LEN(s3)
	sw	t0, N_LOC_LEN(s4)
	lw	t0, N_LOC_LINE(s3)
	sw	t0, N_LOC_LINE(s4)
	lw	t0, N_LOC_COL(s3)
	sw	t0, N_LOC_COL(s4)

	# Add mnemonic as first child
	mv	a0, s4
	mv	a1, s3
	jal	node_add_child

	# Look up mnemonic to determine operand count/format
	lw	t0, N_LOC_OFF(s3)	# token offset
	lw	t1, L_IN(s0)		# input base from lexer
	add	a0, t1, t0		# text ptr
	lw	a1, N_LOC_LEN(s3)	# text len
	jal	asm_lookup
	beqz	a0, px_asm_insn_done	# unknown mnemonic — no operands

	# a0 = table entry. Load class byte
	lbu	a3, 8(a0)		# class (low byte of word at offset 8)

	# Dispatch on class to read operands
	# R-type (class 1): rd, rs1, rs2
	li	t0, AC_R
	beq	a3, t0, px_ai_3reg

	# I-arith (class 2): rd, rs1, imm
	li	t0, AC_I_ARITH
	beq	a3, t0, px_ai_2reg_imm

	# I-shift (class 3): rd, rs1, shamt
	li	t0, AC_I_SHIFT
	beq	a3, t0, px_ai_2reg_imm

	# I-load (class 4): rd, imm(rs1)
	li	t0, AC_I_LOAD
	beq	a3, t0, px_ai_reg_mem

	# S-type (class 5): rs2, imm(rs1)
	li	t0, AC_S
	beq	a3, t0, px_ai_reg_mem

	# B-type (class 6): rs1, rs2, target
	li	t0, AC_B
	beq	a3, t0, px_ai_2reg_imm

	# U-type lui/auipc (class 7,8): rd, imm
	li	t0, AC_U_LUI
	beq	a3, t0, px_ai_reg_imm
	li	t0, AC_U_AUIPC
	beq	a3, t0, px_ai_reg_imm

	# J-type jal (class 9): rd, target  OR just target
	li	t0, AC_J_JAL
	beq	a3, t0, px_ai_reg_imm

	# jalr (class 10): rd, rs1, imm  OR rd, imm(rs1)
	li	t0, AC_JALR
	beq	a3, t0, px_ai_2reg_imm

	# Pseudos with 2 operands: li rd,imm / mv rd,rs / not / neg / seqz / snez
	li	t0, AC_PS_LI
	beq	a3, t0, px_ai_reg_imm
	li	t0, AC_PS_MV
	beq	a3, t0, px_ai_2reg
	li	t0, AC_PS_NOT
	beq	a3, t0, px_ai_2reg
	li	t0, AC_PS_NEG
	beq	a3, t0, px_ai_2reg
	li	t0, AC_PS_SEQZ
	beq	a3, t0, px_ai_2reg
	li	t0, AC_PS_SNEZ
	beq	a3, t0, px_ai_2reg

	# Pseudos with 1 operand: j target / jr rs
	li	t0, AC_PS_J
	beq	a3, t0, px_ai_1op
	li	t0, AC_PS_JR
	beq	a3, t0, px_ai_1op

	# Pseudos with 0 operands: ret nop wfi mret sret
	li	t0, AC_PS_RET
	beq	a3, t0, px_asm_insn_done
	li	t0, AC_PS_NOP
	beq	a3, t0, px_asm_insn_done
	li	t0, AC_PS_WFI
	beq	a3, t0, px_asm_insn_done
	li	t0, AC_MRET
	beq	a3, t0, px_asm_insn_done
	li	t0, AC_SRET
	beq	a3, t0, px_asm_insn_done

	# CSR: csrrw/csrrs/csrrc rd, csr, rs1
	li	t0, AC_CSR
	beq	a3, t0, px_ai_3reg
	# CSRI: csrrwi/csrrsi/csrrci rd, csr, uimm
	li	t0, AC_CSRI
	beq	a3, t0, px_ai_2reg_imm

	# Branch pseudos with 2 ops: beqz/bnez/bltz/bgez rs, target
	li	t0, AC_PS_BEQZ
	beq	a3, t0, px_ai_2reg
	li	t0, AC_PS_BNEZ
	beq	a3, t0, px_ai_2reg
	li	t0, AC_PS_BLTZ
	beq	a3, t0, px_ai_2reg
	li	t0, AC_PS_BGEZ
	beq	a3, t0, px_ai_2reg

	# Branch pseudos with 3 ops: bgt/ble/bgtu/bleu rs1, rs2, target
	li	t0, AC_PS_BGT
	beq	a3, t0, px_ai_3reg
	li	t0, AC_PS_BLE
	beq	a3, t0, px_ai_3reg
	li	t0, AC_PS_BGTU
	beq	a3, t0, px_ai_3reg
	li	t0, AC_PS_BLEU
	beq	a3, t0, px_ai_3reg

	# call/tail: 1 operand (label)
	li	t0, AC_PS_CALL
	beq	a3, t0, px_ai_1op
	li	t0, AC_PS_TAIL
	beq	a3, t0, px_ai_1op

	# fence/sfence — read remaining tokens on this line
	j	px_asm_insn_done

# ── Helper: read one asm operand, skip leading comma ──
# Reads next token (skipping comma if present), adds to s4
asm_read_op:
	prologue	s3 x0
	# Peek for comma, skip it
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1
	jal	lex_next
	li	t0, NK_COMMA
	bne	a0, t0, aro_read
	# Consume comma
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next
aro_read:
	# Read actual operand
	jal	node_alloc
	mv	s3, a0
	mv	a0, s0
	mv	a1, s3
	li	a2, 0
	jal	lex_next

	# Check for label ref: number followed by 'b' or 'f' (adjacent)
	li	t0, NK_NUMBER
	bne	a0, t0, aro_add
	# Peek next — if it's ident "b" or "f" at adjacent column, merge
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 1			# peek
	jal	lex_next
	li	t0, NK_IDENT
	bne	a0, t0, aro_add
	# Check if it's exactly "b" or "f" (len=1)
	lw	t0, N_LOC_LEN(a1)
	li	t1, 1
	bne	t0, t1, aro_add
	# Check adjacency: ident col == number col + number len
	lw	t0, N_LOC_COL(s3)	# number col
	lw	t1, N_LOC_LEN(s3)	# number len
	add	t0, t0, t1		# expected ident col
	lw	t1, N_LOC_COL(a1)	# actual ident col
	bne	t0, t1, aro_add
	# It's a label ref — consume the direction and extend the number's length
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next		# consume 'b' or 'f'
	# Extend s3's length by 1 to include the direction char
	lw	t0, N_LOC_LEN(s3)
	addi	t0, t0, 1
	sw	t0, N_LOC_LEN(s3)

aro_add:
	mv	a0, s4
	mv	a1, s3
	jal	node_add_child
	return

# ── Operand parsers for asm instructions ──
# All use asm_read_op to read tokens and add as children of s4

# 1 operand
px_ai_1op:
	jal	asm_read_op
	j	px_asm_insn_done

# 2 registers
px_ai_2reg:
	jal	asm_read_op
	jal	asm_read_op
	j	px_asm_insn_done

# 3 registers (R-type, CSR)
px_ai_3reg:
	jal	asm_read_op
	jal	asm_read_op
	jal	asm_read_op
	j	px_asm_insn_done

# reg, imm (lui, li, jal, U-type)
px_ai_reg_imm:
	jal	asm_read_op
	jal	asm_read_op
	j	px_asm_insn_done

# 2 reg + imm (I-arith, I-shift, B-type, jalr)
px_ai_2reg_imm:
	jal	asm_read_op
	jal	asm_read_op
	jal	asm_read_op
	j	px_asm_insn_done

# reg, mem: rd, imm(rs1)
# Reads: reg, comma, imm, (, reg, )
px_ai_reg_mem:
	jal	asm_read_op		# rd or rs2
	jal	asm_read_op		# imm (skips comma)
	# Consume (
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next
	# Read base reg
	jal	asm_read_op
	# Consume )
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next
	j	px_asm_insn_done

px_asm_insn_done:
	# Add instruction node to asm
	mv	a1, s4
	mv	a0, s2
	jal	node_add_child
	j	px_asm_lp

px_asm_close:
	# Consume }
	jal	node_alloc
	mv	a1, a0
	mv	a0, s0
	li	a2, 0
	jal	lex_next
	j	px_done

# ── print_ast: indented tree printer ──────────────────────────────────
# a0=node, a1=depth. Uses s2 as write cursor, s5 as input base.
print_ast:
	prologue	s0 s1 s3 x0
	mv	s0, a0			# node
	mv	s3, a1			# depth

	# Print indent (2 spaces per depth level)
	mv	t0, s3
pa_indent:
	beqz	t0, pa_kind
	li	t1, ' '
	sb	t1, 0(s2)
	sb	t1, 1(s2)
	addi	s2, s2, 2
	addi	t0, t0, -1
	j	pa_indent

pa_kind:
	# Print kind as decimal
	lw	a0, N_KIND(s0)
	jal	print_dec_inline

	# Print token text if it has length
	lw	t0, N_LOC_LEN(s0)
	beqz	t0, pa_loc
	li	t0, ':'
	sb	t0, 0(s2)
	addi	s2, s2, 1
	# Copy text
	lw	t0, N_LOC_OFF(s0)
	lw	t1, N_LOC_LEN(s0)
	add	t0, s5, t0
pa_text:
	beqz	t1, pa_loc
	lbu	t2, 0(t0)
	sb	t2, 0(s2)
	addi	t0, t0, 1
	addi	s2, s2, 1
	addi	t1, t1, -1
	j	pa_text

pa_loc:
	# Print location: pad then line:col
	li	t0, ' '
	sb	t0, 0(s2)
	addi	s2, s2, 1
	lw	a0, N_LOC_LINE(s0)
	jal	print_dec_inline
	li	t0, ':'
	sb	t0, 0(s2)
	addi	s2, s2, 1
	lw	a0, N_LOC_COL(s0)
	jal	print_dec_inline

	# Newline
	li	t0, '\n'
	sb	t0, 0(s2)
	addi	s2, s2, 1

	# Recurse on children with depth+1
	lw	s1, N_FIRST_CHILD(s0)
pa_child_lp:
	beqz	s1, pa_done
	mv	a0, s1
	addi	a1, s3, 1
	jal	print_ast
	lw	s1, N_NEXT_SIB(s1)
	j	pa_child_lp

pa_done:
	return

# ══════════════════════════════════════════════════════════════════════
#  compile: a0=input_start, a1=input_end
#  Debug mode: parse and print AST as S-expression.
#  Returns a0=out_start, a1=out_end.
# ══════════════════════════════════════════════════════════════════════
compile:
	prologue	s0 s1 s2 s3 s4 s5 x0
	mv	s5, a0			# s5 = input start (for text extraction)
	mv	s2, a1			# s2 = output write cursor
	mv	s3, a1			# s3 = output start
	sub	a1, a1, a0		# input len
	jal	lexer_init
	mv	s0, a0			# s0 = lexer

	# Parse
	mv	a0, s0
	jal	parse_program
	mv	s4, a0

	# Print AST as indented tree
	mv	a0, s4
	li	a1, 0			# depth = 0
	jal	print_ast

	mv	a0, s3
	mv	a1, s2
	return

# print_dec_inline: a0=value, writes decimal to buffer at s2, advances s2
print_dec_inline:
	prologue	s5 s6 x0
	mv	s5, a0
	li	s6, 0			# digit count
	beqz	s5, pdi_zero
pdi_loop:
	beqz	s5, pdi_emit
	li	t0, 10
	li	t1, 0
pdi_div:
	blt	s5, t0, pdi_rem
	sub	s5, s5, t0
	addi	t1, t1, 1
	j	pdi_div
pdi_rem:
	addi	t2, s5, '0'
	addi	sp, sp, -4
	sb	t2, 0(sp)
	addi	s6, s6, 1
	mv	s5, t1
	j	pdi_loop
pdi_emit:
	beqz	s6, pdi_done
	lbu	t0, 0(sp)
	addi	sp, sp, 4
	sb	t0, 0(s2)
	addi	s2, s2, 1
	addi	s6, s6, -1
	j	pdi_emit
pdi_zero:
	li	t0, '0'
	sb	t0, 0(s2)
	addi	s2, s2, 1
pdi_done:
	return

main:
	# Setup the heap/stack
	lla	gp, data
	addi	gp, gp, 15
	andi	gp, gp, -16
	li	sp, 0x4000000
	add	sp, sp, gp

	# Read data from UART
	mv	a0, sp
	jal	read_data

	# Call compile
	mv	a1, sp
	add	a1, a1, a0
	mv	a0, sp
	jal	compile

	# Write returned data to UART
	jal	write_data

	# Exit
	j	exit

data:
