# ──────────────────────────────────────────────────────────────────────────────
# file: fam2.fam1
# third-stage bootstrap: RV32I mnemonic assembler (fam1 grammar)
# Reads UART text (EOT-terminated), emits RV32I binary to UART, poweroffs.
# Grammar: RV32I + labels + pseudos (li/mv/j/ret/beqz/bnez) + passthrough hex.
# Built by bin/fam1. Source of truth: src/fam2.S (lowered by tools/emit_fam1.py).
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# Entry + static tables
# ──────────────────────────────────────────────────────────────────────────────
:L000  # _start
EF 02 00 00 # jal     t0, after_mnem_tab               ; t0 = &mnem_table (byte after jal)
@L002  # -> after_mnem_tab
:L001  # mnem_table
61 64 64 # .ascii "add"
00 00 00 00 00 # .zero 5
01 00 00 00 # .byte 1, 0, 0x00, 0
73 75 62 # .ascii "sub"
00 00 00 00 00 # .zero 5
01 00 20 00 # .byte 1, 0, 0x20, 0
73 6C 6C # .ascii "sll"
00 00 00 00 00 # .zero 5
01 01 00 00 # .byte 1, 1, 0x00, 0
73 6C 74 # .ascii "slt"
00 00 00 00 00 # .zero 5
01 02 00 00 # .byte 1, 2, 0x00, 0
73 6C 74 75 # .ascii "sltu"
00 00 00 00 # .zero 4
01 03 00 00 # .byte 1, 3, 0x00, 0
78 6F 72 # .ascii "xor"
00 00 00 00 00 # .zero 5
01 04 00 00 # .byte 1, 4, 0x00, 0
73 72 6C # .ascii "srl"
00 00 00 00 00 # .zero 5
01 05 00 00 # .byte 1, 5, 0x00, 0
73 72 61 # .ascii "sra"
00 00 00 00 00 # .zero 5
01 05 20 00 # .byte 1, 5, 0x20, 0
6F 72 # .ascii "or"
00 00 00 00 00 00 # .zero 6
01 06 00 00 # .byte 1, 6, 0x00, 0
61 6E 64 # .ascii "and"
00 00 00 00 00 # .zero 5
01 07 00 00 # .byte 1, 7, 0x00, 0
61 64 64 69 # .ascii "addi"
00 00 00 00 # .zero 4
02 00 00 00 # .byte 2, 0, 0, 0
73 6C 74 69 # .ascii "slti"
00 00 00 00 # .zero 4
02 02 00 00 # .byte 2, 2, 0, 0
73 6C 74 69 75 # .ascii "sltiu"
00 00 00 # .zero 3
02 03 00 00 # .byte 2, 3, 0, 0
78 6F 72 69 # .ascii "xori"
00 00 00 00 # .zero 4
02 04 00 00 # .byte 2, 4, 0, 0
6F 72 69 # .ascii "ori"
00 00 00 00 00 # .zero 5
02 06 00 00 # .byte 2, 6, 0, 0
61 6E 64 69 # .ascii "andi"
00 00 00 00 # .zero 4
02 07 00 00 # .byte 2, 7, 0, 0
73 6C 6C 69 # .ascii "slli"
00 00 00 00 # .zero 4
03 01 00 00 # .byte 3, 1, 0x00, 0
73 72 6C 69 # .ascii "srli"
00 00 00 00 # .zero 4
03 05 00 00 # .byte 3, 5, 0x00, 0
73 72 61 69 # .ascii "srai"
00 00 00 00 # .zero 4
03 05 20 00 # .byte 3, 5, 0x20, 0
6C 62 # .ascii "lb"
00 00 00 00 00 00 # .zero 6
04 00 00 00 # .byte 4, 0, 0, 0
6C 68 # .ascii "lh"
00 00 00 00 00 00 # .zero 6
04 01 00 00 # .byte 4, 1, 0, 0
6C 77 # .ascii "lw"
00 00 00 00 00 00 # .zero 6
04 02 00 00 # .byte 4, 2, 0, 0
6C 62 75 # .ascii "lbu"
00 00 00 00 00 # .zero 5
04 04 00 00 # .byte 4, 4, 0, 0
6C 68 75 # .ascii "lhu"
00 00 00 00 00 # .zero 5
04 05 00 00 # .byte 4, 5, 0, 0
73 62 # .ascii "sb"
00 00 00 00 00 00 # .zero 6
05 00 00 00 # .byte 5, 0, 0, 0
73 68 # .ascii "sh"
00 00 00 00 00 00 # .zero 6
05 01 00 00 # .byte 5, 1, 0, 0
73 77 # .ascii "sw"
00 00 00 00 00 00 # .zero 6
05 02 00 00 # .byte 5, 2, 0, 0
62 65 71 # .ascii "beq"
00 00 00 00 00 # .zero 5
06 00 00 00 # .byte 6, 0, 0, 0
62 6E 65 # .ascii "bne"
00 00 00 00 00 # .zero 5
06 01 00 00 # .byte 6, 1, 0, 0
62 6C 74 # .ascii "blt"
00 00 00 00 00 # .zero 5
06 04 00 00 # .byte 6, 4, 0, 0
62 67 65 # .ascii "bge"
00 00 00 00 00 # .zero 5
06 05 00 00 # .byte 6, 5, 0, 0
62 6C 74 75 # .ascii "bltu"
00 00 00 00 # .zero 4
06 06 00 00 # .byte 6, 6, 0, 0
62 67 65 75 # .ascii "bgeu"
00 00 00 00 # .zero 4
06 07 00 00 # .byte 6, 7, 0, 0
6C 75 69 # .ascii "lui"
00 00 00 00 00 # .zero 5
07 00 00 00 # .byte 7, 0, 0, 0
61 75 69 70 63 # .ascii "auipc"
00 00 00 # .zero 3
08 00 00 00 # .byte 8, 0, 0, 0
6A 61 6C # .ascii "jal"
00 00 00 00 00 # .zero 5
09 00 00 00 # .byte 9, 0, 0, 0
6A 61 6C 72 # .ascii "jalr"
