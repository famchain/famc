0A 00 00 00 # .byte 10, 0, 0, 0
6C 69 # .ascii "li"
00 00 00 00 00 00 # .zero 6
0B 00 00 00 # .byte 11, 0, 0, 0
6D 76 # .ascii "mv"
00 00 00 00 00 00 # .zero 6
0C 00 00 00 # .byte 12, 0, 0, 0
6A  # [01D8] .ascii "j"
00 00 00 00 00 00 00 # .zero 7
0D 00 00 00 # .byte 13, 0, 0, 0
72 65 74 # .ascii "ret"
00 00 00 00 00 # .zero 5
0E 00 00 00 # .byte 14, 0, 0, 0
