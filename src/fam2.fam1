00 00 00 00 # .zero 4
0F 00 00 00 # .byte 15, 0, 0, 0
62 6E 65 7A # .ascii "bnez"
00 00 00 00 # .zero 4
10 00 00 00 # .byte 16, 0, 0, 0
00 00 00 00 00 00 00 00 00 00 00 00 # .zero 12         ; terminator (name starts with 0)
:L002  # after_mnem_tab
6F 03 00 00 # jal     t1, after_reg_tab                ; t1 = &reg_table
@L004  # -> after_reg_tab
:L003  # reg_table
7A 65 72 6F # .ascii "zero"
00 00 00 00 # .byte 0, 0, 0, 0
72 61 # .ascii "ra"
00 00 # .zero 2
01 00 00 00 # .byte 1, 0, 0, 0
73 70 # .ascii "sp"
00 00 # .zero 2
02 00 00 00 # .byte 2, 0, 0, 0
