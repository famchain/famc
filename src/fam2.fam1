# ──────────────────────────────────────────────────────────────────────────────
# Init
# ──────────────────────────────────────────────────────────────────────────────
:L004  # after_reg_tab
93 8C 02 00 # mv      s9, t0       ; mnem_table base
93 0D 03 00 # mv      s11, t1      ; reg_table base
13 0B A0 00 # li      s6, 10
B7 0A 00 10 # lui     s5, 0x10000  ; UART base
17 05 00 00 # auipc   a0, 0        ; a0 = PC base for data regions
B7 13 00 00 # lui     t2, 1
B3 04 75 00 # add     s1, a0, t2   ; output buf  = PC + 0x1000
13 89 04 00 # mv      s2, s1
B7 03 01 00 # lui     t2, 0x10
B3 09 75 00 # add     s3, a0, t2   ; symtab      = PC + 0x10000
13 8A 09 00 # mv      s4, s3
B7 03 02 00 # lui     t2, 0x20
B3 0B 75 00 # add     s7, a0, t2   ; fixup tab   = PC + 0x20000
13 8C 0B 00 # mv      s8, s7
B7 03 03 00 # lui     t2, 0x30
33 0D 75 00 # add     s10, a0, t2  ; token buf   = PC + 0x30000
23 00 0D 02 # sb      x0, 32(s10)  ; sticky EOT flag at token_buf+32
B7 03 04 00 # lui     t2, 0x40
33 01 75 00 # add     sp, a0, t2   ; stack top   = PC + 0x40000
6F 00 00 00 # j       main_loop
@L005  # -> main_loop

# ──────────────────────────────────────────────────────────────────────────────
# Main loop
# ──────────────────────────────────────────────────────────────────────────────
:L005  # main_loop
EF 00 00 00 # jal     ra, read_token
@L016  # -> read_token
63 00 04 00 # beqz    s0, ml_post
@L008  # -> ml_post
B3 02 8D 00 # add     t0, s10, s0
03 C3 F2 FF # lbu     t1, -1(t0)
93 03 A0 03 # li      t2, 0x3A
63 00 73 00 # beq     t1, t2, ml_label
@L006  # -> ml_label
93 03 20 00 # li      t2, 2
63 10 74 00 # bne     s0, t2, ml_mnem
@L007  # -> ml_mnem
03 43 0D 00 # lbu     t1, 0(s10)
EF 00 00 00 # jal     ra, hex_val
@L025  # -> hex_val
93 03 F0 FF # li      t2, -1
63 00 75 00 # beq     a0, t2, ml_mnem
@L007  # -> ml_mnem
13 0E 05 00 # mv      t3, a0       ; hi nibble
03 43 1D 00 # lbu     t1, 1(s10)
EF 00 00 00 # jal     ra, hex_val
@L025  # -> hex_val
93 03 F0 FF # li      t2, -1
63 00 75 00 # beq     a0, t2, ml_mnem
@L007  # -> ml_mnem
13 1E 4E 00 # slli    t3, t3, 4
33 6E AE 00 # or      t3, t3, a0
23 00 C9 01 # sb      t3, 0(s2)
13 09 19 00 # addi    s2, s2, 1
6F 00 00 00 # j       ml_post
@L008  # -> ml_post
:L006  # ml_label
EF 00 00 00 # jal     ra, define_label
@L067  # -> define_label
6F 00 00 00 # j       ml_post
@L008  # -> ml_post
:L007  # ml_mnem
EF 00 00 00 # jal     ra, find_mnem
@L030  # -> find_mnem
93 02 F0 FF # li      t0, -1
63 00 55 00 # beq     a0, t0, halt_err
@L012  # -> halt_err
EF 00 00 00 # jal     ra, dispatch
@L072  # -> dispatch
:L008  # ml_post
83 42 0D 02 # lbu     t0, 32(s10)
63 90 02 00 # bnez    t0, finish_all
@L009  # -> finish_all
6F 00 00 00 # j       main_loop
@L005  # -> main_loop

# ──────────────────────────────────────────────────────────────────────────────
# Finish: fixup pass + dump + poweroff
# ──────────────────────────────────────────────────────────────────────────────
:L009  # finish_all
EF 00 00 00 # jal     ra, fixup_pass
@L089  # -> fixup_pass
EF 00 00 00 # jal     ra, dump_output
@L099  # -> dump_output
:L010  # powoff
B7 0A 10 00 # lui     s5, 0x100
B7 52 00 00 # lui     t0, 5
93 82 52 55 # addi    t0, t0, 0x555
23 A0 5A 00 # sw      t0, 0(s5)
:L011  # powoff_hang
6F 00 00 00 # j       powoff_hang
@L011  # -> powoff_hang
:L012  # halt_err
B7 0A 10 00 # lui     s5, 0x100
B7 52 00 00 # lui     t0, 5
93 82 52 55 # addi    t0, t0, 0x555
23 A0 5A 00 # sw      t0, 0(s5)
:L013  # halt_err_hang
6F 00 00 00 # j       halt_err_hang
@L013  # -> halt_err_hang

# ──────────────────────────────────────────────────────────────────────────────
# UART primitives
# ──────────────────────────────────────────────────────────────────────────────
:L014  # rdch
03 CF 5A 00 # lbu     t5, 5(s5)
13 7F 1F 00 # andi    t5, t5, 1
63 00 0F 00 # beqz    t5, rdch
@L014  # -> rdch
03 C3 0A 00 # lbu     t1, 0(s5)
67 80 00 00 # ret
:L015  # wrch
03 CF 5A 00 # lbu     t5, 5(s5)
13 7F 0F 02 # andi    t5, t5, 0x20
63 00 0F 00 # beqz    t5, wrch
@L015  # -> wrch
23 80 5A 00 # sb      t0, 0(s5)
67 80 00 00 # ret

# ──────────────────────────────────────────────────────────────────────────────
# read_token: reads the next whitespace/comma-delimited token.
#   On entry: nothing.
#   On exit: s0 = token length (0..31), a0 = 1 if EOT seen else 0.
#   Token bytes in buffer at s10, zero-padded to 32 bytes.
#   Halts if token length would exceed 31.
# ──────────────────────────────────────────────────────────────────────────────
:L016  # read_token
13 01 C1 FF # addi    sp, sp, -4
23 20 11 00 # sw      ra, 0(sp)
13 04 00 00 # li      s0, 0
93 02 0D 00 # mv      t0, s10
93 03 0D 02 # addi    t2, s10, 32
:L017  # rt_zero
23 80 02 00 # sb      x0, 0(t0)
93 82 12 00 # addi    t0, t0, 1
63 90 72 00 # bne     t0, t2, rt_zero
@L017  # -> rt_zero
:L018  # rt_skip
EF 00 00 00 # jal     ra, rdch
@L014  # -> rdch
93 02 40 00 # li      t0, 4
63 00 53 00 # beq     t1, t0, rt_eot
@L023  # -> rt_eot
93 02 30 02 # li      t0, 0x23                         ; '#'
63 10 53 00 # bne     t1, t0, rt_skip_not_hash
@L020  # -> rt_skip_not_hash
:L019  # rt_com
EF 00 00 00 # jal     ra, rdch
@L014  # -> rdch
93 02 40 00 # li      t0, 4
63 00 53 00 # beq     t1, t0, rt_eot
@L023  # -> rt_eot
63 10 63 01 # bne     t1, s6, rt_com
@L019  # -> rt_com
6F 00 00 00 # j       rt_skip
@L018  # -> rt_skip
:L020  # rt_skip_not_hash
93 02 C0 02 # li      t0, 0x2C                         ; ','
63 00 53 00 # beq     t1, t0, rt_skip
@L018  # -> rt_skip
93 02 10 02 # li      t0, 33
63 40 53 00 # blt     t1, t0, rt_skip  ; whitespace/control
@L018  # -> rt_skip
:L021  # rt_collect
B3 02 8D 00 # add     t0, s10, s0
23 80 62 00 # sb      t1, 0(t0)
13 04 14 00 # addi    s0, s0, 1
93 02 00 02 # li      t0, 32
63 50 54 00 # bge     s0, t0, halt_err
@L012  # -> halt_err
EF 00 00 00 # jal     ra, rdch
@L014  # -> rdch
93 02 40 00 # li      t0, 4
63 00 53 00 # beq     t1, t0, rt_eot
@L023  # -> rt_eot
93 02 30 02 # li      t0, 0x23
63 00 53 00 # beq     t1, t0, rt_com_post
@L022  # -> rt_com_post
93 02 C0 02 # li      t0, 0x2C
63 00 53 00 # beq     t1, t0, rt_done
@L024  # -> rt_done
93 02 10 02 # li      t0, 33
63 40 53 00 # blt     t1, t0, rt_done
@L024  # -> rt_done
6F 00 00 00 # j       rt_collect
@L021  # -> rt_collect
:L022  # rt_com_post
EF 00 00 00 # jal     ra, rdch
@L014  # -> rdch
93 02 40 00 # li      t0, 4
63 00 53 00 # beq     t1, t0, rt_eot
@L023  # -> rt_eot
63 10 63 01 # bne     t1, s6, rt_com_post
@L022  # -> rt_com_post
6F 00 00 00 # j       rt_done
@L024  # -> rt_done
:L023  # rt_eot
93 02 10 00 # li      t0, 1
23 00 5D 02 # sb      t0, 32(s10)  ; set sticky EOT flag
:L024  # rt_done
83 20 01 00 # lw      ra, 0(sp)
13 01 41 00 # addi    sp, sp, 4
67 80 00 00 # ret

# ──────────────────────────────────────────────────────────────────────────────
# hex_val: t1 = char → a0 = 0..15 or -1
# ──────────────────────────────────────────────────────────────────────────────
:L025  # hex_val
93 02 00 03 # li      t0, 48                           ; '0'
63 40 53 00 # blt     t1, t0, hv_bad
@L026  # -> hv_bad
93 02 A0 03 # li      t0, 58                           ; '9'+1
63 40 53 00 # blt     t1, t0, hv_dig
@L027  # -> hv_dig
93 02 10 04 # li      t0, 65                           ; 'A'
63 40 53 00 # blt     t1, t0, hv_bad
@L026  # -> hv_bad
93 02 70 04 # li      t0, 71                           ; 'F'+1
63 40 53 00 # blt     t1, t0, hv_upr
@L028  # -> hv_upr
93 02 10 06 # li      t0, 97                           ; 'a'
63 40 53 00 # blt     t1, t0, hv_bad
@L026  # -> hv_bad
93 02 70 06 # li      t0, 103                          ; 'f'+1
63 40 53 00 # blt     t1, t0, hv_lwr
@L029  # -> hv_lwr
:L026  # hv_bad
13 05 F0 FF # li      a0, -1
67 80 00 00 # ret
:L027  # hv_dig
13 05 03 FD # addi    a0, t1, -48
67 80 00 00 # ret
:L028  # hv_upr
13 05 93 FC # addi    a0, t1, -55
67 80 00 00 # ret
:L029  # hv_lwr
13 05 93 FA # addi    a0, t1, -87
67 80 00 00 # ret

# ──────────────────────────────────────────────────────────────────────────────
# find_mnem: token in buf at s10 (zero-padded).
#   Returns: a0 = class, a1 = f3, a2 = f7, or a0 = -1 if not found.
# ──────────────────────────────────────────────────────────────────────────────
:L030  # find_mnem
93 82 0C 00 # mv      t0, s9
:L031  # fm_next
03 C3 02 00 # lbu     t1, 0(t0)
63 00 03 00 # beqz    t1, fm_notfound
@L034  # -> fm_notfound
93 03 0D 00 # mv      t2, s10
13 8E 02 00 # mv      t3, t0
93 0E 80 00 # li      t4, 8
:L032  # fm_cmp
03 CF 03 00 # lbu     t5, 0(t2)
83 4F 0E 00 # lbu     t6, 0(t3)
63 10 FF 01 # bne     t5, t6, fm_skip
@L033  # -> fm_skip
93 83 13 00 # addi    t2, t2, 1
13 0E 1E 00 # addi    t3, t3, 1
93 8E FE FF # addi    t4, t4, -1
63 90 0E 00 # bnez    t4, fm_cmp
@L032  # -> fm_cmp
03 C5 82 00 # lbu     a0, 8(t0)
83 C5 92 00 # lbu     a1, 9(t0)
03 C6 A2 00 # lbu     a2, 10(t0)
67 80 00 00 # ret
:L033  # fm_skip
93 82 C2 00 # addi    t0, t0, 12
6F 00 00 00 # j       fm_next
@L031  # -> fm_next
:L034  # fm_notfound
13 05 F0 FF # li      a0, -1
67 80 00 00 # ret

# ──────────────────────────────────────────────────────────────────────────────
# parse_reg: a0 = ptr, a1 = len → a0 = reg num (0..31) or -1
# ──────────────────────────────────────────────────────────────────────────────
:L035  # parse_reg
93 02 05 00 # mv      t0, a0
13 83 05 00 # mv      t1, a1
63 00 03 00 # beqz    t1, pr_bad
@L044  # -> pr_bad
83 C3 02 00 # lbu     t2, 0(t0)
13 0E 80 07 # li      t3, 120                          ; 'x'
63 90 C3 01 # bne     t2, t3, pr_abi
@L038  # -> pr_abi
13 0E 20 00 # li      t3, 2
63 00 C3 01 # beq     t1, t3, pr_x1
@L036  # -> pr_x1
13 0E 30 00 # li      t3, 3
63 00 C3 01 # beq     t1, t3, pr_x2
@L037  # -> pr_x2
6F 00 00 00 # j       pr_bad
@L044  # -> pr_bad
:L036  # pr_x1
83 C3 12 00 # lbu     t2, 1(t0)
93 83 03 FD # addi    t2, t2, -48
63 C0 03 00 # bltz    t2, pr_bad
@L044  # -> pr_bad
13 0E A0 00 # li      t3, 10
63 D0 C3 01 # bge     t2, t3, pr_bad
@L044  # -> pr_bad
13 85 03 00 # mv      a0, t2
