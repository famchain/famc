struct MyStruct {
	x,
	y
};

print = |x| {
	putnum(x);
	putchar('\n');
};

arr1 = alloc(sizeof(MyStruct) * 3);
MyStruct@arr1[0] = MyStruct(1, 2);
MyStruct@arr1[1] = MyStruct(3, 4);
MyStruct@arr1[2] = MyStruct(5, 6);

print(MyStruct@arr1[0].x);
print(MyStruct@arr1[1].y);
print(MyStruct@arr1[2].y);
exit();
