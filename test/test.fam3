  lui     t0, 0x10000                                                                                                       
  loop:                                                                                                                       
      lbu     t1, 5(t0)                                                                                                       
      andi    t1, t1, 0x20                                                                                                    
      beqz    t1, loop                                                                                                        
      li      t2, 65                                                                                                          
      sb      t2, 0(t0)                                                                                                       
  lui     t0, 0x100                                               
  lui     t1, 5
  addi    t1, t1, 0x555                                                                                                       
  sw      t1, 0(t0)
  hang:                                                                                                                       
      j       hang
